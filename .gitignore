# macOS
.DS_Store

# The compiled Hier compiler (built by `make`)
/hierc

# The compiled `hier` daily-driver CLI + its intermediate C (built by `make hier`)
/hier
/hier.c

# The compiled `hierfmt` formatter + its intermediate C (built by `make hierfmt`)
/hierfmt
/hierfmt.c

# The compiled `hier-lsp` language server + its intermediate C (`make hier-lsp`)
/hier-lsp
/hier-lsp.c

# Editor-extension dev artifacts (the sources under editors/ ARE tracked)
/editors/**/node_modules/
/editors/**/*.vsix

# Generated runtime-embed header (built by `make` from runtime/hier_rt.c)
/build/

# Per-example outputs: generated C and native binaries. The .hi sources are
# tracked; everything else in examples/ is reproducible with `make` / `./hierc`.
/examples/*
!/examples/*.hi
# the sqlite FFI example is a multi-file dir (shim + harness); track it (its own
# .gitignore drops the build artifacts, the root *.out exception keeps the golden).
!/examples/sqlite
# the Conway's Life example is also a shim dir (own .gitignore drops the binary +
# intermediate C; the root *.out exception below keeps its golden).
!/examples/life
# the Snake example is a shim dir too (termios input shim + own .gitignore).
!/examples/snake
# the Minesweeper example is a shim dir too (termios input shim + own .gitignore).
!/examples/minesweeper

# Editor/OS noise
*.o
*.out
*.dSYM/

# ...but the recorded test-suite goldens ARE tracked (expected output, not a
# build artifact). Must come after the broad *.out rule above.
!/tests/*.out
# package-program goldens live in a subdir, so they need a separate un-ignore
!/tests/pkg/*.out
# corelib test goldens (corelib/test/<name>.out) are tracked too
!/corelib/test/*.out
# FFI regression golden (tests/ffi/expected.out) is tracked too
!/tests/ffi/*.out
# the sqlite FFI example's golden is tracked too
!/examples/sqlite/*.out
# the Conway's Life example's golden is tracked too
!/examples/life/*.out
# the Snake example's golden is tracked too
!/examples/snake/*.out
# the Minesweeper example's golden is tracked too
!/examples/minesweeper/*.out
.koka/
# concurrency suite goldens (tests/conc/<name>.out) are tracked too
!/tests/conc/*.out
