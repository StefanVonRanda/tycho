# macOS
.DS_Store

# Scratch + build-temp artifacts that must never be committed. Two slipped into
# release tarballs via an unscoped `git add`: a ~3.8MB tmpXXXX/ scratch dir
# (v0.1.0) and a cc-generated ccXXXXXX.s assembler temp (v0.1.1). Match tmp-named
# files AND dirs, plus stray compiler temps (the repo has no hand-written .s).
/tmp*
*.s
cc??????.s
# personal local book draft — not part of the repo
/book/
# profiler output (valgrind --tool=callgrind/cachegrind, perf, gprof) — scratch, never source
cachegrind.out.*
callgrind.out.*
perf.data*
gmon.out
# transpiled C emitted by `tychoc <pkg>.ty --emit-c` next to the source
# (e.g. compiler/tychoc0.c) — a build artifact, never source
/compiler/*.c

# The compiled Tycho compiler (built by `make`)
/tychoc

# The self-hosted compiler binary + its emitted C, when built at the repo root
# (e.g. `tychoc compiler/tychoc0.ty -o ./tychoc0`) — build artifacts, never source
/tychoc0
/tychoc0.c
# ...and the same binary built next to its source (`tychoc compiler/tychoc0.ty
# -o compiler/tychoc0`). The emitted C there is already covered by /compiler/*.c.
/compiler/tychoc0

# The compiled `tycho` daily-driver CLI + its intermediate C (built by `make tycho`)
/tycho
/tycho.c

# The compiled `tychofmt` formatter + its intermediate C (built by `make tychofmt`)
/tychofmt
/tychofmt.c

# The compiled `tycho-lsp` language server + its intermediate C (`make tycho-lsp`)
/tycho-lsp
/tycho-lsp.c

# Editor-extension dev artifacts (the sources under editors/ ARE tracked)
/editors/**/node_modules/
/editors/**/*.vsix

# Generated runtime-embed header (built by `make` from runtime/tycho_rt.c)
/build/

# Per-example outputs: generated C and native binaries. The .ty sources are
# tracked; everything else in examples/ is reproducible with `make` / `./tychoc`.
/examples/*
!/examples/*.ty
!/examples/README.md
# the sqlite FFI example is a multi-file dir (shim + harness); track it (its own
# .gitignore drops the build artifacts, the root *.out exception keeps the golden).
!/examples/sqlite
# the Conway's Life example is also a shim dir (own .gitignore drops the binary +
# intermediate C; the root *.out exception below keeps its golden).
!/examples/life
# the Snake example is a shim dir too (termios input shim + own .gitignore).
!/examples/snake
# the Minesweeper example is a shim dir too (termios input shim + own .gitignore).
!/examples/minesweeper
# the corelib usage examples (one program per core module + their goldens) are
# tracked; the runner builds into a temp dir, so no binaries land here.
!/examples/corelib
# the fetch CLI dogfood (main.ty + fixture + runner + golden); builds into a temp dir.
!/examples/fetch
# the static-site generator dogfood (main.ty + fixture site + runner + golden).
!/examples/site

# Editor/OS noise
*.o
*.out
*.dSYM/

# ...but the recorded test-suite goldens ARE tracked (expected output, not a
# build artifact). Must come after the broad *.out rule above.
!/tests/*.out
# package-program goldens live in a subdir, so they need a separate un-ignore
!/tests/pkg/*.out
# corelib test goldens (corelib/test/<name>.out) are tracked too
!/corelib/test/*.out
# FFI regression golden (tests/ffi/expected.out) is tracked too
!/tests/ffi/*.out
# the sqlite FFI example's golden is tracked too
!/examples/sqlite/*.out
# the Conway's Life example's golden is tracked too
!/examples/life/*.out
# the Snake example's golden is tracked too
!/examples/snake/*.out
# the Minesweeper example's golden is tracked too
!/examples/minesweeper/*.out
# the corelib usage examples' goldens (examples/corelib/<name>.out) are tracked too
!/examples/corelib/*.out
# the fetch dogfood's golden (examples/fetch/expected.out) is tracked too
!/examples/fetch/*.out
# the site dogfood's golden (examples/site/expected.out) is tracked too
!/examples/site/*.out
.koka/
# concurrency suite goldens (tests/conc/<name>.out) are tracked too
!/tests/conc/*.out

# Claude Code session state (locks, worktrees) — never publish
/.claude/
dist/

# generated wiki mirror (see scripts/sync-wiki.py, make wiki)
.wiki/
