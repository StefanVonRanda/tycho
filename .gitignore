# macOS
.DS_Store

# The compiled Hier compiler (built by `make`)
/hierc

# Generated runtime-embed header (built by `make` from runtime/hier_rt.c)
/build/

# Per-example outputs: generated C and native binaries. The .hi sources are
# tracked; everything else in examples/ is reproducible with `make` / `./hierc`.
/examples/*
!/examples/*.hi

# Editor/OS noise
*.o
*.out
*.dSYM/

# ...but the recorded test-suite goldens ARE tracked (expected output, not a
# build artifact). Must come after the broad *.out rule above.
!/tests/*.out
# package-program goldens live in a subdir, so they need a separate un-ignore
!/tests/pkg/*.out
# corelib test goldens (corelib/test/<name>.out) are tracked too
!/corelib/test/*.out
.koka/
