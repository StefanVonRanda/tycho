# Shift edge cases: a count >= the operand's bit width is defined as 0 (was C
# undefined behavior); in-range shifts are exact. Negative counts abort at
# runtime (not exercised here -- see the manual repro / spec).
fn main():
    # int (64-bit): count == width and beyond -> 0, via const-fold and at runtime
    n := 64
    println(str(1 << n))        # 0 (runtime, over-wide)
    println(str(1 << 64))       # 0 (const-fold, over-wide)
    println(str(255 >> n))      # 0
    println(str(1 << 40))       # 1099511627776 (in-range, exact)
    println(str(1024 >> 3))     # 128
    # u32 (width 32)
    u := to_u32(1)
    w32 := 32
    println(str(to_int(u << w32)))   # 0 (over-wide at width 32)
    println(str(to_int(u << 31)))    # 2147483648
    # u64 (width 64)
    v := to_u64(1)
    w64 := 64
    println(str(to_int(v << w64)))   # 0 (over-wide at width 64)
    println(str(to_int(v << 20)))    # 1048576
