# MM-9 regression: overwriting a string-array slot recycles the evicted element
# buffer. The danger (cf. the MM-8 recycle_alias bugs): a value READ out of the
# slot before the overwrite must stay valid -- reads deep-copy, so the recycled
# old buffer is uniquely owned and dead. Distinct values + size matches make any
# unsound reuse show up as a corrupted byte, which value-masking would hide.
fn main():
    a := []string
    push(a, "aaaa")
    push(a, "bbbb")
    push(a, "cccc")
    b := a[0]                 # deep-copies "aaaa" out -- must survive the overwrites
    a[0] = "wxyz"             # evict "aaaa": its buffer is recycled
    a[1] = "mnop"             # next store reuses the recycled buffer -- must NOT touch b
    a[2] = a[2] + "!"         # RHS aliases the old slot (v == old): copy-first keeps it sound
    # self-feeding loop: each store evicts the prior, exercising 1-in-1-out reuse
    i := 0
    for i < 1000:
        a[0] = "v" + str(i % 10)
        i = i + 1
    println(b)           # aaaa  (untouched by any recycle)
    println(a[0])        # v9
    println(a[1])        # mnop
    println(a[2])        # cccc!
