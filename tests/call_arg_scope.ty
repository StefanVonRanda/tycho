# Call arguments are built in the current scope (transients), not the result
# arena. Soundness rests on value semantics: a function's return value is
# always freshly owned and never aliases an argument. These cases would break
# (use-after-free / garbage) if a scope-allocated arg leaked into a stored
# result.

fn build(n: int) -> [int]:
    r := []int
    for i in range(n):
        push(r, i * 10)
    return r

fn echo(xs: [int]) -> [int]:
    return xs                       # returns a COPY of the param (value semantics)

fn main():
    # a transient build(4) passed to a function that returns it; the stored
    # result must be a valid independent array
    a := echo(build(4))
    println("a=" + str(a[0]) + "," + str(a[1]) + "," + str(a[2]) + "," + str(a[3]))  # 0,10,20,30

    # nested calls: each inner result is a transient arg to the outer
    b := echo(echo(build(3)))
    println("b_len=" + str(len(b)) + " b2=" + str(b[2]))        # 3, 20

    # loop: transient arg each iteration, result stored to an outer heap var
    last := []int
    for i in range(5):
        last = echo(build(i + 1))   # build(i+1) is a transient; last gets a copy
    println("last_len=" + str(len(last)) + " last0=" + str(last[0]))  # 5, 0
