struct Vec:
    x: float
    y: float

fn mag2(v: Vec) -> float:
    return v.x * v.x + v.y * v.y

fn avg(xs: [int]) -> float:
    total := 0
    for i in range(len(xs)):
        total = total + xs[i]
    return to_float(total) / to_float(len(xs))

fn main():
    pi := 3.14159
    println("pi=" + str(pi) + " 2pi=" + str(pi * 2.0))
    println("truediv=" + str(7.0 / 2.0))          # 3.5
    println("intdiv=" + str(7 / 2))               # 1
    println("neg=" + str(-pi))
    println("whole=" + str(4.0))                  # 4.0 not 4
    if 1.5 < 2.5 and not (1.0 > 2.0):
        println("cmp-ok")
    v := Vec(3.0, 4.0)
    println("mag2=" + str(mag2(v)))               # 25.0
    println("avg=" + str(avg([1, 2, 3, 4])))      # 2.5
    println("trunc=" + str(to_int(3.9)))          # 3
