1 + 2 * 3  =>  7.0
(1 + 2) * 3  =>  9.0
10 / 4  =>  2.5
let x = 3 + 4  =>  x = 7.0
x * x  =>  49.0
let y = x + 1  =>  y = 8.0
sqrt(y * 2)  =>  4.0
abs(0 - 9)  =>  9.0
-x + 1  =>  -6.0
2 * (x - 1)  =>  12.0
1 / 0  =>  error: division by zero
z + 1  =>  error: undefined variable: z
2 +  =>  parse error: unexpected end of input
foo(2)  =>  error: unknown function: foo
sqrt(0 - 4)  =>  error: sqrt of negative
