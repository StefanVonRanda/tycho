# A generic ENUM passed as a function parameter (by value and inout), across
# instantiations, plus a generic fn returning a generic enum and one held in a
# generic struct field, and a generic enum instantiated over a newtype. Both compilers.
type Id = int

enum Opt($T):
    Has($T)
    Non

fn unwrap(o: Opt($T), d: $T) -> $T:
    match o:
        Has(v): return v
        Non: return d

fn wrap(x: $T) -> Opt($T):
    return Has(x)

struct Holder($T):
    o: Opt($T)

fn hget(h: Holder($T), d: $T) -> $T:
    match h.o:
        Has(x): return x
        Non: return d

fn main():
    println(str(unwrap(Has(5), 0)))                 # 5  (direct arg)
    o := wrap(7)                                     # generic fn returns Opt(int)
    println(str(unwrap(o, 0)))                       # 7
    println(unwrap(Has("hi"), "?"))                 # hi (string instance)
    println(str(unwrap(Non$(int), 9)))              # 9  (explicit type arg)

    xs := [Has(1), Has(2), Has(3)]                   # array of Opt(int), foreach
    s := 0
    for e in xs:
        s = s + unwrap(e, 0)
    println(str(s))                                  # 6

    h := Holder(Has(4))                              # generic enum in a generic struct field
    println(str(hget(h, 0)))                         # 4

    on := Has(Id(8))                                 # generic enum over a newtype
    println(str(to_int(unwrap(on, Id(0)))))          # 8
