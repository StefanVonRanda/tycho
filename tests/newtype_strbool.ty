# Newtypes over string and bool (distinct, zero-cost): wrap with Name(x), unwrap
# with to_str / to_bool, compare/order. Self-hosting in both compilers.
type UserId = string
type Active = bool

fn label(id: UserId) -> string:                   # a UserId param stays distinct
    return "user:" + to_str(id)

fn main():
    a := UserId("alice")
    b := UserId("bob")
    println(label(a) + " " + label(b))        # user:alice user:bob
    println(to_str(a))                         # alice
    if a == UserId("alice"):
        println("a==alice")
    if a < b:                                        # ordering sees through to string
        println("alice<bob")
    act := Active(true)
    off := Active(false)
    if to_bool(act):
        println("act on")
    if to_bool(off):
        println("BUG")
    println("")
