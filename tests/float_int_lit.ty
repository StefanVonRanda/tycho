# An int LITERAL adapts to a float operand in arithmetic AND ordering (B-1 --
# literals only, a variable never widens), uniformly across both compilers,
# including inside a generic numeric body (`if x < 0`). Non-literal int vs float
# is a type error (see tests/reject/float_int_*).
fn gsign(x: $T) -> int where numeric(T):
    if x < 0:
        return 0 - 1
    if x > 0:
        return 1
    return 0

fn main():
    f := 3.5
    println(str(f < 0) + "," + str(0 < f) + "," + str(f - 1))           # false,true,2.5
    println(str(gsign(0.0 - 2.0)) + str(gsign(5.0)) + str(gsign(0.0)))  # -110 (float instance)
    println(str(gsign(0 - 3)) + str(gsign(7)))                          # -11  (int instance)
