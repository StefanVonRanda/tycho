# Two multi-assigns sharing a first target in ONE block: the codegen temp
# (_ma_<first> in hierc0) must be scoped per statement, not redefined.
fn two() -> (int, int):
    return 3, 4

fn swap2(x: int, y: int) -> (int, int):
    return y, x

fn main():
    a := 0
    b := 0
    a, b = two()
    a, b = two()
    print(str(a) + "," + str(b))
    a, b = swap2(a, b)
    a, b = swap2(a, b)
    print(str(a) + "," + str(b))
