# write_file(path, contents) -> bool: writes contents' exact bytes (truncating
# the file), returns true on success / false if the file can't be opened. Round-
# trips through read_file. Writes only to /tmp, so the test is self-contained and
# leaves no state in the repo.
fn main():
    path := "/tmp/tycho_write_file_test.dat"
    body := "alpha\nbeta\ngamma\n"
    if write_file(path, body):
        println("write=ok")
    else:
        println("write=fail")

    back := read_file(path)
    if back == body:
        println("roundtrip=match")
    else:
        println("roundtrip=DIFFER")
    println("len=" + str(len(back)))           # 17

    if write_file(path, "hi"):                       # overwrite truncates
        println("after=" + read_file(path))     # hi

    if write_file("/no_such_dir_zzz/x", "y"):        # unwritable path -> false
        println("bad=ok")
    else:
        println("bad=handled")
