# Construction-arg move: building an aggregate from a uniquely-owned dead
# local hands off its buffer instead of deep-copying it (the same move as
# `b := a`, on the construction side). When the source is reused after the
# construction it is NOT dead, so it is deep-copied and stays independent.

fn build(n: int) -> [int]:
    r := []int
    for i in range(n):
        push(r, i)
    return r

fn moved() -> int:
    a := build(1000)
    b := build(2000)
    t := (a, b)                 # same arena, a & b dead -> MOVED (no copy)
    return len(t.0) + len(t.1)

fn main():
    print("moved_sum=" + str(moved()) + "\n")        # 3000

    # source reused after construction -> deep-copied, so independent
    x := build(5)
    t := (x, 7)                 # x read again below -> count>1 -> COPIED
    print("x0=" + str(x[0]) + " t00=" + str(t.0[0]) + "\n")   # 0, 0
    x[0] = 777                  # mutate the source
    print("after x0=" + str(x[0]) + " t00=" + str(t.0[0]) + "\n")  # 777, still 0

    # struct-literal construction from a (borrowed) param still deep-copies
    # correctly under the unified path
    s := build(3)
    box := pack(s)
    print("box_len=" + str(boxlen(box)) + "\n")      # 3

struct Box:
    data: [int]

fn pack(xs: [int]) -> Box:
    return Box(xs)

fn boxlen(b: Box) -> int:
    return len(b.data)
