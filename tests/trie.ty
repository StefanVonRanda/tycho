# Regression: a recursive struct whose field is a composite-VALUED map (`[int: Trie]`),
# mutated by descending into a child via `&t.kids[c]`. Exercises two fixes:
#   1. tychoc: a struct copy/eq body that calls the composite-map helper
#      (tycho_mapcN_copy/_eq) needs that helper FORWARD-DECLARED (the map family is
#      emitted after the struct bodies).
#   2. tychoc0: `&m[k]` on a composite-valued map must take the slot POINTER, not the
#      address of a by-value map_get (which is not a C lvalue).
struct Trie:
    kids: [int: Trie]          # child keyed by the next byte; recursive via a (heap) map
    word: bool

fn insert(t: inout Trie, s: string, i: int):
    if i >= len(s):
        t.word = true
        return
    c := s[i]
    if not (c in t.kids):
        t.kids[c] = Trie([]int: Trie, false)
    insert(&t.kids[c], s, i + 1)

fn has(t: Trie, s: string, i: int) -> bool:
    if i >= len(s):
        return t.word
    c := s[i]
    if not (c in t.kids):
        return false
    return has(t.kids[c], s, i + 1)

fn count(t: Trie) -> int:              # total nodes incl. root
    acc := 1
    ks := keys(t.kids)
    j := 0
    for j in range(0, len(ks)):
        acc = acc + count(t.kids[ks[j]])
    return acc

fn nwords(t: Trie) -> int:             # how many complete words are stored
    acc := 0
    if t.word:
        acc = 1
    ks := keys(t.kids)
    j := 0
    for j in range(0, len(ks)):
        acc = acc + nwords(t.kids[ks[j]])
    return acc

fn main():
    root := Trie([]int: Trie, false)
    insert(&root, "cat", 0)
    insert(&root, "car", 0)
    insert(&root, "card", 0)
    insert(&root, "dog", 0)
    println("cat=" + str(has(root, "cat", 0)) + " car=" + str(has(root, "car", 0)) + " card=" + str(has(root, "card", 0)))
    println("ca=" + str(has(root, "ca", 0)) + " cow=" + str(has(root, "cow", 0)) + " do=" + str(has(root, "do", 0)))
    println("nkids=" + str(len(root.kids)) + " nodes=" + str(count(root)) + " words=" + str(nwords(root)))
