# Match-arm payload value semantics: binding a heap payload and MUTATING it in
# the arm must not corrupt the scrutinee (the binding is an independent copy).
# Covers enum payloads and Option/Result boxes. Self-hosting in both compilers.
enum Wrap:
    W([int])
    Empty

fn main():
    w := W([1, 2, 3])
    got := 0
    match w:
        W(xs):
            xs[0] = 50
            push(xs, 4)
            got = xs[0] + len(xs)
        Empty:
            got = 0 - 1
    chk := 0
    match w:
        W(ys):
            chk = ys[0] * 100 + len(ys)
        Empty:
            chk = 0 - 1
    print("enum got=" + str(got) + " w-intact=" + str(chk) + "\n")   # 54 103

    o := Some([7, 8])
    og := 0
    match o:
        Some(zs):
            zs[0] = 99
            og = zs[0]
        None:
            og = 0 - 1
    oc := 0
    match o:
        Some(ws):
            oc = ws[0]
        None:
            oc = 0 - 1
    print("opt og=" + str(og) + " o-intact=" + str(oc) + "\n")        # 99 7
