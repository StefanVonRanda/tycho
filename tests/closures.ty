# Closures: lambdas `fn(p: T) -> R: expr`, captured by VALUE, downward-only.
# A lambda is a fat value {env, thunk}; captures are deep-copied into the env so
# the closure is independent of later mutation of the captured variable. Returning
# a capturing closure is rejected (it would dangle); see tests that must compile.

fn apply(f: fn(int) -> int, x: int) -> int:
    return f(x)

fn apply0(f: fn() -> int) -> int:
    return f()

fn applyS(f: fn() -> string) -> string:
    return f()

fn map_int(xs: [int], f: fn(int) -> int) -> [int]:
    out := []int
    for v in xs:
        push(out, f(v))
    return out

fn count_if(xs: [int], pred: fn(int) -> int) -> int:   # pred returns nonzero = keep
    n := 0
    for v in xs:
        if pred(v) > 0:
            n = n + 1
    return n

struct Pt:
    x: int
    y: int

# escaping closures: the returned closure's env re-homes into the caller's arena
# (deep-copying any heap captures) — sound with no lifetime annotations.
fn make_adder(n: int) -> fn(int) -> int:
    return fn(x: int) -> int: x + n

fn make_prefixer(p: string) -> fn(string) -> string:
    return fn(s: string) -> string: p + s

# fn values in containers: a struct field holding a callback, an array of them
struct Op:
    label: string
    cb: fn(int) -> int

fn make_ops(base: int) -> [fn(int) -> int]:     # a container of closures escapes
    out := []fn(int) -> int
    push(out, fn(x: int) -> int: x + base)
    push(out, fn(x: int) -> int: x * base)
    return out

fn main():
    # --- no-capture lambdas ---
    sq := fn(x: int) -> int: x * x
    println(f"sq(7)={apply(sq, 7)}")                         # 49
    println(f"inline={apply(fn(x: int) -> int: x + 1, 41)}") # 42
    ys := map_int([1, 2, 3, 4], fn(x: int) -> int: x * 10)
    println(f"map={ys[0]},{ys[1]},{ys[2]},{ys[3]}")          # 10,20,30,40

    # reassign a fn-typed local, call indirectly
    g := sq
    println(f"g=sq -> {g(9)}")                               # 81
    g = fn(x: int) -> int: 0 - x
    println(f"g=neg -> {g(9)}")                              # -9

    # --- scalar captures, by value ---
    n := 10
    addn := fn(x: int) -> int: x + n
    println(f"addn(5)={apply(addn, 5)}")                     # 15
    n = 1000                                                  # value capture: closure keeps 10
    println(f"addn(5) after n=1000 -> {apply(addn, 5)}")     # 15

    a := 3
    b := 4
    poly := fn(x: int) -> int: x * a + b                     # multi-capture
    println(f"poly(10)={apply(poly, 10)}")                   # 34

    thr := 5
    println(f"count>5={count_if([1, 6, 9, 4, 7], fn(z: int) -> int: z - thr)}")  # 3

    # closure created in an inner block, used after it (env in the function arena)
    h := fn(x: int) -> int: x
    if true:
        bonus := 100
        h = fn(x: int) -> int: x + bonus
    println(f"block-capture={apply(h, 8)}")                  # 108

    # --- heap captures, deep-copied (value semantics) ---
    s := "ada"
    greet := fn() -> string: "hi " + s
    println(f"{applyS(greet)}")                              # hi ada

    arr := [10, 20]
    alen := fn() -> int: len(arr)
    push(arr, 30)                                             # mutate original after capture
    println(f"alen={apply0(alen)} len(arr)={len(arr)}")     # alen=2 len(arr)=3

    vals := [1, 2, 3]
    vsum := fn() -> int: vals[0] + vals[1] + vals[2]
    vals[0] = 100                                            # mutate element after capture
    println(f"vsum={apply0(vsum)}")                          # 6 (copy, not 105)

    p := Pt(7, 8)
    pc := fn() -> int: p.x + p.y                            # struct capture
    println(f"pc={apply0(pc)}")                             # 15

    # --- escaping closures (returned from a function) ---
    add5 := make_adder(5)
    add9 := make_adder(9)
    println(f"escaped: {add5(100)} {add9(100)} {add5(1)}")  # 105 109 6 (each kept its own n)
    pre := make_prefixer(">> ")                             # heap capture escapes + re-homes
    println(pre("done"))                               # >> done
    println(f"down={apply(make_adder(20), 2)}")             # 22 (escaped closure passed straight down)

    # --- fn values in containers + call-on-expression ---
    op := Op("square", sq)                                  # fn in a struct field
    println(f"{op.label}={op.cb(6)}")                       # square=36 (call a fn-typed field)
    ops := [sq, fn(x: int) -> int: x + 1]                   # array of fn values
    println(f"arr: {ops[0](5)},{ops[1](5)}")                # 25,6 (call by index)
    esc := make_ops(10)                                     # container of closures escapes
    println(f"escaped-arr: {esc[0](5)},{esc[1](5)}")        # 15,50
    println(f"chained={make_adder(7)(3)}")                  # 10 (f(a)(b))
