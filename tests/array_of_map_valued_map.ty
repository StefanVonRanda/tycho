# Array whose element is a MAP-VALUED map (`[][int:[int:int]]`). tychoc0 emitted the
# outer map's put/copy (which deep-copy inner-map VALUES via the inner map's
# _copy/_eq) before the inner map's fns, with no forward declaration -> broken C
# (implicit `map_int_int_copy`). Map _copy/_eq are now forward-declared so emission
# order (ets is not dependency-ordered) no longer matters. Also covers a 3-deep
# map-of-map-of-map.
fn main():
    a := [][int:[int:int]]
    push(a, []int: [int:int])
    a[0][1][5] = 50
    a[0][1][6] = 60
    a[0][2][9] = 90
    println(str(a[0][1][5]) + " " + str(len(a[0][1])) + " " + str(len(a[0])))
    m := []int: [int:[int:int]]
    m[1][2][3] = 30
    println(str(m[1][2][3]))
