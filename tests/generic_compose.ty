# Gap fix (composition): a generic call's RESULT can now feed another generic in
# tychoc0 -- nested directly (f(g(x))) or via a bound variable -- matching tychoc.
fn box(xs: [$T]) -> [$T]:
    out := []
    for v in xs:
        push(out, v)
    return out

fn firstn(xs: [$T], n: int) -> [$T]:
    out := []
    i := 0
    for i < n and i < len(xs):
        push(out, xs[i])
        i = i + 1
    return out

fn gid(x: $T) -> T:
    return x

fn main():
    a := firstn(box([3, 1, 4, 1, 5]), 3)     # nested generic-as-arg
    println(str(a[0]) + str(a[2]))            # 34
    s := box(["p", "q", "r"])                 # bound generic (array) result...
    t := firstn(s, 2)                         # ...fed into another generic
    println(t[0] + t[1])                      # pq
    v := gid(42)                              # bound scalar generic result...
    w := gid(v)                               # ...fed into another generic
    println(str(w))                           # 42
