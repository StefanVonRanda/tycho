# Negative-literal consts: `const NAME = -<int/float literal>` folds to one
# negative literal (a bare `-` otherwise parses as a unary op, not a literal),
# top-level and function-local. Used in arithmetic and printed.
const MIN = -100
const FREEZING = -40.0

fn main():
    const OFFSET = -7
    println(str(MIN))              # -100
    println(str(MIN + 1))          # -99
    println(str(FREEZING))         # -40.0
    println(str(FREEZING * 2.0))   # -80.0
    println(str(OFFSET))           # -7
    println(str(MIN - OFFSET))     # -93
