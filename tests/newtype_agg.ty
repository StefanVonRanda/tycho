# Aggregate-underlying newtypes: `type X = [T]` / `[K: V]` / Struct.
# X(v) wraps (zero-cost, literal arg grounds to the underlying type),
# to_under(x) unwraps to the underlying value, and == stays deep between
# two values of the SAME newtype. Copy semantics are the underlying's
# (deep, value-semantic) throughout.

struct Pt:
    x: int
    y: int

type Ids = [int]
type Env = [string: int]
type Pos = Pt

fn total(xs: Ids) -> int:
    raw := to_under(xs)
    s := 0
    i := 0
    for i < len(raw):
        s = s + raw[i]
        i = i + 1
    return s

fn bump(e: Env, k: string) -> Env:
    m := to_under(e)
    m[k] = m.get(k, 0) + 1
    return Env(m)

fn main():
    ids := Ids([1, 2, 3])
    println(str(total(ids)))
    dup := ids
    if dup == ids:
        println("ids eq")
    e := bump(bump(Env([]), "a"), "a")
    println(str(to_under(e).get("a", 0)))
    p := Pos(Pt(7, 9))
    q := to_under(p)
    println(str(q.x + q.y))
