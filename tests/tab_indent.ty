# Tab indentation (B4): tabs are accepted for indentation, on a par with
# spaces. Indented with REAL TABs; exercises INDENT/DEDENT (depth 1..3),
# multi-level dedent, and blank/comment lines whose tab indent must NOT
# touch the indent stack.
fn classify(n: int) -> string:
	if n < 0:
		return "neg"
	if n == 0:
		return "zero"
	return "pos"

fn main():
	total := 0
	# a tab-indented comment line (must not affect the indent stack)
	for i in range(-1, 3):
		s := classify(i)
		if s == "pos":
			total = total + i
		println(classify(i))
	
	println("total=" + str(total))
