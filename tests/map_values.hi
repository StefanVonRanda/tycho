# Maps with arbitrary value types ([string: V], V = string / struct), exercising
# the composite-map runtime in both compilers: CRUD, literals, keys, the heap-value
# lifetime (a bound value must survive later rehashes as an independent copy), and
# value semantics (copying a map and mutating the copy must not touch the original).
struct P:
    x: int
    y: int

fn main():
    # [string: string]
    m := []string: string
    m = map_set(m, "a", "apple")
    m = map_set(m, "b", "banana")
    m = map_set(m, "a", "avocado")            # overwrite
    print(map_get(m, "a", "?") + "\n")         # avocado
    print(map_get(m, "b", "?") + "\n")         # banana
    print(map_get(m, "z", "none") + "\n")      # none (default)
    if map_has(m, "a"):
        print("has-a\n")
    if not map_has(m, "z"):
        print("no-z\n")

    # heap-value lifetime: bind, then force many rehashes; v stays its own copy
    v := map_get(m, "a", "?")
    i := 0
    for i in range(40):
        m = map_set(m, "k" + str(i), "v" + str(i))
    print(v + "\n")                            # avocado (not corrupted by rehash)
    print(str(len(keys(m))) + "\n")            # 42

    # value semantics: copy the map, mutate the copy, original unchanged
    base := []string: string
    base = map_set(base, "k", "orig")
    cp := base
    cp = map_set(cp, "k", "mutated")
    print(map_get(base, "k", "?") + "\n")      # orig (the copy's change must not leak)
    print(map_get(cp, "k", "?") + "\n")        # mutated

    m = map_del(m, "a")
    if not map_has(m, "a"):
        print("a-gone\n")

    # [string: Struct] values
    pts := []string: P
    pts = map_set(pts, "origin", P(0, 0))
    pts = map_set(pts, "unit", P(1, 1))
    q := map_get(pts, "unit", P(9, 9))
    print(str(q.x) + "," + str(q.y) + "\n")    # 1,1
    print(str(map_get(pts, "missing", P(7, 8)).y) + "\n")  # 8 (default)

    # [int: V] composite values (occupancy-array scheme; 0 is a real key)
    im := []int: string
    im = map_set(im, 1, "one")
    im = map_set(im, 0, "zero")
    im = map_set(im, 1, "uno")                 # overwrite
    print(map_get(im, 1, "?") + map_get(im, 0, "?") + map_get(im, 5, "x") + "\n")  # unozerox
    ipt := []int: P
    ipt = map_set(ipt, 9, P(8, 7))
    print(str(map_get(ipt, 9, P(0, 0)).x) + "," + str(map_get(ipt, 9, P(0, 0)).y) + "\n")  # 8,7

    # literal with entries
    lit := ["x": "ex", "y": "why"]
    print(map_get(lit, "x", "?") + map_get(lit, "y", "?") + "\n")  # exwhy

    # == on composite-valued maps (deep value equality)
    e1 := ["k": "v", "j": "w"]
    e2 := ["j": "w", "k": "v"]                 # same entries, different insertion order
    e3 := ["k": "v", "j": "DIFF"]
    if e1 == e2:
        print("eq-ok\n")
    if not (e1 == e3):
        print("neq-ok\n")
