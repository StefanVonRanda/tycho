# Stage 0 enabling builtins: read_all (slurp stdin) + chr (byte -> 1-char string).
fn main():
    src := read_all()                    # the whole of stdin, verbatim
    print(src)
    print(chr(65) + chr(66) + chr(67) + "\n")              # ABC
    s := "Hi!"
    print(str(s[0]) + "," + str(s[1]) + "," + str(s[2]) + "\n")   # 72,105,33 (ord)
    print(chr(s[0]) + chr(s[1]) + chr(s[2]) + "\n")        # Hi! (chr inverts ord)
