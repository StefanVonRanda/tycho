# Integer overflow is DEFINED: signed `int` (C long, 64-bit) wraps two's-
# complement, never C undefined behaviour. Built with -fwrapv in both compilers
# and on the generated-program cc line, so the optimizer can never miscompile
# overflowing arithmetic (e.g. assume `x + 1 > x`). Locks the language's
# integer-overflow contract. See docs/internals/integer-overflow.md.

fn main():
    mx := 9223372036854775807          # LONG_MAX (2^63 - 1)
    println(str(mx + 1))          # wraps to LONG_MIN = -9223372036854775808

    mn := -9223372036854775807 - 1     # LONG_MIN (avoid lexing 2^63 as a literal)
    println(str(mn - 1))          # wraps to LONG_MAX =  9223372036854775807

    println(str(mx * 2))          # (2^63-1)*2 = -2 as signed long

    # overflow inside a comparison the optimizer must NOT fold (x+1 > x is
    # false here): with -fwrapv this is well-defined and prints "wrapped".
    x := 9223372036854775807
    if x + 1 < x:
        println("wrapped")
    else:
        println("no-wrap")
