# `sink` parameter convention: an OWNED, mutable parameter (a borrow is read-only). The
# call-site argument is CONSUMED -- ADOPTED with no copy for a fresh value or a dead local
# (read once, outside any loop, from any enclosing arena). The move is a compiler-checked
# guarantee: passing a variable you then reuse is an error (tests/reject/sink_use_after.ty),
# so you copy explicitly to keep it. Both compilers, byte-identical.
fn dbl(xs: sink [int]) -> int:
    xs[0] = xs[0] + 100        # mutate in place -- legal only because xs is `sink`
    return xs[0]

fn main():
    a := [1]
    println("1 a=" + str(dbl(a)))               # dead after -> adopt: 101

    b := [5]                                         # to keep b, hand the sink a copy:
    keep := b                                        # `keep := b` copies (b is read again below)
    x := dbl(keep)                                   # keep is dead -> adopt; b untouched
    println("2 b=" + str(b[0]) + " x=" + str(x))   # b=5 x=105

    println("3 lit=" + str(dbl([5, 5, 5])))     # fresh literal -> adopt: 105

    e := [2]
    on := true
    if on:
        println("4 e=" + str(dbl(e)))           # e read once (in the branch) -> adopt: 102

    h := [30]
    println("5 ufcs=" + str(h.dbl()))           # UFCS receiver dead -> adopt: 130
