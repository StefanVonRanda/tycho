# Adversarial value-semantics sweep — extends the borrow audit (tests/
# borrow_alias.ty) to the rest of the copy-elision / reuse chain. Every
# optimization that elides a deep copy (move-on-last-use, construction-arg
# move, in-place string/map accumulators) is sound ONLY when its source is
# provably dead or read-only. Each probe below forces a situation the
# optimization must NOT mistake for safe: a value is aliased/snapshotted, then
# one side is mutated, and BOTH sides are observed. The golden is the value-
# semantics-correct answer; a guard that elides a copy it shouldn't prints the
# corrupted value instead. Runs under ASan+UBSan via the differential harness.

struct Box:
    items: [int]
    tag: string

enum Wrap:
    W([int])

fn wrap(xs: [int], t: string) -> Box:
    return Box(xs, t)

fn rewrap(xs: [int]) -> Wrap:
    return W(xs)

fn ok_items(xs: [int]) -> Result([int], string):
    return Ok(xs)

# returns a place (a struct's array field): must deep-copy, else the returned
# value aliases the source struct's buffer.
fn first_items(b: Box) -> [int]:
    return b.items

# inout: the mutation SHOULD reach the caller (that is the contract).
fn bump_first(b: inout Box):
    b.items[0] = 100

fn main():
    # 1. in-place string accumulator: a mid-loop snapshot must FREEZE, not
    #    track the accumulator's subsequent in-place growth.
    acc := ""
    saved := ""
    for i in range(1, 5):
        acc = acc + str(i)
        if i == 2:
            saved = acc
    println("1 acc=" + acc + " saved=" + saved + " (expect acc=1234 saved=12)")

    # 2. in-place map accumulator: same, for map_set put-in-place.
    counts := []string: int
    snap := []string: int
    for i in range(1, 4):
        counts["k"] = i
        if i == 2:
            snap = counts
    println("2 counts=" + str(counts.get("k", 0)) + " snap=" + str(snap.get("k", 0)) + " (expect counts=3 snap=2)")

    # 3. construction-arg move: mutating the source array after it was built
    #    into Box must not change the stored value (move only if source dead).
    a := [1, 2, 3]
    t := wrap(a, "t")
    a[0] = 99
    println("3 t=" + str(t.items[0]) + " a=" + str(a[0]) + " (expect t=1 a=99)")

    # 4. heap-struct value copy: `d := b1` is an independent deep copy; mutating
    #    d's array element and string field must not touch b1.
    b1 := Box([5, 6], "orig")
    d := b1
    d.items[0] = 77
    d.tag = "changed"
    println("4 b1=" + str(b1.items[0]) + " b1.tag=" + b1.tag + " (expect 5 orig)")

    # 5. move-on-last-use guard: e is read AFTER `f := e`, so f must be a copy.
    e := [10, 20]
    f := e
    f[0] = 88
    println("5 e=" + str(e[0]) + " f=" + str(f[0]) + " (expect e=10 f=88)")

    # 6. array literal stores its elements: `[inner, inner]` must deep-copy a
    #    heap place element, so mutating the source after doesn't reach the array.
    inner := [1, 2]
    nested := [inner, inner]
    inner[0] = 99
    println("6 nested[0][0]=" + str(nested[0][0]) + " inner[0]=" + str(inner[0]) + " (expect 1 99)")

    # 7. enum payload: W(a) stores a's array; mutating a after must not reach it.
    a7 := [3, 4]
    w := rewrap(a7)
    a7[0] = 99
    wv := 0
    match w:
        W(v):
            wv = v[0]
    println("7 W payload=" + str(wv) + " a7=" + str(a7[0]) + " (expect 3 99)")

    # 8. Result Ok payload: same, through the Ok(...) box.
    a8 := [5, 6]
    r := ok_items(a8)
    a8[0] = 99
    rv := 0
    match r:
        Ok(v):
            rv = v[0]
        Err(e):
            rv = 0 - 1
    println("8 Ok payload=" + str(rv) + " a8=" + str(a8[0]) + " (expect 5 99)")

    # 9. return path: returning a place field must deep-copy, so mutating the
    #    returned value can't reach the source struct.
    bx := Box([7, 8], "r")
    got := first_items(bx)
    got[0] = 99
    println("9 bx.items[0]=" + str(bx.items[0]) + " got[0]=" + str(got[0]) + " (expect 7 99)")

    # 10. projection write mutates the element in place; binding an element to a
    #     local then copies it (value semantics) -- the local must be independent.
    boxes := [Box([1], "x")]
    push(boxes, Box([2], "y"))
    boxes[0].items[0] = 50
    snapb := boxes[0]
    snapb.items[0] = 77
    println("10 boxes=" + str(boxes[0].items[0]) + " snapb=" + str(snapb.items[0]) + " (expect 50 77)")

    # 11. inout: the mutation reaches the caller (the intended direction).
    bxi := Box([9], "i")
    bump_first(&bxi)
    println("11 bxi=" + str(bxi.items[0]) + " (expect 100)")
