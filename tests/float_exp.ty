# Float-literal exponent forms: e/E, optional sign, with or without a fractional
# part (1e10, 1.5e-3, 2E8). A bare trailing dot or a malformed exponent (1e,
# 1.e5) is not a float -- see tests/reject. Both compilers must agree (fixpoint).
fn main():
    println(str(1e10))
    println(str(1.5e-3))
    println(str(2E8))
    println(str(1e+5))
    println(str(6.022e23))
    a := 2.0e3
    b := 1e3
    println(str(a + b))
    println(str(0 - 1e2))
    println(str(1e3 * 2.0))
