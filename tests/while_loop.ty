# Condition-form `for <cond>:` is Tycho's while loop — load-bearing for the
# bootstrap (a lexer/parser scans with it). Locked here so it stays working.
fn main():
    i := 0
    sum := 0
    for i < 10:
        sum = sum + i
        i = i + 1
    print("sum=" + str(sum) + "\n")          # 45

    a := 0
    pairs := 0
    for a < 3:                                # nested
        b := 0
        for b < 3:
            pairs = pairs + 1
            b = b + 1
        a = a + 1
    print("pairs=" + str(pairs) + "\n")      # 9

    s := "hello"                              # string scan (the lexer pattern)
    j := 0
    ls := 0
    for j < len(s):
        if s[j] == 108:                       # 'l'
            ls = ls + 1
        j = j + 1
    print("Ls=" + str(ls) + "\n")            # 2
