# Composite map keys (Stage 2): a tuple as the key type. Stored by value, deep-hashed
# and deep-compared, occupancy scheme — same machinery as struct keys. Covers a scalar
# tuple, a tuple whose element is a struct, a tuple of tuples, and a struct key that
# itself contains a tuple field (the topological body-emit makes this last one work).
struct Point:
    x: int
    y: int

struct Edge:
    lo: (int, int)          # struct with a by-value tuple field
    hi: int

fn main():
    # (int, string) key
    m := [](int, string): int
    m[(1, "a")] = 10
    m[(2, "b")] = 20
    m[(1, "a")] = 11                          # overwrite, not a new entry
    println("get=" + str(m.get((1, "a"), -1)) + " miss=" + str(m.get((9, "z"), -1)))
    println("in=" + str((2, "b") in m) + " len=" + str(len(m)))
    m[(1, "a")] += 5                          # in-place accumulator on a tuple key
    ks := keys(m)
    println("acc=" + str(m.get((1, "a"), 0)) + " k0=(" + str(ks[0].0) + "," + ks[0].1 + ")")
    delete m[(1, "a")]
    println("del: len=" + str(len(m)) + " gone=" + str(not ((1, "a") in m)))

    # tuple whose element is a struct (recursive hash/eq through the struct)
    a := [](int, Point): string
    a[(1, Point(2, 3))] = "hit"
    println("tstruct=" + a.get((1, Point(2, 3)), "?") + " miss=" + a.get((1, Point(9, 9)), "?"))

    # tuple of tuples + deep ==
    c := []((int, int), int): bool
    c[((1, 2), 3)] = true
    println("ttup=" + str(c.get(((1, 2), 3), false)) + " miss=" + str(c.get(((1, 2), 9), false)))
    d := [](int, string): int
    d[(7, "k")] = 1
    e := [](int, string): int
    e[(7, "k")] = 1
    print("eq=" + str(d == e))
    e[(8, "k")] = 2
    println(" neq=" + str(d == e))

    # struct key whose field is a tuple (struct->tuple by-value emit order)
    g := []Edge: int
    g[Edge((0, 0), 5)] = 42
    g[Edge((0, 0), 5)] += 1
    println("sff=" + str(g.get(Edge((0, 0), 5), -1)) + " miss=" + str(g.get(Edge((1, 1), 5), -1)))
