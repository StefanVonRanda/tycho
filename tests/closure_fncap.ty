# Capturing a fn-VALUE inside a closure -- the parser-combinator pattern.
# Regression: the capture analysis (collect_idents / collect_evars) skipped a
# call's CALLEE name, so in `g(f(x))` the fn-values f and g were never captured;
# the lifted proc referenced undeclared names and the emitted C failed to build.
# Fixed by collecting E_CALL callee names too (the vars_find / has_str filter then
# keeps only enclosing locals -- globals/builtins/constructors are dropped).

fn compose(f: fn(int) -> int, g: fn(int) -> int) -> fn(int) -> int:
    return fn(x: int) -> int: g(f(x))          # captures two fn-values, escapes

fn twice(f: fn(int) -> int) -> fn(int) -> int:
    return fn(x: int) -> int: f(f(x))          # captures one fn-value, escapes

fn apply(f: fn(int) -> int, x: int) -> int:
    return f(x)

fn main():
    inc := fn(x: int) -> int: x + 1
    dbl := fn(x: int) -> int: x * 2

    h := compose(inc, dbl)
    println("compose(inc,dbl)(5) = " + str(h(5)))            # dbl(inc(5)) = 12

    q := twice(inc)
    println("twice(inc)(5) = " + str(q(5)))                  # inc(inc(5)) = 7

    f := dbl                                                       # capture a fn-value, call inline
    g := fn(x: int) -> int: f(x) + 1
    println("inline f(x)+1 at 10 = " + str(g(10)))           # dbl(10)+1 = 21

    println("apply(compose(inc,dbl),3) = " + str(apply(compose(inc, dbl), 3)))  # 8

    h2 := compose(compose(inc, inc), dbl)                          # nested combinators
    println("compose(compose(inc,inc),dbl)(5) = " + str(h2(5)))   # dbl(inc(inc(5))) = 14
