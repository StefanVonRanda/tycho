# `or_return` on an Option: `v := opt_expr or_return` unwraps Some(v), else
# short-circuits the enclosing Option-returning function with None. (Mirrors
# or_return on Result.) Self-hosting (hierc0 supports it).
fn first_even(xs: [int]) -> Option(int):
    i := 0
    for i < len(xs):
        if xs[i] - (xs[i] / 2) * 2 == 0:
            return Some(xs[i])
        i = i + 1
    return None

# chains two or_returns: both must be Some, else the whole thing is None
fn doubled_even(xs: [int]) -> Option(int):
    v := first_even(xs) or_return
    w := first_even([8, 9]) or_return        # always Some(8)
    return Some(v * 10 + w)

fn show(o: Option(int)) -> string:
    match o:
        Some(n):
            return "Some(" + str(n) + ")"
        None:
            return "None"

fn main():
    print(show(doubled_even([1, 3, 4, 5])) + "\n")   # Some(48)
    print(show(doubled_even([1, 3, 5])) + "\n")        # None
    print(show(doubled_even([6])) + "\n")              # Some(68)
