# const generics 1.6B: `[$N]T` generic-over-size. A `$N` size parameter is inferred
# from the (fixed-size) argument at each call and monomorphized; in the body N is an
# ordinary int const. Covers: inference over two lengths (two instances), N in an
# index expression, a repeated `$N` (both args share one length), two distinct size
# params, a float element, and `[$N]$T` (size AND element inferred together).

fn sumN(xs: [$N]int) -> int:            # N inferred from the argument's length
    total := 0
    for i in range(N):                  # N is an int const in the body
        total = total + xs[i]
    return total

fn lastOf(xs: [$N]int) -> int:
    return xs[N - 1]                    # N used in an index expression

fn dotN(a: [$N]int, b: [$N]int) -> int: # a and b MUST share one length N
    d := 0
    for i in range(N):
        d = d + a[i] * b[i]
    return d

fn widthPlusHeight(a: [$W]int, b: [$H]int) -> int:   # two distinct size params
    return W + H

fn avg(xs: [$N]float) -> float:
    s := 0.0
    for i in range(N):
        s = s + xs[i]
    return s / to_float(N)

fn firstOf(xs: [$N]$T) -> $T:           # size N and element T both inferred
    return xs[0]

fn countOf(xs: [$N]$T) -> int:
    return N

fn main():
    a: [3]int = [10, 20, 30]
    b: [4]int = [1, 2, 3, 4]
    println("sum3=" + str(sumN(a)))                 # 60
    println("sum4=" + str(sumN(b)))                 # 10
    println("last3=" + str(lastOf(a)))              # 30
    c: [3]int = [2, 4, 6]
    println("dot=" + str(dotN(a, c)))               # 10*2+20*4+30*6 = 280
    println("wph=" + str(widthPlusHeight(a, b)))    # 3 + 4 = 7
    fs: [4]float = [1.0, 2.0, 3.0, 4.0]
    println("avg=" + str(avg(fs)))                  # 2.5
    ss: [2]string = ["hi", "yo"]
    println("fi=" + str(firstOf(a)) + " fs=" + firstOf(ss))   # fi=10 fs=hi
    println("ci=" + str(countOf(a)) + " cs=" + str(countOf(ss)))   # ci=3 cs=2
