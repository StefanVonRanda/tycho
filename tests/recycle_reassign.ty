# Liveness-driven buffer recycling: a loop-carried scalar array reassigned from a
# function call (`a = step(a)`) hands its dead, uniquely-owned old buffer back to
# the arena for reuse. This is correctness coverage for that codegen path — the
# CALL reads a's old buffer to build the result, so recycling must happen AFTER
# the call returns, never before (else the call's own allocations alias a's live
# buffer). The checksum is only right if every transform saw the correct input.
fn step(a: [int], add: int) -> [int]:
    b := []int
    for i in range(len(a)):
        b2 := a[i] + add        # reads a (the OLD buffer) — must still be intact here
        push(b, b2 * 2 - add)
    return b

fn scale(xs: [float], by: float) -> [float]:
    r := []float
    for i in range(len(xs)):
        push(r, xs[i] * by + 1.0)
    return r

fn main():
    a := []int
    for i in range(50):
        push(a, i)
    # reassign-from-call in a loop: each pass recycles the previous a's buffer
    for j in range(30):
        a = step(a, j)
    s := 0
    for i in range(len(a)):
        s = s + a[i] - (s / 7) * 0

    # float path (the gate also covers [float])
    f := []float
    for i in range(20):
        push(f, to_float(i))
    for j in range(10):
        f = scale(f, 1.0)
    fs := 0
    for i in range(len(f)):
        fs = fs + to_int(f[i])

    print("s=" + str(s - (s / 1000000007) * 1000000007) + "\n")
    print("fs=" + str(fs) + "\n")
    print("alen=" + str(len(a)) + " flen=" + str(len(f)) + "\n")
