fn yn(b: bool) -> string:
    if b:
        return "T"
    return "F"

fn total(m: [string: float]) -> float:
    ks := keys(m)
    s := 0.0
    for i in range(len(ks)):
        s = s + map_get(m, ks[i], 0.0)
    return s

fn bump(m: mut [string: float], k: string, by: float):
    m[k] = map_get(m, k, 0.0) + by

fn main():
    prices := ["apple": 1.5, "pear": 2.25]
    prices["fig"] = 0.75
    println("apple=" + str(map_get(prices, "apple", 0.0)) + " len=" + str(len(prices)))
    println("total=" + str(total(prices)))
    println("has_pear=" + yn("pear" in prices) + " has_x=" + yn("x" in prices))
    snap := prices
    prices["apple"] = 9.0
    println("snap_apple=" + str(map_get(snap, "apple", 0.0)) + " now=" + str(map_get(prices, "apple", 0.0)))
    delete prices["fig"]
    println("after_del len=" + str(len(prices)) + " fig?=" + yn("fig" in prices))
    acc := []string: float
    bump(&acc, "a", 1.5)
    bump(&acc, "a", 2.5)
    println("acc_a=" + str(map_get(acc, "a", 0.0)) + " len=" + str(len(acc)))
    counts := ["x": 1, "y": 2]
    counts["x"] = map_get(counts, "x", 0) + 10
    println("int x=" + str(map_get(counts, "x", 0)))
