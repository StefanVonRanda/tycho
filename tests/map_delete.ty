# `delete m[k]` (B5.2): removes a key from a map in place; replaces map_del.
# Checked via len() + `in` membership + specific-key reads -- NOT keys() order,
# which can legitimately differ after a delete (tychoc tombstones in place,
# tychoc0 rebuilds), an accepted representation-level asymmetry.
fn yn(b: bool) -> string:
    if b:
        return "T"
    return "F"

fn main():
    m := []string: int
    m["a"] = 1
    m["b"] = 2
    m["c"] = 3
    delete m["b"]
    println("del len=" + str(len(m)) + " hasA=" + yn("a" in m) + " hasB=" + yn("b" in m) + " a=" + str(m["a"]) + " c=" + str(m["c"]))
    delete m["zzz"]                                  # deleting a missing key is a no-op
    println("missing len=" + str(len(m)))
    m["b"] = 20                                      # re-insert a previously deleted key
    println("reinsert len=" + str(len(m)) + " b=" + str(m["b"]))
    delete m["a"]
    delete m["b"]
    delete m["c"]
    println("empty len=" + str(len(m)) + " hasC=" + yn("c" in m))

    # int key + composite value type
    n := []int: [int]
    n[1] = [10, 11]
    n[2] = [20, 21]
    delete n[1]
    println("int len=" + str(len(n)) + " has1=" + yn(1 in n) + " has2=" + yn(2 in n))
