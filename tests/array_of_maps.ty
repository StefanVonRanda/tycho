# Array whose ELEMENT is a map (`[][int:int]`): index into an array element that is
# a map, then put / delete / read it, and iterate keys() per element. tychoc0 used to
# emit the `Arr_map_int_int` type without ever defining it (broken C); it now generates
# the array-of-map family (struct + helpers) after the map family, like the C compiler.
fn main():
    arr := [][int:int]
    push(arr, []int: int)
    push(arr, []int: int)
    arr[0][1] = 10
    arr[0][2] = 20
    arr[1][3] = 30
    delete arr[0][1]              # delete from a map that is an array element
    arr[0][5] = 50               # reinsert appends to that element's order
    out := ""
    i := 0
    for i in range(0, len(arr)):
        ks := keys(arr[i])
        j := 0
        for j in range(0, len(ks)):
            out = out + str(i) + ":" + str(ks[j]) + "=" + str(arr[i][ks[j]]) + " "
    print(out + "\n")            # 0:2=20 0:5=50 1:3=30
    print(str(1 in arr[0]) + " " + str(5 in arr[0]) + " " + str(3 in arr[1]) + " n0=" + str(len(arr[0])) + "\n")
