# Stage-2 (#3): a generic function that CALLS another generic, instantiated at
# more than one type. The inner call is instantiated per outer instance; the
# resolve-up-front pass discovers it so it gets both a prototype and a body
# (previously: "defined but not declared").
#
# Scope: single-level nesting (a generic body calls another generic on a plain
# value). A generic call whose ARGUMENT is itself a generic call (`id(id(x))`)
# inside a generic body is a separate, harder case not covered here.
fn id(x: $T) -> T:
    return x

fn relay(x: $T) -> T:            # generic calling another generic
    return id(x)

fn wrap(xs: [$T]) -> [$T]:       # nested generic call inside a fresh-collection build
    out := []
    for v in xs:
        push(out, id(v))
    return out

fn main():
    println(str(relay(7)))               # 7
    println(relay("hi"))                 # hi  (2nd instance of relay + id)
    a := wrap([1, 2, 3])
    println(str(a[0]) + str(a[2]))       # 13
    b := wrap(["p", "q"])                # string instances of wrap + id
    println(b[0] + b[1])                 # pq
