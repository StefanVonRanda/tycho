# Variadic parameters (ROADMAP 2.2a): `xs: ...T` makes `xs` a `[T]`; a call packs its
# trailing arguments into it. `f()` -> empty, `f(arr...)` spreads an existing array.
# The generic form `...$T` infers T from the arguments.
fn sum(xs: ...int) -> int:
    acc := 0
    for x in xs:
        acc = acc + x
    return acc

fn tagged(tag: string, xs: ...int) -> string:      # fixed + variadic
    return tag + "=" + str(sum(xs...))              # forward via spread

fn count(xs: ...$T) -> int:                        # generic: T inferred
    return len(xs)

fn firstof(xs: ...$T) -> $T:                       # returns an element
    return xs[0]

fn main():
    println("s3=" + str(sum(1, 2, 3)))             # 6
    println("s0=" + str(sum()))                    # 0  (empty [] int)
    println("s1=" + str(sum(42)))                  # 42
    nums := [4, 5, 6]
    println("spread=" + str(sum(nums...)))         # 15
    println(tagged("total", 10, 20))               # total=30
    println("ci=" + str(count(1, 2, 3, 4)))        # 4
    println("cs=" + str(count("a", "b")))          # 2
    println("fi=" + str(firstof(7, 8, 9)))         # 7
    println("fs=" + firstof("x", "y"))             # x
