# Result(T, E): the no-exceptions error story. A function returns Ok(value) or
# Err(error); the caller matches both arms exhaustively. Value semantics holds
# -- assigning a Result deep-copies its payload, so copies never alias.

fn checked_div(a: int, b: int) -> Result(int, string):
    if b == 0:
        return Err("divide by zero")
    return Ok(a / b)

# heap ok-type: Result([int], string) -- the Ok payload owns a buffer
fn make_range(n: int) -> Result([int], string):
    if n < 0:
        return Err("negative")
    r := []int
    for i in range(n):
        push(r, i)
    return Ok(r)

fn show(r: Result(int, string)) -> string:
    match r:
        Ok(v):
            return "ok:" + str(v)
        Err(e):
            return "err:" + e

fn main():
    print(show(checked_div(10, 2)) + "\n")    # ok:5
    print(show(checked_div(10, 0)) + "\n")    # err:divide by zero

    # heap Ok payload, bound and read inside the match arm
    match make_range(4):
        Ok(xs):
            print("range_len=" + str(len(xs)) + " last=" + str(xs[3]) + "\n")
        Err(e):
            print("err:" + e + "\n")
    match make_range(-1):
        Ok(xs):
            print("len=" + str(len(xs)) + "\n")
        Err(e):
            print("neg_err=" + e + "\n")

    # value semantics: b is an independent deep copy of a (heap payload)
    a := make_range(3)
    b := a
    match a:
        Ok(xs):
            print("a_len=" + str(len(xs)) + "\n")
        Err(e):
            print(e + "\n")
    match b:
        Ok(xs):
            print("b_len=" + str(len(xs)) + "\n")
        Err(e):
            print(e + "\n")

    # an annotated decl fixes the partial type of a bare Ok/Err
    c : Result(int, string) = Err("annotated")
    print(show(c) + "\n")                      # err:annotated
    d : Result(int, string) = Ok(42)
    print(show(d) + "\n")                      # ok:42
