# `inout` on a scalar array element (`f(&a[i])`) must project a mutable lvalue.
# Regression for a tychoc codegen crash: it emitted a bogus tycho_arr_C<garbage>_ptr
# for the built-in int/str/float arrays (which had no _ptr helper), so the C failed
# to compile. Composite-element arrays already worked. tychoc0 was fine. Both must
# agree now, including through a struct field.

struct S:
    xs: [int]

fn inci(x: inout int):
    x = x + 1

fn ups(s: inout string):
    s = s + "!"

fn dbl(x: inout float):
    x = x * 2.0

fn main():
    a := [5, 6]
    inci(&a[0])
    println(str(a[0]))        # 6

    b := ["hi", "yo"]
    ups(&b[1])
    println(b[1])             # yo!

    c := [1.5, 2.5]
    dbl(&c[0])
    println(str(c[0]))        # 3.0

    s := S([7, 8])
    inci(&s.xs[0])
    println(str(s.xs[0]))     # 8
