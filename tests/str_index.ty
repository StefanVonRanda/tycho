# String indexing in loops: exercises the hoisted-length O(1) bounds check
# (tycho_str_get_n) for a string PARAM (sumbytes' s), a string LOCAL (a), and a
# sliced local (b) -- all indexed and never reassigned. Output is hand-verifiable
# from ASCII codes, so the golden is correct independent of the compiler.
fn sumbytes(s: string) -> int:
    t := 0
    for i in range(len(s)):
        t = t + s[i]
    return t

fn main():
    a := "ABC"
    t := 0
    for i in range(len(a)):
        t = t + a[i]
    println(str(t))                  # 65+66+67 = 198
    println(str(sumbytes("hi")))     # 104+105  = 209
    b := a[0:2]                           # "AB"
    println(str(b[0] + b[1]))        # 65+66    = 131
