fn grade(n: int) -> string:
    if n >= 90:
        return "A"
    elif n >= 80:
        return "B"
    elif n >= 70:
        return "C"
    else:
        return "F"

fn side(tag: string, v: bool) -> bool:
    print("eval:" + tag + " ")
    return v

fn main():
    # precedence: comparisons bind tighter than and/or; not tighter than and
    a := 3
    b := 7
    if a < b and b < 10:
        println("and-ok")
    if a > b or b == 7:
        println("or-ok")
    if not (a == b):
        println("not-ok")
    if not a > b:           # parses as (not (a>b)) -> not false -> true
        println("not-prec-ok")
    # short-circuit: && must not evaluate the right side when left is false
    if side("L", false) and side("R", true):
        println("unreachable")
    println("")
    if side("L2", true) or side("R2", false):
        println("or-short-ok")
    # elif chain
    println(grade(95) + grade(85) + grade(72) + grade(40))
