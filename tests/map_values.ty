# Maps with arbitrary value types ([string: V], V = string / struct), exercising
# the composite-map runtime in both compilers: CRUD, literals, keys, the heap-value
# lifetime (a bound value must survive later rehashes as an independent copy), and
# value semantics (copying a map and mutating the copy must not touch the original).
struct P:
    x: int
    y: int

fn main():
    # [string: string]
    m := []string: string
    m["a"] = "apple"
    m["b"] = "banana"
    m["a"] = "avocado" # overwrite
    println(map_get(m, "a", "?"))         # avocado
    println(map_get(m, "b", "?"))         # banana
    println(map_get(m, "z", "none"))      # none (default)
    if "a" in m:
        println("has-a")
    if not "z" in m:
        println("no-z")

    # heap-value lifetime: bind, then force many rehashes; v stays its own copy
    v := map_get(m, "a", "?")
    i := 0
    for i in range(40):
        m["k" + str(i)] = "v" + str(i)
    println(v)                            # avocado (not corrupted by rehash)
    println(str(len(keys(m))))            # 42

    # value semantics: copy the map, mutate the copy, original unchanged
    base := []string: string
    base["k"] = "orig"
    cp := base
    cp["k"] = "mutated"
    println(map_get(base, "k", "?"))      # orig (the copy's change must not leak)
    println(map_get(cp, "k", "?"))        # mutated

    delete m["a"]
    if not "a" in m:
        println("a-gone")

    # [string: Struct] values
    pts := []string: P
    pts["origin"] = P(0, 0)
    pts["unit"] = P(1, 1)
    q := map_get(pts, "unit", P(9, 9))
    println(str(q.x) + "," + str(q.y))    # 1,1
    println(str(map_get(pts, "missing", P(7, 8)).y))  # 8 (default)

    # [int: V] composite values (occupancy-array scheme; 0 is a real key)
    im := []int: string
    im[1] = "one"
    im[0] = "zero"
    im[1] = "uno" # overwrite
    println(map_get(im, 1, "?") + map_get(im, 0, "?") + map_get(im, 5, "x"))  # unozerox
    ipt := []int: P
    ipt[9] = P(8, 7)
    println(str(map_get(ipt, 9, P(0, 0)).x) + "," + str(map_get(ipt, 9, P(0, 0)).y))  # 8,7

    # literal with entries
    lit := ["x": "ex", "y": "why"]
    println(map_get(lit, "x", "?") + map_get(lit, "y", "?"))  # exwhy

    # == on composite-valued maps (deep value equality)
    e1 := ["k": "v", "j": "w"]
    e2 := ["j": "w", "k": "v"]                 # same entries, different insertion order
    e3 := ["k": "v", "j": "DIFF"]
    if e1 == e2:
        println("eq-ok")
    if not (e1 == e3):
        println("neq-ok")

    # map_has returns a real bool: str() prints true/false (not 1/0), and both
    # compilers must agree (map_has was typed int in tychoc0 before — a str divergence).
    println("has " + str("unit" in pts) + " " + str("nope" in pts))  # has true false
    println("ihas " + str(0 in im) + " " + str(99 in im))             # ihas true false

    # aggregate value types: array values and nested-map values (each monomorphized;
    # the value's own runtime family is emitted, inner map typedef'd before the outer)
    av := []int: [int]
    av[1] = [10, 20, 30]
    da := []int
    println("arrval=" + str(len(map_get(av, 1, da))))                  # arrval=3
    nv := []string: [string: int]
    box := []string: int
    box["x"] = 7
    nv["a"] = box
    dn := []string: int
    println("nestval=" + str(map_get(map_get(nv, "a", dn), "x", 0)))   # nestval=7
    # m[k] = <multi-entry map literal>: the inner map must be built in nv's arena,
    # NOT owner 0 — else the chained-set intermediate tables leak (LSan, make test).
    nv["b"] = ["y": 9, "z": 8]
    println("place=" + str(map_get(map_get(nv, "b", dn), "z", 0)))     # place=8
