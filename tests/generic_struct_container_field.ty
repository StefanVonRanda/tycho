# A generic struct whose field type CONTAINS the type parameter inside a container
# (`[$V]`, `[string:$V]`, `[[$V]]`, `fn($V)->$V`). tychoc0's generic-struct constructor
# inference (mono_expr) only bound a BARE `$V` field (`ft[0] == '$'`), so a typaram nested
# in a container field was never bound -> instantiate_struct substituted nothing -> `$V`
# leaked into the emitted instance ("unknown type '$V'" / undefined `Arr_arr_$V`). Fixed by
# unifying the field pattern against the arg's concrete type via match_typaram_str, which
# already recurses into `[$V]` / `{string:$V}` / `fn(...)`. tychoc always handled it.
struct Box($V):
    a: [$V]

struct Pair($A, $B):
    xs: [$A]
    m: [string: $B]

fn main():
    b := Box([1, 2, 3])
    println(str(b.a[0] + b.a[2]))          # 4
    p := Pair([10, 20], []string: bool)
    p.m["k"] = true
    println(str(p.xs[1]) + " " + str(p.m["k"]))   # 20 true
    s := Box(["hi", "yo"])
    println(s.a[0] + s.a[1])               # hiyo
