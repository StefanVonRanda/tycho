# User-defined projections (ROADMAP 2.4): `subscript name(recv, args) -> inout U`
# yields a PLACE into an argument, generalizing the built-in `&m[k]`. A call inlines
# to the yielded place at compile time (no runtime object); it is usable as a place
# (write / compound / &inout-field) or an rvalue read, exactly like the place it names.
struct Node:
    weight: int

struct Graph:
    nodes: [Node]

struct Row:
    cells: [int]

subscript edge(g: Graph, i: int) -> inout Node:      # composite-value projection
    yield &g.nodes[i]

subscript at(r: Row, i: int) -> inout int:           # scalar-value projection
    yield &r.cells[i]

fn bump(n: inout int):
    n = n + 100

fn main():
    g := Graph([Node(1), Node(2), Node(3)])
    g.edge(1).weight = 99                             # write through the projection
    println("w1=" + str(g.edge(1).weight))           # read through it -> 99
    println("w0=" + str(g.edge(0).weight))           # 1 (unchanged)
    g.edge(2).weight = g.edge(2).weight + 5          # read + write same projection
    println("w2=" + str(g.edge(2).weight))           # 8
    bump(&g.edge(0).weight)                           # projection's field as an inout arg
    println("w0b=" + str(g.edge(0).weight))          # 101

    r := Row([10, 20, 30])
    r.at(0) = 11                                      # scalar element write
    r.at(1) = r.at(1) + r.at(0)                       # scalar read + write (20+11)
    println("r=" + str(r.at(0)) + "," + str(r.at(1)) + "," + str(r.at(2)))   # 11,31,30
