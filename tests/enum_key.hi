# Fieldless-enum map keys: [Color: int]. The key is stored and hashed as
# its TAG (riding the int-key occupancy scheme), so iteration order and
# hashing are deterministic (never pointer/ASLR-dependent); keys() rebuilds
# the wrapped values from the per-variant singletons, which round-trip
# through match. Payload enums are rejected as keys
# (tests/reject/enum_key_payload.hi): equal tags would not mean equal values.

enum Color:
    Red
    Green
    Blue

fn main():
    m : [Color: int] = []
    m = map_set(m, Red, 3)
    m = map_set(m, Blue, 5)
    m[Green] = 4
    print(str(map_get(m, Red, 0) + map_get(m, Green, 0) + map_get(m, Blue, 0)) + "\n")
    print(str(len(m)) + "\n")
    if map_has(m, Red):
        print("has red\n")
    ks := keys(m)
    total := 0
    i := 0
    for i < len(ks):
        total = total + map_get(m, ks[i], 0)
        i = i + 1
    print(str(total) + "\n")
    m = map_del(m, Blue)
    print(str(len(m)) + "\n")
    reds := 0
    ks2 := keys(m)
    j := 0
    for j < len(ks2):
        match ks2[j]:
            Red:
                reds = reds + 1
            Green:
                reds = reds + 0
            Blue:
                reds = reds + 0
        j = j + 1
    print(str(reds) + "\n")
