# Newtype-keyed maps: a newtype over string or int is a valid map key.
# The map type carries the DECLARED key (so a raw base value is rejected,
# see tests/reject/newtype_key_mix.ty); storage and hashing are the base's.
# keys() returns [K] with K still wrapped. Always a composite map.

type UserId = string
type Slot = int

fn main():
    scores : [UserId: int] = []
    scores[UserId("ana")] = 10
    scores[UserId("bo")] = 7
    println(str(map_get(scores, UserId("ana"), 0)))
    println(str(len(scores)))
    ks := keys(scores)
    total := 0
    i := 0
    for i < len(ks):
        total = total + map_get(scores, ks[i], 0)
        i = i + 1
    println(str(total))
    names : [Slot: string] = []
    names[Slot(3)] = "three"
    s3 := Slot(3)
    println(map_get(names, s3, "?"))
    if Slot(3) in names:
        println("has 3")
    delete names[Slot(3)]
    println(str(len(names)))
    counts : [UserId: int] = []
    counts[UserId("x")] = 5
    println(str(map_get(counts, UserId("x"), 0)))
