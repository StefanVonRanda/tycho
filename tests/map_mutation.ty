# In-place map-value mutation (#2, docs/map-mutation.md): m[k] as a PLACE.
# Exercises every place form on both composite and scalar maps: push(m[k], v)
# (fresh + existing key), m[k][i] = x (nested), m[k] op= v (scalar, incl fresh
# key = zero + v), m[k] = v (plain, with heap value), m[k].field = x (auto-insert
# zero struct), single-eval of a call-bearing key, and value semantics (a copied
# map's in-place mutation must not touch the original).
struct P:
    x: int
    y: int

fn k7() -> int:
    print("[k7]")
    return 7

fn main():
    # [string: [int]] inverted index: push into the value array in place
    idx := []string: [int]
    push(idx["cat"], 1)        # fresh key -> auto-insert empty [int], then push
    push(idx["cat"], 4)
    push(idx["dog"], 2)
    push(idx["cat"], 7)
    cat := map_get(idx, "cat", []int)
    print("cat:")
    for i in range(len(cat)):
        print(" " + str(cat[i]))
    print("\n")                                                  # cat: 1 4 7
    print("doglen=" + str(len(map_get(idx, "dog", []int))) + "\n")  # doglen=1

    # nested place: m[k][i] = x
    idx["cat"][1] = 40
    cat2 := map_get(idx, "cat", []int)
    print(str(cat2[0]) + "," + str(cat2[1]) + "," + str(cat2[2]) + "\n")  # 1,40,7

    # [int:int] counter: m[k] += 1, fresh key starts from zero
    cnt := []int: int
    words := [3, 3, 5, 3, 5]
    for i in range(len(words)):
        cnt[words[i]] += 1
    print(str(map_get(cnt, 3, 0)) + "," + str(map_get(cnt, 5, 0)) + "," + str(map_get(cnt, 9, 0)) + "\n")  # 3,2,0

    # [string:int] plain assign + compound (fresh-key compound = 0 + 1)
    s := []string: int
    s["a"] = 10
    s["a"] += 5
    s["b"] += 1
    print(str(map_get(s, "a", -1)) + "," + str(map_get(s, "b", -1)) + "\n")  # 15,1

    # [string: string] plain assign with a heap value (must own its own bytes)
    sv := []string: string
    sv["g"] = "greeting"
    print(map_get(sv, "g", "?") + "\n")                          # greeting

    # [string:P] struct value: m[k].field = x (auto-insert zero struct, then set)
    pts := []string: P
    pts["o"].x = 3
    pts["o"].y = 4
    q := map_get(pts, "o", P(0, 0))
    print(str(q.x) + "," + str(q.y) + "\n")                      # 3,4

    # call-bearing key is single-eval'd: k7() prints exactly once per statement
    km := []int: int
    km[k7()] += 10
    km[k7()] = 5
    print("=" + str(map_get(km, 7, -1)) + "\n")                  # [k7][k7]=5

    # value semantics: copy then mutate the copy in place; original unchanged
    base := []string: int
    base["k"] = 100
    cp := base
    cp["k"] = 999
    cp["k"] += 1
    print(str(map_get(base, "k", -1)) + "," + str(map_get(cp, "k", -1)) + "\n")  # 100,1000
