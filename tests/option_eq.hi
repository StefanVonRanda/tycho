# Structural ==/!= on Option and Result -- deep value equality, the same
# machinery as struct/enum equality (it recurses through the payload). hierc
# previously rejected Option/Result `==` ("match on them instead") while the
# self-hosted hierc0 already accepted it; A3 closes that parity gap by enabling
# the already-present structural-eq codegen in hierc. (or_return-on-Option, the
# other half of A3, was already shipped -- see tests/or_return_option.hi.)

struct P:
    x: int
    y: int

fn yn(b: bool) -> string:
    if b:
        return "T"
    return "F"

fn main():
    # --- Option(int): tag + scalar payload, plus None typing via annotation ---
    a := Some(3)
    b := Some(3)
    c := Some(4)
    ni : Option(int) = None
    nj : Option(int) = None
    print("opt_int " + yn(a == b) + yn(a == c) + yn(a == ni) + yn(ni == nj) + yn(a != c) + yn(a != b) + "\n")
    # expect T F F T T F

    # --- Option(string): heap payload, byte equality ---
    s1 := Some("hi")
    s2 := Some("hi")
    s3 := Some("yo")
    print("opt_str " + yn(s1 == s2) + yn(s1 == s3) + yn(s1 != s3) + "\n")
    # expect T F T

    # --- Option([int]): deep array equality through the payload ---
    oa : Option([int]) = Some([1, 2, 3])
    ob : Option([int]) = Some([1, 2, 3])
    oc : Option([int]) = Some([1, 2, 4])
    print("opt_arr " + yn(oa == ob) + yn(oa == oc) + "\n")
    # expect T F

    # --- Option(P): struct payload recursion ---
    p1 := Some(P(3, 4))
    p2 := Some(P(3, 4))
    p3 := Some(P(3, 5))
    print("opt_struct " + yn(p1 == p2) + yn(p1 == p3) + "\n")
    # expect T F

    # --- nested Option(Option(int)) ---
    nn1 := Some(Some(5))
    nn2 := Some(Some(5))
    nn3 := Some(Some(6))
    print("opt_nested " + yn(nn1 == nn2) + yn(nn1 == nn3) + "\n")
    # expect T F

    # --- Result(int, string): both arms, equal/unequal/cross-tag ---
    ok1 : Result(int, string) = Ok(7)
    ok2 : Result(int, string) = Ok(7)
    ok3 : Result(int, string) = Ok(8)
    er1 : Result(int, string) = Err("bad")
    er2 : Result(int, string) = Err("bad")
    er3 : Result(int, string) = Err("nope")
    print("res_int " + yn(ok1 == ok2) + yn(ok1 == ok3) + yn(ok1 == er1) + yn(er1 == er2) + yn(er1 == er3) + yn(ok1 != er1) + "\n")
    # expect T F F T F T

    # --- Result([int], string): heap Ok payload, deep array equality ---
    rh1 : Result([int], string) = Ok([5, 6])
    rh2 : Result([int], string) = Ok([5, 6])
    rh3 : Result([int], string) = Ok([5, 7])
    print("res_heap " + yn(rh1 == rh2) + yn(rh1 == rh3) + "\n")
    # expect T F
