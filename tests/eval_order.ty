# Regression (spec A5, evaluation order): a side-effecting index in an assignment
# place MUST run before the RHS -- left-to-right, and identically on both
# compilers. This locks the fix for a real divergence: `arr[f()] = g()` evaluated
# g() before f() under tychoc (the C compiler's choice) but f() before g() under
# tychoc0, so the two implementations disagreed on observable order. tychoc now
# hoists the side-effecting index into a temp that sequences before the RHS,
# matching tychoc0. Pure indices are untouched (byte-identical for the common case).

fn a() -> int:
    println("a")
    return 1

fn b() -> int:
    println("b")
    return 2

fn main():
    arr := [0, 0, 0]
    arr[a()] = b()                 # left-to-right: a then b
    println("stored[1]=" + str(arr[1]))     # 2

    # binary operands are already left-to-right; lock that too
    s := a() + b()                 # a then b
    println("sum=" + str(s))       # 3
