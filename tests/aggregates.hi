struct P:
    x: int
    y: int

struct Named:
    name: string
    score: int

fn sumx(ps: [P]) -> int:
    t := 0
    for i in range(len(ps)):
        t = t + ps[i].x
    return t

fn addp(ps: inout [P], p: P):
    push(ps, p)

fn make_row(n: int) -> [int]:
    r := []int
    for i in range(n):
        push(r, i * i)
    return r

fn main():
    ps := [P(1, 2), P(3, 4)]
    push(ps, P(5, 6))
    print("len=" + str(len(ps)) + " sumx=" + str(sumx(ps)) + " p2x=" + str(ps[2].x) + "\n")
    ps[0] = P(100, 200)
    print("set0x=" + str(ps[0].x) + "\n")
    qs := ps
    push(qs, P(7, 8))
    print("ps_len=" + str(len(ps)) + " qs_len=" + str(len(qs)) + "\n")
    addp(&ps, P(9, 9))
    print("after_inout len=" + str(len(ps)) + " last_x=" + str(ps[3].x) + "\n")

    ns := [Named("ada", 10), Named("alan", 20)]
    ms := ns
    ns[0] = Named("Ada", 99)
    print("ns0=" + ns[0].name + " ms0=" + ms[0].name + "\n")

    grid := [][int]
    push(grid, make_row(3))
    push(grid, make_row(4))
    print("grid_len=" + str(len(grid)) + " row1_2=" + str(grid[1][2]) + " grid1len=" + str(len(grid[1])) + "\n")

    a := [P(1, 1), P(2, 2)]
    b := [P(1, 1), P(2, 2)]
    if a == b:
        print("eq-ok\n")
