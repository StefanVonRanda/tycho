# Regression: cap-1 channel (one-cell Vyukov ring). Before the min-ring-2 fix,
# the published seq state (pos+1) equaled the recycled next-lap state (pos+cap),
# so a 2nd send claimed the cell before the receiver took the 1st value -- the
# producer freed the unreceived payload and the consumer parked forever.
# Two sends is the minimal hang; 11 matches the fuzzer's chan_use shape.
fn drain(ch: Channel(int)) -> int:
    s := 0
    for true:
        match recv(ch):
            Some(v):
                s = s + v
            None:
                return s
    return s

fn main():
    ch := channel(int, 1)
    co := spawn drain(ch)
    for i in range(11):
        send(ch, i + 17)
    close(ch)
    a := wait(co)
    ch2 := channel(int, 1)
    co2 := spawn drain(ch2)
    send(ch2, 1)
    send(ch2, 2)
    close(ch2)
    print(str(a) + " " + str(wait(co2)) + "\n")
