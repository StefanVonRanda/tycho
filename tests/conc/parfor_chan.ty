# `parallel for x in ch:` — bounded fan-out draining a channel with K=ncpu
# workers until it is closed+drained. The producer closes the channel when done
# so the workers can exit; every item is consumed exactly once (Vyukov MPMC), so
# the reduction (sum of i*i for 0..99 = 328350) is deterministic. Mirrors the
# manual idiom in workers.ty; both compilers must produce the same output.
fn produce(ch: Channel(int), n: int) -> int:
    for i in range(n):
        send(ch, i)
    close(ch)                 # workers exit when closed AND drained
    return n

fn main():
    jobs := channel(int, 16)
    pr := spawn produce(jobs, 100)
    sum := 0
    parallel for x in jobs:
        sum = sum + x * x
    np := wait(pr)
    print(str(sum) + "\n")    # 328350
    print(str(np) + "\n")     # 100
