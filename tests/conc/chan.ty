# CC-4 channels: bounded MPMC queue. One producer, two consumers; string
# payloads prove the deep copy in (slot arena) and out (receiver arena) --
# every payload is built in the producer task's arena, which dies before the
# consumers stop reading. close() drains then yields None. The sum of both
# consumers' totals is deterministic regardless of how items interleave.

fn producer(ch: Channel(string), n: int) -> int:
    for i in range(n):
        ch.send("item-" + str(i))
    return n

fn consumer(ch: Channel(string)) -> int:
    count := 0
    for true:
        match recv(ch):
            Some(s):
                count = count + len(s)
            None:
                return count
    return count

fn pingpong(ch: Channel(int), n: int) -> int:
    acc := 0
    for i in range(n):
        send(ch, i * i)
        acc = acc + i
    return acc

fn main():
    ch := channel(string, 8)
    c1 := spawn consumer(ch)
    c2 := spawn consumer(ch)
    p := spawn producer(ch, 100)
    n := wait(p)
    close(ch)
    a := wait(c1)
    b := wait(c2)
    print(str(n))
    print(str(a + b))

    ints := channel(int, 4)
    w := spawn pingpong(ints, 6)
    total := 0
    for i in range(6):
        match ints.recv():
            Some(v):
                total = total + v
            None:
                total = 0 - 1
    print(str(wait(w)))
    print(str(total))
    ints.close()
