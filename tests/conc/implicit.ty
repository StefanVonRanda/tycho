# CC-2: implicit join at every scope exit. A task that is never waited (or
# waited on only some paths) is joined and freed at: block end, each loop
# iteration end, break, continue, early return, and proc end. ASan leak
# detection + TSan in the runner prove no handle/arena leaks or races on any
# of these paths.

fn slow(n: int) -> int:
    acc := 0
    for i in range(n):
        acc = acc + i
    return acc

fn early(n: int) -> int:
    t := spawn slow(n)
    if n > 10:
        return 0 - 1        # early return: t joined+freed by return_frees
    return wait(t)

fn looper() -> int:
    total := 0
    for i in range(6):
        t := spawn slow(100)
        if i == 5:
            break           # break: pending t finished before the jump
        if i % 2 == 1:
            continue        # continue: pending t finished before the jump
        total = total + wait(t)
    return total

fn main():
    d := spawn slow(50)                # never waited: joined at main's end
    print(str(early(1000)))
    print(str(early(5)))
    print(str(looper()))
    print(str(wait(spawn slow(10))))   # anonymous spawn: waited and freed inline
    print(str(slow(1)))                # keep d live to main's end (no wait anywhere)
