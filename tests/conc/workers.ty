# Bounded fan-out worker pool — process a stream of jobs with K=ncpu workers
# and channel-capacity backpressure. This is the pattern `parallel for x in ch:`
# sugars over; written here with today's primitives as the reference idiom.
#
# A producer streams N jobs into a bounded channel (cap 16 -> at most 16 jobs
# buffered; send blocks when full, so memory is bounded regardless of N). The
# `parallel for` fans out K=ncpu chunk tasks that all share the one channel and
# pull jobs via `select`/`recv`. Each job is consumed exactly once (the channel
# is a lock-free MPMC queue), so the reduction is deterministic no matter how the
# workers interleave: sum of i*i for i in 0..N-1.
#   N = 100  ->  sum_{0}^{99} i^2 = 99*100*199/6 = 328350
fn produce(ch: Channel(int), n: int) -> int:
    for i in range(n):
        send(ch, i)             # blocks when the 16-slot buffer is full (backpressure)
    return n

fn main():
    jobs := channel(int, 16)
    pr := spawn produce(jobs, 100)      # runs concurrently with the workers below
    sum := 0
    # K = ncpu workers, each pulling one job per iteration; 100 iterations total.
    parallel for i in range(0, 100):
        select:
            recv(jobs, x):
                sum = sum + x * x       # reduction, folded at the in-order join
    np := wait(pr)
    close(jobs)
    println(str(sum))              # 328350
    println(str(np))              # 100
