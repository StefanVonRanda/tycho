# `select` inside a `parallel for`: parallel work-stealing consumers.
# Two producers fill two channels with 32 items each (64 total). The channels
# are captured by-value into the lifted chunk proc -- a Channel is a scalar
# handle, so every chunk shares the SAME queue (not a private copy). The 64
# parfor iterations each recv exactly one item from whichever channel is ready,
# accumulating into `sum` as a reduction folded at the in-order join. Because
# `+` commutes and every item is consumed exactly once (iterations == items),
# the total is deterministic regardless of how the chunks interleave.
#   sum(100..131) = 32*100 + (0+..+31) = 3200 + 496 = 3696
#   sum(200..231) = 32*200 + 496       = 6400 + 496 = 6896
#   total                                            = 10592
fn feed(ch: Channel(int), base: int, n: int) -> int:
    for i in range(n):
        send(ch, base + i)
    return n

fn main():
    a := channel(int, 64)
    b := channel(int, 64)
    ta := spawn feed(a, 100, 32)
    tb := spawn feed(b, 200, 32)
    pa := wait(ta)
    pb := wait(tb)
    total := pa + pb
    sum := 0
    parallel for i in range(0, total):
        select:
            recv(a, x):
                sum = sum + x
            recv(b, y):
                sum = sum + y
    print(str(sum) + "\n")
    close(a)
    close(b)
