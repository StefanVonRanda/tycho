# Self-referential shadow whose initializer is a LAMBDA that CAPTURES the
# shadowed name: `add := fn(x:int)->int: add(x) + 10` in a nested block rebinds
# `add` to a closure capturing the ENCLOSING add (a fn value) and calling it.
# Go/Odin lexical scope: the RHS reads the outer add, so inner add(5) = (outer
# add)(5) + 10 = 6 + 10 = 16; the outer add is unchanged, so the final add(5) = 6.
#
# Regression: a lambda's captures live on the lifted proc (g_laminfo), NOT as
# child exprs in lhs/rhs/args, so tychoc's generic expr_refs_local walk MISSED
# this and emitted `FnC0 h_add = {env copying the NEW, uninitialised h_add}` --
# the env read itself uninitialised (use-before-init UB; segfault on Linux).
# tychoc0's expr_refs already checked the capture-name list; this aligns tychoc
# so both compilers stay byte-identical.
# Expected: inner 16, outer 6.
fn main():
    add := fn(x: int) -> int: x + 1
    if 1 > 0:
        add := fn(x: int) -> int: add(x) + 10
        print("inner " + str(add(5)))
    print("outer " + str(add(5)))
