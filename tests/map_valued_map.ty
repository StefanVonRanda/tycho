# A map whose VALUE is itself a map (`[int:[int:int]]`, `[string:[string:int]]`):
# `m[k1][k2] = v` auto-vivifies the inner map and assigns into it. Regression for a
# crash where the auto-inserted inner map's zero value (`{0}`) left the slot-order
# list head = 0 instead of -1, so the inner map's first-insert rehash walked the
# order list from slot 0 and dereferenced a NULL nxt[] (segfault). A cap==0 map has
# no entries, so the walk must be empty regardless of the zero-initialized head.
fn main():
    m := []int: [int:int]
    m[1][5] = 50
    m[1][6] = 60
    m[2][9] = 90
    delete m[1][5]
    print(str(m[1][6]) + " " + str(len(m[1])) + " " + str(len(m)) + " has5=" + str(5 in m[1]) + "\n")
    s := []string: [string:int]
    s["a"]["x"] = 1
    s["a"]["y"] = 2
    ks := keys(s["a"])
    print(str(len(s)) + " " + str(len(ks)) + " " + str(s["a"]["x"]) + "\n")
