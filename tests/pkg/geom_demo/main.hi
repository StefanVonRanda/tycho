package main
import "geom"

fn total(pts: [geom.Point]) -> int:
    s := 0
    i := 0
    for i < len(pts):
        s = s + pts[i].x + pts[i].y
        i = i + 1
    return s

fn main():
    r := geom.add(geom.Point(3, 4), geom.Point(1, 2))
    pts := [geom.Point(1, 2), r]
    print("sum=(" + str(r.x) + "," + str(r.y) + ") total=" + str(total(pts)) + "\n")   # (4,6) total=13
