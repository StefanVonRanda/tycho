package main
import "geom"

enum Local:
    Circle(int)
    Dot

fn sumpts(pts: [geom.Point]) -> int:
    s := 0
    i := 0
    for i < len(pts):
        s = s + pts[i].x + pts[i].y
        i = i + 1
    return s

fn main():
    pts := [geom.Point(1, 2), geom.Point(3, 4)]
    sh := geom.Square(5)
    loc := Circle(9)
    a := 0
    match sh:
        geom.Circle(r):
            a = r
        geom.Square(side):
            a = side * 100
    l := 0
    match loc:
        Circle(n):
            l = n
        Dot:
            l = -1
    print("pts=" + str(sumpts(pts)) + " shape=" + str(a) + " area=" + str(geom.area(sh)) + " local=" + str(l) + "\n")
    # pts=10 shape=500 area=25 local=9
