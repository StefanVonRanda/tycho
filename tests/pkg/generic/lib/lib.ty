package lib

# generic templates, called QUALIFIED (lib.id etc.) from another package
fn id(x: $T) -> T:
    return x

fn pair_first(a: $T, b: $T) -> T:
    return a

fn sum(xs: [$T]) -> T where numeric(T):     # where-constrained generic, qualified
    total := xs[0]
    i := 1
    for i < len(xs):
        total = total + xs[i]
        i = i + 1
    return total

fn dup(x: $T) -> [$T]:                       # generic returning [$T] (array-typaram grounding)
    out := []
    push(out, x)
    push(out, x)
    return out

fn plain(x: int) -> int:                     # concrete control
    return x + 1
