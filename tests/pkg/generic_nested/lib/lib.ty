package lib

fn id(x: $T) -> T:
    return x

# qualified-callable generic that internally calls ANOTHER generic (id) AND
# builds a fresh collection -- exercises #3 across the package boundary plus the
# package mangling of both the outer and the nested instance.
fn box(xs: [$T]) -> [$T]:
    out := []
    for v in xs:
        push(out, id(v))
    return out
