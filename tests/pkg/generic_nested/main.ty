package main
import "lib"

# A package-qualified generic call (lib.box) whose body calls another generic
# (lib.id), instantiated at two element types.
fn main():
    a := lib.box([1, 2, 3])
    println(str(a[0]) + str(a[2]))       # 13
    b := lib.box(["x", "y"])
    println(b[0] + b[1])                 # xy
