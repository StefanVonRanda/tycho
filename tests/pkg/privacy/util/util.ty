package util

# `_scale` has a leading underscore, so it is package-private: only util's own
# code may call it. A cross-package `util._scale(...)` is rejected by the
# resolver (see tests/reject/privacy_cross.ty).
fn _scale(x: int, k: int) -> int:
    return x * k

fn doubled(x: int) -> int:
    return _scale(x, 2)

fn triple(x: int) -> int:
    return _scale(x, 3)
