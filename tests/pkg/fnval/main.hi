# Function values inside a package: a same-package function used as a VALUE must
# resolve to its mangled name (was "unknown variable"), and a fn-typed LOCAL
# called indirectly must NOT be package-prefixed. hierc + hierc0 (--bundle) agree.
package fnval

fn base(x: int) -> int:
    return x + 1

fn apply(f: fn(int) -> int, x: int) -> int:
    return f(x)

fn via_local(x: int) -> int:
    g := base                  # bare same-package fn as a value
    return g(x)                # indirect call through a local var

fn main():
    print("arg=" + str(apply(base, 41)) + "\n")    # 42  (fn passed as a value within the package)
    print("local=" + str(via_local(9)) + "\n")     # 10
    h := base
    print("bound=" + str(h(99)) + "\n")            # 100
