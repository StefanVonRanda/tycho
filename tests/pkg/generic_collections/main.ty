package main
import "gc"

# Acceptance dogfood: ONE generic `gc` module, used over int / string / float,
# now with COMPOSITION (a generic result fed straight into another generic, e.g.
# join(sort(xs))) and HIGHER-ORDER generics (map/filter take a fn parameter).

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn inc(x: int) -> int:
    return x + 1

fn even(x: int) -> int:
    if x % 2 == 0:
        return 1
    return 0

fn main():
    # ---- int ----
    xs := [3, 1, 4, 1, 5, 9, 2, 6]
    println("int has4=" + str(b2i(gc.contains(xs, 4))) + " idx9=" + str(gc.index_of(xs, 9)) + " min=" + str(gc.min(xs)) + " max=" + str(gc.max(xs)) + " sum=" + str(gc.sum(xs)))
    println("int sorted=" + gc.join(gc.sort(xs), ","))           # composition: join(sort(xs))
    println("int rev=" + gc.join(gc.reverse(xs), ","))           # composition
    println("int inc=" + gc.join(gc.map(xs, inc), ","))          # higher-order + composition
    println("int even=" + gc.join(gc.filter(xs, even), ","))     # higher-order + composition

    # ---- string (comparable + has_str; NOT numeric) ----
    ss := ["pear", "apple", "fig", "kiwi"]
    println("str sorted=" + gc.join(gc.sort(ss), ",") + " min=" + gc.min(ss) + " max=" + gc.max(ss) + " hasfig=" + str(b2i(gc.contains(ss, "fig"))))

    # ---- float (numeric + comparable + has_str) ----
    fs := [1.5, 0.5, 2.5, 1.0]
    println("float sum=" + str(gc.sum(fs)) + " sorted=" + gc.join(gc.sort(fs), ","))
