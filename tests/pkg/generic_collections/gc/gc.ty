package gc

# A single GENERIC collection module over `$T` -- the corelib goal: one
# definition serves int, string, and float (and any element type). Functions
# needing ordering carry `where comparable(T)`; arithmetic ones `where
# numeric(T)`; formatting `where has_str(T)`. This is the Stage-2 acceptance
# dogfood: it compiles + runs identically under tychoc, tychoc0 (--bundle), and
# standalone tychoc0.

fn contains(xs: [$T], x: $T) -> bool:
    for v in xs:
        if v == x:
            return true
    return false

fn index_of(xs: [$T], x: $T) -> int:
    n := len(xs)
    i := 0
    for i < n:
        if xs[i] == x:
            return i
        i = i + 1
    return 0 - 1

fn reverse(xs: [$T]) -> [$T]:
    out := []
    i := len(xs) - 1
    for i >= 0:
        push(out, xs[i])
        i = i - 1
    return out

fn sort(xs: [$T]) -> [$T] where comparable(T):     # ascending; new array
    out := xs
    n := len(out)
    i := 1
    for i < n:
        key := out[i]
        j := i - 1
        for j >= 0 and out[j] > key:
            out[j + 1] = out[j]
            j = j - 1
        out[j + 1] = key
        i = i + 1
    return out

fn min(xs: [$T]) -> $T where comparable(T):        # requires non-empty
    m := xs[0]
    for v in xs:
        if v < m:
            m = v
    return m

fn max(xs: [$T]) -> $T where comparable(T):
    m := xs[0]
    for v in xs:
        if v > m:
            m = v
    return m

fn sum(xs: [$T]) -> $T where numeric(T):           # requires non-empty
    total := xs[0]
    n := len(xs)
    i := 1
    for i < n:
        total = total + xs[i]
        i = i + 1
    return total

fn join(xs: [$T], sep: string) -> string where has_str(T):
    out := ""
    first := true
    for v in xs:
        if first:
            first = false
        else:
            out = out + sep
        out = out + str(v)
    return out

# NOTE: higher-order generics (map/filter with a `fn($T)->$T` parameter) are not
# included -- inferring a typaram through a function-typed parameter is not yet
# supported, and emitting such a template currently produces invalid C in tychoc.
