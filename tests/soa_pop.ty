# pop(soa): shrink the soa and return the (gathered) last struct value. Remaining
# elements stay intact; the freed slot is reused by a later push. Both compilers.
struct P:
    x: int
    y: int
fn main():
    ps := soa []P
    push(ps, P(1, 2))
    push(ps, P(3, 4))
    push(ps, P(5, 6))
    a := pop(ps)
    println("popped " + str(a.x) + "," + str(a.y) + " len=" + str(len(ps)))
    b := pop(ps)
    println("popped " + str(b.x) + "," + str(b.y) + " len=" + str(len(ps)))
    println("remain " + str(ps[0].x) + "," + str(ps[0].y))
    push(ps, P(9, 9))
    println("after push len=" + str(len(ps)) + " idx1.x=" + str(ps[1].x))
