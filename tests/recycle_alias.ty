# Soundness guard for liveness-driven buffer recycling: a recycled buffer must be
# the SOURCE var's OWN, not one it shared via a move. `b := a` can move a's buffer
# to b (move-on-last-use, since a is read exactly once here), so reassigning a
# afterwards must NOT recycle that buffer -- it is still live through b. The gate
# excludes vars read < 2 times for exactly this reason (a >=2-read var is never
# moved). The loop write uses DISTINCT values (base 1000000) and a matching size,
# so if b's buffer were wrongly recycled+reused the corruption is unmissable.
# Regression: both compilers once printed ~100004950 here (b's buffer reused).
fn mkv(n: int, base: int) -> [int]:
    r := []int
    for i in range(n):
        push(r, base + i)
    return r

fn main():
    a := mkv(100, 0)        # b will be 0..99 (sum 4950)
    b := a                  # may move a's buffer to b (a read exactly once)
    for j in range(50):
        a = mkv(100, 1000000)   # distinct values, same size: would clobber b if reused
    s := 0
    for i in range(len(b)):
        s = s + b[i]        # 4950 iff b's buffer was left intact
    println(str(s))
