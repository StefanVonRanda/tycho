# Int-keyed maps: [int: int] and [int: float]. Same open-addressing table as
# string-keyed maps but with a `long` key and an occupancy array (0 is a real
# key, so there is no NULL "empty" marker). Exercises set/get/has/del, the
# in-place accumulator (m = map_set(m, k, ...)), keys() -> [int], value
# semantics (a snapshot is independent), and key 0.
fn main():
    counts := []int: int
    counts[5] = 100
    counts[0] = 7 # key 0
    counts[5] = counts.get(5, 0) + 1
    println("c5=" + str(counts.get(5, 0 - 1)))    # 101
    println("c0=" + str(counts.get(0, 0 - 1)))    # 7
    println("miss=" + str(counts.get(9, 0 - 1)))  # -1
    if 0 in counts:
        println("has0=yes")
    if not 9 in counts:
        println("has9=no")
    println("len=" + str(len(counts)))        # 2

    # value semantics: a snapshot does not see later mutations
    snap := counts
    counts[5] = 999
    println("snap5=" + str(snap.get(5, 0)) + " now5=" + str(counts.get(5, 0)))  # 101 999

    delete counts[5]
    println("afterdel=" + str(len(counts)))   # 1

    # histogram accumulator + keys() iteration (sum of distinct keys)
    h := []int: int
    data := []int
    push(data, 3)
    push(data, 7)
    push(data, 3)
    push(data, 3)
    push(data, 7)
    i := 0
    for i in range(0, len(data)):
        h[data[i]] = h.get(data[i], 0) + 1
    println("h3=" + str(h.get(3, 0)) + " h7=" + str(h.get(7, 0)))   # 3 2
    sumk := 0
    for kk in keys(h):
        sumk = sumk + kk
    println("sumk=" + str(sumk))              # 3+7 = 10

    # [int: float] values
    fm := []int: float
    fm[1] = 1.5
    fm[2] = 2.5
    fm[1] = fm.get(1, 0.0) + 0.25
    println("fm1=" + str(fm_round(fm.get(1, 0.0))) + " fm2=" + str(fm_round(fm.get(2, 0.0))))   # 175 250

fn fm_round(x: float) -> int:        # avoid float-print formatting differences
    return to_int(x * 100.0)
