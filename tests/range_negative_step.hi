# range() with a negative step must count down (sign-aware loop condition).
# Regression: hierc0 hardcoded `i < stop`, so range(3, 0, -1) never ran.
fn main():
    for i in range(3, 0, -1):
        print(str(i))
    for i in range(10, 0, -3):
        print(str(i))
    for i in range(0, 3):
        print(str(i))
    n := 0
    for i in range(5, 5, -1):
        n = n + 1
    print("empty " + str(n))
