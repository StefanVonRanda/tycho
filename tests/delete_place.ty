# `delete` on a map that is a PLACE, not just a bare variable: `delete obj.field[k]`
# (struct-field map) as well as the original `delete m[k]`. The delete parser now
# parses a full place expression and assigns `place = map_del(place, k)` back to the
# right lvalue (S_ASSIGN for a bare var, S_FIELDSET for a field). keys() insertion
# order is preserved across delete + reinsert (reinsert appends to the tail).
struct Cache:
    idx: [int: int]
    tags: [string: int]

fn main():
    c := Cache([]int: int, []string: int)
    c.idx[1] = 10
    c.idx[2] = 20
    c.idx[3] = 30
    delete c.idx[2]                 # delete from a struct-field map
    c.idx[2] = 99                   # reinsert -> appends to the order tail
    ks := keys(c.idx)
    out := ""
    i := 0
    for i in range(0, len(ks)):
        out = out + str(ks[i]) + "=" + str(c.idx[ks[i]]) + " "
    print(out + "\n")              # 1=10 3=30 2=99

    c.tags["a"] = 1                 # a string-keyed field map
    c.tags["b"] = 2
    delete c.tags["a"]
    print(str("a" in c.tags) + " " + str("b" in c.tags) + " n=" + str(len(c.tags)) + "\n")

    m := []int: int                 # the original bare-variable form still works
    m[7] = 70
    delete m[7]
    print("bare=" + str(len(m)) + "\n")
