# Byte-safe strings: a read_file'd string with interior NUL bytes must compare,
# split, hash, and map-key by its TRUE bytes (length header), not truncated at the
# first '\0'. Locks the fix that replaced strcmp/strstr with length-aware ops.
fn main():
    s := read_file("tests/data/strbytes.bin")
    println(str(len(s)))            # 7
    parts := split(s, ",")
    println(str(len(parts)))        # 2
    println(str(len(parts[0])) + " " + str(len(parts[1])))   # 3 3
    if parts[0] == parts[1]:
        println("eq")
    else:
        println("ne")                    # ne: a\0b != c\0d
    println(str(find(s, ",")))      # 3: comma found past the first NUL
    println(str(find(s, parts[1]))) # 4: needle "c\0b" CONTAINS a NUL
    m := [parts[0]: 1]
    m[parts[1]] = 2
    println(str(m[parts[0]]) + " " + str(m[parts[1]]))       # 1 2
    if "a" in m:
        println("collide")
    else:
        println("distinct")              # interior-NUL key != "a"
