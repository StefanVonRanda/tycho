# Stage 3: structured type-param patterns. `$T` is inferred from INSIDE a
# container argument (`[$T]` matched against `[int]`), and the return type
# `Option(T)` / `T` is substituted and monomorphized.

fn first(xs: [$T]) -> Option(T):
    if len(xs) > 0:
        return Some(xs[0])
    return None

fn idx(xs: [$T], i: int) -> T:
    return xs[i]

fn main():
    match first([3, 1, 2]):
        Some(x):
            println(str(x))          # 3
        None:
            println("empty")
    match first(["a", "b"]):
        Some(s):
            println(s)               # a
        None:
            println("empty")
    match first([]int):
        Some(n):
            println(str(n))
        None:
            println("empty")              # None path
    println(str(idx([5, 6, 7], 1)))  # [$T] param, scalar T return -> 6
    println(idx(["x", "y"], 0))      # x
