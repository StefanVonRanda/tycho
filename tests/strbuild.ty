# Locks str(int) itoa (signs, zero, large) and multi-piece concat flattening
# (3..6-piece chains -> sc3..sc6; 7-piece falls back). Output must match the
# C reference exactly (golden + fixpoint differential cover both compilers).
fn main():
    print(str(0) + "|" + str(-7) + "|" + str(123456789) + "|" + str(-987654321) + "\n")
    mx := 9223372036854775807
    print(str(mx) + "|" + str(0 - mx - 1) + "\n")          # LONG_MAX | LONG_MIN
    a := "x"
    b := "yy"
    c := "zzz"
    print(a + b + c + "\n")                                 # 3 pieces
    print(a + b + c + a + "\n")                             # 4
    print(a + b + c + a + b + "\n")                         # 5
    print(a + b + c + a + b + c + "\n")                     # 6
    print(a + b + c + a + b + c + a + "\n")                 # 7 (fallback)
    print("[" + str(1) + ", " + str(22) + ", " + str(333) + "]\n")   # mixed literal+str()
