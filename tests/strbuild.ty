# Locks str(int) itoa (signs, zero, large) and multi-piece concat flattening
# (3..6-piece chains -> sc3..sc6; 7-piece falls back). Output must match the
# C reference exactly (golden + fixpoint differential cover both compilers).
fn main():
    println(str(0) + "|" + str(-7) + "|" + str(123456789) + "|" + str(-987654321))
    mx := 9223372036854775807
    println(str(mx) + "|" + str(0 - mx - 1))          # LONG_MAX | LONG_MIN
    a := "x"
    b := "yy"
    c := "zzz"
    println(a + b + c)                                 # 3 pieces
    println(a + b + c + a)                             # 4
    println(a + b + c + a + b)                         # 5
    println(a + b + c + a + b + c)                     # 6
    println(a + b + c + a + b + c + a)                 # 7 (fallback)
    println("[" + str(1) + ", " + str(22) + ", " + str(333) + "]")   # mixed literal+str()
