# break / continue: early loop exit and iteration skip. Exercised in for-range,
# the condition-form `for COND:` (Tycho's while), nested loops (break targets the
# innermost), and inside `if` blocks while a heap string accumulator grows in the
# loop body -- so the per-iteration/loop arenas must still be freed on the jump
# (LeakSanitizer in `make test` is the real guard here).
fn main():
    # continue: sum only odd i in 0..10  (no modulo: i/2*2==i tests even)
    sum := 0
    i := 0
    for i in range(0, 10):
        if i / 2 * 2 == i:
            continue
        sum = sum + i
    print("odd_sum=" + str(sum) + "\n")        # 25

    # break: stop the scan at 5
    j := 0
    last := 0
    for j in range(0, 100):
        if j == 5:
            break
        last = j
    print("last=" + str(last) + "\n")          # 4

    # break + continue with a heap accumulator growing in the loop body
    acc := ""
    k := 0
    for k in range(0, 6):
        if k == 4:
            break
        if k / 2 * 2 == k:
            continue
        acc = acc + str(k) + ","
    print("acc=" + acc + "\n")                  # 1,3,

    # condition-form loop + break (Tycho's `while true:`)
    n := 0
    for true:
        n = n + 1
        if n >= 3:
            break
    print("n=" + str(n) + "\n")                 # 3

    # nested loops: break exits only the inner loop
    tot := 0
    a := 0
    for a in range(0, 3):
        b := 0
        for b in range(0, 3):
            if b == 1:
                break
            tot = tot + 1
    print("tot=" + str(tot) + "\n")             # 3
