# FFI regression: calls the C fixture lib tests/ffi/demo.c.
# Both compilers must agree and match tests/ffi/expected.out (see tests/ffi/run.sh).
# Stage 1: scalars + string.  Stage 2: opaque ptr handles + null + is_null.
extern "ffidemo" fn ffi_echo(s: string) -> string
extern "ffidemo" fn ffi_sum3(a: int, b: int, c: int) -> int
extern "ffidemo" fn ffi_scale(x: float, k: int) -> float
extern "ffidemo" fn ffi_maybe(s: string) -> string
extern "ffidemo" fn ffi_open(id: int) -> ptr
extern "ffidemo" fn ffi_read(h: ptr) -> int
extern "ffidemo" fn ffi_bsum(b: bytes) -> int            # bytes param -> (ptr,len), int return
extern "ffidemo" fn ffi_brev(b: bytes) -> bytes          # bytes return via the out-param shim
extern "ffidemo" fn ffi_get(key: int) -> Option(string)  # FFI R3a: nullable string return (C NULL -> None)
extern "ffidemo" fn ffi_mk(id: int, out: mut ptr) -> int # FFI R4: out-param constructor (compiler passes &db)
extern "ffidemo" fn ffi_dbl(a: int, out: mut int)        # FFI R4: scalar out-param
extern "ffidemo" fn ffi_neg() -> int                     # returns a negative 32-bit C int (to_i32 recovers the sign)
extern "ffidemo" fn ffi_ptrval(p: ptr) -> int            # echoes a ptr's integer value (to_ptr round-trip)

handle FRes:                                             # FFI R2: a typed C handle, freed by ffi_res_close at scope exit
    free: ffi_res_close
extern "ffidemo" fn ffi_res_open(id: int) -> FRes        # opener -> owned handle
extern "ffidemo" fn ffi_res_use(h: FRes) -> int          # borrow: takes the handle, does not free
extern "ffidemo" fn ffi_res_close(h: FRes) -> int        # the destructor C symbol
extern "ffidemo" fn ffi_res_live() -> int                # live refcount (0 iff freed exactly once)

fn use_res():
    r := ffi_res_open(1)
    println(f"resuse={ffi_res_use(r)} live_in={ffi_res_live()}")   # 7, 1 (borrow keeps it live)
    # r auto-freed here at scope exit -> ffi_res_close(r)

fn use_res_close():                                                # FFI R2: explicit early close(h)
    r := ffi_res_open(2)
    u := ffi_res_use(r)                                            # 7 (borrow before close)
    close(r)                                                       # destructor runs NOW, not at scope exit
    println(f"closeuse={u} live_after_close={ffi_res_live()}")     # 7, 0 (freed by close)
    # scope exit here: the null-guarded finalizer is a no-op -> no double free

fn opts(o: Option(string)) -> string:        # FFI R3a: render an Option(string) result
    match o:
        Some(v):
            return v
        None:
            return "<none>"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn main():
    # Stage 1 — scalars + string
    e := ffi_echo("hi")                        # string arg (zero-cost char*) + string return (arena-copied)
    s := ffi_sum3(1, 2, 39)                     # int args + int return
    sc := to_int(ffi_scale(2.5, 4))             # float + int args, float return
    m1 := ffi_maybe("z")                        # non-null string return
    m0 := ffi_maybe("")                         # NULL return -> "" (guarded)
    println(e)
    println(f"sum={s} scale={sc} maybe1={m1} maybe0=[{m0}]")
    # Stage 2 — opaque ptr handles
    h := ffi_open(7)                            # int -> ptr handle
    bad := ffi_open(0)                          # NULL handle
    rd := ffi_read(h)                           # ptr arg -> int
    pn := ffi_read(null)                        # pass the null literal across the boundary
    println(f"read={rd} passnull={pn} hnull={b2i(is_null(h))} badnull={b2i(is_null(bad))} eqnull={b2i(bad == null)}")
    # peephole: len/print of a DIRECT extern-str call borrow the C pointer (no
    # arena copy) -- sound, consumed read-once inline. A bound result still copies.
    print(ffi_echo("peep"))                     # print borrow -> [peep]
    println("")
    el := len(ffi_echo("xyz"))                  # len borrow -> len("[xyz]") = 5
    println(f"echolen={el}")
    # Stage R1 — bytes crossing as (ptr,len), and a bytes return via out-param shim
    bb := to_bytes("abc")
    rev := ffi_brev(bb)                          # bytes -> bytes (97,98,99 -> "cba")
    println(f"bsum={ffi_bsum(bb)} brev={to_str(rev)} brevlen={len(rev)}")
    # interior 0x00 must survive the round-trip (a NUL-terminated API could not)
    nul := to_bytes("a" + chr(0) + "b")
    rn := ffi_brev(nul)
    println(f"nulsum={ffi_bsum(nul)} nullen={len(rn)}")
    # Stage R2 — a typed handle freed (exactly once) by its destructor at scope exit
    println(f"live0={ffi_res_live()}")          # 0 before
    use_res()                                   # opens a handle, uses it, auto-frees at its scope exit
    println(f"live1={ffi_res_live()}")          # 0 again -> destructor ran exactly once
    use_res_close()                             # opens a handle, closes it early (destructor at close)
    println(f"live2={ffi_res_live()}")          # 0 -> closed exactly once, scope-exit was a no-op
    # Stage R3a — `-> Option(string)`: a C NULL surfaces as None (not "")
    println(f"get1={opts(ffi_get(1))} get0={opts(ffi_get(0))}")   # hit -> Some, miss -> None
    # Stage R4 — out-param constructors: `ffi_mk(id, &db) -> rc` + a scalar out-param, no shim
    db := null
    mrc := ffi_mk(9, &db)                       # rc=0, db <- &slot(9)
    n := 0
    ffi_dbl(21, &n)                             # n <- 42
    println(f"r4 rc={mrc} read={ffi_read(db)} dbl={n}")   # rc=0 read=9 dbl=42
    # to_i32: sign-extend a 32-bit C int return; to_ptr: an integer-valued sentinel pointer
    println(f"neg={to_i32(ffi_neg())} rawneg_ok={to_i32(ffi_neg()) < 0} sentinel={ffi_ptrval(to_ptr(-1))}")
