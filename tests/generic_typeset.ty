# Go-style type-set `where` constraints: `where T: a | b | ...` bounds a type
# parameter to a user-listed set (newtype base resolved), alongside the fixed
# predicates. Checked at instantiation like any `where` clause.

fn pick(a: $T, b: $T, first: bool) -> $T where T: int | string:
    if first:
        return a
    return b

fn label(x: $T, y: $U) -> $T where numeric(T), U: int | string:
    return x

fn main():
    println(str(pick(1, 2, true)))         # 1   (int in the set)
    println(pick("x", "y", false))         # y   (string in the set)
    println(str(label(3, "tag")))          # 3   (numeric(T) + U=string in set)
    println(str(label(7, 9)))              # 7   (U=int also in set)
