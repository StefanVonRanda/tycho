# A char combines with another char (any comparison) or with an int via +/- (-> a
# char, byte offset). Mixing a char with an int any other way (<, ==, *, %) is a
# type error in both compilers -- see tests/reject/char_int_*.
fn main():
    a := 'A'
    b := 'B'
    println(str(a < b) + "," + str(a == b) + "," + str((a + 1) == b))   # true,false,true
    println(str(('B' - 1) == 'A'))                                      # true
