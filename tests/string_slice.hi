# String slices: s[a:b] is a fresh substring (sugar for substr), with the
# array-slice forms s[a:], s[:b], s[:]. Self-hosting (hierc0 supports it).
fn main():
    s := "hello, world"
    print(s[0:5] + "|" + s[7:] + "|" + s[:5] + "|" + s[:] + "\n")   # hello|world|hello|hello, world
    # slices of a computed string + nesting
    t := s[7:12]                                  # "world"
    print(t[0:3] + " len=" + str(len(t[1:])) + "\n")   # wor len=4
    # empty slice
    print("[" + s[3:3] + "]\n")                   # []
