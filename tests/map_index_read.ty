# m[k] as an rvalue READ: a PURE zero-value read -- returns the value type's zero
# on a missing key and NEVER inserts. Scalar value types (int/float/string/bool),
# string + int keys. Write/compound forms (m[k]=v, m[k] op= v) stay the in-place
# slot (a mutation, so they DO insert). Composite-value reads still need an
# explicit map_get(m, k, default).
fn main():
    cnt := []string: int
    words := ["a", "b", "a", "a", "c", "b"]
    for i in range(len(words)):
        cnt[words[i]] = cnt[words[i]] + 1          # the counter idiom (read sugar)
    println("a=" + str(cnt["a"]) + " b=" + str(cnt["b"]) + " c=" + str(cnt["c"]))
    miss := cnt["zzz"]                              # pure read of a missing key -> 0
    println("miss=" + str(miss) + " distinct=" + str(len(cnt)))   # zzz NOT inserted
    f := []string: float
    f["x"] = 2.5
    println("f=" + str(f["x"]) + "/" + str(f["y"]))
    s := []int: string
    s[1] = "hi"
    println("s=[" + s[1] + "][" + s[2] + "]")
    b := []string: bool
    b["t"] = true
    println("b=" + str(b["t"]) + "/" + str(b["f"]))
    acc := []string: int
    acc["k"] += 10                                  # compound op= is a mutation -> inserts
    acc["k"] += 5
    println("acc=" + str(acc["k"]) + " acclen=" + str(len(acc)))
