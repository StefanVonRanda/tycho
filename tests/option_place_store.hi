# Regression (found by fuzz/): storing an Option PLACE (a variable, not a fresh
# Some(...) construction) into a longer-lived array must RE-BOX it. Otherwise the
# stored box aliases the source's box, which here lives in the per-iteration loop
# arena -- so once that arena resets, the array dangles (heap-use-after-free).
# Reading the options after the loop must still see the right values.
fn main():
    xs := [Some(0)]
    for i in range(4):
        o := Some(i)            # box built in the loop block arena (reset each iter)
        push(xs, o)             # storing a PLACE -> must re-box into xs's arena
    total := 0
    for j in range(len(xs)):
        match xs[j]:
            Some(v):
                total = total + v
            None:
                total = total + 0
    print(str(len(xs)) + " " + str(total) + "\n")   # 5 6
