# Self-referential shadow whose initializer CONTAINS A CALL: `y := dbl(y)` in a
# nested block. Scalar + has-call, so in tychoc0 it routes through the
# scalar-transient (per-statement _t arena) path rather than the plain decl
# path; both must still read the ENCLOSING y (= 5) -> dbl(5) = 10, with the
# outer y unchanged. Expected: inner 10, outer 5.
fn dbl(n: int) -> int:
    return n * 2

fn main():
    y := 5
    if y > 0:
        y := dbl(y)
        print("inner " + str(y))
    print("outer " + str(y))
