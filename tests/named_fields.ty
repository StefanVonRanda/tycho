# F4: named struct construction P(x: 1, y: 2), order-independent. Both transpilers.
struct Point:
    x: int
    y: int

struct Config:
    width: int
    height: int
    depth: int

fn main():
    a := Point(x: 1, y: 2)
    b := Point(y: 20, x: 10)                 # any order
    c := Config(depth: 3, width: 1, height: 2)
    println(str(a.x) + "," + str(a.y))
    println(str(b.x) + "," + str(b.y))
    println(str(c.width) + "," + str(c.height) + "," + str(c.depth))
