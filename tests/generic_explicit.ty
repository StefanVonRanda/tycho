# Stage 3: explicit call-site type args for the non-inferable case. `empty() -> [$T]`
# names a type param no argument pins; `empty$(int)` supplies it. A return-only $T
# is folded into the instance name so empty$(int)/empty$(string) stay distinct.

fn empty() -> [$T]:
    return []T

fn singleton(x: $V) -> [$V]:
    r := []V
    push(r, x)
    return r

fn main():
    xs := empty$(int)
    push(xs, 5)
    push(xs, 7)
    println(str(len(xs)))               # 2
    ss := empty$(string)
    push(ss, "hi")
    println(str(len(ss)))               # 1
    fs := empty$(float)
    push(fs, 1.5)
    println(str(len(fs)))               # 1
    ys := singleton$(int)(42)           # explicit type arg on an inferable fn (allowed)
    println(str(ys[0]))                 # 42
