# Stage-2: a generic body with a typaram-typed LOCAL annotation (`out : [T] = []`,
# `picked : T = ...`), instantiated at more than one type. The annotation's `$T`
# must be substituted per instance (at clone time); the prior shared template
# left it unsubstituted and reported `declared type [void]`.
fn collect(xs: [$T]) -> [$T]:
    out : [T] = []
    for v in xs:
        push(out, v)
    return out

fn last_or(xs: [$T], dflt: $T) -> $T:
    picked : T = dflt
    for v in xs:
        picked = v
    return picked

fn main():
    a := collect([10, 20, 30])
    println(str(len(a)) + ":" + str(a[0]) + str(a[2]))    # 3:1030
    b := collect(["p", "q"])                               # string instance
    println(str(len(b)) + ":" + b[0] + b[1])              # 2:pq
    println(str(last_or([5, 6, 7], 0)))                    # 7
    println(last_or(["x", "y"], "none"))                   # y
