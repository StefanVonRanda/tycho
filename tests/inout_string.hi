# mut string: reassignment through the borrow reaches the caller, and the
# new bytes build in the caller's (owner) arena via _ina_, not the callee's
# scope -- so they survive the call and the caller's loop arenas.

fn shout(s: mut string):
    s = s + "!"

fn rename(s: mut string, n: string):
    s = n

fn grow(s: mut string, n: int):
    i := 0
    for i < n:
        s = s + "."
        i = i + 1

fn main():
    msg := "hi"
    shout(&msg)
    shout(&msg)
    print(msg + "\n")
    rename(&msg, "bye")
    print(msg + "\n")
    grow(&msg, 3)
    print(msg + "\n")
    acc := ""
    i := 0
    for i < 4:
        shout(&acc)
        i = i + 1
    print(acc + "\n")
