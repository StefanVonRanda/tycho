# Composite map keys (Stage 1): a struct as the key type. Stored by value, deep-hashed
# and deep-compared, occupancy scheme. Covers scalar-field and heap(string)-field keys,
# all ops, insertion-ordered keys(), in-place accumulation, value semantics, deep ==,
# and a nested-struct key.
struct Point:
    x: int
    y: int

struct Person:
    name: string
    age: int

struct Edge:
    a: Point
    b: Point

fn main():
    # scalar-field struct key
    m := []Point: int
    m[Point(1, 2)] = 10
    m[Point(3, 4)] = 20
    m[Point(1, 2)] = 11                       # overwrite, not a new entry
    println("get=" + str(map_get(m, Point(1, 2), -1)) + " miss=" + str(map_get(m, Point(9, 9), -1)))
    println("in=" + str(Point(3, 4) in m) + " len=" + str(len(m)))
    ks := keys(m)
    println("order=(" + str(ks[0].x) + "," + str(ks[0].y) + ")(" + str(ks[1].x) + "," + str(ks[1].y) + ")")
    delete m[Point(1, 2)]
    println("del: len=" + str(len(m)) + " gone=" + str(not (Point(1, 2) in m)))

    # heap (string) field key: deep-copied in, source mutation doesn't leak
    tally := []Person: int
    p := Person("alice", 30)
    tally[p] = 1
    tally[p] += 4                             # in-place accumulator
    p.name = "X"
    println("alice=" + str(map_get(tally, Person("alice", 30), 0)) + " keyname=" + keys(tally)[0].name)

    # deep == (entry-wise, order-independent)
    a := []Person: int
    a[Person("k", 1)] = 7
    b := []Person: int
    b[Person("k", 1)] = 7
    print("eq=" + str(a == b))
    b[Person("k", 1)] = 8
    println(" neq=" + str(a == b))

    # nested-struct key (Edge has Point fields -> recursive hash/eq)
    g := []Edge: string
    g[Edge(Point(0, 0), Point(1, 1))] = "diag"
    println("edge=" + map_get(g, Edge(Point(0, 0), Point(1, 1)), "?") + " emiss=" + map_get(g, Edge(Point(0, 0), Point(2, 2)), "?"))
