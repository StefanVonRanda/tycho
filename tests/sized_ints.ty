# First-class sized numerics: u32/u64 wrap at their C width (unsigned int /
# unsigned long long), f32 is single precision. Arithmetic, bitwise, shifts,
# comparison, conversions, printing, and [T] arrays. Locked by the golden .out;
# the u32 path is also cross-checked end-to-end by the NIST vectors in
# corelib/test/sha256 (which this type rewrote).
fn main():
    a: u32 = 3000000000
    b: u32 = 2000000000
    print(f"u32 add={a + b}\n")            # (5e9) mod 2^32 = 705032704
    print(f"u32 sub={b - a}\n")            # (2e9-3e9) mod 2^32 = 3294967296
    x: u32 = 3735928559                    # 0xdeadbeef
    print(f"u32 not={~x}\n")               # 559038736
    print(f"u32 shl={x << 4}\n")           # 0xeadbeef0 = 3940282096
    print(f"u32 shr={x >> 4}\n")           # 0x0deadbee = 233495534
    print(f"u32 and={x & 255}\n")          # 0xef = 239
    print(f"u32 or={x | 256}\n")           # 0xdeadbfef = 3735928815
    print(f"u32 xor={x ^ 4294967295}\n")   # ~x = 559038736
    print(f"u32 div={x / 16}\n")           # 233495534
    print(f"u32 mod={x % 16}\n")           # 15
    print(f"u32 cmp={a > b} {a == b}\n")   # true false

    p: u64 = 10000000000                   # 1e10 (> 2^32)
    q: u64 = 5000000000
    print(f"u64 add={p + q}\n")            # 15000000000
    print(f"u64 shl={to_u64(1) << 40}\n")  # 1099511627776
    print(f"u64 cmp={p > q}\n")            # true

    f: f32 = to_f32(1)
    g: f32 = to_f32(2)
    print(f"f32 div={f / g}\n")            # 0.5
    print(f"f32 add={f + g}\n")            # 3.0

    print(f"to_int={to_int(x & 255)}\n")   # 239
    print(f"to_u32={to_u32(300)}\n")       # 300
    print(f"to_float={to_float(to_u32(7))}\n")  # 7.0

    arr := []u32
    push(arr, a)
    push(arr, x >> 8)
    print(f"arr={arr[0]} {arr[1]} len={len(arr)}\n")   # 3000000000 14593470 len=2
