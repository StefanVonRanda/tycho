# Generics Stage 1: `$T` type parameters, monomorphized per concrete argument
# type. A `$T` introduces a parameter; a later bare `T` refers to it. Each
# distinct instantiation is one concrete function; calls dispatch statically.

struct Box:
    v: int

fn id(x: $T) -> T:
    return x

fn fst(a: $A, b: $B) -> A:
    return a

fn snd(a: $A, b: $B) -> B:
    return b

fn main():
    print(str(id(5)) + "\n")              # int instance
    print(id("hi") + "\n")                # string instance
    print(str(id(5) + id(6)) + "\n")      # id__int reused (dedup) -> 11
    print(str(fst(7, "x")) + "\n")        # two type params -> 7
    print(snd(7, "x") + "\n")             # returns the second -> x
    b := id(Box(9))                       # struct type argument
    print(str(b.v) + "\n")                # 9
