# Generics Stage 1: `$T` type parameters, monomorphized per concrete argument
# type. A `$T` introduces a parameter; a later bare `T` refers to it. Each
# distinct instantiation is one concrete function; calls dispatch statically.

struct Box:
    v: int

fn id(x: $T) -> T:
    return x

fn fst(a: $A, b: $B) -> A:
    return a

fn snd(a: $A, b: $B) -> B:
    return b

fn main():
    println(str(id(5)))              # int instance
    println(id("hi"))                # string instance
    println(str(id(5) + id(6)))      # id__int reused (dedup) -> 11
    println(str(fst(7, "x")))        # two type params -> 7
    println(snd(7, "x"))             # returns the second -> x
    b := id(Box(9))                       # struct type argument
    println(str(b.v))                # 9
