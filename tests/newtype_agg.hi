# Aggregate-underlying newtypes: `type X = [T]` / `[K: V]` / Struct.
# X(v) wraps (zero-cost, literal arg grounds to the underlying type),
# to_under(x) unwraps to the underlying value, and == stays deep between
# two values of the SAME newtype. Copy semantics are the underlying's
# (deep, value-semantic) throughout.

struct Pt:
    x: int
    y: int

type Ids = [int]
type Env = [string: int]
type Pos = Pt

fn total(xs: Ids) -> int:
    raw := to_under(xs)
    s := 0
    i := 0
    for i < len(raw):
        s = s + raw[i]
        i = i + 1
    return s

fn bump(e: Env, k: string) -> Env:
    m := to_under(e)
    m = map_set(m, k, map_get(m, k, 0) + 1)
    return Env(m)

fn main():
    ids := Ids([1, 2, 3])
    print(str(total(ids)) + "\n")
    dup := ids
    if dup == ids:
        print("ids eq\n")
    e := bump(bump(Env([]), "a"), "a")
    print(str(map_get(to_under(e), "a", 0)) + "\n")
    p := Pos(Pt(7, 9))
    q := to_under(p)
    print(str(q.x + q.y) + "\n")
