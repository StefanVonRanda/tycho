# SOA core ops — a focused minimal SOA test (the fuller tests/soa.ty adds
# pass/return-by-value, ==, slices, and nesting). Both compilers now support all
# of SOA, so both files run in the fixpoint differential (B vs the C compiler).
# Core here: empty literal, push, len, field read a[i].f, field write a[i].f = v,
# whole-element gather p := a[i].

struct P:
    x: int
    y: int
    z: int

fn main():
    ps := soa []P
    i := 0
    for i < 5:
        push(ps, P(i, i * 10, i + 100))
        i = i + 1
    println("len=" + str(len(ps)))          # 5

    # field writes (scatter)
    ps[2].x = 99
    ps[2].z = ps[2].z + 1                         # 102 -> 103

    # field-wise reads across all elements
    i = 0
    sx := 0
    sz := 0
    for i < len(ps):
        sx = sx + ps[i].x
        sz = sz + ps[i].z
        i = i + 1
    println("sumx=" + str(sx) + " sumz=" + str(sz))   # 0+1+99+3+4=107 ; 100+101+103+103+104=511

    # whole-element gather
    g := ps[3]
    println("gather x=" + str(g.x) + " y=" + str(g.y) + " z=" + str(g.z))   # 3 30 103
