# A newtype used as a map KEY: write `m[k]=v`, membership `k in m`, and read `m[k]`
# all accept a newtype key whose type_of resolves to its base, and reject a bare
# base value. Both compilers.
type Id = int

fn main():
    m := []Id: int
    a := Id(1)
    b := Id(2)
    m[a] = 10
    m[b] = 20
    println(str(a in m) + " " + str(Id(3) in m))   # true false
    println(str(m[a]) + " " + str(m[b]))            # 10 20
    delete m[a]
    println(str(a in m) + " " + str(len(m)))        # false 1
