# UFCS on built-ins: `recv.name(args)` desugars to `name(recv, args)`, routing
# through the same built-in dispatch the direct-call form uses. Both compilers.
fn main():
    s := "a,b,c,d"
    parts := s.split(",")
    println(str(parts.len()))          # split + len on the result
    println(parts.pop())               # pop returns the last element
    println(str("hello".len()))        # len on a string literal
    println(str(s.find(",")))          # find on a string receiver

    xs := [3, 1, 2]
    xs.push(9)
    xs.push(8)
    println(str(xs.len()))
    println(str(xs.pop()))

    n := 42
    println(str(n.to_float().to_int()))   # chained builtin methods on a scalar

    m := []string: int
    m["x"] = 1
    m["y"] = 2
    ks := m.keys()
    println(str(ks.len()))
