# m[k] as a READ for COMPOSITE value types (array / struct): a PURE read that
# yields the value's zero -- empty array / zeroed struct -- on a missing key and
# NEVER inserts. Writes through the slot (m[k]=v, push(m[k]), m[k].f=x,
# m[k][j]=x) keep working. Both compilers must agree (this reconciled a latent
# parity bug: tychoc rejected composite reads, tychoc0 insert-on-read them).
struct P:
    x: int
    y: int
fn main():
    ma := []string: [int]
    ma["g"] = [1, 2]
    push(ma["g"], 3)
    println("arr present=" + str(len(ma["g"])) + " missing=" + str(len(ma["zz"])) + " size=" + str(len(ma)))
    mp := []string: P
    mp["o"] = P(10, 20)
    mp["o"].x = 11
    got := mp["o"]
    println("struct x=" + str(got.x) + " y=" + str(got.y) + " missX=" + str(mp["none"].x) + " size=" + str(len(mp)))
    println("direct field=" + str(mp["o"].y))
    ma["g"] = [5, 6, 7]
    ma["g"][1] = 99
    println("elem1=" + str(ma["g"][1]) + " elem0=" + str(ma["g"][0]))
