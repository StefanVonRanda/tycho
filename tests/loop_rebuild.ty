# Loop-carried self-rebuild move: `t = Pair(t, Leaf(..))` in a loop hands off
# t's buffer into the new node instead of deep-copying it (O(n) build, not
# O(n^2)). A snapshot taken mid-build must stay frozen: value semantics still
# deep-copies `snap = t` eagerly, so the later in-place moves can't reach it.

enum Tree:
    Leaf(int)
    Pair(Tree, Tree)

fn size(t: Tree) -> int:
    match t:
        Leaf(v):
            return 1
        Pair(a, b):
            return size(a) + size(b)

fn sumv(t: Tree) -> int:
    match t:
        Leaf(v):
            return v
        Pair(a, b):
            return sumv(a) + sumv(b)

fn build(n: int) -> Tree:
    t := Leaf(0)
    for i in range(n):
        t = Pair(t, Leaf(i + 1))    # self-rebuild -> loop-carried move
    return t

fn build_snap(n: int) -> int:
    t := Leaf(0)
    snap := Leaf(0)
    for i in range(n):
        t = Pair(t, Leaf(i + 1))
        if i == 2:
            snap = t                # deep-copied snapshot, frozen at 4 leaves
    return size(snap)               # must be 4, regardless of later moves

fn main():
    t := build(5)
    print("size=" + str(size(t)) + "\n")        # 6 leaves
    print("sum=" + str(sumv(t)) + "\n")          # 0+1+2+3+4+5 = 15
    print("snap_frozen=" + str(build_snap(5)) + "\n")   # 4, not 6
