# An early bare `return` in main() -- not just on the last line. tychoc0 inlined
# main's body into `int main()`, so a bare `return;` was emitted into an int-
# returning function (cc error). Fixed by emitting the body as a void function
# (h_main) called by a thin `int main` wrapper, mirroring tychoc. Covers an early
# return in a plain branch, inside a loop, and the normal fall-through.
fn pick(n: int) -> int:
    return n

fn main():
    x := pick(5)
    if x > 0:
        println("pos")
        return
    println("unreachable")
