# SOA arrays (struct-of-arrays), foundational core: `soa [Struct]` is stored as
# one growable arena buffer per field + a shared len/cap, instead of an array of
# records. Core ops: empty literal `soa []Struct`, push, len, field read
# `a[i].f`, field write `a[i].f = v`. Bounds-checked like the AoS arrays.
# Deterministic, so the differential harness asserts native and ASan/UBSan
# builds agree byte-for-byte. (Whole-element gather `p := a[i]`, ==, slices, and
# pass/return-by-value are deferred to later increments.)

struct Particle:
    x: int
    y: int
    vx: int
    vy: int

# nesting: a soa as a struct field
struct Bag:
    items: soa [Particle]
    label: int

# pass a soa BY VALUE (read-only); sums a field across all elements
fn total_vx(ps: soa [Particle]) -> int:
    i := 0
    t := 0
    for i < len(ps):
        t = t + ps[i].vx
        i = i + 1
    return t

# build and RETURN a soa from a function
fn make_soa(n: int) -> soa [Particle]:
    r := soa []Particle
    i := 0
    for i < n:
        push(r, Particle(i, i * 2, i + 1, i + 3))
        i = i + 1
    return r

fn yn(b: bool) -> string:
    if b:
        return "T"
    return "F"

# a soa param is a read-only borrow; to mutate, copy it first (`local := ps`).
# The returned copy is independent of the caller's soa (value semantics).
fn doubled_x(ps: soa [Particle]) -> soa [Particle]:
    local := ps
    i := 0
    for i < len(local):
        local[i].x = local[i].x * 2
        i = i + 1
    return local

fn main():
    ps := soa []Particle
    i := 0
    for i < 5:
        push(ps, Particle(i, i * 10, 1, 2))
        i = i + 1
    print("len=" + str(len(ps)) + "\n")          # 5

    # field-wise update across all elements (the cache-win access pattern):
    # advance each particle by its velocity, twice.
    step := 0
    for step < 2:
        i = 0
        for i < len(ps):
            ps[i].x = ps[i].x + ps[i].vx
            ps[i].y = ps[i].y + ps[i].vy
            i = i + 1
        step = step + 1

    # read back x and y for each element
    i = 0
    sx := 0
    sy := 0
    for i < len(ps):
        sx = sx + ps[i].x
        sy = sy + ps[i].y
        i = i + 1
    # x: each started i, +1 twice -> i+2; sum over i=0..4 = 10 + 5*2 = 20
    # y: each started i*10, +2 twice -> i*10+4; sum = 100 + 5*4 = 120
    print("sumx=" + str(sx) + " sumy=" + str(sy) + "\n")   # 20 120

    # a direct field write to one element
    ps[2].x = 999
    print("ps2x=" + str(ps[2].x) + " ps0x=" + str(ps[0].x) + "\n")   # 999 2

    # whole-element gather: p := ps[i] is an independent struct copy; mutating
    # it must not touch the soa.
    p := ps[0]
    p.x = 0 - 7
    print("gather: p.x=" + str(p.x) + " ps0.x=" + str(ps[0].x) + "\n")   # -7 2

    # pass a soa by value (read-only) to a function
    print("total_vx=" + str(total_vx(ps)) + "\n")                       # 5*1 = 5

    # build and return a soa from a function; read it back
    q := make_soa(4)
    print("q.len=" + str(len(q)) + " q2.x=" + str(q[2].x) + " q2.y=" + str(q[2].y) + "\n")  # 4 2 4

    # structural equality: same length + every field equal elementwise
    r := make_soa(4)
    print("eq q==r: " + yn(q == r) + " q!=mk3: " + yn(q != make_soa(3)) + "\n")   # T T

    # slice: a sub-range view, copied on bind so it is independent of the source
    sl := q[1:3]
    print("slice len=" + str(len(sl)) + " sl0.x=" + str(sl[0].x) + " sl1.y=" + str(sl[1].y) + "\n")  # 2 1 4
    sl[0].x = 0 - 1
    print("slice indep: sl0.x=" + str(sl[0].x) + " q1.x=" + str(q[1].x) + "\n")   # -1 1

    # read-only soa param: doubled_x copies then mutates the copy; the caller's
    # soa is untouched (sound zero-copy borrow + copy-on-`:=`).
    base := make_soa(3)
    dbl := doubled_x(base)
    print("borrow base1.x=" + str(base[1].x) + " dbl1.x=" + str(dbl[1].x) + "\n")   # 1 2

    # nesting: a soa as a struct field; copying the struct deep-copies the soa,
    # so the two structs' soas are independent (value semantics through nesting).
    bag := Bag(make_soa(2), 7)
    bag2 := bag
    bag2.items[0].x = 0 - 9
    print("nest bag0.x=" + str(bag.items[0].x) + " bag2_0.x=" + str(bag2.items[0].x) + " label=" + str(bag.label) + "\n")  # 0 -9 7
