# `where hashable(T)`: constrain a type parameter to be usable as a map KEY.
# T is introduced by a list param and then used as a map key in the body, so the
# constraint is load-bearing -- without it a bad key type (e.g. float) would fail
# deep in the body; with it, instantiation gives a clean signature error
# (tests/reject/where_hashable_bad.ty). Exercises every key shape the predicate
# accepts: int + string (scalars), a fieldless enum, and a composite struct
# (value-hashed via the same key_hashable path the standalone map-key check uses).

enum Color:
    Red
    Green
    Blue

struct Point:
    x: int
    y: int

fn distinct(xs: [$T]) -> int where hashable(T):
    m : [T: int] = []
    for x in xs:
        m[x] = m.get(x, 0) + 1
    return len(m)

fn main():
    println(str(distinct([3, 1, 4, 1, 5, 9, 2, 6, 5])))          # {3,1,4,5,9,2,6} = 7
    println(str(distinct(["a", "b", "a", "c", "b"])))            # {a,b,c} = 3
    println(str(distinct([Red, Green, Red])))                    # {Red,Green} = 2
    println(str(distinct([Point(1, 2), Point(1, 2), Point(3, 4)])))  # {(1,2),(3,4)} = 2
