# Fieldless-enum map keys: [Color: int]. The key is stored and hashed as
# its TAG (riding the int-key occupancy scheme), so iteration order and
# hashing are deterministic (never pointer/ASLR-dependent); keys() rebuilds
# the wrapped values from the per-variant singletons, which round-trip
# through match. Payload enums are rejected as keys
# (tests/reject/enum_key_payload.ty): equal tags would not mean equal values.

enum Color:
    Red
    Green
    Blue

fn main():
    m : [Color: int] = []
    m[Red] = 3
    m[Blue] = 5
    m[Green] = 4
    println(str(m.get(Red, 0) + m.get(Green, 0) + m.get(Blue, 0)))
    println(str(len(m)))
    if Red in m:
        println("has red")
    ks := keys(m)
    total := 0
    i := 0
    for i < len(ks):
        total = total + m.get(ks[i], 0)
        i = i + 1
    println(str(total))
    delete m[Blue]
    println(str(len(m)))
    reds := 0
    ks2 := keys(m)
    j := 0
    for j < len(ks2):
        match ks2[j]:
            Red:
                reds = reds + 1
            Green:
                reds = reds + 0
            Blue:
                reds = reds + 0
        j = j + 1
    println(str(reds))
