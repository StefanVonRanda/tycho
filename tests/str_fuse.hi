# Push-loop fusion for [string] arrays (heap elements): the fused store must
# deep-copy each element into the array's own arena (value semantics), and the
# grow hook must regrow the char* spine across several doublings (4->8->16).
fn build(n: int) -> [string]:
    acc := []string
    i := 0
    for i < n:
        push(acc, "w" + str(i))
        i = i + 1
    return acc

fn main():
    a := build(10)                      # 10 pushes -> 3 spine grows
    println("len=" + str(len(a)))
    j := 0
    for j < len(a):
        println(a[j])
        j = j + 1

    # value semantics: a pushed variable is an independent copy, so mutating
    # the source afterward must not change what landed in the array.
    s := "orig"
    b := []string
    k := 0
    for k < 3:
        push(b, s)
        k = k + 1
    s = "mutated"
    println(b[0] + b[1] + b[2])         # orig x3, not "mutated"
