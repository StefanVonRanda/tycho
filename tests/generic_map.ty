# Stage 3: map-pattern generics. `[$K: $V]` infers both the key and value type
# from inside the map argument, then substitutes + monomorphizes per concrete map.

fn msize(m: [$K: $V]) -> int:
    return len(m)

fn lookup(m: [$K: $V], k: $K, d: $V) -> $V:    # $K, $V used in params and return
    return map_get(m, k, d)

fn main():
    counts := ["a": 1, "b": 2, "c": 3]
    println(str(msize(counts)))             # 3   ([string: int])
    println(str(lookup(counts, "b", 0)))    # 2
    println(str(lookup(counts, "z", -1)))   # -1
    prices := ["x": 1.5, "y": 2.5]
    println(str(msize(prices)))             # 2   ([string: float])
    byid := [1: "one", 2: "two"]
    println(lookup(byid, 2, "?"))           # two ([int: string])
    println(lookup(byid, 9, "none"))        # none
