# A bare None/Ok/Err payload is fixed from the surrounding Option/Result type at any
# nesting depth (Some(None) : Option(Option(int)), Ok(None), Some(Ok(1))). Both
# compilers accept and agree (tychoc's resolve_exp now pushes the inner type in).
fn mk() -> Option(Option(int)):
    return Some(None)

fn main():
    x : Option(Option(int)) = Some(None)
    match x:
        Some(inner):
            match inner:
                Some(v): println("v" + str(v))
                None: println("inner-none")
        None: println("outer-none")

    y : Result(Option(int), string) = Ok(None)
    match y:
        Ok(inner): println("ok-none")
        Err(e): println(e)

    z : Option(Result(int, string)) = Some(Ok(1))
    match z:
        Some(r): println("some-ok")
        None: println("none")

    match mk():
        Some(i): println("mk-some")
        None: println("mk-none")
