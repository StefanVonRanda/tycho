# Regression: in-place accumulators INSIDE a `match` arm. collect_accums once
# walked if/for/while bodies but not match/select arm bodies, so a map_set or
# string-append accumulator inside a `match recv(ch):` arm silently reverted to
# the pure O(n)-copy path (correct output, but O(n^2) time + memory -- it took
# the parallel indexer dogfood to 7.2 GB). This locks the in-place rewrite as
# sound inside a match arm: same answer as the plain-loop form.
fn classify(n: int) -> Option(int):
    if n < 0:
        return None
    return Some(n % 5)

fn build(n: int) -> [int: int]:
    counts := []int: int
    word := ""
    i := 0
    for i in range(n):
        match classify(i):
            Some(bucket):
                counts[bucket] = counts.get(bucket, 0) + 1
                word = word + "a"          # string-append accumulator in the same arm
            None:
                return counts              # unreachable for i >= 0
    return counts

fn main():
    c := build(20)
    ks := keys(c)
    total := 0
    for i in range(len(ks)):
        total = total + c.get(ks[i], 0)
    println("buckets=" + str(len(c)) + " total=" + str(total))
