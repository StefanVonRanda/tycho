# Soundness guard for liveness-driven buffer recycling: a recycled buffer must be
# the SOURCE var's OWN, not one it shared via a move. `b := a` can move a's buffer
# to b (move-on-last-use), so reassigning a afterwards must NOT recycle that buffer
# -- it is still live through b. The gate excludes movable vars for exactly this
# reason. (Regression: hierc0 once printed 49 here by recycling b's buffer.)
fn mk(n: int) -> [int]:
    r := []int
    for i in range(n):
        push(r, i)
    return r

fn main():
    a := mk(5)
    b := a          # may move a's buffer to b
    a = mk(3)       # reassign a from a call that does NOT read a -- must not recycle b's buffer
    sb := 0
    for i in range(len(b)):
        sb = sb + b[i]      # 0+1+2+3+4 = 10, only if b is intact
    sa := 0
    for i in range(len(a)):
        sa = sa + a[i]      # 0+1+2 = 3
    print("b=" + str(sb) + " a=" + str(sa) + "\n")
