# cond ? a : b -- C-style conditional expression, lowest precedence,
# right-associative. Condition must be a bool; arms must agree in type
# (the then-arm's type grounds a bare-literal else-arm). Lazy: only the
# taken arm evaluates.

fn pick(b: bool) -> int:
    return b ? 1 : 2

fn side(s: string) -> string:
    print("eval " + s + "\n")
    return s

fn main():
    print(str(pick(true)) + str(pick(false)) + "\n")
    n := 7
    s := n % 2 == 0 ? "even" : "odd"
    print(s + "\n")
    xs := n > 0 ? [n, n] : []
    print(str(len(xs)) + "\n")
    nested := n > 5 ? (n > 6 ? "a" : "b") : "c"
    print(nested + "\n")
    lazy := true ? side("yes") : side("no")
    print(lazy + "\n")
