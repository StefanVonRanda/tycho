# reserve() (capacity hint) now works for composite-element arrays -- structs, tuples,
# and nested arrays -- not just [int]/[float]/[string]. Both compilers.
struct P:
    x: int
    y: int

fn main():
    a := []P
    reserve(a, 100)                 # struct-element array
    push(a, P(1, 2))
    push(a, P(3, 4))
    t := [](int, int)
    reserve(t, 50)                  # tuple-element array
    push(t, (5, 6))
    nested := [][int]
    reserve(nested, 10)             # nested-array element
    push(nested, [7, 8, 9])
    print("a=" + str(len(a)) + " " + str(a[1].x) + " t=" + str(t[0].0) + " n=" + str(nested[0][2]) + "\n")
