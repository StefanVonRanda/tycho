fn maxv(xs: [$T]) -> $T where comparable(T):
    m := xs[0]
    for i in range(1, len(xs)):
        if xs[i] > m:
            m = xs[i]
    return m

fn sum(xs: [$T]) -> $T where numeric(T):
    total := xs[0]
    for i in range(1, len(xs)):
        total = total + xs[i]
    return total

fn show(x: $T) -> string where has_str(T):
    return "[" + str(x) + "]"

# A CONCRETE-array return type immediately followed by `where`. This must parse as
# the dynamic array `[int]` + a constraint clause, NOT as `[int]where` (const-size
# `int`, element type `where`). tychoc0's [W]T const-size parser was missing the
# `where` guard its [$N]T sibling had (1.6A regression), which broke `-> [int] where`
# -- the exact shape of core:sort's argsort, silently reddening `make corelib`.
fn indices(xs: [$T]) -> [int] where comparable(T):
    r := []int
    for i in range(len(xs)):
        push(r, i)
    return r

fn main():
    ints := [3, 1, 4, 1, 5, 9, 2]
    println(str(maxv(ints)))          # 9
    println(str(sum(ints)))           # 25
    words := ["pear", "apple", "fig"]
    println(maxv(words))              # pear
    println(show(42))                 # [42]
    println(show(true))               # [true]
    println(str(sum([1.5, 2.5])))     # 4.0
    println(str(len(indices(ints))))  # 7 (return type `[int] where` must parse)
