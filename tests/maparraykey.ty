# Composite map keys (Stage 3a): an array as the key type. Stored by value, hashed
# ORDER-SENSITIVELY (element-wise fold) and deep-compared, occupancy scheme. Covers an
# int array, a string array, a composite-element array ([Point]), order-sensitivity,
# in-place accumulation, deep ==, and keys() returning [[T]].
struct Point:
    x: int
    y: int

fn main():
    # int-array key — order matters ([1,2,3] != [3,2,1])
    m := [][int]: string
    m[[1, 2, 3]] = "abc"
    m[[3, 2, 1]] = "cba"
    println("get=" + m.get([1, 2, 3], "?") + " rev=" + m.get([3, 2, 1], "?") + " miss=" + m.get([1, 2], "?"))
    println("in=" + str([1, 2, 3] in m) + " len=" + str(len(m)))
    ks := keys(m)
    println("k0len=" + str(len(ks[0])) + " k0=(" + str(ks[0][0]) + "," + str(ks[0][1]) + "," + str(ks[0][2]) + ")")
    delete m[[1, 2, 3]]
    println("del: len=" + str(len(m)) + " gone=" + str(not ([1, 2, 3] in m)))

    # string-array key + in-place accumulator
    tally := [][string]: int
    tally[["a", "b"]] = 1
    tally[["a", "b"]] += 9
    println("sa=" + str(tally.get(["a", "b"], -1)) + " miss=" + str(tally.get(["b", "a"], -1)))

    # composite-element array key ([Point]) + deep ==
    p := [][Point]: int
    p[[Point(1, 2), Point(3, 4)]] = 99
    println("pa=" + str(p.get([Point(1, 2), Point(3, 4)], -1)) + " miss=" + str(p.get([Point(1, 2)], -1)))
    a := [][int]: int
    a[[5, 6]] = 1
    b := [][int]: int
    b[[5, 6]] = 1
    print("eq=" + str(a == b))
    b[[7]] = 2
    println(" neq=" + str(a == b))
