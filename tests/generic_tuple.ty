# Generic function/struct instantiated over a TUPLE type. tychoc0's generic
# instance name-mangler (gen_inst_mangle) had no tuple case: a bare tuple type
# arg's '(' sits at position 0, so the Name(args) arm (which needs '(' > 0) never
# caught it and it fell through to `return ty` -- emitting the raw "(int,int)" as
# a C function-name suffix (invalid C, uncompilable). The tup_<T0>_<T1> case fixes
# it. Found by extending the differential fuzzer to generics. Exercises a generic
# fn and a generic struct over a tuple, plus gid over an array (the working path).
fn gid(x: $T) -> T:
    return x

struct GBox($T):
    v: T

fn main():
    t := gid((3, 4))
    println(str(t.0 + t.1))            # 7
    b := GBox((10, 20))
    println(str(b.v.0 + b.v.1))        # 30
    a := gid([1, 2, 3])
    println(str(a[0] + len(a)))        # 4
