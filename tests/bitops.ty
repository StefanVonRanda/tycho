# Integer modulo and bitwise/shift operators, Go-style precedence: `% << >> &`
# bind at the multiplicative level and `| ^` at the additive level, so every
# bitwise op binds TIGHTER than comparison (no C `a & b == c` footgun). Unary `~`
# is bitwise NOT. All are integer-only (a float operand is a type error).
fn main():
    println("mod=" + str(17 % 5))            # 2
    println("modprec=" + str(0 - 17 % 5))    # 0 - (17%5) = -2  (% tighter than -)
    println("and=" + str(12 & 10))           # 8
    println("or=" + str(12 | 10))            # 14
    println("xor=" + str(12 ^ 10))           # 6
    println("shl=" + str(1 << 10))           # 1024
    println("shr=" + str(1024 >> 3))         # 128
    println("bnot0=" + str(~0))              # -1
    println("bnot5=" + str(~5))              # -6
    println("p1=" + str(1 + 2 & 3))          # 1 + (2&3) = 3   (& tighter than +)
    println("p2=" + str(2 | 1 << 2))         # 2 | (1<<2) = 6  (<< tighter than |)

    ok := 0
    if 4 & 6 == 4:                                # (4&6)==4 -> 4==4 -> true
        ok = 1
    println("cmp=" + str(ok))                # 1

    s := 0
    i := 0
    for i in range(0, 8):
        if i & 1 == 1:                            # odd test via mask
            s = s + i
    println("oddsum=" + str(s))              # 1+3+5+7 = 16
