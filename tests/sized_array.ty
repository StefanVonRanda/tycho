# Empty typed-array literals []T for the full fixed-width family. tychoc's []T
# lookahead used to recognize only u32/u64/f32 and REJECTED []u8/[]u16/[]i8/
# []i16/[]i32/[]i64 ("expected newline") while tychoc0 accepted them -- a parser
# divergence found by the sized-int differential drift hunt. Exercises build +
# index + wrapping arithmetic + len across every width, on both compilers.
fn main():
    a := []u8
    push(a, to_u8(200))
    push(a, to_u8(100))
    println(str(a[0] + a[1]))          # 300 mod 256 = 44

    b := []i8
    push(b, to_i8(100))
    println(str(b[0] + b[0]))          # 200 -> i8 wrap -> -56

    c := []u16
    push(c, to_u16(70000))             # 70000 mod 65536 = 4464
    println(str(c[0]))

    d := []i16
    push(d, to_i16(-1))
    println(str(d[0]))                 # -1

    e := []i32
    push(e, to_i32(1000000))
    println(str(e[0] * e[0]))          # 10^12 wraps i32 -> -727379968

    f := []i64
    push(f, to_i64(1))
    println(str(f[0] << to_i64(40)))   # 1099511627776

    g := []u32
    push(g, to_u32(3000000000))
    println(str(g[0]))                 # 3000000000 (u32, in range)

    h := []u64
    push(h, to_u64(10000000000))
    println(str(h[0]))                 # 1e10

    # to_int of a sized BINARY OP: tychoc0 typed every sized binop as plain int
    # (its type_of recognized only u32/u64/f32), so to_int(sized_binop) was wrongly
    # rejected. The type_of fix keeps the operand width through +,-,*,/,shift,bitwise.
    ub := to_u8(200)
    println(str(to_int(ub + to_u8(100))))    # u8 binop wraps -> 44
    println(str(to_int(e[0] * e[0])))        # to_int of an i32 binop (var operands) wraps -> -727379968

    println(str(len(a) + len(b) + len(c)))   # 2 + 1 + 1 = 4
