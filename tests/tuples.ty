# Multiple return values via first-class tuples. `return a, b` builds a tuple;
# you can destructure it (x, y := f()), store it whole (t := f()), index it
# (t.0), pass it as an argument, and compare it. A tuple is a value: deep-copied
# on bind, so copies never alias.

fn divmod(a: int, b: int) -> (int, int):
    q := a / b
    return q, a - q * b

fn stats(xs: [int]) -> (int, int, int):       # min, max, sum
    lo := xs[0]
    hi := xs[0]
    total := 0
    for i in range(len(xs)):
        if xs[i] < lo:
            lo = xs[i]
        if xs[i] > hi:
            hi = xs[i]
        total = total + xs[i]
    return lo, hi, total

fn labelled(xs: [int]) -> (string, [int]):    # heap element: a label + a buffer
    ys := []int
    for i in range(len(xs)):
        push(ys, xs[i] * 2)
    return "doubled", ys

fn sum_pair(p: (int, int)) -> int:            # a tuple as a parameter
    return p.0 + p.1

fn main():
    # destructure into fresh locals
    q, r := divmod(17, 5)
    print("q=" + str(q) + " r=" + str(r) + "\n")

    # store the tuple whole, then index it
    t := divmod(20, 6)
    print("t0=" + str(t.0) + " t1=" + str(t.1) + "\n")

    # a 3-tuple
    lo, hi, sm := stats([4, 1, 7, 3])
    print("lo=" + str(lo) + " hi=" + str(hi) + " sum=" + str(sm) + "\n")

    # tuple as an argument: from a call, and from a literal
    print("sum_pair=" + str(sum_pair(divmod(17, 5))) + "\n")
    print("sum_lit=" + str(sum_pair((10, 20))) + "\n")

    # heap element, destructured
    name, dbl := labelled([5, 6, 7])
    print(name + " len=" + str(len(dbl)) + " last=" + str(dbl[2]) + "\n")

    # value semantics: b is an independent deep copy of a
    a := labelled([1, 2])
    b := a
    print("a0=" + a.0 + " b1len=" + str(len(b.1)) + "\n")

    # tuple equality (element-wise)
    if divmod(17, 5) == (3, 2):
        print("eq-ok\n")
