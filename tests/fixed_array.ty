# Fixed-size arrays `[N]T` (const generics, ROADMAP 1.6): stored INLINE (no heap),
# value-copied, static bounds. N is an int literal or an int `const`. `len` is a
# compile-time constant; `==` is element-wise.
const W = 4

struct Vec3:
    xs: [3]float

fn yn(b: bool) -> string:
    if b:
        return "T"
    return "F"

fn dot(a: [3]float, b: [3]float) -> float:      # fixed-array params, by value
    return a[0] * b[0] + a[1] * b[1] + a[2] * b[2]

fn ramp() -> [W]int:                            # const-sized return
    r: [W]int = [0, 0, 0, 0]
    for i in range(W):
        r[i] = i * 10
    return r

fn main():
    v: [3]int = [10, 20, 30]
    println("e1=" + str(v[1]))                  # 20
    w := v                                       # value copy
    v[0] = 99
    println("v0=" + str(v[0]) + " w0=" + str(w[0]))   # v0=99 w0=10
    println("len=" + str(len(v)))               # 3

    a: [3]float = [1.0, 2.0, 3.0]
    b: [3]float = [4.0, 5.0, 6.0]
    println("dot=" + str(dot(a, b)))            # 32.0
    c: [3]float = [1.0, 2.0, 3.0]
    println("eq=" + yn(a == c) + " ne=" + yn(a == b))   # eq=T ne=F

    p := Vec3([7.0, 8.0, 9.0])                    # fixed-array struct field
    println("p1=" + str(p.xs[1]))               # 8.0

    r := ramp()
    println("r=" + str(r[0]) + "," + str(r[3]) + " len=" + str(len(r)))  # 0,30 len=4

    names: [2]string = ["hi", "yo"]              # composite (heap) elements
    println("nm=" + names[0] + names[1])        # hiyo
