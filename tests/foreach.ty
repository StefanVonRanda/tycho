# `for x in COLL:` iterates a collection (array or string), binding each element
# to x. It desugars to a once-evaluated collection temp + an index loop, so
# element value-semantics, bounds-check elision, and break/continue all carry
# over. The collection is evaluated exactly once (a function result is not
# re-called per element).
fn nums() -> [int]:
    a := []int
    push(a, 10)
    push(a, 20)
    push(a, 30)
    return a

fn main():
    xs := []int
    push(xs, 1)
    push(xs, 2)
    push(xs, 3)
    s := 0
    for x in xs:
        s = s + x
    println("sum=" + str(s))            # 6

    p := 1
    for k in [2, 3, 4]:                       # array literal
        p = p * k
    println("prod=" + str(p))           # 24

    t := 0
    for v in nums():                          # function result -> evaluated once
        t = t + v
    println("tsum=" + str(t))           # 60

    words := []string                         # heap (string) elements
    push(words, "a")
    push(words, "bb")
    push(words, "ccc")
    out := ""
    for w in words:
        out = out + w + "."
    println("joined=" + out)            # a.bb.ccc.

    n := 0
    for ch in "hello":                        # iterate a string -> chars
        n = n + 1
    println("chars=" + str(n))          # 5

    acc := 0
    for x in xs:                              # break / continue inside foreach
        if x == 2:
            continue
        if x == 3:
            break
        acc = acc + x
    println("acc=" + str(acc))          # 1

    g := 0
    for a in xs:                              # nested foreach
        for b in [10, 20]:
            g = g + 1
    println("grid=" + str(g))           # 6
