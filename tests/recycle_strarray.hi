# Gate widening (element types): buffer recycling now applies to ANY array element
# type, not just [int]/[float]. For a heap-element array ([string]) we recycle the
# SPINE buffer (the char** ) -- dead+unique exactly as a scalar array's buffer;
# the strings it pointed to are separate (also dead, not recycled = partial). This
# checks correctness of the reassign-recycle for [string] AND the move-alias guard
# (qb must stay intact: a moved spine must not be recycled while shared).
fn rep(n: int, base: int) -> [string]:
    r := []string
    for i in range(n):
        push(r, str(base + i))
    return r
fn grow(a: [string]) -> [string]:
    r := []string
    for i in range(len(a)):
        push(r, a[i] + "x")
    return r
fn main():
    a := rep(60, 0)
    b := a
    for j in range(30):
        a = rep(60, 1000000)
    qa := 0
    for i in range(len(a)):
        qa = qa + len(a[i])
    c := rep(40, 0)
    for j in range(20):
        c = grow(c)
    qc := 0
    for i in range(len(c)):
        qc = qc + len(c[i])
    qb := 0
    for i in range(len(b)):
        qb = qb + len(b[i])
    print("qa=" + str(qa) + " qb=" + str(qb) + " qc=" + str(qc) + "\n")
