                    die_at(dc, _el, "`in` tests membership in a map; the right operand must be a map")
                if lt != map_key(rt):             # and the key must be the map's key type (matches tychoc)
                    die_at(dc, _el, "`in` key must be " + map_key(rt))
                return mfam(rt) + "_has(" + gen_expr(r, names, types, dc, ctx) + ", " + krt(dc, ctx, rt, gen_expr(l, names, types, dc, ctx)) + ")"
            if op == "+" and lt == "str":         # string concat: the left operand is a string
                rcat := type_of(r, names, types, dc, ctx)
                if rcat == "char":                 # str + char: append one byte
                    return "sc_char(" + ctx.owner + ", " + gen_expr(l, names, types, dc, ctx) + ", " + gen_expr(r, names, types, dc, ctx) + ")"
                if rcat == "str":
                    pieces := []Expr            # flatten a 3..6-piece all-string chain to one scN call
                    concat_pieces(e, names, types, dc, ctx, &pieces)
                    np := len(pieces)
                    if np >= 3 and np <= 6:
                        call := "sc" + str(np) + "(" + ctx.owner
                        k := 0
                        for k < np:
                            call = call + ", " + gen_expr(pieces[k], names, types, dc, ctx)
                            k = k + 1
                        return call + ")"
                    return "sc(" + ctx.owner + ", " + gen_expr(l, names, types, dc, ctx) + ", " + gen_expr(r, names, types, dc, ctx) + ")"
                # str + non-(str/char) falls through to the operand-type check below (rejected, like tychoc)
            if is_cmp(op) and resolve_nt(dc, ctx, lt) == "str" and resolve_nt(dc, ctx, type_of(r, names, types, dc, ctx)) == "str":   # lexicographic string compare (incl. string newtypes, which resolve to str); BOTH operands must resolve to str, AND carry the same newtype identity
                if nt_skin_of(l, names, types, dc, ctx) != nt_skin_of(r, names, types, dc, ctx):
