# tychoc0 — a compiler for a SUBSET of Tycho, written in Tycho. Stage 1 of the
# self-hosting bootstrap (docs/bootstrap.md). Emits C to stdout. With no
# argument it reads source on stdin; `tychoc0 path/to/main.ty` compiles that file
# directly, and if the file declares a `package` it walks the whole package
# (imports included) from disk via the read_file/list_dir/args builtins — a
# standalone driver, no `tychoc --bundle` needed.
#
# Subset: one or more `fn name(p: int, ...) -> int:` / `fn main():`, whose
# indented bodies have `x := EXPR`, `x = EXPR`, `print(SEXPR)`, `return EXPR`,
# and `if`/`elif`/`else`. EXPR = integer arithmetic (`+ - *`, parens, vars, int
# literals, calls `f(args)`) and comparisons (`== < >`). SEXPR (string, only in
# print position) = string literals and `str(EXPR)` joined by `+`. Validated
# DIFFERENTIALLY against the C compiler by `make bootstrap`.

# ---------------------------------------------------------------- lexer ----

enum Tok:
    TInt
    TFloat
    TStr
    TFStr                                        # f"..." interpolated string literal
    TChar
    TIdent
    TPlus
    TMinus
    TStar
    TSlash
    TLParen
    TRParen
    TLBracket
    TRBracket
    TComma
    TColon
    TDot
    TArrow
    TWalrus
    TEq
    TEqEq
    TLt
    TGt
    TLe
    TGe
    TNe
    TAmp
    TPercent
    TPipe
    TCaret
    TTilde
    TDollar
    TShl
    TShr
    TNewline
    TIndent
    TDedent
    TEof

struct Token:
    kind: Tok
    text: string
    line: int                 # 1-based source line, for parse diagnostics
    col: int                  # 0-based source column, for the diagnostic caret

fn is_digit(c: int) -> bool:
    return c >= 48 and c <= 57

fn is_alpha(c: int) -> bool:
    return (c >= 97 and c <= 122) or (c >= 65 and c <= 90) or c == 95

fn is_alnum(c: int) -> bool:
    return is_alpha(c) or is_digit(c)

# After a value-producing token a '.' is field/tuple access (t.0, x.field), so a
# `.5` there stays DOT + INT; everywhere else `.<digit>` begins a leading-dot float.
fn tok_postfixable(k: Tok) -> bool:
    return k == TIdent or k == TInt or k == TFloat or k == TStr or k == TChar or k == TRParen or k == TRBracket

# Lexer diagnostic: print `msg` then the offending source line + a caret under
# byte offset `at`, then exit. die() is terminal, so this never returns. (Mirrors
# tychoc's snippet+caret for lex errors; src + offset are local to the lexer, so no
# globals/threading are needed. Parse errors report "line N" via Token.line;
# resolve/codegen errors stay message-only — tychoc0's AST carries no position.)
fn lex_err(src: string, at: int, msg: string):
    n := len(src)
    p := at
    if p > n:
        p = n
    ls := 0                                   # start offset of the line containing `p`
    ln := 1                                   # 1-based line number
    j := 0
    for j < p:
        if src[j] == 10:
            ln = ln + 1
            ls = j + 1
        j = j + 1
    le := ls                                  # end offset (the newline or EOF)
    for le < n and src[le] != 10:
        le = le + 1
    gutter := "  " + str(ln) + " | "
    npad := len(gutter) + (p - ls)            # spaces before the caret
    pad := ""
    k := 0
    for k < npad:
        pad = pad + " "
        k = k + 1
    die(msg + "\n" + gutter + substr(src, ls, le) + "\n" + pad + "^")

# encode a token's (line, col) into one int for the AST position field; die_at
# decodes it back. 1-based line, 0-based col; assumes no line >= 100000 chars.
fn tloc(t: Token) -> int:
    return t.line * 100000 + t.col

fn scan_token(src: string, n: int, i: int, toks: inout [Token], line: int, linestart: int) -> int:
    c := src[i]
    tok0 := i                                    # token start, for the error caret (i advances as we scan)
    col := tok0 - linestart                       # 0-based column of the token start (for the diagnostic caret)
    if c == 32 or c == 9:
        return i + 1
    elif c == 35:
        for i < n and src[i] != 10:
            i = i + 1
        return i
    elif c == 34:                                # string literal "..."
        start := i + 1
        i = i + 1
        for i < n and src[i] != 34:
            if src[i] == 92:                     # backslash escapes the next char
                if i + 1 >= n:
                    lex_err(src, tok0, "lex: unterminated string")
                e := src[i + 1]                  # only \n \t \\ \" are valid (matches tychoc)
                if e != 110 and e != 116 and e != 92 and e != 34:
                    lex_err(src, tok0, "lex: unsupported string escape (use \\n \\t \\\\ \\\")")
                i = i + 1
            elif src[i] < 32 and src[i] != 9:    # reject raw control bytes (newline/CR/NUL/...); tab excepted
                lex_err(src, tok0, "lex: raw control byte in string literal (use an escape such as \\n or \\t)")
            i = i + 1
        if i >= n:
            lex_err(src, tok0, "lex: unterminated string")
        push(toks, Token(TStr, substr(src, start, i), line, col))
        return i + 1                             # consume closing quote
    elif c == 102 and i + 1 < n and src[i + 1] == 34:   # f"..." interpolated string (102='f', 34='"')
        start := i + 2
        i = i + 2
        depth := 0                               # brace depth inside a `{...}` hole (0 in the literal part)
        for i < n and (src[i] != 34 or depth > 0):
            ch := src[i]
            if ch == 92:                         # backslash escapes the next char
                if i + 1 >= n:
                    lex_err(src, tok0, "lex: unterminated f-string")
                fe := src[i + 1]                 # only \n \t \\ \" (matches tychoc)
                if fe != 110 and fe != 116 and fe != 92 and fe != 34:
                    lex_err(src, tok0, "lex: unsupported string escape (use \\n \\t \\\\ \\\")")
                i = i + 2
            elif depth == 0 and ch == 123 and i + 1 < n and src[i + 1] == 123:   # {{ literal brace
                i = i + 2
            elif depth == 0 and ch == 125 and i + 1 < n and src[i + 1] == 125:   # }} literal brace
                i = i + 2
            elif ch == 123:                      # { opens / nests a hole
                depth = depth + 1
                i = i + 1
            elif depth > 0 and ch == 125:        # } closes a hole level
                depth = depth - 1
                i = i + 1
            elif depth > 0 and ch == 34:         # nested string literal inside a hole: skip it whole
                i = i + 1
                for i < n and src[i] != 34:
                    if src[i] == 92:
                        i = i + 1
                    i = i + 1
                if i >= n:
                    lex_err(src, tok0, "lex: unterminated string in f-string hole")
                i = i + 1                         # consume closing quote
            else:
                i = i + 1
        if i >= n:
            lex_err(src, tok0, "lex: unterminated f-string")
        push(toks, Token(TFStr, substr(src, start, i), line, col))
        return i + 1
    elif c == 39:                                # char literal '...' -> one byte
        i = i + 1
        if i >= n:
            lex_err(src, tok0, "lex: unterminated char literal")
        b := 0
        if src[i] == 92:                         # backslash escape
            i = i + 1
            if i >= n:
                lex_err(src, tok0, "lex: unterminated char literal")
            e := src[i]
            if e == 110:                         # \n
                b = 10
            elif e == 116:                       # \t
                b = 9
            elif e == 114:                       # \r
                b = 13
            elif e == 48:                        # \0
                b = 0
            elif e == 92:                        # backslash
                b = 92
            elif e == 39:                        # quote
                b = 39
            else:
                lex_err(src, tok0, "lex: bad char escape (use \\n \\t \\r \\0 \\\\ \\')")
            i = i + 1
        else:
            b = src[i]
            i = i + 1
        if i >= n or src[i] != 39:
            lex_err(src, tok0, "lex: char literal must be exactly one character")
        push(toks, Token(TChar, str(b), line, col))
        return i + 1                             # consume closing quote
    elif is_digit(c):
        start := i
        for i < n and is_digit(src[i]):
            i = i + 1
        isf := false
        if i < n and src[i] == 46 and i + 1 < n and is_digit(src[i + 1]):   # D.D fractional part (46 = '.')
            isf = true
            i = i + 1
            for i < n and is_digit(src[i]):
                i = i + 1
        if i < n and (src[i] == 101 or src[i] == 69):   # e/E exponent (101='e' 69='E'): optional sign, >=1 digit
            j := i + 1
            if j < n and (src[j] == 43 or src[j] == 45):   # 43='+' 45='-'
                j = j + 1
            if j < n and is_digit(src[j]):                 # well-formed only; else 'e...' stays a separate ident
                isf = true
                i = j
                for i < n and is_digit(src[i]):
                    i = i + 1
        if isf:
            push(toks, Token(TFloat, substr(src, start, i), line, col))
            return i
        push(toks, Token(TInt, substr(src, start, i), line, col))
        return i
    elif is_alpha(c):
        start := i
        for i < n and is_alnum(src[i]):
            i = i + 1
        push(toks, Token(TIdent, substr(src, start, i), line, col))
        return i
    elif c == 43:
        push(toks, Token(TPlus, "+", line, col))
        return i + 1
    elif c == 45:
        if i + 1 < n and src[i + 1] == 62:
            push(toks, Token(TArrow, "->", line, col))
            return i + 2
        push(toks, Token(TMinus, "-", line, col))
        return i + 1
    elif c == 42:
        push(toks, Token(TStar, "*", line, col))
        return i + 1
    elif c == 47:
        push(toks, Token(TSlash, "/", line, col))
        return i + 1
    elif c == 40:
        push(toks, Token(TLParen, "(", line, col))
        return i + 1
    elif c == 41:
        push(toks, Token(TRParen, ")", line, col))
        return i + 1
    elif c == 91:
        push(toks, Token(TLBracket, "[", line, col))
        return i + 1
    elif c == 93:
        push(toks, Token(TRBracket, "]", line, col))
        return i + 1
    elif c == 44:
        push(toks, Token(TComma, ",", line, col))
        return i + 1
    elif c == 46 and i + 1 < n and is_digit(src[i + 1]) and (len(toks) == 0 or not tok_postfixable(toks[len(toks) - 1].kind)):
        # leading-dot float: .5 / .5e3 (the '.' is not field/tuple access here)
        start := i
        i = i + 1                                       # consume '.'
        for i < n and is_digit(src[i]):
            i = i + 1
        if i < n and (src[i] == 101 or src[i] == 69):   # e/E exponent (101='e' 69='E')
            j := i + 1
            if j < n and (src[j] == 43 or src[j] == 45):   # 43='+' 45='-'
                j = j + 1
            if j < n and is_digit(src[j]):
                i = j
                for i < n and is_digit(src[i]):
                    i = i + 1
        push(toks, Token(TFloat, substr(src, start, i), line, col))
        return i
    elif c == 46:
        push(toks, Token(TDot, ".", line, col))
        return i + 1
    elif c == 58:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TWalrus, ":=", line, col))
            return i + 2
        push(toks, Token(TColon, ":", line, col))
        return i + 1
    elif c == 61:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TEqEq, "==", line, col))
            return i + 2
        push(toks, Token(TEq, "=", line, col))
        return i + 1
    elif c == 60:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TLe, "<=", line, col))
            return i + 2
        if i + 1 < n and src[i + 1] == 60:
            push(toks, Token(TShl, "<<", line, col))
            return i + 2
        push(toks, Token(TLt, "<", line, col))
        return i + 1
    elif c == 62:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TGe, ">=", line, col))
            return i + 2
        if i + 1 < n and src[i + 1] == 62:
            push(toks, Token(TShr, ">>", line, col))
            return i + 2
        push(toks, Token(TGt, ">", line, col))
        return i + 1
    elif c == 33:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TNe, "!=", line, col))
            return i + 2
        lex_err(src, tok0, "lex: '!' must be part of '!='")
        return i + 1
    elif c == 38:
        push(toks, Token(TAmp, "&", line, col))
        return i + 1
    elif c == 37:
        push(toks, Token(TPercent, "%", line, col))
        return i + 1
    elif c == 124:
        push(toks, Token(TPipe, "|", line, col))
        return i + 1
    elif c == 94:
        push(toks, Token(TCaret, "^", line, col))
        return i + 1
    elif c == 126:
        push(toks, Token(TTilde, "~", line, col))
        return i + 1
    elif c == 36:                                # '$' — generics: `$T` type parameter
        push(toks, Token(TDollar, "$", line, col))
        return i + 1
    else:
        lex_err(src, tok0, "lex: unexpected character")
        return i + 1

fn lex(src: string) -> [Token]:
    toks := []Token
    stack := []int
    push(stack, 0)
    sp := 1
    n := len(src)
    i := 0
    line := 1
    linestart := 0                                # byte offset of the current line's start (for token columns)
    at_bol := true
    for i < n:
        if at_bol:
            ind := 0
            ws_sp := false                            # tabs OR spaces, never a mix within one line
            ws_tab := false
            for i < n and (src[i] == 32 or src[i] == 9):
                if src[i] == 32:
                    ws_sp = true
                else:
                    ws_tab = true
                ind = ind + 1
                i = i + 1
            if ws_sp and ws_tab:
                lex_err(src, i, "lex: mixed tabs and spaces in indentation")
            if i >= n:
                at_bol = false
            elif src[i] == 10:
                push(toks, Token(TNewline, "", line, 0))
                i = i + 1
                line = line + 1
                linestart = i
            elif src[i] == 35:
                for i < n and src[i] != 10:
                    i = i + 1
            elif ind > stack[sp - 1]:
                if sp >= 256:                        # H2: cap block nesting (mirrors tychoc's indent_stack[256]); else parse_block recursion overflows the C stack
                    lex_err(src, i, "lex: indentation too deep")
                if sp < len(stack):
                    stack[sp] = ind
                else:
                    push(stack, ind)
                sp = sp + 1
                push(toks, Token(TIndent, "", line, 0))
                at_bol = false
            else:
                for sp > 1 and stack[sp - 1] > ind:
                    sp = sp - 1
                    push(toks, Token(TDedent, "", line, 0))
                if stack[sp - 1] != ind:
                    lex_err(src, i, "lex: inconsistent indentation")
                at_bol = false
        else:
            if src[i] == 10:
                push(toks, Token(TNewline, "", line, 0))
                i = i + 1
                line = line + 1
                linestart = i
                at_bol = true
            else:
                i = scan_token(src, n, i, &toks, line, linestart)
    push(toks, Token(TNewline, "", line, 0))
    for sp > 1:
        sp = sp - 1
        push(toks, Token(TDedent, "", line, 0))
    push(toks, Token(TEof, "", line, 0))
    return toks

# ------------------------------------------------------------------ AST ----

enum Expr:
    EInt(string, int)
    EBool(string, int)             # bool literal `true`/`false`, carried as "1"/"0" (distinct from int so str() prints true/false)
    EChar(string, int)             # char literal `'x'`, carried as the byte value in decimal text
    EFloat(string, int)            # float literal, emitted verbatim (round-trips as a double)
    EStr(string, int)              # string literal (raw content, escapes preserved)
    EVar(string, int)
    EBin(string, Expr, Expr, int)
    ECall(string, [Expr], int)    # function call OR struct construction `Point(1,2)`
    EField(Expr, string, int)     # field access `base.field` (nests: `r.lo.x`)
    EIndex(Expr, Expr, int)       # array index `base[idx]`
    EArrLit([Expr], int)          # array literal `[1, 2, 3]` (int elements)
    EArrEmpty(string, int)        # empty typed array `[]int`
    EMapEmpty(string, string, int) # empty typed map `[]string: int` (key, value types)
    EMapLit([Expr], [Expr], int)  # non-empty map literal `[k0: v0, k1: v1]` (keys, vals)
    ETuple([Expr], int)           # tuple literal `(a, b, ...)` / `return a, b`
    ESlice(Expr, Expr, Expr, int) # `base[lo:hi]` sub-array (owning copy)
    EAddr(Expr, int)              # `&place` at a call site (pass to a inout param)
    ELambda(int, [string], [string], string, Expr, [string], [string], int)   # `fn(p)->r: e` closure literal: id, params, ptypes, ret, body-expr, capnames, captypes (last two filled by the lift pass)
    ECallV(Expr, [Expr], int)     # call-on-expression: `<expr>(args)` — an indirect call on a fn VALUE (array elem, struct field, call result)
    ESpawn(int, string, [Expr], int)   # `spawn f(args)` (CC-1): spawn-site id (assigned by the lift pass), callee, args

enum Stmt:
    SDecl(string, Expr, int)
    SAssign(string, Expr, int)
    SFieldAssign(Expr, Expr, int) # `lvalue = rhs`, lvalue an EField path
    SPrint(Expr, int)             # the Expr is a string expression
    SReturn(Expr, int)
    SReturnVoid              # bare `return` (no value)
    SIf(Expr, [Stmt], [Stmt], int)
    SWhile(Expr, [Stmt], int)     # condition-form `for COND:` (Tycho's while loop)
    SForRange(string, Expr, Expr, Expr, [Stmt], int)   # `for i in range(start, stop, step):`
    SExpr(Expr, int)              # bare expression statement, e.g. a call `f(x)`
    STypedDecl(string, string, Expr, int)   # `name : Type = expr` (annotation fixes the type)
    SOrReturn(string, Expr, int)  # `name := result_expr or_return` (unwrap Ok or propagate Err)
    SDestructure([string], Expr, int)       # `a, b := tuple_expr`
    SMultiAssign([string], Expr, int)       # `a, b = tuple_expr` (assign existing vars)
    SMatch(Expr, [string], [[string]], [[Stmt]], int)  # subj, arm variants, arm binds, arm bodies
    SBreak                   # break out of the nearest enclosing loop
    SContinue                # skip to the next iteration of the nearest loop
    SSelect(string, [string], [Expr], [string], [[Stmt]], int)   # `select` (CC-5): uid, arm kinds ("recv"/"default"/"closed"),
                             # per-arm channel exprs (dummy for non-recv), per-arm bind names ("" for non-recv), arm bodies
    SParFor(string, Expr, Expr, [Stmt], int, int)   # `parallel for` (CC-3): loopvar, start, stop, body, par-id
                             # (parse: body=original, par-id=-1; the lift pass moves the body into a
                             # lifted __par<N> chunk proc and stores caps/accs in the pars side table)
    SConst(string, Expr, int)   # `const NAME = <literal>` local: folded at each use in the mangle pass; a no-op in every other pass (no runtime storage)
    SValDecl(string, string, Stmt, int)   # `x := if.../match...` / `x : T = if.../match...` (ROADMAP 2.1): name, annot ("" = inferred), the SIf/SMatch whose single-expr tails feed the decl (rewritten to `x = tail` in gen). Other tail positions desugar to plain SIf/SMatch at parse time.

struct Param:
    name: string
    ty: string                # "int" | "str"

struct Func:
    name: string
    params: [string]
    ptypes: [string]          # parallel to params: "int" | "str"
    ret: string               # "int" | "str" | "void"
    body: [Stmt]
    is_extern: int            # FFI: 1 -> `extern fn`, calls a C symbol directly (no arena, name unmangled, no body)
    lib: string               # FFI: link library from `extern "Lib" fn`; "" for bare extern
    constraints: string       # generics: `where` predicates as "pred:T,pred:U"; "" for none (inert unless generic)

struct Sig:                   # collected up front, for typing calls
    name: string
    ret: string
    ptypes: [string]          # parameter types, so a bare fn name can be typed as a value
    is_extern: int            # FFI: 1 -> call the C symbol `name` directly (no arena); str ret arena-copied

struct LamInfo:               # one per lambda, produced by the lift pass; drives env-struct + thunk emission
    id: int
    ftype: string             # the VALUE's fn type fn(lamparams->ret) — for the Fn_<suffix>
    capnames: [string]
    captypes: [string]        # env field types (Tycho types)
    lamptypes: [string]       # the lambda's OWN param types — the thunk's call signature
    ret: string

struct SpawnInfo:             # one per spawn SITE (incl. each parallel-for chunk), from the lift
    fname: string             # pass; drives the HSpawnA_<i> args-struct + tycho_spawn_<i> thread
    argtypes: [string]        # trampoline emission in the driver (mirrors tychoc's g_spawn)
    retty: string

struct ParInfo:               # one per `parallel for` site (CC-3), from the lift pass
    sid: int                  # its chunk proc's spawn-site id (HSpawnA_<sid>/tycho_spawn_<sid>)
    capnames: [string]        # captured outer vars (deep-copied per chunk at the site)
    captypes: [string]
    accnames: [string]        # reduction accumulators (outer int/float locals)
    accops: [string]          # "+" | "*" (the fold op, applied at the in-order join)
    retty: string             # the chunk proc's partial type (acc type, or a tuple of them)

struct Field:
    name: string
    ty: string                # "int" | "str" | a struct name

struct StructDef:
    name: string
    fields: [Field]
    typeparams: [string]      # generics: `struct Box($T)` -> ["T"]; empty for a normal struct
    inst_args: [string]       # generics: a struct INSTANCE's concrete type args (typeparam order); [] for templates/normal. Mirrors EnumDef.inst_args -- lets a sole nested-generic field recover its typaram (recover_struct_binds).

struct Variant:
    name: string
    ptypes: [string]          # payload types: "int"/"str"/struct/enum names

struct EnumDef:
    name: string
    variants: [Variant]
    typeparams: [string]      # generics: `enum Tree($T)` -> ["T"]; empty for a normal enum
    inst_args: [string]       # generics: an INSTANCE's concrete type args (typeparam order); [] otherwise. Lets a recursive-enum constructor recover $T from a self-referential argument.

# Read-only typing/codegen context, threaded by value: function return types,
# struct layouts, and enum definitions. (The mutable per-block var env stays as
# the separate names/types arrays.) This is the `Ctx` docs/bootstrap.md wanted.
struct Decls:                 # immutable after parse — threaded read-only as `dc`,
    sigs: [Sig]               # NEVER reconstructed, so its (large) arrays are never
    structs: [StructDef]      # deep-copied per scope change. The old Ctx kept these
    enums: [EnumDef]          # fields, so with_owner/enter_block deep-copied all of
    ntnames: [string]         # sigs/structs/enums on every owner/depth change (~37%
    ntunder: [string]         # of self-compile). tychoc threads `arena` the same way.
    sigmap: [string: int]     # function name -> index in `sigs`, built once: O(1) sig_ret
    pars: [ParInfo]           # parallel-for sites from the lift pass (CC-3), indexed by SParFor's par-id
                              # (safe to map here precisely because Decls is never rebuilt)
    src_lines: [string]       # the source split into lines (bundle-relative), for die_at snippet + caret
    vmap: [string: int]       # variant name -> enum index, built once (sibling of sigmap): O(1) is_variant/variant_enum, was a nested linear scan over all enums x variants (~7% of self-compile)
    handles: [string]         # FFI R2 typed handles: "Name=c_free_fn" per `handle` decl (for is_handle/cty/finalizer)

struct Ctx:                   # mutable per-scope / per-function state only
    vparams: [string]         # current func's NON-inout param names (map accum guard)
    saccums: [string]         # current func's string-append accumulator locals (in-place hi_append)
    rettype: string           # current func's Tycho return type (for the return-slot _scope free)
    owner: string             # arena that fresh allocations go into ("0"=NULL=malloc; "&_t"/"_parent"/"&_scope")
    depth: int                # current block nesting depth (0 = function body _scope; d = block _b<d>)
    bbases: [int]             # env length at entry to each nested block (one per depth 1..depth); a var's
                              # declaration depth = deepest k with bbases[k-1] <= its env index (see var_block_depth)
    movables: [string]        # locals read exactly once in the body and not inside a loop — move-on-last-use
                              # candidates: a `b := a` over one of these hands off a's buffer (no deep copy)
    loopdepth: int            # block depth of the innermost enclosing loop's body arena (0 = not in a loop);
                              # break/continue free _b<depth> .. _b<loopdepth> before the C jump
    fusearr: [string]         # push-loop fusion: array names whose cursor is live (cached data/len/cap)
    fusesuf: [string]         # parallel: the C cursor suffix (e.g. "3_0") -> _fd3_0/_fl3_0/_fc3_0
    fusety: [string]          # parallel: scalar element type ("int" | "float") for the grow hook
    line: int               # current statement source line, for resolve/codegen diagnostics
    curpkg: string            # current function's package prefix ("mathx__", or "" if unmangled/main); lets a
                              # UFCS method on a NON-package-typed receiver (e.g. a scalar) find a same-package
                              # method whose mangled name can't be derived from the receiver type

struct Program:
    structs: [StructDef]
    enums: [EnumDef]
    funcs: [Func]
    ntnames: [string]
    ntunder: [string]
    handles: [string]         # FFI R2 typed handles: "Name=c_free_fn" per `handle` decl

# --------------------------------------------------------------- parser ----

fn expect(toks: [Token], pos: inout int, k: Tok):
    if toks[pos].kind != k:
        die("parse: line " + str(toks[pos].line) + ": unexpected token")
    pos = pos + 1

fn expect_ident(toks: [Token], pos: inout int, name: string):
    if toks[pos].kind != TIdent or toks[pos].text != name:
        die("parse: line " + str(toks[pos].line) + ": expected a keyword")
    pos = pos + 1

# Open an indented block: a newline, then any number of blank/comment-only
# lines (each a stray NEWLINE), then the INDENT.
fn open_block(toks: [Token], pos: inout int):
    expect(toks, &pos, TNewline)
    for toks[pos].kind == TNewline:
        pos = pos + 1
    expect(toks, &pos, TIndent)

# String interpolation: an f-string's text "a{e}b" desugars to ("a" + str(e) + "b").
# `{{`/`}}` are literal braces; each `{e}` is lexed+parsed as a sub-expression and
# wrapped in str() (identity on a string, i2s/f2s on int/float). No new AST node.
fn desugar_interp(s: string) -> Expr:
    _el := 0
    pieces := []Expr
    n := len(s)
    buf := ""
    i := 0
    for i < n:
        c := s[i]
        if c == 123 and i + 1 < n and s[i + 1] == 123:        # {{ -> literal {
            buf = buf + chr(123)
            i = i + 2
        elif c == 125 and i + 1 < n and s[i + 1] == 125:      # }} -> literal }
            buf = buf + chr(125)
            i = i + 2
        elif c == 125:
            die("interp: unmatched } in an f-string (use }} for a literal brace)")
        elif c == 123:                                        # {expr}
            if len(buf) > 0:
                push(pieces, EStr(buf, _el))
                buf = ""
            i = i + 1
            estart := i
            depth := 1                                         # balance nested braces; skip nested strings
            for i < n and depth > 0:
                ch := s[i]
                if ch == 34:                                   # string literal in the hole: '}' inside it is not a hole end
                    i = i + 1
                    for i < n and s[i] != 34:
                        if s[i] == 92:
                            i = i + 1
                        i = i + 1
                    if i >= n:
                        die("interp: unterminated string in an f-string hole")
                    i = i + 1
                elif ch == 123:
                    depth = depth + 1
                    i = i + 1
                elif ch == 125:
                    depth = depth - 1
                    if depth > 0:
                        i = i + 1
                else:
                    i = i + 1
            if depth > 0:
                die("interp: unterminated { in an f-string")
            esub := substr(s, estart, i)
            i = i + 1                                          # consume }
            if len(esub) == 0:
                die("interp: empty {} in an f-string")
            etoks := lex(esub)
            ep := 0
            ex := parse_expr(etoks, &ep)
            args := []Expr
            push(args, ex)
            push(pieces, ECall("str", args, _el))
        else:
            buf = buf + chr(c)
            i = i + 1
    if len(buf) > 0:
        push(pieces, EStr(buf, _el))
    if len(pieces) == 0:
        return EStr("", _el)
    acc := pieces[0]
    j := 1
    for j < len(pieces):
        acc = EBin("+", acc, pieces[j], _el)
        j = j + 1
    return acc

# Parser context threaded through the expression chain. Carries the current
# expression-nesting depth so parse_atom_d can bound recursion (H2).
struct Pctx:
    depth: int

fn parse_atom_d(toks: [Token], pos: inout int, pc: Pctx) -> Expr:
    _el := tloc(toks[pos])
    # H2: every expression-nesting level (parens, unary, call args, array/map
    # elements, index/slice) passes through parse_atom, so bounding depth here
    # caps total parser recursion -- a crafted deeply-nested expression reports
    # an error instead of overflowing the stack (SIGSEGV). `nd` is the depth
    # handed to any sub-expression this atom parses. Mirrors tychoc's guard.
    if pc.depth > 256:
        die("parse: line " + str(toks[pos].line) + ": expression nesting too deep")
    nd := Pctx(pc.depth + 1)
    t := toks[pos]
    if t.kind == TStr:
        pos = pos + 1
        return EStr(t.text, _el)
    elif t.kind == TFStr:                        # f"a{e}b" -> ("a" + str(e) + "b")
        pos = pos + 1
        return desugar_interp(t.text)
    elif t.kind == TMinus:                       # unary minus -E: marker op (operand in L); the
        pos = pos + 1                            # strict int/float check + the (0 - E) emit live in
        return EBin("u-", parse_atom_d(toks, &pos, nd), EInt("0", _el), _el)   # codegen, so `-char` etc. reject like tychoc
    elif t.kind == TTilde:                        # unary bitwise NOT ~E: marker op; codegen checks the
        pos = pos + 1                            # operand is EXACTLY int and emits ((0 - E) - 1). Was
        return EBin("u~", parse_atom_d(toks, &pos, nd), EInt("0", _el), _el)   # desugared here, which over-accepted ~float/~char
    elif t.kind == TAmp:                         # &place : pass to a inout param
        pos = pos + 1
        return EAddr(parse_postfix_d(toks, &pos, nd), _el)
    elif t.kind == TInt:
        pos = pos + 1
        return EInt(t.text, _el)
    elif t.kind == TChar:
        pos = pos + 1
        return EChar(t.text, _el)
    elif t.kind == TFloat:
        pos = pos + 1
        return EFloat(t.text, _el)
    elif t.kind == TIdent:
        name := t.text
        pos = pos + 1
        if name == "fn" and toks[pos].kind == TLParen:   # lambda literal `fn(p: T, ...) [-> R]: expr`
            return parse_lambda(toks, &pos, nd)
        if name == "soa":                        # soa []Struct : empty SOA literal
            expect(toks, &pos, TLBracket)
            expect(toks, &pos, TRBracket)
            st := parse_type(toks, &pos)
            return EArrEmpty("soa[" + st + "]", _el)
        if name == "spawn":                      # spawn f(args): run the call on a new thread (CC-1)
            sp := parse_postfix_d(toks, &pos, nd)
            match sp:
                ECall(sn, sa, _el):
                    return ESpawn(0, sn, sa, _el)     # site id assigned by the lift pass
                EInt(t, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EBool(t, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EChar(t, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EFloat(t, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EStr(t, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EVar(t, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EBin(o, l, r, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EField(b, f, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EIndex(b, ix, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EArrLit(es, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EArrEmpty(t, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EMapEmpty(k, mv, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EMapLit(ks, vs, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                ETuple(es, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                ESlice(b, lo, hi, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EAddr(x, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                ELambda(lid, ps, pts, ret, bx, cn, ct, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                ECallV(c, a, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                ESpawn(sid, sn2, sa2, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
            return EInt("0", _el)
        if name == "channel" and toks[pos].kind == TLParen:   # channel(T, cap) (CC-4); the type rides the name
            pos = pos + 1
            chty := parse_type(toks, &pos)
            expect(toks, &pos, TComma)
            chargs := []Expr
            push(chargs, parse_expr_d(toks, &pos, nd))
            expect(toks, &pos, TRParen)
            return ECall("channel:" + chty, chargs, _el)
        if name == "true":
            return EBool("1", _el)
        if name == "false":
            return EBool("0", _el)
        if name == "null":                       # FFI opaque ptr literal -> a 0-arg builtin call
            return ECall("null", []Expr, _el)
        if toks[pos].kind == TDot and toks[pos + 1].kind == TIdent and toks[pos + 2].kind == TLParen:
            qn := name + "." + toks[pos + 1].text     # qualified call pkg.name(args); resolved by the mangler
            pos = pos + 3
            qargs := []Expr
            if toks[pos].kind != TRParen:
                push(qargs, parse_expr_d(toks, &pos, nd))
                for toks[pos].kind == TComma:
                    pos = pos + 1
                    push(qargs, parse_expr_d(toks, &pos, nd))
            expect(toks, &pos, TRParen)
            return ECall(qn, qargs, _el)
        if toks[pos].kind == TDollar:            # generics: explicit type args -- name$(T1, ...) [ (value args) ]
            pos = pos + 1
            expect(toks, &pos, TLParen)
            tas := []string
            if toks[pos].kind != TRParen:
                push(tas, parse_type(toks, &pos))
                for toks[pos].kind == TComma:
                    pos = pos + 1
                    push(tas, parse_type(toks, &pos))
            expect(toks, &pos, TRParen)
            if len(tas) == 0:
                die("parse: line " + str(_el) + ": '" + name + "$()' needs at least one explicit type argument")
            ta := ""
            ti := 0
            for ti < len(tas):
                if ti > 0:
                    ta = ta + ";"                # ';' never appears in a type string (tuples use ',')
                ta = ta + tas[ti]
                ti = ti + 1
            enc := name + "$<" + ta + ">"
            eargs := []Expr
            if toks[pos].kind == TLParen:        # the value-arg list is optional (absent => no value args)
                pos = pos + 1
                if toks[pos].kind != TRParen:
                    push(eargs, parse_expr_d(toks, &pos, nd))
                    for toks[pos].kind == TComma:
                        pos = pos + 1
                        push(eargs, parse_expr_d(toks, &pos, nd))
                expect(toks, &pos, TRParen)
            return ECall(enc, eargs, _el)
        if toks[pos].kind == TLParen:
            if name == "map_set":          # B5: removed -> reject user calls (the delete desugar builds map_del directly)
                die("parse: map_set was removed; use m[k] = v")
            if name == "map_has":
                die("parse: map_has was removed; use k in m")
            if name == "map_del":
                die("parse: map_del was removed; use delete m[k]")
            if name == "map_get":
                die("parse: map_get was removed; use m.get(k, default)")
            pos = pos + 1
            args := []Expr
            if toks[pos].kind != TRParen:
                push(args, parse_expr_d(toks, &pos, nd))
                for toks[pos].kind == TComma:
                    pos = pos + 1
                    push(args, parse_expr_d(toks, &pos, nd))
            expect(toks, &pos, TRParen)
            return ECall(name, args, _el)
        return EVar(name, _el)
    elif t.kind == TLParen:
        pos = pos + 1
        e := parse_expr_d(toks, &pos, nd)
        if toks[pos].kind == TComma:             # tuple literal (a, b, ...)
            elems := []Expr
            push(elems, e)
            for toks[pos].kind == TComma:
                pos = pos + 1
                push(elems, parse_expr_d(toks, &pos, nd))
            expect(toks, &pos, TRParen)
            return ETuple(elems, _el)
        expect(toks, &pos, TRParen)
        return e
    elif t.kind == TLBracket:
        pos = pos + 1
        if toks[pos].kind == TRBracket:          # []T : empty array  /  []K: V : empty map  /  bare []
            pos = pos + 1
            # B-0 (bidirectional inference): `[]` not followed by a type-starter token
            # is a bare empty literal, grounded from the destination type by the
            # pre-lift checking pass (ground_pre) at every supplying position.
            if toks[pos].kind != TIdent and toks[pos].kind != TLBracket and toks[pos].kind != TLParen:
                return EArrEmpty("", _el)
            kty := parse_type(toks, &pos)
            if toks[pos].kind == TColon:
                pos = pos + 1
                vty := parse_type(toks, &pos)
                return EMapEmpty(kty, vty, _el)
            return EArrEmpty(kty, _el)
        first := parse_expr_d(toks, &pos, nd)
        if toks[pos].kind == TColon:             # [k0: v0, k1: v1] : map literal
            keys := []Expr
            vals := []Expr
            pos = pos + 1
            push(keys, first)
            push(vals, parse_expr_d(toks, &pos, nd))
            for toks[pos].kind == TComma:
                pos = pos + 1
                push(keys, parse_expr_d(toks, &pos, nd))
                expect(toks, &pos, TColon)
                push(vals, parse_expr_d(toks, &pos, nd))
            expect(toks, &pos, TRBracket)
            return EMapLit(keys, vals, _el)
        elems := []Expr                          # [e0, e1, ...] : array literal
        push(elems, first)
        for toks[pos].kind == TComma:
            pos = pos + 1
            push(elems, parse_expr_d(toks, &pos, nd))
        expect(toks, &pos, TRBracket)
        return EArrLit(elems, _el)
    else:
        die("parse: line " + str(toks[pos].line) + ": expected an atom")
        return EInt("0", _el)

fn parse_postfix_d(toks: [Token], pos: inout int, pc: Pctx) -> Expr:
    _el := tloc(toks[pos])
    e := parse_atom_d(toks, &pos, pc)
    d := pc.depth                                # each postfix step (.field / [idx] / (call)) wraps `e`, deepening + deep-copying the tree
    for toks[pos].kind == TDot or toks[pos].kind == TLBracket or toks[pos].kind == TLParen:
        d = d + 1
        if d > 2000:
            die("parse: line " + str(toks[pos].line) + ": expression nesting too deep")
        if toks[pos].kind == TLParen:            # call-on-expression: <expr>(args) -- indirect call on a fn value
            pos = pos + 1
            cargs := []Expr
            if toks[pos].kind != TRParen:
                push(cargs, parse_expr_d(toks, &pos, pc))
                for toks[pos].kind == TComma:
                    pos = pos + 1
                    push(cargs, parse_expr_d(toks, &pos, pc))
            expect(toks, &pos, TRParen)
            e = ECallV(e, cargs, _el)
        elif toks[pos].kind == TDot:             # field access: a.b  /  tuple index: a.0
            pos = pos + 1
            if toks[pos].kind != TIdent and toks[pos].kind != TInt:
                die("parse: line " + str(toks[pos].line) + ": expected a field name or index after '.'")
            e = EField(e, toks[pos].text, _el)
            pos = pos + 1
        else:                                    # index a[i]  or  slice a[lo:hi]
            pos = pos + 1
            lenargs := []Expr
            push(lenargs, e)
            if toks[pos].kind == TColon:         # a[:hi] / a[:]
                pos = pos + 1
                hi := ECall("len", lenargs, _el)
                if toks[pos].kind != TRBracket:
                    hi = parse_expr_d(toks, &pos, pc)
                expect(toks, &pos, TRBracket)
                e = ESlice(e, EInt("0", _el), hi, _el)
            else:
                idx := parse_expr_d(toks, &pos, pc)
                if toks[pos].kind == TColon:     # a[lo:hi] / a[lo:]
                    pos = pos + 1
                    hi := ECall("len", lenargs, _el)
                    if toks[pos].kind != TRBracket:
                        hi = parse_expr_d(toks, &pos, pc)
                    expect(toks, &pos, TRBracket)
                    e = ESlice(e, idx, hi, _el)
                else:
                    expect(toks, &pos, TRBracket)
                    e = EIndex(e, idx, _el)
    return e

fn parse_mul_d(toks: [Token], pos: inout int, pc: Pctx) -> Expr:
    _el := tloc(toks[pos])
    l := parse_postfix_d(toks, &pos, pc)
    d := pc.depth                                # each chain step deepens the left-spine tree (value-semantics deep-copies `l`)
    for toks[pos].kind == TStar or toks[pos].kind == TSlash or toks[pos].kind == TPercent or toks[pos].kind == TShl or toks[pos].kind == TShr or toks[pos].kind == TAmp:
        d = d + 1
        if d > 2000:
            die("parse: line " + str(toks[pos].line) + ": expression nesting too deep")
        op := toks[pos].text
        pos = pos + 1
        r := parse_postfix_d(toks, &pos, pc)
        l = EBin(op, l, r, _el)
    return l

fn parse_add_d(toks: [Token], pos: inout int, pc: Pctx) -> Expr:
    _el := tloc(toks[pos])
    l := parse_mul_d(toks, &pos, pc)
    d := pc.depth                                # each chain step deepens the left-spine tree (value-semantics deep-copies `l`)
    for toks[pos].kind == TPlus or toks[pos].kind == TMinus or toks[pos].kind == TPipe or toks[pos].kind == TCaret:
        d = d + 1
        if d > 2000:
            die("parse: line " + str(toks[pos].line) + ": expression nesting too deep")
        op := toks[pos].text
        pos = pos + 1
        r := parse_mul_d(toks, &pos, pc)
        l = EBin(op, l, r, _el)
    return l

fn parse_cmp_d(toks: [Token], pos: inout int, pc: Pctx) -> Expr:
    _el := tloc(toks[pos])
    l := parse_add_d(toks, &pos, pc)
    k := toks[pos].kind
    if k == TEqEq or k == TLt or k == TGt or k == TLe or k == TGe or k == TNe or (k == TIdent and toks[pos].text == "in"):
        op := toks[pos].text
        pos = pos + 1
        r := parse_add_d(toks, &pos, pc)
        return EBin(op, l, r, _el)
    return l

fn parse_not_d(toks: [Token], pos: inout int, pc: Pctx) -> Expr:
    _el := tloc(toks[pos])
    if toks[pos].kind == TIdent and toks[pos].text == "not":
        if pc.depth > 256:                       # H2: a `not not not ...` chain recurses parse_not_d -- cap it like parens/unary
            die("parse: line " + str(toks[pos].line) + ": expression nesting too deep")
        pos = pos + 1
        return EBin("not", parse_not_d(toks, &pos, Pctx(pc.depth + 1)), EInt("0", _el), _el)   # logical not; operand must be bool (validated in codegen). rhs is an unused placeholder
    return parse_cmp_d(toks, &pos, pc)

fn parse_and_d(toks: [Token], pos: inout int, pc: Pctx) -> Expr:
    _el := tloc(toks[pos])
    l := parse_not_d(toks, &pos, pc)
    d := pc.depth                                # each `and` step deepens the left-spine tree (value-semantics deep-copies `l`)
    for toks[pos].kind == TIdent and toks[pos].text == "and":
        d = d + 1
        if d > 2000:
            die("parse: line " + str(toks[pos].line) + ": expression nesting too deep")
        pos = pos + 1
        r := parse_not_d(toks, &pos, pc)
        l = EBin("&&", l, r, _el)
    return l

fn parse_expr_d(toks: [Token], pos: inout int, pc: Pctx) -> Expr:
    _el := tloc(toks[pos])
    l := parse_and_d(toks, &pos, pc)
    d := pc.depth                                # each `or` step deepens the left-spine tree (value-semantics deep-copies `l`)
    for toks[pos].kind == TIdent and toks[pos].text == "or":
        d = d + 1
        if d > 2000:
            die("parse: line " + str(toks[pos].line) + ": expression nesting too deep")
        pos = pos + 1
        r := parse_and_d(toks, &pos, pc)
        l = EBin("||", l, r, _el)
    return l

# Public entry point: starts a fresh nesting-depth context. H2 (parser
# recursion bound) is enforced in parse_atom_d via the threaded Pctx.
fn parse_expr(toks: [Token], pos: inout int) -> Expr:
    return parse_expr_d(toks, &pos, Pctx(0))

# `for x in COLL:` desugars to a collection-temp decl plus a range loop over its
# indices, pushed as TWO statements (Tycho has no globals for a prelude queue, so
# the block builder calls this directly). COLL is bound to a temp so it is
# evaluated exactly once; the element read `x := _fc[_fi]` reuses array/string
# indexing. The temp id is the `for` token position -- unique per occurrence.
fn parse_foreach(toks: [Token], pos: inout int, out: inout [Stmt]):
    _el := tloc(toks[pos])
    _sl := tloc(toks[pos])
    uid := str(pos)
    pos = pos + 1                            # 'for'
    varname := toks[pos].text
    pos = pos + 1
    expect_ident(toks, &pos, "in")
    coll := parse_expr(toks, &pos)
    expect(toks, &pos, TColon)
    body := parse_block(toks, &pos)
    cn := "_fc" + uid
    iv := "_fi" + uid
    largs := []Expr
    push(largs, EVar(cn, _el))                    # len(_fc)
    fbody := []Stmt
    push(fbody, SDecl(varname, EIndex(EVar(cn, _el), EVar(iv, _el), _el), _sl))   # x := _fc[_fi]
    k := 0
    for k < len(body):
        push(fbody, body[k])
        k = k + 1
    push(out, SDecl(cn, coll, _sl))                                # _fc := COLL  (the prelude)
    push(out, SForRange(iv, EInt("0", _el), ECall("len", largs, _el), EInt("1", _el), fbody, _sl))

fn parse_block(toks: [Token], pos: inout int) -> [Stmt]:
    stmts := []Stmt
    open_block(toks, &pos)
    for toks[pos].kind != TDedent:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        else:
            # foreach `for x in <non-range>:` -> handled here so it can push the
            # collection-temp decl ahead of the loop; everything else is one stmt.
            isfe := false
            if toks[pos].kind == TIdent and toks[pos].text == "for" and pos + 4 < len(toks):
                if toks[pos + 1].kind == TIdent and toks[pos + 2].kind == TIdent and toks[pos + 2].text == "in":
                    if not (toks[pos + 3].kind == TIdent and toks[pos + 3].text == "range" and toks[pos + 4].kind == TLParen):
                        isfe = true
            if isfe:
                parse_foreach(toks, &pos, &stmts)
            else:
                firstkw := ""                        # the stmt's leading keyword (compound stmts self-terminate via their block)
                if toks[pos].kind == TIdent:
                    firstkw = toks[pos].text
                pend := []Stmt                       # preludes (e.g. hoisted index temps)
                st := parse_stmt(toks, &pos, &pend)
                pj := 0
                for pj < len(pend):
                    push(stmts, pend[pj])
                    pj = pj + 1
                push(stmts, st)
                # fail-closed: a SIMPLE statement must end at a newline; without this
                # two statements on one line (`print(x)  continue`) were silently
                # accepted. Compound stmts (if/for/while/match/select/parallel-for)
                # end at their block's dedent, so the next token is the following
                # stmt -- exempt them (keyed on the leading keyword).
                cmpd := firstkw == "if" or firstkw == "for" or firstkw == "while" or firstkw == "match" or firstkw == "select" or firstkw == "parallel" or stmt_self_terminates(st)
                if not cmpd and toks[pos].kind != TNewline and toks[pos].kind != TDedent:
                    die("parse: line " + str(toks[pos].line) + ": expected newline")
            if toks[pos].kind == TNewline:
                pos = pos + 1
    pos = pos + 1
    return stmts

fn parse_else(toks: [Token], pos: inout int) -> [Stmt]:
    _sl := tloc(toks[pos])
    t := toks[pos]
    if t.kind == TIdent and t.text == "elif":
        pos = pos + 1
        cond := parse_expr(toks, &pos)
        expect(toks, &pos, TColon)
        then_body := parse_block(toks, &pos)
        rest := parse_else(toks, &pos)
        inner := []Stmt
        push(inner, SIf(cond, then_body, rest, _sl))
        return inner
    elif t.kind == TIdent and t.text == "else":
        pos = pos + 1
        expect(toks, &pos, TColon)
        return parse_block(toks, &pos)
    else:
        return []Stmt

# the binary-operator token kinds that have a compound-assignment form `x OP= e`
# (detected as the operator token followed by `=`, so no dedicated token needed).
fn is_caop_kind(k: Tok) -> bool:
    return k == TPlus or k == TMinus or k == TStar or k == TSlash or k == TPercent or k == TAmp or k == TPipe or k == TCaret or k == TShl or k == TShr

fn parse_stmt(toks: [Token], pos: inout int, pending: inout [Stmt]) -> Stmt:
    _el := tloc(toks[pos])
    _sl := tloc(toks[pos])
    t := toks[pos]
    if t.kind == TIdent and t.text == "print":
        pos = pos + 1
        expect(toks, &pos, TLParen)
        e := parse_expr(toks, &pos)
        expect(toks, &pos, TRParen)
        return SPrint(e, _sl)
    elif t.kind == TIdent and t.text == "const" and toks[pos + 1].kind == TIdent:   # `const NAME = <literal>` local (folded at each use; contextual keyword)
        pos = pos + 1
        cname := toks[pos].text
        pos = pos + 1
        expect(toks, &pos, TEq)
        noc := []string
        noe := []Expr
        clit := const_fold(parse_expr(toks, &pos), noc, noe, "")   # local: literals + int arithmetic, no sibling-const refs
        if not is_lit(clit):
            die("parse: const value must be a literal")
        return SConst(cname, clit, _sl)
    elif t.kind == TIdent and t.text == "delete" and toks[pos + 1].kind == TIdent:   # `delete PLACE[k]` -> PLACE = map_del(PLACE, k)
        pos = pos + 1
        name := toks[pos].text
        pos = pos + 1
        dkinds := []int                       # the place steps after the head ident: 0 = field, 1 = index
        dflds := []string
        didxs := []Expr
        for toks[pos].kind == TDot or toks[pos].kind == TLBracket:
            if toks[pos].kind == TDot:
                pos = pos + 1
                push(dkinds, 0)
                push(dflds, toks[pos].text)
                push(didxs, EInt("0", _el))
                pos = pos + 1
            else:
                pos = pos + 1
                push(dkinds, 1)
                push(dflds, "")
                push(didxs, parse_expr(toks, &pos))
                expect(toks, &pos, TRBracket)
        nstep := len(dkinds)
        if nstep == 0 or dkinds[nstep - 1] != 1:
            die("parse: line " + str(t.line) + ": delete removes a map element: delete m[k]")
        key := didxs[nstep - 1]               # the last [..] is the key; the map place is everything before it
        lv := EVar(name, _el)
        j := 0
        for j < nstep - 1:
            if dkinds[j] == 0:
                lv = EField(lv, dflds[j], _el)
            else:
                lv = EIndex(lv, didxs[j], _el)
            j = j + 1
        call := ECall("map_del", [lv, key], _el)
        if nstep == 1:                        # bare `delete m[k]` -> SAssign (keeps tychoc's in-place rewrite path)
            return SAssign(name, call, _sl)
        return SFieldAssign(lv, call, _sl)
    elif t.kind == TIdent and t.text == "println":   # desugar: println(x)
        pos = pos + 1
        expect(toks, &pos, TLParen)
        e := parse_expr(toks, &pos)
        expect(toks, &pos, TRParen)
        return SPrint(EBin("+", e, EStr("\\n", _el), _el), _sl)
    elif t.kind == TIdent and t.text == "return":
        pos = pos + 1
        if is_value_ctrl_kw(toks[pos]):          # `return if.../match...`: each tail becomes its own return
            return ctrl_rewrite_tails(parse_value_ctrl(toks, &pos), 0, "", EInt("0", _el))
        if toks[pos].kind == TNewline:           # bare `return` (void)
            return SReturnVoid
        re := parse_expr(toks, &pos)
        if toks[pos].kind == TComma:             # `return a, b` builds a tuple
            elems := []Expr
            push(elems, re)
            for toks[pos].kind == TComma:
                pos = pos + 1
                push(elems, parse_expr(toks, &pos))
            return SReturn(ETuple(elems, _el), _sl)
        return SReturn(re, _sl)
    elif t.kind == TIdent and t.text == "if":
        pos = pos + 1
        cond := parse_expr(toks, &pos)
        expect(toks, &pos, TColon)
        then_body := parse_block(toks, &pos)
        else_body := parse_else(toks, &pos)
        return SIf(cond, then_body, else_body, _sl)
    elif t.kind == TIdent and t.text == "select":   # select over channels (CC-5)
        suid := str(pos)
        pos = pos + 1
        expect(toks, &pos, TColon)
        expect(toks, &pos, TNewline)
        expect(toks, &pos, TIndent)
        svars := []string
        schans := []Expr
        sbinds := []string
        sbodies := [][Stmt]
        for toks[pos].kind != TDedent:
            if toks[pos].kind == TNewline:
                pos = pos + 1
            else:
                if toks[pos].kind != TIdent:
                    die("parse: line " + str(toks[pos].line) + ": a select arm is `recv(ch, x):`, `default:`, or `closed:`")
                av := toks[pos].text
                pos = pos + 1
                ach := EInt("0", _el)
                abind := ""
                if av == "recv":
                    expect(toks, &pos, TLParen)
                    ach = parse_expr(toks, &pos)
                    expect(toks, &pos, TComma)
                    abind = toks[pos].text
                    pos = pos + 1
                    expect(toks, &pos, TRParen)
                elif av != "default" and av != "closed":
                    die("parse: line " + str(toks[pos].line) + ": a select arm is `recv(ch, x):`, `default:`, or `closed:`")
                expect(toks, &pos, TColon)
                push(svars, av)
                push(schans, ach)
                push(sbinds, abind)
                push(sbodies, parse_block(toks, &pos))
        pos = pos + 1
        return SSelect(suid, svars, schans, sbinds, sbodies, _sl)
    elif t.kind == TIdent and t.text == "parallel":   # parallel for ... (CC-3)
        pos = pos + 1
        if not (toks[pos].kind == TIdent and toks[pos].text == "for"):
            die("parse: line " + str(toks[pos].line) + ": expected 'for' after 'parallel'")
        pos = pos + 1
        if toks[pos].kind == TIdent and toks[pos + 1].kind == TIdent and toks[pos + 1].text == "in":
            pvar := toks[pos].text
            pos = pos + 1
            expect_ident(toks, &pos, "in")
            if toks[pos].kind == TIdent and toks[pos].text == "range" and toks[pos + 1].kind == TLParen:
                pos = pos + 1
                expect(toks, &pos, TLParen)
                pa1 := parse_expr(toks, &pos)
                pstart := EInt("0", _el)
                pstop := pa1
                if toks[pos].kind == TComma:
                    pos = pos + 1
                    pstart = pa1
                    pstop = parse_expr(toks, &pos)
                    if toks[pos].kind == TComma:
                        die("parse: line " + str(toks[pos].line) + ": parallel for does not support a range step")
                expect(toks, &pos, TRParen)
                expect(toks, &pos, TColon)
                pbody := parse_block(toks, &pos)
                return SParFor(pvar, pstart, pstop, pbody, 0 - 1, _sl)
            # foreach form: `parallel for x in EXPR:` — defer the array-vs-channel
            # choice to the lift pass (types are needed and unknown here). EXPR must
            # name a variable; the lift pass type-branches it (sentinel par-id -2).
            # No `_fc` temp: a channel cannot be aliased into one, and an identifier
            # source is re-eval-free.
            pcoll := parse_expr(toks, &pos)
            expect(toks, &pos, TColon)
            pubody := parse_block(toks, &pos)
            if evar_name(pcoll) == "":
                die("parse: line " + str(t.line) + ": parallel for over a collection or channel must name a variable")
            return SParFor(pvar, pcoll, EInt("0", _el), pubody, 0 - 2, _sl)
        die("parse: line " + str(t.line) + ": parallel supports 'for x in range(...)' and 'for x in collection' loops")
        return SBreak
    elif t.kind == TIdent and t.text == "for":
        pos = pos + 1
        if toks[pos].kind == TIdent and toks[pos + 1].kind == TIdent and toks[pos + 1].text == "in":
            varname := toks[pos].text       # counting form: for i in range(...)
            pos = pos + 1
            expect_ident(toks, &pos, "in")
            expect_ident(toks, &pos, "range")
            expect(toks, &pos, TLParen)
            a1 := parse_expr(toks, &pos)
            start := EInt("0", _el)              # range(n): 0..n
            stop := a1
            step := EInt("1", _el)
            if toks[pos].kind == TComma:    # range(a, b[, c])
                pos = pos + 1
                start = a1
                stop = parse_expr(toks, &pos)
                if toks[pos].kind == TComma:
                    pos = pos + 1
                    step = parse_expr(toks, &pos)
            expect(toks, &pos, TRParen)
            expect(toks, &pos, TColon)
            body := parse_block(toks, &pos)
            return SForRange(varname, start, stop, step, body, _sl)
        cond := parse_expr(toks, &pos)      # condition form: for COND:
        expect(toks, &pos, TColon)
        body := parse_block(toks, &pos)
        return SWhile(cond, body, _sl)
    elif t.kind == TIdent and t.text == "match":
        return parse_match(toks, &pos, false)
    elif t.kind == TIdent and t.text == "break":
        pos = pos + 1
        return SBreak
    elif t.kind == TIdent and t.text == "continue":
        pos = pos + 1
        return SContinue
    elif t.kind == TIdent:
        name := t.text
        pos = pos + 1
        if toks[pos].kind == TComma:             # destructure: a, b := tuple_expr
            names := []string
            push(names, name)
            for toks[pos].kind == TComma:
                pos = pos + 1
                if toks[pos].kind != TIdent:
                    die("parse: line " + str(toks[pos].line) + ": expected a name in destructure")
                push(names, toks[pos].text)
                pos = pos + 1
            if toks[pos].kind == TWalrus:        # `:=` declares new vars
                pos = pos + 1
                return SDestructure(names, parse_expr(toks, &pos), _sl)
            expect(toks, &pos, TEq)              # `=` assigns existing vars
            return SMultiAssign(names, parse_expr(toks, &pos), _sl)
        if toks[pos].kind == TWalrus:
            pos = pos + 1
            if is_value_ctrl_kw(toks[pos]):      # `x := if.../match...`: infer type + assign in gen
                return SValDecl(name, "", parse_value_ctrl(toks, &pos), _sl)
            rhs := parse_expr(toks, &pos)
            if toks[pos].kind == TIdent and toks[pos].text == "or_return":
                pos = pos + 1
                return SOrReturn(name, rhs, _sl)
            return SDecl(name, rhs, _sl)
        elif toks[pos].kind == TColon:           # `name : Type = expr` typed decl
            pos = pos + 1
            ty := parse_type(toks, &pos)
            expect(toks, &pos, TEq)
            if is_value_ctrl_kw(toks[pos]):      # `x : T = if.../match...`
                return SValDecl(name, ty, parse_value_ctrl(toks, &pos), _sl)
            return STypedDecl(name, ty, parse_expr(toks, &pos), _sl)
        elif toks[pos].kind == TEq:
            pos = pos + 1
            if is_value_ctrl_kw(toks[pos]):      # `x = if.../match...`: each tail becomes `x = tail`
                return ctrl_rewrite_tails(parse_value_ctrl(toks, &pos), 1, name, EInt("0", _el))
            return SAssign(name, parse_expr(toks, &pos), _sl)
        elif is_caop_kind(toks[pos].kind) and toks[pos + 1].kind == TEq:   # x OP= rhs -> x = x OP rhs
            op := toks[pos].text
            pos = pos + 1
            expect(toks, &pos, TEq)
            return SAssign(name, EBin(op, EVar(name, _el), parse_expr(toks, &pos), _el), _sl)
        elif toks[pos].kind == TDot or toks[pos].kind == TLBracket:
            # qualified/method call in STATEMENT position: `name.fn(args)` -> a single
            # ECall("name.fn", ...), exactly as parse_atom builds it in expression
            # position (the mangler resolves package call / UFCS / conc method). Without
            # this, a bare `pkg.fn(args)` statement parsed as ECallV(EField(EVar(pkg)..))
            # and the resolver saw `pkg` as an unknown variable (tychoc accepted it).
            if toks[pos].kind == TDot and toks[pos + 1].kind == TIdent and toks[pos + 2].kind == TLParen:
                qn := name + "." + toks[pos + 1].text
                pos = pos + 3
                qargs := []Expr
                if toks[pos].kind != TRParen:
                    push(qargs, parse_expr(toks, &pos))
                    for toks[pos].kind == TComma:
                        pos = pos + 1
                        push(qargs, parse_expr(toks, &pos))
                expect(toks, &pos, TRParen)
                return SExpr(ECall(qn, qargs, _el), _sl)
            # collect the place steps first (a.b[i].c ...) so that, for a compound
            # assignment, a call-bearing index can be hoisted to a temp -- the place
            # is evaluated twice (read + store), and a side-effecting index must run
            # once. Plain assignment and pure indices are unchanged.
            pkinds := []int                      # 0 = field, 1 = index
            pflds := []string
            pidxs := []Expr
            for toks[pos].kind == TDot or toks[pos].kind == TLBracket:
                if toks[pos].kind == TDot:
                    pos = pos + 1
                    if toks[pos].kind != TIdent and toks[pos].kind != TInt:
                        die("parse: line " + str(toks[pos].line) + ": expected a field name or tuple index after '.'")
                    push(pkinds, 0)
                    push(pflds, toks[pos].text)   # TInt -> tuple element place (t.0 = v)
                    push(pidxs, EInt("0", _el))        # placeholder; unused for a field step
                    pos = pos + 1
                    if toks[pos].kind == TLParen:   # method-call STATEMENT (ch.send(v), t.wait(), x.foo(a)):
                        mb := EVar(name, _el)            # rebuild the receiver from the steps before the method name
                        mj := 0
                        for mj < len(pkinds) - 1:
                            if pkinds[mj] == 0:
                                mb = EField(mb, pflds[mj], _el)
                            else:
                                mb = EIndex(mb, pidxs[mj], _el)
                            mj = mj + 1
                        pos = pos + 1
                        margs := []Expr
                        if toks[pos].kind != TRParen:
                            push(margs, parse_expr(toks, &pos))
                            for toks[pos].kind == TComma:
                                pos = pos + 1
                                push(margs, parse_expr(toks, &pos))
                        expect(toks, &pos, TRParen)
                        return SExpr(ECallV(EField(mb, pflds[len(pflds) - 1], _el), margs, _el), _sl)
                else:
                    pos = pos + 1
                    push(pkinds, 1)
                    push(pflds, "")
                    push(pidxs, parse_expr(toks, &pos))
                    expect(toks, &pos, TRBracket)
            nst := len(pkinds)               # reject index-assign THROUGH a tuple element (`t.0[k] = v`): mirrors tychoc, which forbids indexing a tuple-element place. A tuple index is a `.N` field (numeric — struct field names can't start with a digit).
            if nst > 0 and pkinds[nst - 1] == 1:
                tj := 0
                for tj < nst - 1:
                    if pkinds[tj] == 0 and len(pflds[tj]) > 0 and is_digit(pflds[tj][0]):
                        die("parse: line " + str(toks[pos].line) + ": can only index-assign an array or map variable or field")
                    tj = tj + 1
            iscomp := is_caop_kind(toks[pos].kind) and toks[pos + 1].kind == TEq
            lv := EVar(name, _el)
            ci := 0
            j := 0
            for j < len(pkinds):
                if pkinds[j] == 0:
                    lv = EField(lv, pflds[j], _el)
                else:
                    ix := pidxs[j]
                    if iscomp and expr_has_call(ix):   # bind a side-effecting index once
                        tn := "_cx" + str(pos) + "_" + str(ci)
                        ci = ci + 1
                        push(pending, SDecl(tn, ix, _sl))
                        ix = EVar(tn, _el)
                    lv = EIndex(lv, ix, _el)
                j = j + 1
            if iscomp:                           # lv OP= rhs -> lv = lv OP rhs
                op := toks[pos].text
                pos = pos + 1
                expect(toks, &pos, TEq)
                return SFieldAssign(lv, EBin(op, lv, parse_expr(toks, &pos), _el), _sl)
            expect(toks, &pos, TEq)
            if is_value_ctrl_kw(toks[pos]):      # `place = if.../match...`: each tail becomes `place = tail`
                return ctrl_rewrite_tails(parse_value_ctrl(toks, &pos), 2, "", lv)
            return SFieldAssign(lv, parse_expr(toks, &pos), _sl)
        elif toks[pos].kind == TLParen:          # bare call statement: f(args)
            if name == "map_set":          # B5: removed -> reject (the parse_atom copy covers the expression form)
                die("parse: map_set was removed; use m[k] = v")
            if name == "map_has":
                die("parse: map_has was removed; use k in m")
            if name == "map_del":
                die("parse: map_del was removed; use delete m[k]")
            if name == "map_get":
                die("parse: map_get was removed; use m.get(k, default)")
            pos = pos + 1
            args := []Expr
            if toks[pos].kind != TRParen:
                push(args, parse_expr(toks, &pos))
                for toks[pos].kind == TComma:
                    pos = pos + 1
                    push(args, parse_expr(toks, &pos))
            expect(toks, &pos, TRParen)
            return SExpr(ECall(name, args, _el), _sl)
        else:
            die("parse: line " + str(toks[pos].line) + ": expected ':=', '=', or '('")
            return SReturn(EInt("0", _el), _sl)
    else:
        die("parse: line " + str(toks[pos].line) + ": expected a statement")
        return SReturn(EInt("0", _el), _sl)

fn parse_type_d(toks: [Token], pos: inout int, depth: int) -> string:
    # H2 (type vector): bound nested-type recursion ([[[[...]]]], tuples,
    # generics) so a crafted deeply-nested type can't overflow the stack.
    if depth > 256:
        die("parse: line " + str(toks[pos].line) + ": type nesting too deep")
    if toks[pos].kind == TDollar:                # generics: `$T` introduces a type parameter
        pos = pos + 1
        if toks[pos].kind != TIdent:
            die("parse: line " + str(toks[pos].line) + ": expected a type-parameter name after '$'")
        nm := toks[pos].text
        pos = pos + 1
        return "$" + nm
    if toks[pos].kind == TLParen:                # tuple type (T, U, ...)
        pos = pos + 1
        parts := []string
        push(parts, parse_type_d(toks, &pos, depth + 1))
        for toks[pos].kind == TComma:
            pos = pos + 1
            push(parts, parse_type_d(toks, &pos, depth + 1))
        expect(toks, &pos, TRParen)
        out := "("
        i := 0
        for i < len(parts):
            if i > 0:
                out = out + ","
            out = out + parts[i]
            i = i + 1
        return out + ")"
    if toks[pos].kind == TLBracket:              # [T] array  or  [K: V] map
        pos = pos + 1
        inner := parse_type_d(toks, &pos, depth + 1)
        if toks[pos].kind == TColon:
            pos = pos + 1
            v := parse_type_d(toks, &pos, depth + 1)
            expect(toks, &pos, TRBracket)
            return "{" + inner + ":" + v + "}"
        expect(toks, &pos, TRBracket)
        return "[" + inner + "]"
    if toks[pos].kind == TIdent and toks[pos].text == "soa":   # soa [Struct]
        pos = pos + 1
        expect(toks, &pos, TLBracket)
        st := parse_type_d(toks, &pos, depth + 1)
        expect(toks, &pos, TRBracket)
        return "soa[" + st + "]"
    if toks[pos].kind == TIdent and toks[pos].text == "fn":    # function type fn(P...) [-> R]
        pos = pos + 1
        expect(toks, &pos, TLParen)
        params := []string
        if toks[pos].kind != TRParen:
            push(params, parse_type_d(toks, &pos, depth + 1))
            for toks[pos].kind == TComma:
                pos = pos + 1
                push(params, parse_type_d(toks, &pos, depth + 1))
        expect(toks, &pos, TRParen)
        ret := "void"
        if toks[pos].kind == TArrow:
            pos = pos + 1
            ret = parse_type_d(toks, &pos, depth + 1)
        out := "fn("
        i := 0
        for i < len(params):
            if i > 0:
                out = out + ","
            out = out + params[i]
            i = i + 1
        return out + "->" + ret + ")"
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected a type")
    name := toks[pos].text
    pos = pos + 1
    if toks[pos].kind == TDot and toks[pos + 1].kind == TIdent:   # qualified type pkg.Type
        name = name + "." + toks[pos + 1].text
        pos = pos + 2
    if name == "int":
        return "int"
    elif name == "bool":
        return "bool"                            # distinct type; same C repr as int (long 0/1)
    elif name == "float":
        return "float"
    elif name == "string":
        return "str"
    elif name == "bytes":                        # immutable byte buffer: same char* repr as str, crosses FFI as (ptr,len)
        return "bytes"
    elif name == "u32":                          # first-class 32-bit unsigned: C `unsigned int`, wraps at 2^32
        return "u32"
    elif name == "u64":                          # first-class 64-bit unsigned: C `unsigned long long`, wraps at 2^64
        return "u64"
    elif name == "f32":                          # first-class 32-bit float: C `float`
        return "f32"
    elif name == "ptr":                          # FFI opaque handle -> void*
        return "ptr"
    elif name == "Channel":                      # Channel(T): a worker param's queue type (CC-4)
        expect(toks, &pos, TLParen)
        cht := parse_type_d(toks, &pos, depth + 1)
        expect(toks, &pos, TRParen)
        return "Channel(" + cht + ")"
    elif name == "Option":
        expect(toks, &pos, TLParen)
        t := parse_type_d(toks, &pos, depth + 1)
        expect(toks, &pos, TRParen)
        return "Option(" + t + ")"
    elif name == "Result":
        expect(toks, &pos, TLParen)
        t := parse_type_d(toks, &pos, depth + 1)
        expect(toks, &pos, TComma)
        e := parse_type_d(toks, &pos, depth + 1)
        expect(toks, &pos, TRParen)
        return "Result(" + t + "," + e + ")"
    else:
        if toks[pos].kind == TLParen:            # generics: `Box(int)` generic-struct instance in type position
            pos = pos + 1
            targs := []string
            push(targs, parse_type_d(toks, &pos, depth + 1))
            for toks[pos].kind == TComma:
                pos = pos + 1
                push(targs, parse_type_d(toks, &pos, depth + 1))
            expect(toks, &pos, TRParen)
            out := name + "("
            j := 0
            for j < len(targs):
                if j > 0:
                    out = out + ","
                out = out + targs[j]
                j = j + 1
            return out + ")"
        return name                              # a struct or enum type name

# Public entry point: starts a fresh type-nesting depth context (H2).
fn parse_type(toks: [Token], pos: inout int) -> string:
    return parse_type_d(toks, &pos, 0)

fn parse_param(toks: [Token], pos: inout int) -> Param:
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected a parameter name")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TColon)
    if toks[pos].kind == TIdent and toks[pos].text == "inout":
        pos = pos + 1
        return Param(name, "&" + parse_type(toks, &pos))   # inout marker
    if toks[pos].kind == TIdent and toks[pos].text == "sink":
        pos = pos + 1
        return Param(name, "~" + parse_type(toks, &pos))   # sink marker (owned, mutable, by-value)
    return Param(name, parse_type(toks, &pos))

# Generics: collect the names introduced by `$X` in a type string ("$T" -> "T",
# "[$T]" -> "T"). Used to rewrite a later bare `T` reference back to "$T".
fn collect_dollar_names(s: string, bs: inout [string]):
    i := 0
    for i < len(s):
        if s[i] == 36:                           # '$'
            j := i + 1
            for j < len(s) and is_alnum(s[j]):
                j = j + 1
            push(bs, substr(s, i + 1, j))
            i = j
        else:
            i = i + 1

# Rewrite every bare reference to an in-scope type parameter to "$"+name,
# ANYWHERE in the type string -- including nested ("Option(T)" -> "Option($T)",
# "[T]" -> "[$T]"). Already-"$X" markers are copied verbatim. (Stage 3.)
fn subst_bare_typaram(ty: string, bases: [string]) -> string:
    out := ""
    i := 0
    n := len(ty)
    for i < n:
        c := ty[i]
        if c == 36:                              # '$' -> copy "$name" verbatim (already marked)
            out = out + "$"
            i = i + 1
            for i < n and is_alnum(ty[i]):
                out = out + substr(ty, i, i + 1)
                i = i + 1
        elif is_alpha(c):
            j := i
            for j < n and is_alnum(ty[j]):
                j = j + 1
            word := substr(ty, i, j)
            if has_str(bases, word):
                out = out + "$" + word
            else:
                out = out + word
            i = j
        else:
            out = out + substr(ty, i, i + 1)
            i = i + 1
    return out

# A function is a generic template if any parameter or return type mentions `$`.
fn ty_is_generic(t: string) -> bool:
    i := 0
    for i < len(t):
        if t[i] == 36:
            return true
        i = i + 1
    return false
fn func_is_generic(f: Func) -> bool:
    i := 0
    for i < len(f.ptypes):
        if ty_is_generic(f.ptypes[i]):
            return true
        i = i + 1
    return ty_is_generic(f.ret)

fn parse_func(toks: [Token], pos: inout int) -> Func:
    expect_ident(toks, &pos, "fn")
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected a function name")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TLParen)
    params := []string
    ptypes := []string
    if toks[pos].kind != TRParen:
        p := parse_param(toks, &pos)
        push(params, p.name)
        push(ptypes, p.ty)
        for toks[pos].kind == TComma:
            pos = pos + 1
            p2 := parse_param(toks, &pos)
            push(params, p2.name)
            push(ptypes, p2.ty)
    expect(toks, &pos, TRParen)
    ret := "void"
    if toks[pos].kind == TArrow:
        pos = pos + 1
        ret = parse_type(toks, &pos)
    # generics: `$T` introduces a type parameter; rewrite a later bare `T` ref to "$T"
    bases := []string
    bi := 0
    for bi < len(ptypes):
        collect_dollar_names(ptypes[bi], &bases)
        bi = bi + 1
    if len(bases) > 0:
        bi = 0
        for bi < len(ptypes):
            ptypes[bi] = subst_bare_typaram(ptypes[bi], bases)
            bi = bi + 1
        ret = subst_bare_typaram(ret, bases)
    # generics: optional `where pred(T), pred2(T2)` -- a fixed compiler-known predicate set
    constraints := ""
    if toks[pos].kind == TIdent and toks[pos].text == "where":
        if len(bases) == 0:
            die("parse: line " + str(toks[pos].line) + ": `where` constraints require a generic function (a `$T` parameter)")
        pos = pos + 1
        cont := true
        for cont:
            if toks[pos].kind != TIdent:
                die("parse: line " + str(toks[pos].line) + ": expected a `where` predicate (numeric, comparable, has_str, hashable, defaultable) or a type parameter")
            first := toks[pos].text
            pos = pos + 1
            entry := ""
            known := false
            ki := 0
            if toks[pos].kind == TColon:           # type-set form: T: type1 | type2 | ... (Go-style)
                for ki < len(bases):
                    if bases[ki] == first:
                        known = true
                    ki = ki + 1
                if not known:
                    die("parse: line " + str(toks[pos].line) + ": `where " + first + ": ...`: '" + first + "' is not a type parameter of this function")
                pos = pos + 1
                set := parse_type(toks, &pos)
                for toks[pos].kind == TPipe:
                    pos = pos + 1
                    set = set + "|" + parse_type(toks, &pos)
                entry = first + "=" + set          # encoded `T=t1|t2|...` (`=` marks a type-set)
            else:                                  # predicate form: pred(T)
                if first != "numeric" and first != "comparable" and first != "has_str" and first != "hashable" and first != "defaultable":
                    die("parse: line " + str(toks[pos].line) + ": unknown `where` predicate '" + first + "' (known: numeric, comparable, has_str, hashable, defaultable -- or use a type set, `T: int | float`)")
                expect(toks, &pos, TLParen)
                if toks[pos].kind != TIdent:
                    die("parse: line " + str(toks[pos].line) + ": expected a type-parameter name")
                tpn := toks[pos].text
                for ki < len(bases):
                    if bases[ki] == tpn:
                        known = true
                    ki = ki + 1
                if not known:
                    die("parse: line " + str(toks[pos].line) + ": `where` refers to '" + tpn + "', not a type parameter of this function")
                pos = pos + 1
                expect(toks, &pos, TRParen)
                entry = first + ":" + tpn
            if constraints != "":
                constraints = constraints + "#"
            constraints = constraints + entry
            if toks[pos].kind == TComma:
                pos = pos + 1
            else:
                cont = false
    expect(toks, &pos, TColon)
    body := parse_block(toks, &pos)
    return Func(name, params, ptypes, ret, body, 0, "", constraints)

# FFI Stage 1: only scalars + string cross the C boundary (composites have
# tycho-internal C reps, not a stable ABI). Reject everything else (fail closed).
fn ffi_scalar(ty: string) -> bool:
    return ty == "int" or ty == "char" or ty == "float" or ty == "bool" or ty == "str" or ty == "ptr" or ty == "u32" or ty == "u64" or ty == "f32"

# FFI-boundary sized-integer types: recognized ONLY in `extern fn` param/return
# positions. The value is `int` to Tycho; this is the real C ABI type emitted in the
# extern prototype so a call matches e.g. `uint32_t f(uint32_t)`. Built-in C types
# (not stdint) -- width-exact + ABI-compatible with uintN_t on every target. "" = not sized.
fn ffi_sized_cty(ty: string) -> string:
    if ty == "u8":
        return "unsigned char "
    if ty == "u16":
        return "unsigned short "
    if ty == "u32":
        return "unsigned int "
    if ty == "u64":
        return "unsigned long long "
    if ty == "i8":
        return "signed char "
    if ty == "i16":
        return "short "
    if ty == "i32":
        return "int "
    if ty == "i64":
        return "long long "
    return ""

# A boundary-only sized FFI type (u8/u16/i8/i16/i32/i64) is `int` to Tycho -- normalize
# it so a Sig (call-typing) never sees the sized name. u32/u64/f32 are FIRST-CLASS types
# (real arithmetic/printing), so they are NOT normalized -- an extern `-> u32` is a u32.
fn ffi_norm(ty: string) -> string:
    if ty == "u8" or ty == "u16" or ty == "i8" or ty == "i16" or ty == "i32" or ty == "i64":
        return "int"
    return ty

fn ffi_norm_list(ts: [string]) -> [string]:
    out := []string
    for t in ts:
        push(out, ffi_norm(t))
    return out

# Build a Sig, normalizing an extern's sized FFI param/return types to `int` (a
# non-extern type literally named "u32" is left intact -- only externs are normalized).
fn mk_sig(name: string, ret: string, ptypes: [string], is_extern: int) -> Sig:
    if is_extern == 1:
        return Sig(name, ffi_norm(ret), ffi_norm_list(ptypes), is_extern)
    return Sig(name, ret, ptypes, is_extern)

# An extern's param/return type is allowed if it is a scalar, `bytes`, or a bare
# name (a `handle` type -- can't consult dc here at parse time, so accept any
# non-composite identifier; cty resolves it to void* iff it's a real handle).
fn extern_ok_ty(ty: string) -> bool:
    if ffi_scalar(ty) or ty == "bytes":
        return true
    return find(ty, "[") < 0 and find(ty, "(") < 0 and find(ty, ":") < 0

# An extern PARAMETER is allowed if it is a non-inout scalar/bytes/handle (extern_ok_ty),
# OR a `inout` (out) param `&T` (FFI R4) whose T is int/char/float/bool/ptr -- a clean T*
# the C fn fills and tycho reads back by value. `&str` (a char** out-param) would hand
# tycho a raw C pointer with no length header; `&bytes`/`&handle`/`&composite` likewise
# have no trivial pointer-to-self ABI -- all rejected.
fn extern_param_ok(ty: string) -> bool:
    if has_prefix(ty, "&"):
        b := base_ty(ty)
        return b == "int" or b == "char" or b == "float" or b == "bool" or b == "ptr"
    return extern_ok_ty(ty)

# extern [ "Lib" ] fn name(p: T, ...) [-> T]   (bodyless; calls a C symbol).
# Name is NOT mangled — a C symbol is global.
fn parse_extern_func(toks: [Token], pos: inout int) -> Func:
    expect_ident(toks, &pos, "extern")
    lib := ""
    if toks[pos].kind == TStr:                 # optional link-library name
        lib = toks[pos].text
        pos = pos + 1
    expect_ident(toks, &pos, "fn")
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected a C function name after 'extern fn'")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TLParen)
    params := []string
    ptypes := []string
    if toks[pos].kind != TRParen:
        p := parse_param(toks, &pos)
        if not extern_param_ok(p.ty):
            die("parse: line " + str(toks[pos].line) + ": extern fn '" + name + "': a parameter must be int/char/float/bool/string/ptr/bytes or a handle (or `inout` int/char/float/bool/ptr for an out-param)")
        push(params, p.name)
        push(ptypes, p.ty)
        for toks[pos].kind == TComma:
            pos = pos + 1
            p2 := parse_param(toks, &pos)
            if not extern_param_ok(p2.ty):
                die("parse: line " + str(toks[pos].line) + ": extern fn '" + name + "': a parameter must be int/char/float/bool/string/ptr/bytes or a handle (or `inout` int/char/float/bool/ptr for an out-param)")
            push(params, p2.name)
            push(ptypes, p2.ty)
    expect(toks, &pos, TRParen)
    ret := "void"
    if toks[pos].kind == TArrow:
        pos = pos + 1
        ret = parse_type(toks, &pos)
        if not extern_ok_ty(ret) and not (is_option(ret) and option_inner(ret) == "str"):
            # FFI R3a: `-> Option(string)` is allowed (a C NULL becomes None, vs `-> string`
            # which maps NULL to ""). The C symbol still returns char*; cty/proto emit that.
            die("parse: line " + str(toks[pos].line) + ": extern fn '" + name + "': return type must be int/char/float/bool/string/bytes, Option(string), a handle, or omitted")
    return Func(name, params, ptypes, ret, []Stmt, 1, lib, "")

# A lambda literal `fn(p: T, ...) [-> R]: expr` — single-expression body (implicit
# return). The leading `fn` and the opening `(` have already been consumed-checked
# by the caller (parse_atom). id is a placeholder (0); the lift pass assigns it.
fn parse_lambda(toks: [Token], pos: inout int, pc: Pctx) -> Expr:
    _el := tloc(toks[pos])
    expect(toks, &pos, TLParen)
    params := []string
    ptypes := []string
    if toks[pos].kind != TRParen:
        # B-2: the `: T` is elidable -- "" is filled from the expected fn type
        # by ground_pre before the lift (or dies with a local error there)
        push(params, toks[pos].text)
        pos = pos + 1
        lt0 := ""
        if toks[pos].kind == TColon:
            pos = pos + 1
            lt0 = parse_type(toks, &pos)
        push(ptypes, lt0)
        for toks[pos].kind == TComma:
            pos = pos + 1
            push(params, toks[pos].text)
            pos = pos + 1
            lt1 := ""
            if toks[pos].kind == TColon:
                pos = pos + 1
                lt1 = parse_type(toks, &pos)
            push(ptypes, lt1)
    expect(toks, &pos, TRParen)
    ret := "void"
    if toks[pos].kind == TArrow:
        pos = pos + 1
        ret = parse_type(toks, &pos)
    expect(toks, &pos, TColon)
    bexpr := parse_expr_d(toks, &pos, pc)   # thread depth so nested inline lambdas can't overflow the stack (H2)
    return ELambda(0, params, ptypes, ret, bexpr, []string, []string, _el)   # body is the single expr; lift wraps it in a Func

# handle Name:
#     free: c_free_fn
# FFI R2 typed handle (docs/internals/typed-handles-design.md): an affine void* whose
# destructor `c_free_fn` runs at the owning var's scope exit. Returns "Name=c_free_fn".
fn parse_handle(toks: [Token], pos: inout int) -> string:
    expect_ident(toks, &pos, "handle")
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected a handle name")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TColon)
    open_block(toks, &pos)
    for toks[pos].kind == TNewline:
        pos = pos + 1
    if toks[pos].kind != TIdent or toks[pos].text != "free":
        die("parse: line " + str(toks[pos].line) + ": a handle body is exactly 'free: <c_free_fn>'")
    pos = pos + 1
    expect(toks, &pos, TColon)
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected the C destructor function name")
    freefn := toks[pos].text
    pos = pos + 1
    for toks[pos].kind == TNewline:
        pos = pos + 1
    expect(toks, &pos, TDedent)
    return name + "=" + freefn

fn parse_struct(toks: [Token], pos: inout int) -> StructDef:
    expect_ident(toks, &pos, "struct")
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected a struct name")
    name := toks[pos].text
    pos = pos + 1
    typeparams := []string                       # generics: `struct Box($T, $U)` type parameters
    if toks[pos].kind == TLParen:
        pos = pos + 1
        for toks[pos].kind != TRParen:
            tp := parse_type(toks, &pos)
            if not ty_is_generic(tp):
                die("parse: line " + str(toks[pos].line) + ": a struct type parameter must be written `$Name`")
            push(typeparams, substr(tp, 1, len(tp)))
            if toks[pos].kind == TComma:
                pos = pos + 1
            else:
                break
        expect(toks, &pos, TRParen)
    expect(toks, &pos, TColon)
    open_block(toks, &pos)
    fields := []Field
    for toks[pos].kind != TDedent:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        else:
            if toks[pos].kind != TIdent:
                die("parse: line " + str(toks[pos].line) + ": expected a field name")
            fname := toks[pos].text
            pos = pos + 1
            expect(toks, &pos, TColon)
            fty := parse_type(toks, &pos)
            push(fields, Field(fname, fty))
            if toks[pos].kind == TNewline:
                pos = pos + 1
    pos = pos + 1                                # consume TDedent
    if len(typeparams) > 0:                       # generics: rewrite a bare `T` field type to "$T"
        j := 0
        for j < len(fields):
            fields[j] = Field(fields[j].name, subst_bare_typaram(fields[j].ty, typeparams))
            j = j + 1
    return StructDef(name, fields, typeparams, []string)

# --- expression-valued if/match (ROADMAP 2.1) --------------------------------
# A value branch/arm is a SINGLE expression (INDENT expr NEWLINE DEDENT), held as
# a lone SExpr. `is_value_ctrl_kw` recognises the `if`/`match` that opens one in a
# tail position (RHS of :=/typed-:=/=/place-=/return).
fn is_value_ctrl_kw(t: Token) -> bool:
    return t.kind == TIdent and (t.text == "if" or t.text == "match")

fn is_sif(s: Stmt) -> bool:
    match s:
        SIf(a, b, c, d):
            return true
        _:
            return false

# a statement that self-terminates via its own block's dedent (so parse_block
# must NOT demand a trailing newline). Covers the value if/match tail positions,
# whose leading token is a name/`return`, not the `if`/`match` keyword.
fn stmt_self_terminates(s: Stmt) -> bool:
    match s:
        SIf(a, b, c, d):
            return true
        SMatch(a, b, c, d, e):
            return true
        SValDecl(a, b, c, d):
            return true
        _:
            return false

fn parse_value_block(toks: [Token], pos: inout int) -> [Stmt]:
    open_block(toks, &pos)
    _tl2 := tloc(toks[pos])
    tail := parse_expr(toks, &pos)
    if toks[pos].kind != TNewline:
        die("parse: line " + str(toks[pos].line) + ": a value branch must be a single expression (multi-statement value branches are not yet supported)")
    for toks[pos].kind == TNewline:
        pos = pos + 1
    expect(toks, &pos, TDedent)
    body := []Stmt
    push(body, SExpr(tail, _tl2))
    return body

# the single tail expression of a value branch (its lone SExpr)
fn branch_tail(body: [Stmt]) -> Expr:
    match body[0]:
        SExpr(e, ln):
            return e
        _:
            die("internal: value branch is not a single expression")
            return EInt("0", 0)

fn branch_tail_line(body: [Stmt]) -> int:
    match body[0]:
        SExpr(e, ln):
            return ln
        _:
            return 0

# rewrite one value branch's tail into a concrete statement (mode 0=return,
# 1=assign name, 2=place-set target) — the parse-time desugar for non-decl tails.
fn rewrite_branch(body: [Stmt], mode: int, name: string, target: Expr) -> [Stmt]:
    e := branch_tail(body)
    ln := branch_tail_line(body)
    out := []Stmt
    if mode == 0:
        push(out, SReturn(e, ln))
    elif mode == 1:
        push(out, SAssign(name, e, ln))
    else:
        push(out, SFieldAssign(target, e, ln))
    return out

fn ctrl_rewrite_tails(c: Stmt, mode: int, name: string, target: Expr) -> Stmt:
    match c:
        SIf(cond, body, els, ln):
            nb := rewrite_branch(body, mode, name, target)
            ne := els
            if len(els) == 1 and is_sif(els[0]):
                ne = [ctrl_rewrite_tails(els[0], mode, name, target)]
            else:
                ne = rewrite_branch(els, mode, name, target)
            return SIf(cond, nb, ne, ln)
        SMatch(subj, vars, binds, bodies, ln):
            nbodies := [][Stmt]
            i := 0
            for i < len(bodies):
                push(nbodies, rewrite_branch(bodies[i], mode, name, target))
                i = i + 1
            return SMatch(subj, vars, binds, nbodies, ln)
        _:
            return c

# collect the tail expression of every branch/arm — used to unify their types.
fn ctrl_tails(c: Stmt) -> [Expr]:
    out := []Expr
    match c:
        SIf(cond, body, els, ln):
            push(out, branch_tail(body))
            if len(els) == 1 and is_sif(els[0]):
                inner := ctrl_tails(els[0])
                k := 0
                for k < len(inner):
                    push(out, inner[k])
                    k = k + 1
            else:
                push(out, branch_tail(els))
        SMatch(subj, vars, binds, bodies, ln):
            i := 0
            for i < len(bodies):
                push(out, branch_tail(bodies[i]))
                i = i + 1
        _:
            die("internal: ctrl_tails on a non-if/match")
    return out

fn parse_value_if(toks: [Token], pos: inout int, sl: int) -> Stmt:
    pos = pos + 1                        # consume `if`
    cond := parse_expr(toks, &pos)
    expect(toks, &pos, TColon)
    then_body := parse_value_block(toks, &pos)
    els := []Stmt
    t := toks[pos]
    if t.kind == TIdent and t.text == "elif":
        esl := tloc(toks[pos])
        els = [parse_value_if(toks, &pos, esl)]     # parse_value_if consumes the `elif` keyword
    elif t.kind == TIdent and t.text == "else":
        pos = pos + 1
        expect(toks, &pos, TColon)
        els = parse_value_block(toks, &pos)
    else:
        die("parse: line " + str(t.line) + ": an `if` used as a value must have an `else` — every path must produce a value")
    return SIf(cond, then_body, els, sl)

# parse an `if`/`match` in value (tail) position; caller is ON the keyword.
fn parse_value_ctrl(toks: [Token], pos: inout int) -> Stmt:
    _sl := tloc(toks[pos])
    if toks[pos].text == "if":
        return parse_value_if(toks, &pos, _sl)
    return parse_match(toks, &pos, true)

fn parse_match(toks: [Token], pos: inout int, value: bool) -> Stmt:
    _sl := tloc(toks[pos])
    expect_ident(toks, &pos, "match")
    subj := parse_expr(toks, &pos)
    expect(toks, &pos, TColon)
    open_block(toks, &pos)
    variants := []string
    allbinds := [][string]
    bodies := [][Stmt]
    for toks[pos].kind != TDedent:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        else:
            if toks[pos].kind != TIdent:
                die("parse: line " + str(toks[pos].line) + ": expected a variant name in match arm")
            avar := toks[pos].text
            pos = pos + 1
            if toks[pos].kind == TDot and toks[pos + 1].kind == TIdent:   # qualified arm pkg.Variant
                avar = avar + "." + toks[pos + 1].text
                pos = pos + 2
            push(variants, avar)
            binds := []string
            if toks[pos].kind == TLParen:        # payload list is optional (e.g. `None:`)
                pos = pos + 1
                if toks[pos].kind != TRParen:
                    if toks[pos].kind != TIdent:
                        die("parse: line " + str(toks[pos].line) + ": expected a binding name")
                    push(binds, toks[pos].text)
                    pos = pos + 1
                    for toks[pos].kind == TComma:
                        pos = pos + 1
                        if toks[pos].kind != TIdent:
                            die("parse: line " + str(toks[pos].line) + ": expected a binding name")
                        push(binds, toks[pos].text)
                        pos = pos + 1
                expect(toks, &pos, TRParen)
            expect(toks, &pos, TColon)
            push(allbinds, binds)
            if value:
                push(bodies, parse_value_block(toks, &pos))
            else:
                push(bodies, parse_block(toks, &pos))
    pos = pos + 1                                # consume TDedent
    return SMatch(subj, variants, allbinds, bodies, _sl)

fn parse_enum(toks: [Token], pos: inout int) -> EnumDef:
    expect_ident(toks, &pos, "enum")
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected an enum name")
    name := toks[pos].text
    pos = pos + 1
    typeparams := []string                       # generics: `enum Tree($T, $U)` type parameters
    if toks[pos].kind == TLParen:
        pos = pos + 1
        for toks[pos].kind != TRParen:
            tp := parse_type(toks, &pos)
            if not ty_is_generic(tp):
                die("parse: line " + str(toks[pos].line) + ": an enum type parameter must be written `$Name`")
            push(typeparams, substr(tp, 1, len(tp)))
            if toks[pos].kind == TComma:
                pos = pos + 1
            else:
                break
        expect(toks, &pos, TRParen)
    expect(toks, &pos, TColon)
    open_block(toks, &pos)
    variants := []Variant
    for toks[pos].kind != TDedent:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        else:
            if toks[pos].kind != TIdent:
                die("parse: line " + str(toks[pos].line) + ": expected a variant name")
            vname := toks[pos].text
            pos = pos + 1
            ptypes := []string
            if toks[pos].kind == TLParen:
                pos = pos + 1
                if toks[pos].kind != TRParen:
                    push(ptypes, parse_type(toks, &pos))
                    for toks[pos].kind == TComma:
                        pos = pos + 1
                        push(ptypes, parse_type(toks, &pos))
                expect(toks, &pos, TRParen)
            push(variants, Variant(vname, ptypes))
            if toks[pos].kind == TNewline:
                pos = pos + 1
    pos = pos + 1                                # consume TDedent
    if len(typeparams) > 0:                       # generics: rewrite a bare `T` payload type to "$T"
        vi := 0
        for vi < len(variants):
            npt := []string
            pj := 0
            for pj < len(variants[vi].ptypes):
                push(npt, subst_bare_typaram(variants[vi].ptypes[pj], typeparams))
                pj = pj + 1
            variants[vi] = Variant(variants[vi].name, npt)
            vi = vi + 1
    return EnumDef(name, variants, typeparams, []string)

fn parse_newtype(toks: [Token], pos: inout int) -> Param:   # `type Name = Underlying`
    expect_ident(toks, &pos, "type")
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected a newtype name")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TEq)
    return Param(name, parse_type(toks, &pos))

# ---- package mangling (Stage D) ------------------------------------------
# The stdin stream may concatenate several packages, each headed by `package X`
# (produced by `tychoc --bundle`, dependencies first). Every top-level name in an
# imported package is mangled `<pkg>__name` so distinct packages never collide
# in the one flat namespace; the `main` package and a plain single-file program
# keep the empty prefix, so their output is unchanged. Mangling runs ONLY when a
# `package` decl was seen, so a normal single-file compile (incl. tychoc0.ty
# itself) is byte-identical. Qualified references arrive from the parser as
# dotted `pkg.name` strings; they become `<realpkg>__name` (`realpkg` resolves an
# import alias to the package's true name).
#
# Mctx is the read-only resolution table built once per program in pass 1 of
# parse_program: `prefix` is the current def's package prefix; `aliasn`/`aliasp`
# map an import alias to its package name; `pkgs` is every usable qualifier
# (package names + aliases); `variants` is every mangled variant name (so a bare
# `Red`/`pkg.Red` payload-less variant value resolves).
struct Mctx:
    prefix: string
    aliasn: [string]
    aliasp: [string]
    pkgs: [string]
    variants: [string]
    locals: [string]          # enclosing fn's param names: a call to one is an INDIRECT call (fn value), not a package fn -> don't prefix
    externs: [string]         # FFI extern fn names: global C symbols, never package-mangled (like builtins)
    constn: [string]          # `const` names in scope (top-level: mangled; local: bare) — a use folds to its literal
    constv: [Expr]            # the literal Expr each const name folds to (parallel to constn)

fn is_builtin_call(name: string) -> bool:
    return name == "str" or name == "substr" or name == "chr" or name == "input" or name == "split" or name == "keys" or name == "map_get" or name == "map_has" or name == "map_set" or name == "map_del" or name == "find" or name == "sqrt" or name == "pow" or name == "floor" or name == "fabs" or name == "to_float" or name == "to_int" or name == "to_u32" or name == "to_u64" or name == "to_f32" or name == "to_str" or name == "to_bytes" or name == "to_ptr" or name == "to_i32" or name == "to_bool" or name == "read_all" or name == "clock" or name == "now" or name == "ncpu" or name == "read_file" or name == "write_file" or name == "list_dir" or name == "args" or name == "getenv" or name == "is_null" or name == "null" or name == "die" or name == "eprint" or name == "len" or name == "push" or name == "pop" or name == "reserve" or name == "Some" or name == "Ok" or name == "Err" or name == "None"

fn resolve_pkg(m: Mctx, qual: string) -> string:       # import alias -> real package name (else identity)
    i := 0
    for i < len(m.aliasn):
        if m.aliasn[i] == qual:
            return m.aliasp[i]
        i = i + 1
    return qual

fn mangle_dotted(m: Mctx, s: string) -> string:        # "g.add" -> "<realpkg(g)>__add"
    idx := find(s, ".")
    qual := substr(s, 0, idx)
    bare := substr(s, idx + 1, len(s))
    realpkg := resolve_pkg(m, qual)
    # package privacy (B3): a leading-underscore name is private to its own
    # package; reject a cross-package qualified access to it.
    if is_pkg_ref(m, qual) and realpkg + "__" != m.prefix and len(bare) > 0 and bare[0] == 95:
        die("resolve: '" + qual + "." + bare + "' is package-private: a leading-underscore name is not accessible from another package")
    return realpkg + "__" + bare

fn is_pkg_ref(m: Mctx, name: string) -> bool:          # is `name` a package name or import alias?
    i := 0
    for i < len(m.pkgs):
        if m.pkgs[i] == name:
            return true
        i = i + 1
    return false

fn is_known_variant(m: Mctx, mn: string) -> bool:      # is `mn` (already mangled) a declared variant?
    i := 0
    for i < len(m.variants):
        if m.variants[i] == mn:
            return true
        i = i + 1
    return false

fn mangle_ref(m: Mctx, name: string) -> string:
    if find(name, ".") >= 0:
        return mangle_dotted(m, name)
    if is_builtin_call(name):
        return name
    if has_str(m.externs, name):                 # FFI: a global C symbol — never package-mangle a call to it
        return name
    if has_str(m.locals, name):                  # an enclosing param (a fn value): `f(v)` is an indirect call, NOT a package fn
        return name
    return m.prefix + name

# Mangle a comma-separated type list (tuple / Result element types), splitting on
# TOP-LEVEL commas only so nested `[..]`/`(..)`/`{..}` are left intact.
fn mangle_type_list(m: Mctx, s: string) -> string:
    out := ""
    part := ""
    depth := 0
    i := 0
    for i < len(s):
        ch := substr(s, i, i + 1)
        if ch == "(" or ch == "[" or ch == "{":
            depth = depth + 1
            part = part + ch
        elif ch == ")" or ch == "]" or ch == "}":
            depth = depth - 1
            part = part + ch
        elif ch == "," and depth == 0:
            if len(out) > 0:
                out = out + ","
            out = out + mangle_type(m, part)
            part = ""
        else:
            part = part + ch
        i = i + 1
    if len(out) > 0:
        out = out + ","
    return out + mangle_type(m, part)

fn mangle_type(m: Mctx, ty: string) -> string:
    if ty == "":
        return ty                  # an empty/pending element type (e.g. a bare `[]`) is never package-qualified
    if has_prefix(ty, "$"):
        return ty                  # a `$T` type parameter is never package-qualified (generics)
    if has_prefix(ty, "&"):
        return "&" + mangle_type(m, substr(ty, 1, len(ty)))
    if has_prefix(ty, "~"):                           # sink marker — preserve it, mangle the inner type
        return "~" + mangle_type(m, substr(ty, 1, len(ty)))
    if has_prefix(ty, "soa["):
        return "soa[" + mangle_type(m, substr(ty, 4, len(ty) - 1)) + "]"
    if has_prefix(ty, "["):
        return "[" + mangle_type(m, substr(ty, 1, len(ty) - 1)) + "]"
    if has_prefix(ty, "Option("):
        return "Option(" + mangle_type(m, substr(ty, 7, len(ty) - 1)) + ")"
    if has_prefix(ty, "Result("):
        return "Result(" + mangle_type_list(m, substr(ty, 7, len(ty) - 1)) + ")"
    if has_prefix(ty, "{"):
        return ty                  # map [str: int/float]: value is primitive, never a package type
    if has_prefix(ty, "("):
        return "(" + mangle_type_list(m, substr(ty, 1, len(ty) - 1)) + ")"
    if has_prefix(ty, "fn("):                  # fn(P...->R): mangle the param + ret types, keep the fn(...) shape (else it falls through to m.prefix+ty -> a broken type, breaking indirect-call typing in packages)
        inner := func_inner(ty)
        ar := func_arrow(inner)
        mp := ""
        if ar > 0:
            mp = mangle_type_list(m, substr(inner, 0, ar))
        return "fn(" + mp + "->" + mangle_type(m, substr(inner, ar + 2, len(inner))) + ")"
    if ty == "int" or ty == "float" or ty == "str" or ty == "void" or ty == "bool" or ty == "char" or ty == "ptr" or ty == "bytes" or ty == "u32" or ty == "u64" or ty == "f32":
        return ty                  # builtin scalar types are never package-qualified (ptr = FFI opaque handle)
    if find(ty, ".") >= 0:
        return mangle_dotted(m, ty)
    return m.prefix + ty

fn mangle_types(m: Mctx, tys: [string]) -> [string]:
    out := []string
    i := 0
    for i < len(tys):
        push(out, mangle_type(m, tys[i]))
        i = i + 1
    return out

fn mangle_args(m: Mctx, es: [Expr]) -> [Expr]:
    out := []Expr
    i := 0
    for i < len(es):
        push(out, mangle_expr(m, es[i]))
        i = i + 1
    return out

fn mangle_expr(m: Mctx, e: Expr) -> Expr:
    match e:
        EInt(s, _el):
            return EInt(s, _el)
        EBool(s, _el):
            return EBool(s, _el)
        EChar(s, _el):
            return EChar(s, _el)
        EFloat(s, _el):
            return EFloat(s, _el)
        EStr(s, _el):
            return EStr(s, _el)
        EVar(s, _el):
            if is_known_variant(m, m.prefix + s):   # a bare payload-less variant value in this package
                return EVar(m.prefix + s, _el)
            if has_str(m.locals, s) or s == "None":  # a local var / None: never package-qualified (shadows a const)
                return EVar(s, _el)
            ci := const_idx(m, s)                    # precedence: local var -> const -> variant -> fn
            if ci >= 0:                              # a const: fold this use into a copy of its literal
                return m.constv[ci]
            return EVar(m.prefix + s, _el)                # a bare same-package fn name used as a VALUE (e.g. `g := base`)
        EBin(op, l, r, _el):
            return EBin(op, mangle_expr(m, l), mangle_expr(m, r), _el)
        ECall(nm, a, _el):
            di := find(nm, ".")
            if di >= 0 and has_str(m.locals, substr(nm, 0, di)):   # `h.cb(args)` where h is a LOCAL var (not a package): call through a fn-typed struct field
                return ECallV(EField(EVar(substr(nm, 0, di), _el), substr(nm, di + 1, len(nm)), _el), mangle_args(m, a), _el)
            return ECall(mangle_ref(m, nm), mangle_args(m, a), _el)
        EField(b, f, _el):
            bn := evar_name(b)
            # `pkg.Variant` (no parens) parses as a field access; if `pkg` is an
            # imported package and `pkg.Variant` names a real variant, it is a
            # qualified payload-less variant VALUE, not a struct field read.
            if bn != "" and is_pkg_ref(m, bn) and is_known_variant(m, resolve_pkg(m, bn) + "__" + f):
                if resolve_pkg(m, bn) + "__" != m.prefix and len(f) > 0 and f[0] == 95:
                    die("resolve: '" + bn + "." + f + "' is package-private: a leading-underscore name is not accessible from another package")
                return EVar(resolve_pkg(m, bn) + "__" + f, _el)
            return EField(mangle_expr(m, b), f, _el)
        EIndex(b, ix, _el):
            return EIndex(mangle_expr(m, b), mangle_expr(m, ix), _el)
        EArrLit(es, _el):
            return EArrLit(mangle_args(m, es), _el)
        EArrEmpty(ty, _el):
            return EArrEmpty(mangle_type(m, ty), _el)
        EMapEmpty(k, v, _el):
            return EMapEmpty(k, v, _el)
        EMapLit(ks, vs, _el):
            return EMapLit(mangle_args(m, ks), mangle_args(m, vs), _el)
        ETuple(es, _el):
            return ETuple(mangle_args(m, es), _el)
        ESlice(b, lo, hi, _el):
            return ESlice(mangle_expr(m, b), mangle_expr(m, lo), mangle_expr(m, hi), _el)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return ELambda(id, ps, mangle_types(m, pts), mangle_type(m, ret), mangle_expr(m, body), cn, ct, _el)
        ECallV(callee, cargs, _el):
            return ECallV(mangle_expr(m, callee), mangle_args(m, cargs), _el)
        EAddr(x, _el):
            return EAddr(mangle_expr(m, x), _el)
        ESpawn(id, nm, a, _el):
            return ESpawn(id, mangle_ref(m, nm), mangle_args(m, a), _el)

fn mctx_add(m: Mctx, name: string) -> Mctx:       # extend the local-name set (a new binding shadows a package name)
    nl := []string
    i := 0
    for i < len(m.locals):
        push(nl, m.locals[i])
        i = i + 1
    push(nl, name)
    return Mctx(m.prefix, m.aliasn, m.aliasp, m.pkgs, m.variants, nl, m.externs, m.constn, m.constv)

# a local `const` binding: fold subsequent uses of `name` to the literal `lit`
fn mctx_add_const(m: Mctx, name: string, lit: Expr) -> Mctx:
    cn := []string
    cv := []Expr
    i := 0
    for i < len(m.constn):
        push(cn, m.constn[i])
        push(cv, m.constv[i])
        i = i + 1
    push(cn, name)
    push(cv, lit)
    return Mctx(m.prefix, m.aliasn, m.aliasp, m.pkgs, m.variants, m.locals, m.externs, cn, cv)

# index of `name` in the const table (bare name first, then package-prefixed), or -1.
# Searched newest-first so a local const shadows a same-named top-level one.
fn const_idx(m: Mctx, name: string) -> int:
    i := len(m.constn) - 1
    for i >= 0:
        if m.constn[i] == name or m.constn[i] == m.prefix + name:
            return i
        i = i - 1
    return 0 - 1

fn is_lit(e: Expr) -> bool:
    match e:
        EInt(s, _el):
            return true
        EBool(s, _el):
            return true
        EChar(s, _el):
            return true
        EFloat(s, _el):
            return true
        EStr(s, _el):
            return true
        _:
            return false

# Parse a decimal int-literal string (optional leading '-') to an int. Operand
# strings are pure digits from the lexer or a "-"-prefixed result of an earlier
# fold. 45 = '-', 48 = '0'.
fn lit_to_int(s: string) -> int:
    n := 0
    i := 0
    neg := false
    if len(s) > 0 and s[0] == 45:
        neg = true
        i = 1
    for i < len(s):
        n = n * 10 + (s[i] - 48)
        i = i + 1
    if neg:
        return 0 - n
    return n

# unary minus: negate an int literal (str() gives the same canonical decimal
# tychoc's %ld emits) or prefix a float literal's source spelling with '-'.
fn cf_neg(fl: Expr, orig: Expr) -> Expr:
    match fl:
        EInt(s, _l):
            return EInt(str(0 - lit_to_int(s)), _l)
        EFloat(s, _l):
            return EFloat("-" + s, _l)
        _:
            return orig

# unary bitwise NOT over an int literal: ~x == 0 - x - 1 in two's complement.
fn cf_bnot(fl: Expr, orig: Expr) -> Expr:
    match fl:
        EInt(s, _l):
            return EInt(str(0 - lit_to_int(s) - 1), _l)
        _:
            return orig

# fold an integer binary op over two int literals to one int literal.
fn fold_ii(op: string, x: int, y: int, orig: Expr, line: int) -> Expr:
    if op == "+":
        return EInt(str(x + y), line)
    if op == "-":
        return EInt(str(x - y), line)
    if op == "*":
        return EInt(str(x * y), line)
    if op == "/":
        if y == 0:
            die("const expression divides by zero")
        return EInt(str(x / y), line)
    if op == "%":
        if y == 0:
            die("const expression divides by zero")
        return EInt(str(x % y), line)
    if op == "&":
        return EInt(str(x & y), line)
    if op == "|":
        return EInt(str(x | y), line)
    if op == "^":
        return EInt(str(x ^ y), line)
    if op == "<<":
        return EInt(str(x << y), line)
    if op == ">>":
        return EInt(str(x >> y), line)
    return orig   # comparison / logical / string op: not const-foldable -> is_lit fails

fn cf_binop(op: string, fl: Expr, fr: Expr, orig: Expr, line: int) -> Expr:
    match fl:
        EInt(a, _la):
            match fr:
                EInt(b, _lb):
                    return fold_ii(op, lit_to_int(a), lit_to_int(b), orig, line)
                _:
                    return orig
        _:
            return orig

# Fold a const-expression into a single literal: integer arithmetic/bitwise/unary
# over int literals (`const MB = 1024 * 1024`, `const MASK = 1 << 8`, `const N = ~0`),
# unary minus over a numeric literal (`const MIN = -100`, `const T = -3.14`), and
# backward references to earlier top-level consts resolved via (cn, cv, pfx). Float
# arithmetic and (with an empty table) identifier refs pass through unfolded and
# then fail the is_lit check at the call site -- fail closed. Mirrors tychoc's const_fold.
fn const_fold(e: Expr, cn: [string], cv: [Expr], pfx: string) -> Expr:
    match e:
        EVar(name, _el):
            i := len(cn) - 1
            for i >= 0:
                if cn[i] == name or cn[i] == pfx + name:
                    return cv[i]
                i = i - 1
            return e
        EBin(op, l, r, _el):
            fl := const_fold(l, cn, cv, pfx)
            fr := const_fold(r, cn, cv, pfx)
            if op == "u-":
                return cf_neg(fl, e)
            if op == "u~":
                return cf_bnot(fl, e)
            return cf_binop(op, fl, fr, e, _el)
        _:
            return e

# does a block (recursively) declare a local `const`? Gates whether the mangle
# pass runs for an otherwise package-free single-file program (mangle folds consts).
fn block_has_const(ss: [Stmt]) -> bool:
    i := 0
    for i < len(ss):
        if stmt_has_const(ss[i]):
            return true
        i = i + 1
    return false

fn stmt_has_const(s: Stmt) -> bool:
    match s:
        SConst(n, e, _sl):
            return true
        SIf(c, t, el, _sl):
            return block_has_const(t) or block_has_const(el)
        SWhile(c, b, _sl):
            return block_has_const(b)
        SForRange(v, a, b, st, body, _sl):
            return block_has_const(body)
        SParFor(v, a, b, body, pid, _sl):
            return block_has_const(body)
        SMatch(subj, vars, binds, bodies, _sl):
            j := 0
            for j < len(bodies):
                if block_has_const(bodies[j]):
                    return true
                j = j + 1
            return false
        _:
            return false

fn mctx_bind(m: Mctx, s: Stmt) -> Mctx:           # the block-level binding(s) a statement introduces (visible to later siblings)
    match s:
        SConst(n, e, _sl):
            return mctx_add_const(m, n, e)        # a local const: later siblings fold uses of `n` to its literal
        SDecl(n, e, _sl):
            return mctx_add(m, n)
        STypedDecl(n, ty, e, _sl):
            return mctx_add(m, n)
        SOrReturn(n, e, _sl):
            return mctx_add(m, n)
        SDestructure(ns, e, _sl):
            mm := m
            i := 0
            for i < len(ns):
                mm = mctx_add(mm, ns[i])
                i = i + 1
            return mm
        SMultiAssign(ns, e, _sl):
            return m
        SAssign(n, e, _sl):
            return m
        SFieldAssign(lv, r, _sl):
            return m
        SPrint(e, _sl):
            return m
        SReturn(e, _sl):
            return m
        SReturnVoid:
            return m
        SBreak:
            return m
        SContinue:
            return m
        SIf(c, t, el, _sl):
            return m
        SWhile(c, b, _sl):
            return m
        SForRange(v, a, b, st, body, _sl):
            return m
        SExpr(e, _sl):
            return m
        SMatch(subj, vars, binds, bodies, _sl):
            return m
        SParFor(v, a, b, body, pid, _sl):
            return m
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            return m
        SValDecl(n, ty, c, _sl):
            return mctx_add(m, n)

fn mangle_block(m: Mctx, ss: [Stmt]) -> [Stmt]:
    out := []Stmt
    mm := m                                       # thread locals: a decl is in scope for the statements after it
    i := 0
    for i < len(ss):
        push(out, mangle_stmt(mm, ss[i]))
        mm = mctx_bind(mm, ss[i])
        i = i + 1
    return out

fn mangle_arm(m: Mctx, v: string) -> string:
    if find(v, ".") >= 0:
        return mangle_dotted(m, v)
    if v == "_" or v == "Some" or v == "None" or v == "Ok" or v == "Err":
        return v                                  # `_` wildcard + Option/Result arms are never package symbols
    return m.prefix + v

fn mangle_variants(m: Mctx, vs: [string]) -> [string]:
    out := []string
    i := 0
    for i < len(vs):
        push(out, mangle_arm(m, vs[i]))
        i = i + 1
    return out

fn mangle_bodies(m: Mctx, bs: [[Stmt]]) -> [[Stmt]]:
    out := [][Stmt]
    i := 0
    for i < len(bs):
        push(out, mangle_block(m, bs[i]))
        i = i + 1
    return out

fn mangle_stmt(m: Mctx, s: Stmt) -> Stmt:
    match s:
        SConst(n, e, _sl):
            return SConst(n, mangle_expr(m, e), _sl)   # a no-op downstream; the value is a literal (mangle is identity on it)
        SDecl(n, e, _sl):
            return SDecl(n, mangle_expr(m, e), _sl)
        SAssign(n, e, _sl):
            if const_idx(m, n) >= 0:                    # reject reassignment of a const (both compilers must reject)
                die("resolve: cannot assign to constant '" + n + "'")
            return SAssign(n, mangle_expr(m, e), _sl)
        SFieldAssign(lv, r, _sl):
            return SFieldAssign(mangle_expr(m, lv), mangle_expr(m, r), _sl)
        SPrint(e, _sl):
            return SPrint(mangle_expr(m, e), _sl)
        SReturn(e, _sl):
            return SReturn(mangle_expr(m, e), _sl)
        SReturnVoid:
            return SReturnVoid
        SBreak:
            return SBreak
        SContinue:
            return SContinue
        SIf(c, t, el, _sl):
            return SIf(mangle_expr(m, c), mangle_block(m, t), mangle_block(m, el), _sl)
        SWhile(c, b, _sl):
            return SWhile(mangle_expr(m, c), mangle_block(m, b), _sl)
        SForRange(v, a, b, st, body, _sl):
            return SForRange(v, mangle_expr(m, a), mangle_expr(m, b), mangle_expr(m, st), mangle_block(mctx_add(m, v), body), _sl)
        SExpr(e, _sl):
            return SExpr(mangle_expr(m, e), _sl)
        STypedDecl(n, ty, e, _sl):
            return STypedDecl(n, mangle_type(m, ty), mangle_expr(m, e), _sl)
        SOrReturn(n, e, _sl):
            return SOrReturn(n, mangle_expr(m, e), _sl)
        SDestructure(ns, e, _sl):
            return SDestructure(ns, mangle_expr(m, e), _sl)
        SMultiAssign(ns, e, _sl):
            return SMultiAssign(ns, mangle_expr(m, e), _sl)
        SMatch(subj, vars, binds, bodies, _sl):
            nb := [][Stmt]                            # each arm's payload binds are locals in that arm's body
            k := 0
            for k < len(bodies):
                mm := m
                bi := 0
                for bi < len(binds[k]):
                    mm = mctx_add(mm, binds[k][bi])
                    bi = bi + 1
                push(nb, mangle_block(mm, bodies[k]))
                k = k + 1
            return SMatch(mangle_expr(m, subj), mangle_variants(m, vars), binds, nb, _sl)
        SParFor(v, a, b, body, pid, _sl):
            return SParFor(v, mangle_expr(m, a), mangle_expr(m, b), mangle_block(mctx_add(m, v), body), pid, _sl)
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            nch := mangle_args(m, schans)
            nb := [][Stmt]
            sk := 0
            for sk < len(sbodies):
                mm := m
                if svars[sk] == "recv":
                    mm = mctx_add(mm, sbinds[sk])
                push(nb, mangle_block(mm, sbodies[sk]))
                sk = sk + 1
            return SSelect(uid, svars, nch, sbinds, nb, _sl)
        SValDecl(n, ty, c, _sl):
            nty := ty
            if ty != "":
                nty = mangle_type(m, ty)
            return SValDecl(n, nty, mangle_stmt(m, c), _sl)

fn mangle_func(m: Mctx, f: Func) -> Func:
    mb := Mctx(m.prefix, m.aliasn, m.aliasp, m.pkgs, m.variants, f.params, m.externs, m.constn, m.constv)   # body sees the params as locals (indirect calls stay unprefixed)
    nm := m.prefix + f.name
    if f.is_extern == 1:                      # FFI: a C symbol is global — never package-mangle it
        nm = f.name
    return Func(nm, f.params, mangle_types(m, f.ptypes), mangle_type(m, f.ret), mangle_block(mb, f.body), f.is_extern, f.lib, f.constraints)

fn mangle_struct(m: Mctx, sd: StructDef) -> StructDef:
    fs := []Field
    i := 0
    for i < len(sd.fields):
        push(fs, Field(sd.fields[i].name, mangle_type(m, sd.fields[i].ty)))
        i = i + 1
    return StructDef(m.prefix + sd.name, fs, sd.typeparams, sd.inst_args)

fn mangle_enum(m: Mctx, ed: EnumDef) -> EnumDef:
    vs := []Variant
    i := 0
    for i < len(ed.variants):
        push(vs, Variant(m.prefix + ed.variants[i].name, mangle_types(m, ed.variants[i].ptypes)))
        i = i + 1
    return EnumDef(m.prefix + ed.name, vs, ed.typeparams, ed.inst_args)

fn path_last(path: string) -> string:                  # "math/geom" -> "geom"
    out := path
    j := 0
    for j < len(path):
        if substr(path, j, j + 1) == "/":
            out = substr(path, j + 1, len(path))
        j = j + 1
    return out

fn parse_program(toks: [Token], pos: inout int) -> Program:
    # Pass 1: parse every def, recording its package prefix, and collect the
    # package / alias / variant tables. Two passes are needed because a qualified
    # or bare reference may name a package, alias, or variant declared later in
    # the stream (mangling can't run until all of them are known).
    rstructs := []StructDef
    spfx := []string
    renums := []EnumDef
    epfx := []string
    rfuncs := []Func
    fpfx := []string
    rntn := []string
    rntu := []string
    npfx := []string
    pkgs := []string
    aliasn := []string
    aliasp := []string
    variants := []string
    externs := []string                          # FFI extern fn names (global C symbols, never mangled)
    handles := []string                          # FFI R2 typed handles: "Name=c_free_fn" per `handle` decl
    constn := []string                           # top-level `const` names (mangled: curpfx+name)
    constv := []Expr                             # the literal each const folds to (parallel to constn)
    curpfx := ""
    sawpkg := false
    for toks[pos].kind != TEof:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        elif toks[pos].kind == TIdent and toks[pos].text == "package":
            pos = pos + 1
            pname := toks[pos].text
            pos = pos + 1
            sawpkg = true
            if pname == "main":
                curpfx = ""
            else:
                curpfx = pname + "__"
                push(pkgs, pname)
            for toks[pos].kind != TNewline and toks[pos].kind != TEof:
                pos = pos + 1
        elif toks[pos].kind == TIdent and toks[pos].text == "import":
            pos = pos + 1
            alias := ""
            if toks[pos].kind == TIdent:           # `import alias "path"`
                alias = toks[pos].text
                pos = pos + 1
            if toks[pos].kind == TStr:
                pkn := path_last(toks[pos].text)
                pos = pos + 1
                if alias != "":
                    push(aliasn, alias)
                    push(aliasp, pkn)
                    push(pkgs, alias)
                push(pkgs, pkn)
            for toks[pos].kind != TNewline and toks[pos].kind != TEof:
                pos = pos + 1
        elif toks[pos].kind == TIdent and toks[pos].text == "struct":
            push(rstructs, parse_struct(toks, &pos))
            push(spfx, curpfx)
        elif toks[pos].kind == TIdent and toks[pos].text == "enum":
            ed := parse_enum(toks, &pos)
            push(renums, ed)
            push(epfx, curpfx)
            vi := 0
            for vi < len(ed.variants):             # remember every variant's mangled name
                push(variants, curpfx + ed.variants[vi].name)
                vi = vi + 1
        elif toks[pos].kind == TIdent and toks[pos].text == "type":
            nt := parse_newtype(toks, &pos)
            push(rntn, nt.name)
            push(rntu, nt.ty)
            push(npfx, curpfx)
        elif toks[pos].kind == TIdent and toks[pos].text == "extern":   # FFI: extern fn (bodyless C decl)
            ef := parse_extern_func(toks, &pos)
            push(rfuncs, ef)
            push(fpfx, curpfx)
            push(externs, ef.name)                                      # global C symbol — bare calls to it stay unmangled
        elif toks[pos].kind == TIdent and toks[pos].text == "handle":   # FFI R2: typed handle decl
            push(handles, parse_handle(toks, &pos))
        elif toks[pos].kind == TIdent and toks[pos].text == "const":   # `const NAME = <literal>` module-level (folded at use)
            pos = pos + 1
            cnm := toks[pos].text
            pos = pos + 1
            expect(toks, &pos, TEq)
            clit := const_fold(parse_expr(toks, &pos), constn, constv, curpfx)   # top level: also resolve backward const refs
            if not is_lit(clit):
                die("parse: const value must be a literal")
            push(constn, curpfx + cnm)
            push(constv, clit)
        else:
            push(rfuncs, parse_func(toks, &pos))
            push(fpfx, curpfx)
    # a const name must not collide with a function / struct / enum / newtype /
    # variant / another const (mirror tychoc's "already defined").
    dupnames := []string
    di := 0
    for di < len(rstructs):
        push(dupnames, spfx[di] + rstructs[di].name)
        di = di + 1
    di = 0
    for di < len(renums):
        push(dupnames, epfx[di] + renums[di].name)
        di = di + 1
    di = 0
    for di < len(rfuncs):
        push(dupnames, fpfx[di] + rfuncs[di].name)
        di = di + 1
    di = 0
    for di < len(rntn):
        push(dupnames, npfx[di] + rntn[di])
        di = di + 1
    ci := 0
    for ci < len(constn):
        if has_str(dupnames, constn[ci]) or has_str(variants, constn[ci]):
            die("resolve: '" + constn[ci] + "' is already defined")
        cj := 0
        for cj < ci:
            if constn[cj] == constn[ci]:
                die("resolve: '" + constn[ci] + "' is already defined")
            cj = cj + 1
        ci = ci + 1
    # Fold consts even in a package-free single-file program: run the func mangle
    # pass (identity except for const substitution) when any const is present.
    hasconst := len(constn) > 0
    if hasconst == false:
        fc := 0
        for fc < len(rfuncs):
            if block_has_const(rfuncs[fc].body):
                hasconst = true
            fc = fc + 1
    dofold := sawpkg or hasconst
    # Pass 2: mangle, but only if the stream actually declared packages — so a
    # plain single-file program is returned untouched (byte-identical).
    structs := []StructDef
    enums := []EnumDef
    funcs := []Func
    ntnames := []string
    ntunder := []string
    si := 0
    for si < len(rstructs):
        if sawpkg:
            push(structs, mangle_struct(Mctx(spfx[si], aliasn, aliasp, pkgs, variants, []string, externs, constn, constv), rstructs[si]))
        else:
            push(structs, rstructs[si])
        si = si + 1
    ei := 0
    for ei < len(renums):
        if sawpkg:
            push(enums, mangle_enum(Mctx(epfx[ei], aliasn, aliasp, pkgs, variants, []string, externs, constn, constv), renums[ei]))
        else:
            push(enums, renums[ei])
        ei = ei + 1
    fi := 0
    for fi < len(rfuncs):
        if dofold:
            push(funcs, mangle_func(Mctx(fpfx[fi], aliasn, aliasp, pkgs, variants, []string, externs, constn, constv), rfuncs[fi]))
        else:
            push(funcs, rfuncs[fi])
        fi = fi + 1
    ni := 0
    for ni < len(rntn):
        if sawpkg:
            push(ntnames, npfx[ni] + rntn[ni])
            push(ntunder, mangle_type(Mctx(npfx[ni], aliasn, aliasp, pkgs, variants, []string, externs, constn, constv), rntu[ni]))
        else:
            push(ntnames, rntn[ni])
            push(ntunder, rntu[ni])
        ni = ni + 1
    return Program(structs, enums, funcs, ntnames, ntunder, handles)

# -------------------------------------------------------------- codegen ----
# Type-directed: each expression's C form follows its inferred type. A type is
# "int" (-> long), "str" (-> char*), or a struct name (-> that typedef). The
# mutable per-block var env is the names/types arrays; function return types
# and struct layouts come from the read-only `ctx`.

fn is_enum(dc: Decls, ctx: Ctx, name: string) -> bool:
    i := 0
    for i < len(dc.enums):
        if dc.enums[i].name == name:
            return true
        i = i + 1
    return false

# Build the variant-name -> enum-index map once (called at Decls construction).
# Variant names are globally unique (check_dups rejects duplicates), so a flat
# map is exact -- last-write equals the old scan's first-match.
fn build_vmap(enums: [EnumDef]) -> [string: int]:
    m : [string: int] = []
    i := 0
    for i < len(enums):
        j := 0
        for j < len(enums[i].variants):
            m[enums[i].variants[j].name] = i
            j = j + 1
        i = i + 1
    return m

fn vbase(name: string) -> string:                 # "Has#Box__int" -> "Has"; "Has" -> "Has"
    h := find(name, "#")
    if h >= 0:
        return substr(name, 0, h)
    return name

fn vinst(name: string) -> string:                 # "Has#Box__int" -> "Box__int" (mono-encoded generic-enum instance); "" if none
    h := find(name, "#")
    if h >= 0:
        return substr(name, h + 1, len(name))
    return ""

fn is_variant(dc: Decls, ctx: Ctx, name: string) -> bool:
    return dc.vmap.get(vbase(name), -1) >= 0

fn variant_enum(dc: Decls, ctx: Ctx, vname: string) -> string:
    inst := vinst(vname)                           # generics: a mono-encoded constructor carries its concrete instance enum
    if inst != "":
        return inst
    i := dc.vmap.get(vbase(vname), -1)
    if i < 0:
        die("type: unknown variant")
    return dc.enums[i].name

# Qualified C constructor name mk_<enum>_<variant>, so two instances of one generic
# enum (Box__int, Box__string) don't collide on a shared variant name.
fn gen_mk_name(dc: Decls, ctx: Ctx, name: string) -> string:
    return "mk_" + variant_enum(dc, ctx, name) + "_" + vbase(name)

fn variant_tag(dc: Decls, ctx: Ctx, vname: string) -> int:
    b := vbase(vname)
    inst := vinst(vname)                           # generics: prefer the encoded instance's variant order
    i := 0
    for i < len(dc.enums):
        if inst == "" or dc.enums[i].name == inst:
            j := 0
            for j < len(dc.enums[i].variants):
                if dc.enums[i].variants[j].name == b:
                    return j
                j = j + 1
        i = i + 1
    die("type: unknown variant")
    return 0

fn variant_ptypes(dc: Decls, ctx: Ctx, vname: string) -> [string]:
    i := 0
    for i < len(dc.enums):
        j := 0
        for j < len(dc.enums[i].variants):
            if dc.enums[i].variants[j].name == vname:
                return dc.enums[i].variants[j].ptypes
            j = j + 1
        i = i + 1
    die("type: unknown variant")
    return []string

# Variant payload types looked up in a SPECIFIC enum -- needed when generic-enum
# instances (Box__int, Box__string) share a variant name: a `match` must bind the
# payload from the scrutinee's instance, not whichever instance comes first.
fn variant_ptypes_in(dc: Decls, ename: string, vname: string) -> [string]:
    i := 0
    for i < len(dc.enums):
        if dc.enums[i].name == ename:
            j := 0
            for j < len(dc.enums[i].variants):
                if dc.enums[i].variants[j].name == vname:
                    return dc.enums[i].variants[j].ptypes
                j = j + 1
        i = i + 1
    i = 0                                          # fallback: any enum with the variant (non-generic / single instance)
    for i < len(dc.enums):
        j := 0
        for j < len(dc.enums[i].variants):
            if dc.enums[i].variants[j].name == vname:
                return dc.enums[i].variants[j].ptypes
            j = j + 1
        i = i + 1
    die("type: unknown variant")
    return []string

# Payload types a match arm `vname` binds over a scrutinee of type `sty`: handles
# Option/Result/wildcard directly, user enums via the instance's variants. `sty`
# should be resolve_ginst'd. Used by the mono pass to register arm bindings before
# walking the arm body (codegen does the same in SMatch); without it a foreach in a
# generic-enum arm (`Node(kids): for k in kids`) desugars to `_fc := kids`, whose
# mono types the rhs -> `unknown variable 'kids'`.
fn match_arm_ptypes(dc: Decls, ctx: Ctx, sty: string, vname: string) -> [string]:
    if vname == "_":
        return []string
    if is_option(sty):
        if vname == "Some":
            return [option_inner(sty)]
        return []string
    if is_result(sty):
        if vname == "Ok":
            return [result_ok(sty)]
        if vname == "Err":
            return [result_err(sty)]
        return []string
    return variant_ptypes_in(dc, sty, vname)

# A inout parameter's type is marked with a leading '&'. The base type drives
# all type logic; the marker only affects C codegen (pointer + deref).
fn is_inout(ty: string) -> bool:
    return len(ty) > 0 and ty[0] == 38

fn is_sink(ty: string) -> bool:
    return len(ty) > 0 and ty[0] == 126          # '~' — a `sink` (owned, mutable, by-value) param

fn base_ty(ty: string) -> string:
    if is_inout(ty) or is_sink(ty):
        return substr(ty, 1, len(ty))
    return ty

fn is_array(ty: string) -> bool:
    return len(ty) > 0 and ty[0] == 91           # "[T]"

fn elem_ty(ty: string) -> string:               # "[T]" -> "T"
    return substr(ty, 1, len(ty) - 1)

# SOA arrays: `soa [Struct]` is encoded "soa[Struct]" (one growable buffer per
# struct field + a shared len/cap, instead of an array of records).
fn is_soa(ty: string) -> bool:
    return len(ty) > 4 and substr(ty, 0, 4) == "soa["
fn soa_struct(ty: string) -> string:            # "soa[Struct]" -> "Struct"
    return substr(ty, 4, len(ty) - 1)

fn is_map(ty: string) -> bool:
    return len(ty) > 0 and ty[0] == 123          # "{str:V}"  (V = int or float)

fn map_val(ty: string) -> string:               # "{K:V}" -> "V"
    inner := substr(ty, 1, len(ty) - 1)
    i := 0
    for i < len(inner):
        if inner[i] == 58:                       # first ':'
            return substr(inner, i + 1, len(inner))
        i = i + 1
    return "int"

fn map_key(ty: string) -> string:               # "{K:V}" -> "K"
    inner := substr(ty, 1, len(ty) - 1)
    i := 0
    for i < len(inner):
        if inner[i] == 58:                       # first ':'
            return substr(inner, 0, i)
        i = i + 1
    return "str"

fn mstruct(ty: string) -> string:                # map C struct name
    return "Map_" + mangle(map_key(ty)) + "_" + mangle(map_val(ty))

fn mfam(ty: string) -> string:                   # map runtime function prefix
    return "map_" + mangle(map_key(ty)) + "_" + mangle(map_val(ty))

fn mtag(k: string) -> string:                    # slotptr family tag: 1-char for the base keys,
    if k == "int" or k == "str":                 # the full (distinct) name for a newtype/struct key
        return substr(k, 0, 1)                   # (1-char tags would collide across newtypes)
    if is_tuple(k) or is_array(k):               # a tuple/array type string isn't a valid identifier
        return mangle(k)
    return k

fn is_cmp(op: string) -> bool:
    return op == "==" or op == "!=" or op == "<" or op == ">" or op == "<=" or op == ">="

# Option(T)/Result(T,E) types are stored as their normalized source string.
fn has_prefix(s: string, p: string) -> bool:
    if len(s) < len(p):
        return false
    return substr(s, 0, len(p)) == p

fn is_task(ty: string) -> bool:                   # Task(T): the handle from `spawn f(args)` (CC-1)
    return has_prefix(ty, "Task(")
fn task_inner(ty: string) -> string:              # "Task(T)" -> "T"
    return substr(ty, 5, len(ty) - 1)

# FFI R2 typed handles: a handle type is just its name (like a struct name);
# dc.handles holds "Name=c_free_fn" entries. is_handle tests membership; handle_free
# returns the destructor C symbol the finalizer emits at scope exit.
fn is_handle(dc: Decls, ty: string) -> bool:
    i := 0
    for i < len(dc.handles):
        eq := find(dc.handles[i], "=")
        if eq >= 0 and substr(dc.handles[i], 0, eq) == ty:
            return true
        i = i + 1
    return false
fn handle_free(dc: Decls, ty: string) -> string:
    i := 0
    for i < len(dc.handles):
        eq := find(dc.handles[i], "=")
        if eq >= 0 and substr(dc.handles[i], 0, eq) == ty:
            return substr(dc.handles[i], eq + 1, len(dc.handles[i]))
        i = i + 1
    return ""
# FFI R2 affine ban: does `ty` carry a handle (directly, or nested in an array/
# map/tuple/Option/struct field)? A handle stored in any composite could be
# aliased into a double-free or escape its destructor -- fail closed. (Result and
# soa nesting are not deep-checked; tychoc, the reference, rejects those.)
fn ty_has_handle(dc: Decls, ctx: Ctx, ty: string) -> bool:
    if len(dc.handles) == 0:                          # no `handle` decl -> nothing can carry one (free for self-compile + all normal code)
        return false
    if is_handle(dc, ty):
        return true
    # array/map/tuple/Option recurse on the type STRING, which strictly shrinks -> bounded.
    if is_array(ty):
        return ty_has_handle(dc, ctx, elem_ty(ty))
    if is_map(ty):
        return ty_has_handle(dc, ctx, map_key(ty)) or ty_has_handle(dc, ctx, map_val(ty))
    if is_option(ty):
        return ty_has_handle(dc, ctx, option_inner(ty))
    if is_tuple(ty):
        parts := tuple_parts(ty)
        i := 0
        for i < len(parts):
            if ty_has_handle(dc, ctx, parts[i]):
                return true
            i = i + 1
        return false
    if is_struct(dc, ctx, ty):
        i := 0
        for i < len(dc.structs):
            if dc.structs[i].name == ty:
                j := 0
                for j < len(dc.structs[i].fields):
                    ft := dc.structs[i].fields[j].ty
                    if not is_struct(dc, ctx, ft) and ty_has_handle(dc, ctx, ft):   # recurse non-struct fields ([Res]/(int,Res)/Res); skip nested structs so a recursive struct can't cycle
                        return true
                    j = j + 1
                return false
        return false
    return false
fn is_chan(ty: string) -> bool:                   # Channel(T): the bounded queue handle (CC-4)
    return has_prefix(ty, "Channel(")
fn chan_inner(ty: string) -> string:              # "Channel(T)" -> "T"
    return substr(ty, 8, len(ty) - 1)
fn is_conc_method(nm: string) -> bool:            # the task/channel "methods" outside the Sig table
    return nm == "wait" or nm == "send" or nm == "recv" or nm == "close"

fn is_option(ty: string) -> bool:
    return has_prefix(ty, "Option(")

fn is_result(ty: string) -> bool:
    return has_prefix(ty, "Result(")

fn option_inner(ty: string) -> string:            # "Option(T)" -> "T"
    return substr(ty, 7, len(ty) - 1)

# index of the top-level comma in a Result inner "T,E" (depth-aware over ()[])
fn top_comma(s: string) -> int:
    depth := 0
    i := 0
    for i < len(s):
        c := s[i]
        if c == 40 or c == 91:
            depth = depth + 1
        elif c == 41 or c == 93:
            depth = depth - 1
        elif c == 44 and depth == 0:
            return i
        i = i + 1
    return -1

fn result_ok(ty: string) -> string:               # "Result(T,E)" -> "T"
    inner := substr(ty, 7, len(ty) - 1)
    return substr(inner, 0, top_comma(inner))

fn result_err(ty: string) -> string:               # "Result(T,E)" -> "E"
    inner := substr(ty, 7, len(ty) - 1)
    return substr(inner, top_comma(inner) + 1, len(inner))

fn is_tuple(ty: string) -> bool:
    return len(ty) > 0 and ty[0] == 40           # "(T,U,...)"

fn tuple_parts(ty: string) -> [string]:          # depth-aware split of the inner types
    inner := substr(ty, 1, len(ty) - 1)
    parts := []string
    depth := 0
    start := 0
    i := 0
    for i < len(inner):
        c := inner[i]
        if c == 40 or c == 91 or c == 123:
            depth = depth + 1
        elif c == 41 or c == 93 or c == 125:
            depth = depth - 1
        elif c == 44 and depth == 0:
            push(parts, substr(inner, start, i))
            start = i + 1
        i = i + 1
    push(parts, substr(inner, start, len(inner)))
    return parts

fn tup_suffix(ty: string) -> string:             # parts mangled, joined by "_"
    parts := tuple_parts(ty)
    out := ""
    i := 0
    for i < len(parts):
        if i > 0:
            out = out + "_"
        out = out + mangle(parts[i])
        i = i + 1
    return out

# First-class function values: a `fn(P...) -> R` type is the string
# "fn(p1,p2->ret)" (ret always present, "void" if none). A value is a C function
# pointer to a top-level function (no capture). Encoded/parsed depth-aware so a
# function-type param can itself be a function/tuple/array type.
fn is_func(ty: string) -> bool:
    return len(ty) >= 3 and ty[0] == 102 and ty[1] == 110 and ty[2] == 40   # "fn("

fn func_inner(ty: string) -> string:             # the body between `fn(` and the final `)`
    return substr(ty, 3, len(ty) - 1)

fn func_arrow(inner: string) -> int:             # offset of the top-level "->" (params|ret split)
    depth := 0
    i := 0
    for i < len(inner):
        c := inner[i]
        if c == 40 or c == 91 or c == 123:
            depth = depth + 1
        elif c == 41 or c == 93 or c == 125:
            depth = depth - 1
        elif depth == 0 and c == 45 and i + 1 < len(inner) and inner[i + 1] == 62:
            return i
        i = i + 1
    return -1

fn func_params(ty: string) -> [string]:
    inner := func_inner(ty)
    pstr := substr(inner, 0, func_arrow(inner))
    parts := []string
    if len(pstr) == 0:
        return parts
    depth := 0
    start := 0
    i := 0
    for i < len(pstr):
        c := pstr[i]
        if c == 40 or c == 91 or c == 123:
            depth = depth + 1
        elif c == 41 or c == 93 or c == 125:
            depth = depth - 1
        elif c == 44 and depth == 0:
            push(parts, substr(pstr, start, i))
            start = i + 1
        i = i + 1
    push(parts, substr(pstr, start, len(pstr)))
    return parts

fn func_ret(ty: string) -> string:
    inner := func_inner(ty)
    return substr(inner, func_arrow(inner) + 2, len(inner))

fn func_suffix(ty: string) -> string:            # a C identifier for the signature
    out := "fn"
    ps := func_params(ty)
    i := 0
    for i < len(ps):
        out = out + "_" + mangle(ps[i])
        i = i + 1
    return out + "_ret_" + mangle(func_ret(ty))

# A valid C identifier suffix for an element type, so composite element types
# (nested arrays, Option/Result/tuple elements) get legal `Arr_<mangle>` names.
fn mangle(ty: string) -> string:
    if is_array(ty):
        return "arr_" + mangle(elem_ty(ty))
    if is_option(ty):
        return "opt_" + mangle(option_inner(ty))
    if is_result(ty):
        return "res_" + mangle(result_ok(ty)) + "_" + mangle(result_err(ty))
    if is_tuple(ty):
        return "tup_" + tup_suffix(ty)
    if is_map(ty):                               # recurse on key/value: scalar/string are no-ops, a composite value (`[int:[int]]` -> map_int_arr_int) mangles to a valid identifier (matches the map struct's name)
        return "map_" + mangle(map_key(ty)) + "_" + mangle(map_val(ty))
    if is_soa(ty):
        return "soa_" + soa_struct(ty)
    if is_func(ty):
        return func_suffix(ty)                   # fn(int->int) -> fn_int_ret_int
    return ty                                    # int/str/float/struct/enum/newtype: already valid

# Newtypes (`type X = U`) are zero-cost: distinct only for type checking (which
# the C compiler already did), so codegen resolves them to the underlying type.
fn is_newtype(dc: Decls, ctx: Ctx, name: string) -> bool:
    i := 0
    for i < len(dc.ntnames):
        if dc.ntnames[i] == name:
            return true
        i = i + 1
    return false

fn resolve_nt(dc: Decls, ctx: Ctx, ty: string) -> string:
    i := 0
    for i < len(dc.ntnames):
        if dc.ntnames[i] == ty:
            return resolve_nt(dc, ctx, dc.ntunder[i])
        i = i + 1
    return ty

# Every variant nullary: usable as a map key (the tag IS the value; the cells
# are immortal per-variant singletons). A payload enum is rejected by tychoc.
fn enum_fieldless(dc: Decls, ctx: Ctx, ty: string) -> bool:
    i := 0
    for i < len(dc.enums):
        if dc.enums[i].name == ty:
            j := 0
            for j < len(dc.enums[i].variants):
                if len(dc.enums[i].variants[j].ptypes) > 0:
                    return false
                j = j + 1
            return true
        i = i + 1
    return false

fn krt(dc: Decls, ctx: Ctx, mt: string, ke: string) -> string:   # a map key as the runtime
    if enum_fieldless(dc, ctx, map_key(mt)):     # stores it: an enum key passes its TAG
        return "((" + ke + ")->tag)"
    return ke

fn cty(dc: Decls, ctx: Ctx, ty: string) -> string:
    if is_newtype(dc, ctx, ty):
        return cty(dc, ctx, resolve_nt(dc, ctx, ty))
    if is_sink(ty):                              # sink T -> plain T (by value, owned)
        return cty(dc, ctx, base_ty(ty))
    if is_inout(ty):                              # inout T -> pointer to T's C type
        inner := cty(dc, ctx, base_ty(ty))           # ends with a space
        return substr(inner, 0, len(inner) - 1) + "* "
    if ty == "int":
        return "long "
    if ty == "bool":                             # bool carried as a long 0/1
        return "long "
    if ty == "char":                             # one byte carried as a long
        return "long "
    if ty == "u32":                              # wraps at 2^32 natively
        return "unsigned int "
    if ty == "u64":                              # wraps at 2^64 natively
        return "unsigned long long "
    if ty == "f32":
        return "float "
    if ty == "float":
        return "double "
    if ty == "str":
        return "char* "
    if ty == "bytes":                            # same length-headered char* buffer as str (distinct type; FFI crosses as (ptr,len))
        return "char* "
    if ty == "ptr":                              # FFI opaque handle
        return "void* "
    if is_handle(dc, ty):                        # FFI R2 typed C handle: opaque void*, freed by its destructor at scope exit
        return "void* "
    if is_task(ty):                              # opaque runtime task handle (spawn/wait, CC-1)
        return "HTask* "
    if is_chan(ty):                              # shared bounded-queue handle (channels, CC-4)
        return "HChan* "
    if is_array(ty):                              # [T] -> the monomorphized Arr_T
        return "Arr_" + mangle(elem_ty(ty)) + " "
    if is_map(ty):                                # {str:V} -> Map_str_V
        return mstruct(ty) + " "
    if is_option(ty):
        return "HOption "
    if is_result(ty):
        return "HResult "
    if is_tuple(ty):
        return "Tup_" + tup_suffix(ty) + " "
    if is_soa(ty):                                # soa [Struct] -> Soa_Struct
        return "Soa_" + soa_struct(ty) + " "
    if is_func(ty):                               # fn(P...) -> R : a function-pointer typedef
        return "Fn_" + func_suffix(ty) + " "
    if is_enum(dc, ctx, ty):                          # enum value -> pointer to node
        return uet(ty) + "* "
    if ty == "void":
        return "void "
    if is_struct(dc, ctx, ty):                        # struct type: its own typedef
        return ust(ty) + " "
    rg := resolve_ginst(ty, dc, ctx)                  # fallback: a generic-struct application ("Box(int)") that some type position didn't run through resolve_gtype (channel element, generic-fn call result) -> resolve to its already-created instance name and emit that
    if rg != ty:
        return cty(dc, ctx, rg)
    die_at(dc, ctx.line, "type: unknown type '" + ty + "'")   # fail-closed: an unknown bare name would emit a dangling S_<name>
    return ust(ty) + " "

fn var_type(names: [string], types: [string], name: string) -> string:
    i := len(names) - 1                          # newest-first (shadowing)
    for i >= 0:
        if names[i] == name:
            return types[i]
        i = i - 1
    die("type: unknown variable '" + name + "'")
    return "int"

fn is_struct(dc: Decls, ctx: Ctx, name: string) -> bool:
    i := 0
    for i < len(dc.structs):
        if dc.structs[i].name == name:
            return true
        i = i + 1
    return false

fn field_type(dc: Decls, ctx: Ctx, sname: string, fld: string) -> string:
    i := 0
    for i < len(dc.structs):
        if dc.structs[i].name == sname:
            j := 0
            for j < len(dc.structs[i].fields):
                if dc.structs[i].fields[j].name == fld:
                    return dc.structs[i].fields[j].ty
                j = j + 1
            die_at(dc, ctx.line, "type: no such field '" + fld + "' on struct '" + sname + "'")
        i = i + 1
    # generic-application receiver like "LL(int)": the concrete instance isn't interned
    # in dc during the mono pass, but its layout is the template's with the type args
    # substituted -- find the field in the template and subst $T. Recurses (the returned
    # type may itself be a generic application, e.g. "[LL(int)]").
    pp := -1
    pi := 0
    for pi < len(sname):
        if sname[pi] == 40 and pp < 0:           # first '('
            pp = pi
        pi = pi + 1
    if pp > 0 and sname[len(sname) - 1] == 41:
        gname := substr(sname, 0, pp)
        gargs := split_type_args(substr(sname, pp + 1, len(sname) - 1))
        gsi := find_generic_struct(dc.structs, gname)
        if gsi >= 0 and len(gargs) == len(dc.structs[gsi].typeparams):
            fj := 0
            for fj < len(dc.structs[gsi].fields):
                if dc.structs[gsi].fields[fj].name == fld:
                    return subst_field_type(dc.structs[gsi].fields[fj].ty, dc.structs[gsi].typeparams, gargs)
                fj = fj + 1
    rg := resolve_ginst(sname, dc, ctx)               # the generic TEMPLATE is gone by gen time, so the template-subst above misses -> resolve the application to its instance (which IS in dc) and look its field up there
    if rg != sname:
        return field_type(dc, ctx, rg, fld)
    die_at(dc, ctx.line, "type: '" + sname + "' is not a struct (field ." + fld + ")")
    return "int"

# A struct is "heap-bearing" if any field owns heap memory (a string, an array,
# or a nested heap-bearing struct) and so needs a deep copy on value binding.
# Enum fields are immutable pointers — shared sharing is observationally safe.
fn struct_is_heap(dc: Decls, ctx: Ctx, sname: string) -> bool:
    i := 0
    for i < len(dc.structs):
        if dc.structs[i].name == sname:
            j := 0
            for j < len(dc.structs[i].fields):
                ft := dc.structs[i].fields[j].ty
                if ft == "str":
                    return true
                if is_array(ft):
                    return true
                if is_soa(ft):                   # a soa field owns heap buffers
                    return true
                if is_map(ft):                   # a map field owns its table (keys now arena-allocated)
                    return true
                if is_struct(dc, ctx, ft) and struct_is_heap(dc, ctx, ft):
                    return true
                j = j + 1
            return false
        i = i + 1
    return false

fn sig_ret(dc: Decls, ctx: Ctx, name: string) -> string:
    if name == "str":
        return "str"
    if name == "substr":
        return "str"
    if name == "chr":
        return "str"
    if name == "input":
        return "str"
    if name == "split":
        return "[str]"
    if name == "keys":
        return "[str]"
    if name == "map_get":
        return "int"
    if name == "map_has":
        return "bool"
    if name == "find":
        return "int"
    if name == "sqrt" or name == "pow" or name == "floor" or name == "fabs":
        return "float"
    if name == "to_float":
        return "float"
    if name == "to_int":
        return "int"
    if name == "to_u32":                          # numeric -> u32 (truncate to low 32 bits)
        return "u32"
    if name == "to_u64":                          # numeric -> u64
        return "u64"
    if name == "to_f32":                          # numeric -> f32 (single precision)
        return "f32"
    if name == "to_str":                          # unwrap a string newtype, or reinterpret bytes -> str
        return "str"
    if name == "to_bytes":                        # str -> bytes (same buffer, distinct type)
        return "bytes"
    if name == "to_bool":                         # unwrap a bool newtype
        return "bool"
    if name == "read_all":
        return "str"
    if name == "clock":                           # monotonic nanoseconds
        return "int"
    if name == "now":                             # wall-clock UNIX seconds
        return "int"
    if name == "ncpu":                            # parallel-for fan-out width
        return "int"
    if name == "read_file":
        return "str"
    if name == "write_file":                      # (path, contents) -> bool
        return "bool"
    if name == "list_dir":
        return "[str]"
    if name == "args":
        return "[str]"
    if name == "getenv":                          # env var value, or "" if unset
        return "str"
    if name == "null":                            # FFI opaque ptr literal
        return "ptr"
    if name == "to_ptr":                          # FFI: int -> opaque ptr sentinel
        return "ptr"
    if name == "to_i32":                          # FFI: sign-extend a 32-bit C int return
        return "int"
    if name == "is_null":                         # FFI: opaque-handle NULL test
        return "bool"
    if name == "die":
        return "int"
    if name == "eprint":
        return "int"
    if name == "len":
        return "int"
    if name == "input":
        return "str"
    if is_newtype(dc, ctx, name):                     # X(v) constructor -> the newtype
        return name
    if is_variant(dc, ctx, name):                     # enum construction yields its enum
        return variant_enum(dc, ctx, name)
    if is_struct(dc, ctx, name):                      # construction yields the struct
        return name
    si := dc.sigmap.get(name, -1)                # O(1) user-function lookup (was a linear scan)
    if si >= 0:
        return dc.sigs[si].ret
    die_at(dc, ctx.line, "type: unknown function '" + name + "'")
    return "int"

# The function-value type "fn(p1,p2->ret)" for a top-level function name, or ""
# if `name` is not a user function (so a bare name can be typed as a value).
fn sig_ptypes(dc: Decls, name: string) -> [string]:   # the named fn's param types (spawn-site copy-in, CC-1)
    si := dc.sigmap.get(name, -1)
    if si < 0:
        die("type: unknown function '" + name + "' in spawn")
    return dc.sigs[si].ptypes

fn sig_functype(dc: Decls, name: string) -> string:
    si := dc.sigmap.get(name, -1)
    if si < 0:
        return ""
    s := dc.sigs[si]
    out := "fn("
    i := 0
    for i < len(s.ptypes):
        if i > 0:
            out = out + ","
        out = out + s.ptypes[i]
        i = i + 1
    return out + "->" + s.ret + ")"

# UFCS methods: x.foo(args) / expr.foo(args) lowers (via the mangler / postfix
# parse) to a call-on-expression with an EField callee. At codegen, if the field
# name isn't a fn-typed struct field but IS a free fn whose first parameter has
# the receiver's type, it's a method call -> foo(recv, args). Static dispatch;
# mirrors tychoc. Resolution (ufcs_name) tries the bare name, then the receiver
# TYPE's package (geom__Circle -> geom__area), then the CURRENT function's package
# (ctx.curpkg) -- the last covers a same-package method on a receiver whose type
# carries no package prefix (a scalar/builtin), which the receiver-type lookup
# can't reach. This is tychoc's package scope, threaded through ctx.curpkg.
fn efield_fname(e: Expr) -> string:               # field name if e is EField, else ""
    match e:
        EField(b, f, _el):
            return f
        EInt(s, _el):
            return ""
        EBool(s, _el):
            return ""
        EChar(s, _el):
            return ""
        EFloat(s, _el):
            return ""
        EStr(s, _el):
            return ""
        EVar(s, _el):
            return ""
        EBin(o, l, r, _el):
            return ""
        ECall(nm, a, _el):
            return ""
        EIndex(b, ix, _el):
            return ""
        EArrLit(es, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        EMapLit(ks, vs, _el):
            return ""
        ETuple(es, _el):
            return ""
        ESlice(b, lo, hi, _el):
            return ""
        EAddr(x, _el):
            return ""
        ELambda(id, ps, pts, r, bx, cn, ct, _el):
            return ""
        ECallV(c, a, _el):
            return ""
        ESpawn(id, nm, a, _el):
            return ""

fn efield_base(e: Expr) -> Expr:                  # base of an EField (caller guards via efield_fname)
    match e:
        EField(b, f, _el):
            return b
        EInt(s, _el):
            return e
        EBool(s, _el):
            return e
        EChar(s, _el):
            return e
        EFloat(s, _el):
            return e
        EStr(s, _el):
            return e
        EVar(s, _el):
            return e
        EBin(o, l, r, _el):
            return e
        ECall(nm, a, _el):
            return e
        EIndex(b, ix, _el):
            return e
        EArrLit(es, _el):
            return e
        EArrEmpty(t, _el):
            return e
        EMapEmpty(k, v, _el):
            return e
        EMapLit(ks, vs, _el):
            return e
        ETuple(es, _el):
            return e
        ESlice(b, lo, hi, _el):
            return e
        EAddr(x, _el):
            return e
        ELambda(id, ps, pts, r, bx, cn, ct, _el):
            return e
        ECallV(c, a, _el):
            return e
        ESpawn(id, nm, a, _el):
            return e

fn struct_fn_field(dc: Decls, sname: string, fname: string) -> bool:   # sname has a fn-typed field fname?
    i := 0
    for i < len(dc.structs):
        if dc.structs[i].name == sname:
            j := 0
            for j < len(dc.structs[i].fields):
                if dc.structs[i].fields[j].name == fname and is_func(dc.structs[i].fields[j].ty):
                    return true
                j = j + 1
            return false
        i = i + 1
    return false

# Method name (matches un()) if `callee` is a UFCS method call, else "".
# The package prefix of a mangled function name: "mathx__use_int" -> "mathx__".
# "" if unmangled (single-file fn) or a leading-"__" compiler-internal name
# (__par<N> chunk procs), which carry no user package.
fn pkg_prefix_of(name: string) -> string:
    us := find(name, "__")
    if us > 0:
        return substr(name, 0, us + 2)
    return ""

# A UFCS receiver matches a method's first parameter if the types are equal, or that
# parameter is `sink` (the receiver is consumed -- gen_call_args_sink adopts-or-copies it
# at the call). `inout` is NOT relaxed here: a inout receiver would need `&`, which the UFCS
# desugar does not insert, so a inout first param must stay unmatched.
fn recv_matches(ptype: string, bt: string) -> bool:
    return ptype == bt or (is_sink(ptype) and base_ty(ptype) == bt)

fn ufcs_name(dc: Decls, ctx: Ctx, names: [string], types: [string], callee: Expr) -> string:
    fname := efield_fname(callee)
    if fname == "":
        return ""
    if is_builtin_call(fname):
        return ""
    bt := type_of(efield_base(callee), names, types, dc, ctx)
    if struct_fn_field(dc, bt, fname):            # a real fn-typed field wins (call-through-field)
        return ""
    si := dc.sigmap.get(fname, -1)
    if si >= 0 and len(dc.sigs[si].ptypes) >= 1:
        if recv_matches(dc.sigs[si].ptypes[0], bt):
            return fname
        gbn := []string
        gbt := []string
        if match_typaram_str(dc.sigs[si].ptypes[0], bt, &gbn, &gbt):   # UFCS x generics: a generic method whose first param pattern accepts the receiver
            return fname
    us := find(bt, "__")                          # method in the receiver type's package: geom__Circle -> geom__area
    if us >= 0:
        qn := substr(bt, 0, us + 2) + fname
        sj := dc.sigmap.get(qn, -1)
        if sj >= 0 and len(dc.sigs[sj].ptypes) >= 1 and recv_matches(dc.sigs[sj].ptypes[0], bt):
            return qn
    if ctx.curpkg != "":                          # same-package method on a receiver whose TYPE carries no
        cn := ctx.curpkg + fname                  # package prefix (a scalar/builtin): try <curpkg>__method
        sk := dc.sigmap.get(cn, -1)
        if sk >= 0 and len(dc.sigs[sk].ptypes) >= 1 and recv_matches(dc.sigs[sk].ptypes[0], bt):
            return cn
    return ""

fn type_of(e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    match e:
        EInt(t, _el):
            return "int"
        EBool(t, _el):
            return "bool"
        EChar(t, _el):
            return "char"
        EFloat(f, _el):
            return "float"
        EStr(s, _el):
            return "str"
        EVar(name, _el):
            if name == "None":
                return "Option()"
            if is_variant(dc, ctx, name):            # bare no-payload variant (e.g. Green)
                return variant_enum(dc, ctx, name)
            if not has_str(names, name):             # not a local: a bare top-level fn name as a value
                ft := sig_functype(dc, name)
                if ft != "":
                    return ft
                die_at(dc, _el, "type: unknown variable '" + name + "'")
            vt := base_ty(var_type(names, types, name))
            return resolve_nt(dc, ctx, vt)
        EField(base, fld, _el):
            bt := type_of(base, names, types, dc, ctx)
            if is_tuple(bt):                      # tuple index t.0 -> the i-th part type
                # parse the FULL index and range-check it (fail closed): the old
                # fld[0]-48 read one digit, silently accepting t.10 as part 1
                # (tychoc: "tuple index %ld out of range", src/tychoc.c:2259)
                parts := tuple_parts(bt)
                tidx := 0
                tk := 0
                for tk < len(fld):
                    if fld[tk] < 48 or fld[tk] > 57:
                        die("type: tuple index ." + fld + " is not a number")
                    tidx = tidx * 10 + (fld[tk] - 48)
                    tk = tk + 1
                if tidx >= len(parts):
                    die("type: tuple index ." + fld + " out of range (the tuple has " + str(len(parts)) + " elements)")
                return parts[tidx]
            return resolve_nt(dc, ctx, field_type(dc, with_line(ctx, _el), bt, fld))
        EIndex(base, idx, _el):
            bt := type_of(base, names, types, dc, ctx)
            if bt == "str":
                return "int"                      # s[i] is the byte value (ord)
            if is_soa(bt):
                return soa_struct(bt)             # soa element -> the struct
            if is_map(bt):                        # m[k] place -> the value type (#2)
                return resolve_nt(dc, ctx, map_val(bt))
            return resolve_nt(dc, ctx, substr(bt, 1, len(bt) - 1))   # else array element type (resolved like a var read, so a [Newtype] element is consistently its base in queries; identity is recovered separately via nt_skin_of off the container's stored type)
        EArrLit(elems, _el):
            return "[" + type_of(elems[0], names, types, dc, ctx) + "]"
        EArrEmpty(ety, _el):
            if ety == "":                         # bare []: ground_pre had no destination type for it
                die("type: cannot type a bare [] here -- no expected type (write []T, or use it where the element type is known)")
            if is_soa(ety):                       # `soa []Struct` carries the full soa type
                return ety
            return "[" + ety + "]"
        EMapEmpty(kty, vty, _el):
            return "{" + kty + ":" + vty + "}"
        EMapLit(keys, vals, _el):
            return "{" + type_of(keys[0], names, types, dc, ctx) + ":" + type_of(vals[0], names, types, dc, ctx) + "}"
        ETuple(elems, _el):
            out := "("
            j := 0
            for j < len(elems):
                if j > 0:
                    out = out + ","
                out = out + type_of(elems[j], names, types, dc, ctx)
                j = j + 1
            return out + ")"
        ESlice(base, lo, hi, _el):
            return type_of(base, names, types, dc, ctx)   # same array type
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return mk_functype(pts, ret)
        ECallV(callee, cargs, _el):
            cfn := efield_fname(callee)           # t.wait() / ch.send(v) ...: a task/chan "method" (CC)
            if cfn == "get":                      # m.get(k[, default]): a map read spelled as a method -> value type
                gbt := type_of(efield_base(callee), names, types, dc, ctx)
                if is_map(gbt):
                    return map_val(gbt)
            if is_conc_method(cfn):
                cbt := type_of(efield_base(callee), names, types, dc, ctx)
                if is_task(cbt) and cfn == "wait":
                    return task_inner(cbt)
                if is_chan(cbt):
                    if cfn == "recv":
                        return "Option(" + chan_inner(cbt) + ")"
                    return "void"                 # send / close
            mn := ufcs_name(dc, ctx, names, types, callee)
            if mn != "":                          # UFCS method: its return type
                msi := dc.sigmap.get(mn, -1)
                if msi >= 0 and len(dc.sigs[msi].ptypes) >= 1 and ty_is_generic(dc.sigs[msi].ret):
                    rbt := type_of(efield_base(callee), names, types, dc, ctx)   # generic method: substitute its return from the receiver type
                    sbn := []string
                    sbt := []string
                    if match_typaram_str(dc.sigs[msi].ptypes[0], rbt, &sbn, &sbt):
                        return resolve_nt(dc, ctx, subst_field_type(dc.sigs[msi].ret, sbn, sbt))
                return resolve_nt(dc, ctx, sig_ret(dc, ctx, mn))
            return resolve_nt(dc, ctx, func_ret(type_of(callee, names, types, dc, ctx)))
        ESpawn(id, nm, sargs, _el):
            return "Task(" + resolve_nt(dc, ctx, sig_ret(dc, ctx, nm)) + ")"
        EAddr(inner, _el):
            return type_of(inner, names, types, dc, ctx)
        EBin(op, l, r, _el):
            if op == "not":                       # logical not -> bool (operand validated in codegen)
                return "bool"
            if op == "u-":                        # unary minus -> the operand's (numeric) type
                return type_of(l, names, types, dc, ctx)
            if op == "u~":                        # unary bitwise NOT -> the operand type (~u32 is a u32)
                return type_of(l, names, types, dc, ctx)
            lt := type_of(l, names, types, dc, ctx)
            rt := type_of(r, names, types, dc, ctx)
            if op == "+" and (lt == "str" or rt == "str"):
                return "str"                      # str + char appends one byte
            if (op == "+" or op == "-") and (lt == "char" or rt == "char"):
                return "char"                     # char +/- int (or char) stays a byte
            if op == "+" or op == "-" or op == "*" or op == "/":
                # sized numerics widen the result to their type; a bare int literal on
                # the other side adapts (legality — literals only — enforced in gen_expr).
                if lt == "f32" or rt == "f32":
                    return "f32"
                if lt == "float" or rt == "float":
                    return "float"
                if lt == "u32" or rt == "u32":
                    return "u32"
                if lt == "u64" or rt == "u64":
                    return "u64"
                return "int"
            if is_cmp(op) or op == "in" or op == "&&" or op == "||":
                return "bool"                     # comparisons / `in` / and / or -> bool
            if op == "<<" or op == ">>":          # shift result = the shifted value's width
                if lt == "u32":
                    return "u32"
                if lt == "u64":
                    return "u64"
                return "int"
            if lt == "u32" or rt == "u32":        # %, &, |, ^ on u32/u64 keep the width
                return "u32"
            if lt == "u64" or rt == "u64":
                return "u64"
            return "int"                          # %, <<, >>, &, |, ^ -> int
        ECall(name, args, _el):
            tm0 := find(name, "$<")
            if tm0 >= 0:
                if substr(name, 0, tm0) == "zero":   # zero$<T>: the defaultable-type zero; its type IS the type arg
                    return substr(name, tm0 + 2, len(name) - 1)
                name = substr(name, 0, tm0)       # generics: strip the explicit-type-arg encoding for the template sig lookup (placeholder type; codegen recomputes)
            di := find(name, ".")
            if di >= 0 and has_str(names, substr(name, 0, di)):   # `h.cb(args)` where h is a LOCAL: a fn-field call
                return type_of(ECallV(EField(EVar(substr(name, 0, di), _el), substr(name, di + 1, len(name)), _el), args, _el), names, types, dc, ctx)
            if has_str(names, name):              # indirect call through a function-typed variable
                vt := base_ty(var_type(names, types, name))
                if is_func(vt):
                    return resolve_nt(dc, ctx, func_ret(vt))
            if name == "map_set" or name == "map_del":   # return the first arg's map type
                return type_of(args[0], names, types, dc, ctx)
            if name == "map_get":                 # returns the map's value type
                return map_val(type_of(args[0], names, types, dc, ctx))
            if name == "pop":                      # pop(arr) -> the array's element type
                pt := type_of(args[0], names, types, dc, ctx)
                if is_soa(pt):                     # pop(soa) yields the struct value
                    return soa_struct(pt)
                return elem_ty(pt)
            if name == "keys":                     # returns [K] (the map's key array)
                return "[" + map_key(type_of(args[0], names, types, dc, ctx)) + "]"
            if has_prefix(name, "channel:"):      # channel(T, cap) creation (the type rides the name)
                return "Channel(" + substr(name, 8, len(name)) + ")"
            if name == "wait":                    # wait(t) -> T (CC-1)
                return task_inner(type_of(args[0], names, types, dc, ctx))
            if name == "recv":                    # recv(ch) -> Option(T); None = closed+drained (CC-4)
                return "Option(" + chan_inner(type_of(args[0], names, types, dc, ctx)) + ")"
            if name == "send" or name == "close":
                return "void"
            if name == "to_under":                # generic newtype unwrap -> the underlying type. resolve_nt is
                # NOT redundant: type_of resolves a newtype at a VAR read, but an
                # array-element read (to_under(ks[i]) over ks: [Nt]) returns the
                # bare elem type "Nt" (fuzz-found: len() then gen'd the array path)
                return resolve_nt(dc, ctx, type_of(args[0], names, types, dc, ctx))
            if name == "Some":
                return "Option(" + type_of(args[0], names, types, dc, ctx) + ")"
            if name == "Ok":
                return "Result(" + type_of(args[0], names, types, dc, ctx) + ",)"
            if name == "Err":
                return "Result(," + type_of(args[0], names, types, dc, ctx) + ")"
            gsi := dc.sigmap.get(name, -1)
            if gsi >= 0 and ty_is_generic(dc.sigs[gsi].ret):   # generic call: infer type args from the argument types and substitute the CONCRETE return, so a generic result can feed a bound var or another generic (matches tychoc; was returning the template's "$T")
                gbn := []string
                gbt := []string
                gok := true
                gk := 0
                for gk < len(dc.sigs[gsi].ptypes) and gk < len(args):
                    if ty_is_generic(dc.sigs[gsi].ptypes[gk]):
                        if not match_typaram_str(dc.sigs[gsi].ptypes[gk], type_of(args[gk], names, types, dc, ctx), &gbn, &gbt):
                            gok = false
                    gk = gk + 1
                if gok:
                    return resolve_nt(dc, ctx, subst_field_type(dc.sigs[gsi].ret, gbn, gbt))
            if is_newtype(dc, ctx, name):             # Nt(v) constructor: KEEP the newtype identity unresolved, so a decl `r := Nt(v)` stores "Nt" and the value can be distinguished from its base. A var read (the EVar case above) and cty still resolve to the base, so codegen is unchanged.
                return name
            return resolve_nt(dc, ctx, sig_ret(dc, with_line(ctx, _el), name))

fn gen_args(args: [Expr], names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    out := ""
    i := 0
    for i < len(args):
        if i > 0:
            out = out + ", "
        out = out + gen_expr(args[i], names, types, dc, ctx)
        i = i + 1
    return out

# If `arg` is a inout container argument (`&place` where place is an array/map/
# soa), the extra hidden arena to pass after it: the place's home arena in the
# CALLER (a local -> its scope/block arena; a chained inout -> the caller's own
# _ina_, threading the true home up the chain). "" otherwise. Mirrors
# inout_container_param exactly so call arity matches the callee signature.
fn arg_ina(arg: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    match arg:
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return ""
        ECallV(callee, cargs, _el):
            return ""
        EAddr(inner, _el):
            b := base_ty(type_of(inner, names, types, dc, ctx))
            if resolve_nt(dc, ctx, b) == "str" or is_array(b) or is_map(b) or is_soa(b) or (is_struct(dc, ctx, b) and struct_is_heap(dc, ctx, b)):   # mirrors inout_container_param
                return ", " + owner_arena_of(inner, names, types, dc, ctx)
            return ""
        EVar(n, _el):
            return ""
        EInt(t, _el):
            return ""
        EBool(t, _el):
            return ""
        EChar(t, _el):
            return ""
        EFloat(f, _el):
            return ""
        EStr(s, _el):
            return ""
        EBin(o, l, r, _el):
            return ""
        ECall(nm, a, _el):
            return ""
        EField(b, f, _el):
            return ""
        EIndex(b, i, _el):
            return ""
        EArrLit(es, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        EMapLit(ks, vs, _el):
            return ""
        ETuple(es, _el):
            return ""
        ESlice(b, lo, hi, _el):
            return ""
        ESpawn(id, nm, a, _el):
            return ""

# Like gen_args, but after each inout-container arg, interleave its home arena
# (the hidden _ina_ param) — kept positionally in sync with gen_params.
fn gen_call_args(args: [Expr], names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    out := ""
    i := 0
    for i < len(args):
        if i > 0:
            out = out + ", "
        out = out + gen_expr(args[i], names, types, dc, ctx) + arg_ina(args[i], names, types, dc, ctx)
        i = i + 1
    return out

# Like gen_args, but for CONSTRUCTION (struct/enum/array literal): the argument
# value is STORED in the aggregate and outlives the expression, so a heap place
# argument must be deep-copied for value semantics — else the stored field
# aliases the source's buffer, and mutating the source later corrupts the stored
# value (`a := [..]; t := Box(a, ..); a[0] = 9` must leave t untouched). gen_rhs
# copies only is_place heap args; fresh values / scalars / strings pass through.
# Mirrors the tuple path (gen_rhs per element) and the C compiler's per-field
# copy_into. (Found by tests/value_semantics.ty probe 3.)
fn gen_store_args(args: [Expr], names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    # Values STORED into a container (array-literal / struct / enum / tuple
    # fields) must be malloc'd (owner "0"), not built in the ambient owner: a
    # construction inside a `return` expr has owner=_parent, and the constructed
    # container would then hold _parent-arena string pointers that dangle once the
    # caller's scope frees. Forcing "0" keeps stored strings immortal. (Outside a
    # return, owner is already "0", so this is a no-op there.)
    return gen_store_args_owner(args, names, types, dc, ctx, "0")

# Like gen_store_args but with an explicit owner arena for the stored values.
# Array literals of a deep-copied element type pass ctx.owner (the array's home
# arena) so element temporaries are freed at scope instead of leaking; struct/
# enum/tuple construction keeps owner "0" (immortal) via gen_store_args.
fn gen_store_args_owner(args: [Expr], names: [string], types: [string], dc: Decls, ctx: Ctx, owner: string) -> string:
    sctx := with_owner(dc, ctx, owner)
    out := ""
    i := 0
    for i < len(args):
        if i > 0:
            out = out + ", "
        out = out + gen_rhs(args[i], names, types, dc, sctx)
        i = i + 1
    return out

# index of field `fld` in struct `sname` (the soa buffer is f<index>).
fn soa_field_index(dc: Decls, ctx: Ctx, sname: string, fld: string) -> int:
    si := 0
    for si < len(dc.structs):
        if dc.structs[si].name == sname:
            j := 0
            for j < len(dc.structs[si].fields):
                if dc.structs[si].fields[j].name == fld:
                    return j
                j = j + 1
        si = si + 1
    return 0

# If `base` is `soa[i]`, the C for `base.fld` is the field buffer slot
# `(soa).fN[i]` -- a real lvalue, so it serves BOTH read and write. Else "".
# (Tycho has no wildcard match, so every Expr arm is listed.)
fn soa_field_access(dc: Decls, ctx: Ctx, base: Expr, fld: string, names: [string], types: [string]) -> string:
    match base:
        EIndex(sb, ix, _el):
            sbt := type_of(sb, names, types, dc, ctx)
            if is_soa(sbt):
                fi := soa_field_index(dc, ctx, soa_struct(sbt), fld)
                return "(" + gen_expr(sb, names, types, dc, ctx) + ").f" + str(fi) + "[" + gen_expr(ix, names, types, dc, ctx) + "]"
            return ""
        EInt(t, _el):
            return ""
        EBool(t, _el):
            return ""
        EChar(t, _el):
            return ""
        EFloat(f, _el):
            return ""
        EStr(s, _el):
            return ""
        EVar(n, _el):
            return ""
        EBin(o, l, r, _el):
            return ""
        ECall(nm, a, _el):
            return ""
        EField(b, f, _el):
            return ""
        EArrLit(es, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        EMapLit(ks, vs, _el):
            return ""
        ETuple(es, _el):
            return ""
        ESlice(b, lo, hi, _el):
            return ""
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return ""
        ECallV(callee, cargs, _el):
            return ""
        EAddr(x, _el):
            return ""
        ESpawn(id, nm, a, _el):
            return ""

# gather a whole struct value from the soa's field buffers at index `ix`.
# (param is `basec` not `sc` — tychoc0 emits user names un-prefixed and `sc` is
# the runtime string-concat function, so a `sc` local would shadow it.)
fn gen_soa_gather(dc: Decls, ctx: Ctx, ty: string, basec: string, ix: string) -> string:
    sn := soa_struct(ty)
    si := 0
    for si < len(dc.structs):
        if dc.structs[si].name == sn:
            flds := dc.structs[si].fields
            out := "(" + ust(sn) + "){"
            i := 0
            for i < len(flds):
                if i > 0:
                    out = out + ","
                out = out + " (" + basec + ").f" + str(i) + "[" + ix + "]"
                i = i + 1
            return out + " }"
        si = si + 1
    die("codegen: soa gather of unknown struct")
    return ""

# soa sub-range [lo:hi]: offset every field buffer by lo (len hi-lo, cap 0).
fn gen_soa_slice(dc: Decls, ctx: Ctx, ty: string, basec: string, loc: string, hic: string) -> string:
    sn := soa_struct(ty)
    si := 0
    for si < len(dc.structs):
        if dc.structs[si].name == sn:
            flds := dc.structs[si].fields
            out := "(Soa_" + sn + "){"
            i := 0
            for i < len(flds):
                out = out + " (" + basec + ").f" + str(i) + " + (" + loc + "),"
                i = i + 1
            return out + " (" + hic + ") - (" + loc + "), 0 }"
        si = si + 1
    die("codegen: soa slice of unknown struct")
    return ""

# Return a copy of ctx with a different allocation owner. Sub-expressions of an
# expression built with this ctx allocate into `o` (an arena lvalue string like
# "&_t" / "_parent", or "0" for malloc).
fn with_owner(dc: Decls, ctx: Ctx, o: string) -> Ctx:
    return Ctx(ctx.vparams, ctx.saccums, ctx.rettype, o, ctx.depth, ctx.bbases, ctx.movables, ctx.loopdepth, ctx.fusearr, ctx.fusesuf, ctx.fusety, ctx.line, ctx.curpkg)

# set the current statement source line (for resolve/codegen diagnostics)
fn with_line(ctx: Ctx, n: int) -> Ctx:
    return Ctx(ctx.vparams, ctx.saccums, ctx.rettype, ctx.owner, ctx.depth, ctx.bbases, ctx.movables, ctx.loopdepth, ctx.fusearr, ctx.fusesuf, ctx.fusety, n, ctx.curpkg)

# a statement's source line (0 for the no-payload variants -- callers fall back to ctx.line)
fn stmt_line(s: Stmt) -> int:
    match s:
        SDecl(a, b, ln):
            return ln
        SAssign(a, b, ln):
            return ln
        SFieldAssign(a, b, ln):
            return ln
        SPrint(a, ln):
            return ln
        SReturn(a, ln):
            return ln
        SConst(a, b, ln):
            return ln
        SReturnVoid:
            return 0
        SIf(a, b, c, ln):
            return ln
        SWhile(a, b, ln):
            return ln
        SForRange(a, b, c, d, e, ln):
            return ln
        SExpr(a, ln):
            return ln
        STypedDecl(a, b, c, ln):
            return ln
        SOrReturn(a, b, ln):
            return ln
        SDestructure(a, b, ln):
            return ln
        SMultiAssign(a, b, ln):
            return ln
        SMatch(a, b, c, d, ln):
            return ln
        SBreak:
            return 0
        SContinue:
            return 0
        SSelect(a, b, c, d, e, ln):
            return ln
        SParFor(a, b, c, d, e, ln):
            return ln
        SValDecl(a, b, c, ln):
            return ln

# abort with "line N: msg" + the source line and a caret under its first
# non-blank char (resolve/codegen diagnostics). line 0 / out of range = no snippet.
fn die_at(dc: Decls, code: int, msg: string):
    nl := chr(10)
    lineno := code / 100000                        # decode tloc: 1-based line, 0-based col
    col := code % 100000
    if lineno > 0 and lineno <= len(dc.src_lines):
        txt := dc.src_lines[lineno - 1]
        pad := ""                                  # spaces to push the caret under the token's column
        c := 0
        for c < col:
            pad = pad + " "
            c = c + 1
        die("line " + str(lineno) + ": " + msg + nl + "    " + txt + nl + "    " + pad + "^")
    if lineno > 0:
        die("line " + str(lineno) + ": " + msg)
    die(msg)

# warn_at: non-fatal diagnostic. Mirrors die_at (same tloc decode + snippet/caret)
# but writes stderr via eprint and does NOT exit. Used by the loop-progress check.
fn warn_at(dc: Decls, code: int, msg: string):
    nl := chr(10)
    lineno := code / 100000                        # decode tloc: 1-based line, 0-based col
    col := code % 100000
    if lineno > 0 and lineno <= len(dc.src_lines):
        txt := dc.src_lines[lineno - 1]
        pad := ""
        c := 0
        for c < col:
            pad = pad + " "
            c = c + 1
        eprint("line " + str(lineno) + ": warning: " + msg + nl + "    " + txt + nl + "    " + pad + "^" + nl)
        return
    if lineno > 0:
        eprint("line " + str(lineno) + ": warning: " + msg + nl)
        return
    eprint("warning: " + msg + nl)

# Loop-progress check (1:1 port of src/tychoc.c wl_*): a `for COND:` whose condition
# variables are never changed in the body (and which can't break/return/die) may
# spin forever. Sound under value semantics: a var changes only by assign-to-it,
# place-mutation (v[i]=/v.f=), push/pop(v,..), or &v passed to a inout param.
fn wl_root(e: Expr) -> string:                     # base identifier of a place: v / v[i] / v.f
    match e:
        EIndex(b, ix, p):
            return wl_root(b)
        EField(b, fld, p):
            return wl_root(b)
        EVar(n, p):
            return n
        EInt(t, p):
            return ""
        EBool(t, p):
            return ""
        EChar(t, p):
            return ""
        EFloat(t, p):
            return ""
        EStr(t, p):
            return ""
        EBin(op, l, r, p):
            return ""
        ECall(nm, args, p):
            return ""
        EArrLit(es, p):
            return ""
        EArrEmpty(t, p):
            return ""
        EMapEmpty(kt, vt, p):
            return ""
        EMapLit(ks, vls, p):
            return ""
        ETuple(es, p):
            return ""
        ESlice(b, lo, hi, p):
            return ""
        EAddr(x, p):
            return ""
        ELambda(lid, ps, pts, ret, lb, cn, ct, p):
            return ""
        ECallV(callee, cargs, p):
            return ""
        ESpawn(sid, snm, sargs, p):
            return ""

fn wl_cond_vars(e: Expr, vs: inout [string], hc: inout bool):   # collect cond idents; flag a call/spawn
    match e:
        ECall(nm, args, p):
            hc = true
        ECallV(callee, cargs, p):
            hc = true
        ESpawn(sid, snm, sargs, p):
            hc = true
        EVar(n, p):
            push(vs, n)
        EBin(op, l, r, p):
            wl_cond_vars(l, &vs, &hc)
            wl_cond_vars(r, &vs, &hc)
        EField(b, fld, p):
            wl_cond_vars(b, &vs, &hc)
        EIndex(b, ix, p):
            wl_cond_vars(b, &vs, &hc)
            wl_cond_vars(ix, &vs, &hc)
        ESlice(b, lo, hi, p):
            wl_cond_vars(b, &vs, &hc)
            wl_cond_vars(lo, &vs, &hc)
            wl_cond_vars(hi, &vs, &hc)
        EAddr(x, p):
            wl_cond_vars(x, &vs, &hc)
        ETuple(es, p):
            k := 0
            for k < len(es):
                wl_cond_vars(es[k], &vs, &hc)
                k = k + 1
        EArrLit(es, p):
            k := 0
            for k < len(es):
                wl_cond_vars(es[k], &vs, &hc)
                k = k + 1
        EMapLit(ks, vls, p):
            k := 0
            for k < len(ks):
                wl_cond_vars(ks[k], &vs, &hc)
                k = k + 1
            j := 0
            for j < len(vls):
                wl_cond_vars(vls[j], &vs, &hc)
                j = j + 1
        EInt(t, p):
            hc = hc
        EBool(t, p):
            hc = hc
        EChar(t, p):
            hc = hc
        EFloat(t, p):
            hc = hc
        EStr(t, p):
            hc = hc
        EArrEmpty(t, p):
            hc = hc
        EMapEmpty(kt, vt, p):
            hc = hc
        ELambda(lid, ps, pts, ret, lb, cn, ct, p):
            hc = hc

fn wl_scan_expr(e: Expr, muts: inout [string], ex: inout bool):   # &v / push/pop(v) / die hiding in an expr
    match e:
        EAddr(x, p):
            r := wl_root(x)
            if r != "":
                push(muts, r)
            wl_scan_expr(x, &muts, &ex)
        ECall(nm, args, p):
            if nm == "die":
                ex = true
            if (nm == "push" or nm == "pop") and len(args) >= 1:
                r := wl_root(args[0])
                if r != "":
                    push(muts, r)
            k := 0
            for k < len(args):
                wl_scan_expr(args[k], &muts, &ex)
                k = k + 1
        ECallV(callee, cargs, p):
            wl_scan_expr(callee, &muts, &ex)
            k := 0
            for k < len(cargs):
                wl_scan_expr(cargs[k], &muts, &ex)
                k = k + 1
        ESpawn(sid, snm, sargs, p):
            k := 0
            for k < len(sargs):
                wl_scan_expr(sargs[k], &muts, &ex)
                k = k + 1
        EBin(op, l, r, p):
            wl_scan_expr(l, &muts, &ex)
            wl_scan_expr(r, &muts, &ex)
        EField(b, fld, p):
            wl_scan_expr(b, &muts, &ex)
        EIndex(b, ix, p):
            wl_scan_expr(b, &muts, &ex)
            wl_scan_expr(ix, &muts, &ex)
        ESlice(b, lo, hi, p):
            wl_scan_expr(b, &muts, &ex)
            wl_scan_expr(lo, &muts, &ex)
            wl_scan_expr(hi, &muts, &ex)
        ETuple(es, p):
            k := 0
            for k < len(es):
                wl_scan_expr(es[k], &muts, &ex)
                k = k + 1
        EArrLit(es, p):
            k := 0
            for k < len(es):
                wl_scan_expr(es[k], &muts, &ex)
                k = k + 1
        EMapLit(ks, vls, p):
            k := 0
            for k < len(ks):
                wl_scan_expr(ks[k], &muts, &ex)
                k = k + 1
            j := 0
            for j < len(vls):
                wl_scan_expr(vls[j], &muts, &ex)
                j = j + 1
        ELambda(lid, ps, pts, ret, lb, cn, ct, p):
            wl_scan_expr(lb, &muts, &ex)
        EVar(n, p):
            ex = ex
        EInt(t, p):
            ex = ex
        EBool(t, p):
            ex = ex
        EChar(t, p):
            ex = ex
        EFloat(t, p):
            ex = ex
        EStr(t, p):
            ex = ex
        EArrEmpty(t, p):
            ex = ex
        EMapEmpty(kt, vt, p):
            ex = ex

fn wl_scan_body(stmts: [Stmt], muts: inout [string], ex: inout bool):
    i := 0
    for i < len(stmts):
        match stmts[i]:
            SDecl(n, e, p):
                push(muts, n)
                wl_scan_expr(e, &muts, &ex)
            SAssign(n, e, p):
                push(muts, n)
                wl_scan_expr(e, &muts, &ex)
            STypedDecl(n, t, e, p):
                push(muts, n)
                wl_scan_expr(e, &muts, &ex)
            SOrReturn(n, e, p):
                push(muts, n)
                wl_scan_expr(e, &muts, &ex)
            SForRange(n, a, b, st, body, p):
                push(muts, n)
                wl_scan_expr(a, &muts, &ex)
                wl_scan_expr(b, &muts, &ex)
                wl_scan_expr(st, &muts, &ex)
                wl_scan_body(body, &muts, &ex)
            SMultiAssign(ns, e, p):
                k := 0
                for k < len(ns):
                    push(muts, ns[k])
                    k = k + 1
                wl_scan_expr(e, &muts, &ex)
            SDestructure(ns, e, p):
                k := 0
                for k < len(ns):
                    push(muts, ns[k])
                    k = k + 1
                wl_scan_expr(e, &muts, &ex)
            SFieldAssign(lv, r, p):
                rt := wl_root(lv)
                if rt != "":
                    push(muts, rt)
                wl_scan_expr(lv, &muts, &ex)
                wl_scan_expr(r, &muts, &ex)
            SReturn(e, p):
                ex = true
            SConst(n, e, p):
                ex = ex
            SReturnVoid:
                ex = true
            SBreak:
                ex = true
            SContinue:
                i = i
            SIf(cnd, b, els, p):
                wl_scan_expr(cnd, &muts, &ex)
                wl_scan_body(b, &muts, &ex)
                wl_scan_body(els, &muts, &ex)
            SWhile(cnd, b, p):
                wl_scan_expr(cnd, &muts, &ex)
                wl_scan_body(b, &muts, &ex)
            SMatch(subj, vsn, bs, bodies, p):
                wl_scan_expr(subj, &muts, &ex)
                k := 0
                for k < len(bodies):
                    wl_scan_body(bodies[k], &muts, &ex)
                    k = k + 1
            SExpr(e, p):
                wl_scan_expr(e, &muts, &ex)
            SPrint(e, p):
                wl_scan_expr(e, &muts, &ex)
            SParFor(v, a, b, body, pid, p):
                push(muts, v)
                wl_scan_expr(a, &muts, &ex)
                wl_scan_expr(b, &muts, &ex)
                wl_scan_body(body, &muts, &ex)
            SSelect(uid, svars, schans, sbinds, sbodies, p):
                k := 0
                for k < len(schans):
                    wl_scan_expr(schans[k], &muts, &ex)
                    k = k + 1
                j := 0
                for j < len(sbodies):
                    wl_scan_body(sbodies[j], &muts, &ex)
                    j = j + 1
            SValDecl(n, ty, c, p):
                push(muts, n)
                wl_scan_body([c], &muts, &ex)
        i = i + 1

fn wl_check(cond: Expr, body: [Stmt], pos: int, dc: Decls):   # `body` is the loop body of a `for COND:`
    cv := []string
    hc := false
    wl_cond_vars(cond, &cv, &hc)
    if len(cv) == 0 or hc:                          # constant cond (`for true:`) or a call in it: skip
        return
    muts := []string
    ex := false
    wl_scan_body(body, &muts, &ex)
    if ex:                                          # a break/return/die can end the loop
        return
    i := 0
    for i < len(cv):
        if count_str_occ(muts, cv[i]) > 0:           # a condition variable is changed -> progresses
            return
        i = i + 1
    warn_at(dc, pos, "loop condition never changes; this `for` may run forever (forgot to advance a variable? consider `for x in range(...)`)")

# "pure" builtins: no side effect, so discarding the result in statement position
# is a no-op (map_set/map_del return a NEW map — a common footgun). Mirrors
# is_pure_builtin in src/tychoc.c.
fn is_pure_bi(n: string) -> bool:
    return n == "str" or n == "substr" or n == "chr" or n == "split" or n == "keys" or n == "find" or n == "map_get" or n == "map_has" or n == "map_set" or n == "map_del" or n == "sqrt" or n == "pow" or n == "floor" or n == "fabs" or n == "to_float" or n == "to_int" or n == "to_u32" or n == "to_u64" or n == "to_f32" or n == "to_str" or n == "to_bytes" or n == "to_ptr" or n == "to_i32" or n == "to_bool" or n == "is_null" or n == "len"

fn pure_call_name(e: Expr) -> string:              # the pure-builtin name if e is such a call, else ""
    match e:
        ECall(name, args, p):
            if is_pure_bi(name):
                return name
            return ""
        EInt(t, p):
            return ""
        EBool(t, p):
            return ""
        EChar(t, p):
            return ""
        EFloat(t, p):
            return ""
        EStr(t, p):
            return ""
        EVar(n, p):
            return ""
        EBin(op, l, r, p):
            return ""
        EField(b, fld, p):
            return ""
        EIndex(b, ix, p):
            return ""
        EArrLit(es, p):
            return ""
        EArrEmpty(t, p):
            return ""
        EMapEmpty(kt, vt, p):
            return ""
        EMapLit(ks, vls, p):
            return ""
        ETuple(es, p):
            return ""
        ESlice(b, lo, hi, p):
            return ""
        EAddr(x, p):
            return ""
        ELambda(lid, ps, pts, ret, lb, cn, ct, p):
            return ""
        ECallV(callee, cargs, p):
            return ""
        ESpawn(sid, snm, sargs, p):
            return ""

# Enter a nested block: a fresh child arena `_b<depth+1>` becomes the allocation
# owner for the block's transients/local decls. `base` is the env length at entry
# (vars declared from here on are block-local). Sibling blocks reuse the same
# name in separate C scopes; nested blocks get distinct names by depth.
fn enter_block(dc: Decls, ctx: Ctx, base: int) -> Ctx:
    d := ctx.depth + 1
    nb := ctx.bbases                              # push this block's entry index (depth d -> nb[d-1])
    push(nb, base)
    return Ctx(ctx.vparams, ctx.saccums, ctx.rettype, "&_b" + str(d), d, nb, ctx.movables, ctx.loopdepth, ctx.fusearr, ctx.fusesuf, ctx.fusety, ctx.line, ctx.curpkg)

# C lvalue of the current block's arena.
fn cur_arena(dc: Decls, ctx: Ctx) -> string:
    if ctx.depth == 0:
        return "&_scope"
    return "&_b" + str(ctx.depth)

# Free sequence a `return` must run: every enclosing block arena innermost-first,
# then the proc's own _scope. (The returned value lives in _parent, which
# outlives all of these.)
fn return_frees(dc: Decls, ctx: Ctx) -> string:
    out := ""
    k := ctx.depth
    for k > 0:
        out = out + "arena_free(&_b" + str(k) + "); "
        k = k - 1
    return out + "arena_free(&_scope);"

# break/continue free every block arena from the current depth down to AND
# INCLUDING the innermost loop's body arena (_b<loopdepth>). tychoc0 arena_child's
# the loop body at the top of each iteration and arena_free's it at the bottom,
# so a C break/continue that jumps over that free would leak it (plus any
# enclosing if-block arenas). Unlike return_frees this stops at the loop, not _scope.
fn loop_frees(dc: Decls, ctx: Ctx) -> string:
    out := ""
    k := ctx.depth
    for k >= ctx.loopdepth:
        out = out + "arena_free(&_b" + str(k) + "); "
        k = k - 1
    return out

# Mark a block ctx as a loop body: its own depth becomes the boundary that an
# enclosed break/continue frees down to (nested if-blocks inherit it via enter_block).
fn in_loop(ctx: Ctx) -> Ctx:
    return Ctx(ctx.vparams, ctx.saccums, ctx.rettype, ctx.owner, ctx.depth, ctx.bbases, ctx.movables, ctx.depth, ctx.fusearr, ctx.fusesuf, ctx.fusety, ctx.line, ctx.curpkg)

# Emitted C name for a USER variable / parameter / function identifier. Prefixed so a
# user name can never collide with tychoc0's emitted runtime helpers (sc/hs/amem/i2s/
# mk_*/Arr_*/...) or a C keyword (int/long/struct/default/...). Mirrors the C compiler's
# h_ scheme. Generated temps (_scope/_ret/_fc.../_ina_...) are emitted raw, never via un.
# `main` is the C entry point and is carved out upstream (gen_func early-returns it,
# the proto loop skips it, and nothing calls it), so it never reaches un.
fn un(n: string) -> string:
    return "h_" + n

# Emitted C name for a user STRUCT FIELD (member). f_ prefix so a field named a C
# keyword (default/case/...) is legal. Mirrors the C compiler. Positional tuple/soa
# fields (.f0/.f1) and enum variant union members are NOT routed through this (the
# latter matches the C compiler, which also leaves them raw).
fn uf(n: string) -> string:
    return "f_" + n

# Emitted C type names for user STRUCT (S_) and ENUM (E_) types — so a user type named
# a C keyword (default/...) or a generated family (Arr_int/HOption/...) can't collide.
# Mirrors the C compiler. The struct/enum NAME also labels generated families
# (Arr_<name>/Soa_<name>/<name>_copy) — those labels stay raw (they're distinct from the
# S_/E_ TYPE name, so no collision), only the C type and the type's own copy/eq/typedef
# identifiers are prefixed. tcopy/teq dispatch a copy/eq call site to the right prefix.
fn ust(n: string) -> string:
    return "S_" + n
fn uet(n: string) -> string:
    return "E_" + n
fn tcopy(dc: Decls, ctx: Ctx, ty: string) -> string:
    if is_enum(dc, ctx, ty):
        return uet(ty) + "_copy"
    return ust(ty) + "_copy"
fn teq(dc: Decls, ctx: Ctx, ty: string) -> string:
    if is_enum(dc, ctx, ty):
        return uet(ty) + "_eq"
    return ust(ty) + "_eq"

# Collect the leaf pieces of an all-string left-spine `+` chain into `out`
# (forward / source order). A string-`+` node recurses left then appends its rhs;
# anything else (incl. a sub-expr like `a + 'c'` that isn't a plain string-`+`) is
# a single leaf. Lets gen_expr flatten `a + b + c [..]` to one scN call.
fn concat_pieces(e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx, out: inout [Expr]):
    match e:
        EBin(op, l, r, _el):
            if op == "+" and type_of(l, names, types, dc, ctx) == "str" and type_of(r, names, types, dc, ctx) == "str":
                concat_pieces(l, names, types, dc, ctx, &out)
                push(out, r)
            else:
                push(out, e)
        EInt(t, _el):
            push(out, e)
        EBool(t, _el):
            push(out, e)
        EChar(t, _el):
            push(out, e)
        EFloat(t, _el):
            push(out, e)
        EStr(s, _el):
            push(out, e)
        EVar(n, _el):
            push(out, e)
        ECall(n, a, _el):
            push(out, e)
        EField(b, f, _el):
            push(out, e)
        EIndex(b, ix, _el):
            push(out, e)
        EArrLit(es, _el):
            push(out, e)
        EArrEmpty(t, _el):
            push(out, e)
        EMapEmpty(k, v, _el):
            push(out, e)
        EMapLit(ks, vs, _el):
            push(out, e)
        ETuple(es, _el):
            push(out, e)
        ESlice(b, lo, hi, _el):
            push(out, e)
        EAddr(x, _el):
            push(out, e)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            push(out, e)
        ECallV(callee, cargs, _el):
            push(out, e)
        ESpawn(sid, snm, sa, _el):
            push(out, e)

fn gen_expr(e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    match e:
        EInt(t, _el):
            return t
        EBool(t, _el):
            return t
        EChar(t, _el):
            return t
        EFloat(f, _el):
            return f
        EStr(s, _el):                                    # length-headered, interned once per occurrence (cached static)
            return "({ static char* _l = 0; if (!_l) _l = hi_intern(\"" + s + "\"); _l; })"
        EVar(name, _el):
            if name == "None":
                return "hnone()"
            if is_variant(dc, ctx, name):            # bare no-payload variant -> constructor call
                return gen_mk_name(dc, ctx, name) + "(" + ctx.owner + ")"
            if not has_str(names, name):             # not a local: a bare fn name -> the fat value {0, thunk}
                ft := sig_functype(dc, name)
                if ft != "":
                    return "(Fn_" + func_suffix(ft) + "){0, " + un(name) + "__clo, 0}"   # plain ref: no env to re-home
                return un(name)
            if is_inout(var_type(names, types, name)):   # inout param -> deref the pointer
                return "(*" + un(name) + ")"
            return un(name)
        EField(base, fld, _el):
            sf := soa_field_access(dc, ctx, base, fld, names, types)   # soa[i].f -> (soa).fN[i]
            if sf != "":
                return sf
            if is_tuple(type_of(base, names, types, dc, ctx)):   # tuple index t.0 -> t.f0
                return gen_expr(base, names, types, dc, ctx) + ".f" + fld
            return gen_expr(base, names, types, dc, ctx) + "." + uf(fld)
        EIndex(base, idx, _el):
            bt := type_of(base, names, types, dc, ctx)
            if bt == "str":                                 # s[i] -> the byte as an int, bounds-checked via the length header
                return "hi_sidx(" + gen_expr(base, names, types, dc, ctx) + ", " + gen_expr(idx, names, types, dc, ctx) + ")"
            if is_soa(bt):                                  # soa[i] -> gather a struct value
                return gen_soa_gather(dc, ctx, bt, gen_expr(base, names, types, dc, ctx), gen_expr(idx, names, types, dc, ctx))
            if is_map(bt):                                  # m[k] rvalue READ -> a PURE map_get (never inserts)
                vt := map_val(bt)
                z := map_read_zero(vt)                       # scalar value: literal zero (0 / 0.0 / "" / false)
                if z == "":                                  # composite value: the empty/zeroed (V){0} -- the SAME
                    z = "(" + cty(dc, ctx, vt) + "){0}"      # value slotptr inserts (empty array / zeroed struct)
                # Write targets / push / reserve route through gen_place -> the slot
                # lvalue instead, so reaching gen_expr here is always a read.
                return mfam(bt) + "_get(" + gen_expr(base, names, types, dc, ctx) + ", " + krt(dc, ctx, bt, gen_expr(idx, names, types, dc, ctx)) + ", " + z + ")"
            # array read a[i]: bounds-checked (hi_bchk) to match tychoc/runtime. The
            # descriptor is copied into _a so `base` is evaluated ONCE (a side-effecting
            # base like m[k] must not run twice). Nested a[i][j] -> nested blocks, each
            # with its own _a (block-scoped shadowing is fine).
            return "({ " + cty(dc, ctx, bt) + " _a = " + gen_expr(base, names, types, dc, ctx) + "; _a.data[hi_bchk(" + gen_expr(idx, names, types, dc, ctx) + ", _a.len)]; })"
        EArrLit(elems, _el):
            et := type_of(elems[0], names, types, dc, ctx)
            eo := "0"                              # deep-copied element temporaries
            if elem_deepcopy(dc, ctx, et):             # live in the array's arena (no leak);
                eo = ctx.owner                     # _from re-copies them into `ar` anyway
            return "Arr_" + mangle(et) + "_from(" + ctx.owner + ", (" + cty(dc, ctx, et) + "[]){" + gen_store_args_owner(elems, names, types, dc, ctx, eo) + "}, " + str(len(elems)) + ")"
        EArrEmpty(ety, _el):
            if is_soa(ety):                       # empty soa: zeroed descriptor
                return "(" + cty(dc, ctx, ety) + "){0}"
            return "Arr_" + mangle(ety) + "_new()"
        EMapEmpty(kty, vty, _el):                      # key+value mangled to match the family (a tuple key (int,str) -> tup_int_str)
            return "map_" + mangle(kty) + "_" + mangle(vty) + "_new()"
        EMapLit(keys, vals, _el):                      # chain of _set onto a fresh map
            mt := type_of(e, names, types, dc, ctx)
            f := mfam(mt)
            out := f + "_new()"
            j := 0
            for j < len(keys):
                # value in ctx.owner, not owner 0: _set's put deep-copies it into the map's
                # arena anyway, so an owner-0 (malloc) source leaks (same as the map_set fix).
                # String literals are interned (owner-independent) so existing cases are unchanged.
                out = f + "_set(" + ctx.owner + ", " + out + ", " + krt(dc, ctx, mt, gen_expr(keys[j], names, types, dc, ctx)) + ", " + gen_rhs(vals[j], names, types, dc, ctx) + ")"
                j = j + 1
            return out
        ETuple(elems, _el):                            # a tuple owns its fields: deep-copy place elements
            out := "(Tup_" + tup_suffix(type_of(e, names, types, dc, ctx)) + "){"
            j := 0
            for j < len(elems):
                if j > 0:
                    out = out + ", "
                out = out + gen_rhs(elems[j], names, types, dc, ctx)   # fields inherit the ambient arena (Tup_*_copy re-homes them on any cross-arena move; enum/box/field-store set owner 0 first to keep stored tuples immortal)
                j = j + 1
            return out + "}"
        ESlice(base, lo, hi, _el):
            bt := type_of(base, names, types, dc, ctx)
            if bt == "str":                       # s[a:b] -> a fresh substring
                return "substr(" + ctx.owner + ", " + gen_expr(base, names, types, dc, ctx) + ", " + gen_expr(lo, names, types, dc, ctx) + ", " + gen_expr(hi, names, types, dc, ctx) + ")"
            if is_soa(bt):
                return gen_soa_slice(dc, ctx, bt, gen_expr(base, names, types, dc, ctx), gen_expr(lo, names, types, dc, ctx), gen_expr(hi, names, types, dc, ctx))
            return "Arr_" + mangle(elem_ty(bt)) + "_slice(" + ctx.owner + ", " + gen_expr(base, names, types, dc, ctx) + ", " + gen_expr(lo, names, types, dc, ctx) + ", " + gen_expr(hi, names, types, dc, ctx) + ")"
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            suffix := func_suffix(mk_functype(pts, ret))
            if len(cn) == 0:
                return "(Fn_" + suffix + "){0, " + un("__lam" + str(id)) + "__clo, 0}"
            # captures: build the env as a compound literal and hbox it into the
            # OWNER arena (where this closure value is stored) — so a loop-local
            # closure is reclaimed each iteration with its block, not retained in the
            # function arena. Every escape re-homes the env via Env_<id>_copy.
            env := "(Env_" + str(id) + "[]){"
            j := 0
            for j < len(cn):
                if j > 0:
                    env = env + ", "
                cv := gen_expr(EVar(cn[j], _el), names, types, dc, ctx)
                if elem_deepcopy(dc, ctx, ct[j]):                          # heap capture: own a deep copy in the env arena (value semantics)
                    cv = cp_field(dc, ctx, ct[j], ctx.owner, cv)
                env = env + cv
                j = j + 1
            env = env + "}"
            return "(Fn_" + suffix + "){hbox(" + ctx.owner + ", sizeof(Env_" + str(id) + "), " + env + "), " + un("__lam" + str(id)) + "__clo, Env_" + str(id) + "_copy}"
        ECallV(callee, cargs, _el):
            cfn := efield_fname(callee)           # t.wait() / ch.send(v) / ch.recv() / ch.close() (CC):
            if is_conc_method(cfn):               # rewrite to the free-call form and recurse
                cbt := type_of(efield_base(callee), names, types, dc, ctx)
                if is_task(cbt) or is_chan(cbt):
                    nca := []Expr
                    push(nca, efield_base(callee))
                    cci := 0
                    for cci < len(cargs):
                        push(nca, cargs[cci])
                        cci = cci + 1
                    return gen_expr(ECall(cfn, nca, _el), names, types, dc, ctx)
            if cfn == "get":                      # m.get(k) == m[k] read; m.get(k, d) == m.get(k, d)
                gbt := type_of(efield_base(callee), names, types, dc, ctx)
                if is_map(gbt):
                    if len(cargs) == 1:
                        return gen_expr(EIndex(efield_base(callee), cargs[0], _el), names, types, dc, ctx)
                    if len(cargs) == 2:
                        nca := []Expr
                        push(nca, efield_base(callee))
                        push(nca, cargs[0])
                        push(nca, cargs[1])
                        return gen_expr(ECall("map_get", nca, _el), names, types, dc, ctx)
                    die("m.get(key) or m.get(key, default) takes one or two arguments")
            mn := ufcs_name(dc, ctx, names, types, callee)
            if mn != "":                          # UFCS method call: foo(recv, args)
                allargs := []Expr
                push(allargs, efield_base(callee))
                ci := 0
                for ci < len(cargs):
                    push(allargs, cargs[ci])
                    ci = ci + 1
                msi := dc.sigmap.get(mn, -1)     # sink-aware args: a `sink` receiver/param adopts-or-copies
                return un(mn) + "(" + ctx.owner + ", " + gen_call_args_sink(allargs, dc.sigs[msi].ptypes, names, types, dc, ctx) + ")"
            ct := cty(dc, ctx, type_of(callee, names, types, dc, ctx))
            code := "({ " + ct + "_f = " + gen_expr(callee, names, types, dc, ctx) + "; _f.call(_f.env, " + ctx.owner
            if len(cargs) > 0:
                code = code + ", " + gen_call_args(cargs, names, types, dc, ctx)
            return code + "); })"
        EAddr(inner, _el):                             # &(*p) == p, so passing a inout param onward works
            if is_place(inner):   # &place: take the real storage lvalue via gen_place, which recurses the field/index spine (map slot ptr, checked array element, struct field). gen_expr lowers m[k]/a[i] to non-assignable reads (map_get / checked stmt-expr), so &gen_expr would be address-of-rvalue and either fail to compile or alias a copy.
                return "&" + gen_place(inner, names, types, dc, ctx)
            return "&" + gen_expr(inner, names, types, dc, ctx)
        EBin(op, l, r, _el):
            lt := type_of(l, names, types, dc, ctx)
            if op == "not":                       # logical not: operand MUST be bool (matches tychoc; fixes the `not <non-bool>` fail-open)
                if lt != "bool":
                    die_at(dc, _el, "not needs a bool operand")
                return "(!" + gen_expr(l, names, types, dc, ctx) + ")"
            if op == "u-":                        # unary minus: base must be int/float (numeric newtype ok, like tychoc's base_of)
                if resolve_nt(dc, ctx, lt) != "int" and resolve_nt(dc, ctx, lt) != "float":
                    die_at(dc, _el, "unary - needs an int or a float")
                return "(0 - " + gen_expr(l, names, types, dc, ctx) + ")"   # emit the (0 - E) directly (byte-identical to the old EBin desugar) WITHOUT re-entering the binary newtype-identity check, which would reject `0 - newtype` -- `-newtype` is valid, the user's `0 - newtype` is not, and tychoc0 can't tell them apart once desugared
            if op == "u~":                        # unary bitwise NOT: operand must be int/u32/u64 (not float/char, not a newtype). For an unsigned operand `((0 - E) - 1)` computes 2^w - E - 1 = ~E in C, so the same emit is correct at every width.
                ubase := resolve_nt(dc, ctx, lt)
