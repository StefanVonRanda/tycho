            if (op == "/" or op == "%") and (rlt == "u32" or rlt == "u64"):   # unsigned guard (div/mod by zero aborts cleanly)
                gfn := "hi_udiv"
                if op == "%":
                    gfn = "hi_umod"
                return gfn + "(" + gen_expr(l, names, types, dc, ctx) + ", " + gen_expr(r, names, types, dc, ctx) + ")"
            return "(" + gen_expr(l, names, types, dc, ctx) + " " + op + " " + gen_expr(r, names, types, dc, ctx) + ")"
        ECall(name, args, _el):
            zmk := find(name, "$<")
            if zmk >= 0 and substr(name, 0, zmk) == "zero":   # zero$<T>: emit the scalar zero LITERAL (same node the map-read zero uses; byte-identical with tychoc's scalar_zero_expr lowering)
                if len(args) != 0:
                    die_at(dc, ctx.line, "zero$(T) takes no value arguments")
                zt := substr(name, zmk + 2, len(name) - 1)
                if find(zt, ";") >= 0:
                    die_at(dc, ctx.line, "zero$(T) takes exactly one type argument")
                if zt == "int":
                    return gen_expr(EInt("0", _el), names, types, dc, ctx)
                if zt == "float":
                    return gen_expr(EFloat("0.0", _el), names, types, dc, ctx)
                if zt == "bool":
                    return gen_expr(EBool("0", _el), names, types, dc, ctx)
                if zt == "str":
                    return gen_expr(EStr("", _el), names, types, dc, ctx)
                die_at(dc, ctx.line, "zero$(" + zt + "): only int, float, bool, and string are defaultable")
            cdi := find(name, ".")
            if cdi >= 0 and has_str(names, substr(name, 0, cdi)):   # `h.cb(args)` where h is a LOCAL: a fn-field call
                return gen_expr(ECallV(EField(EVar(substr(name, 0, cdi), _el), substr(name, cdi + 1, len(name)), _el), args, _el), names, types, dc, ctx)
            if name == "push":                    # push(arr, v): mutate in place
