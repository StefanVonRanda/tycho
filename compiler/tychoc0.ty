            elif is_cmp(op):     # ordering: same newtype identity + an orderable base; an int LITERAL adapts to a float operand, a numeric literal to a u32/u64/f32 (all non-newtype)
                lit_ok := (rlt == "float" and frlt == "int" and is_int_lit(r) and sl == "" and sr == "") or (rlt == "int" and frlt == "float" and is_int_lit(l) and sl == "" and sr == "")
                if not (lit_ok or num_lit_ok or (sl == sr and rlt == frlt and (rlt == "int" or rlt == "float" or rlt == "char"))):
                    die_at(dc, _el, "ordering compares two ints, two floats, two strings, or two values of the same numeric newtype")
            else:                # arithmetic + - * /
                lit_ok := (rlt == "float" and frlt == "int" and is_int_lit(r) and sl == "" and sr == "") or (rlt == "int" and frlt == "float" and is_int_lit(l) and sl == "" and sr == "")
                char_ok := (op == "+" or op == "-") and (lt == "char" or frt == "char") and (lt == "char" or rlt == "int") and (frt == "char" or frlt == "int")
                if not (lit_ok or char_ok or num_lit_ok or (sl == sr and rlt == frlt and (rlt == "int" or rlt == "float"))):
