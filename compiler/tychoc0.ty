                rty := type_of(r, names, types, dc, ctx)
                if lt != rty:
                    die_at(dc, _el, "cannot compare " + lt + " with " + rty)
                eqx := eq_field(dc, ctx, lt, gen_expr(l, names, types, dc, ctx), gen_expr(r, names, types, dc, ctx))
                if op == "!=":
                    return "(!(" + eqx + "))"
                return eqx
