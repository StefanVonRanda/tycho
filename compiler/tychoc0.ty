                rint := (frlt == "int" or frlt == "u32" or frlt == "u64") and sr == ""
                if not lint or not rint:
                    die_at(dc, _el, "shift operators require integer operands")
            elif op == "%" or op == "&" or op == "|" or op == "^":   # modulo / bitwise: two matching integer widths (int/u32/u64), or a uint with an adapting int literal
                intl := (rlt == "int" or rlt == "u32" or rlt == "u64") and sl == ""
                intr := (frlt == "int" or frlt == "u32" or frlt == "u64") and sr == ""
                uint_lit := ((rlt == "u32" or rlt == "u64") and frlt == "int" and is_int_lit(r)) or ((frlt == "u32" or frlt == "u64") and rlt == "int" and is_int_lit(l))
                if not intl or not intr or not (rlt == frlt or uint_lit):
