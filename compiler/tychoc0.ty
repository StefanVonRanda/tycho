            # x%0 and LONG_MIN/-1 still trap (SIGFPE). Route int `/` and `%` (incl. an
            # int newtype, rlt=="int") through the runtime guard, which aborts cleanly
            # with a tycho: message. Float `/` is IEEE (x/0.0 = inf), left as a raw op.
            if (op == "/" or op == "%") and rlt == "int":
