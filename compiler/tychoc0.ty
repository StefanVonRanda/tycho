                if is_soa(at):                    # soa push: grow each field buffer (in the soa's arena) + scatter
                    return "Soa_" + soa_struct(at) + "_push(" + owner_arena_of(args[0], names, types, dc, ctx) + ", &" + gen_place(args[0], names, types, dc, ctx) + ", " + gen_rhs(args[1], names, types, dc, with_owner(dc, ctx, "0")) + ")"
                et := elem_ty(at)
                pv := evar_name(args[0])              # push-loop fusion: register-resident cursor write
                if pv != "" and count_str_occ(ctx.fusearr, pv) > 0:
                    fi := 0
                    for fi < len(ctx.fusearr):
                        if ctx.fusearr[fi] == pv:
                            suf := ctx.fusesuf[fi]
                            ow := owner_arena_of(args[0], names, types, dc, ctx)
                            gname := "Arr_" + mangle(ctx.fusety[fi]) + "_grow"
                            v := gen_expr(args[1], names, types, dc, ctx)
                            if elem_deepcopy(dc, ctx, et):    # heap element (str): deep-copy into the array's arena, like the non-fused push
                                v = gen_rhs(args[1], names, types, dc, with_owner(dc, ctx, ow))
                            return "({ if (_fl" + suf + " == _fc" + suf + ") " + gname + "(" + ow + ", &_fd" + suf + ", &_fc" + suf + ", _fl" + suf + "); _fd" + suf + "[_fl" + suf + "++] = " + v + "; })"
                        fi = fi + 1
                oa := owner_arena_of(args[0], names, types, dc, ctx)   # array's home arena (buffer + deep-copied elements)
                vo := ctx.owner                    # a scalar element needs no arena, but a nested TRANSIENT alloc
                                                   # (e.g. str() consumed by len()) must be freed with the current
                                                   # scope, not malloc'd at owner-0 and leaked (leak fuzzer found it)
                if elem_deepcopy(dc, ctx, et):         # deep-copy elements (str/struct) are STORED in the array's arena
                    vo = oa
                return "Arr_" + mangle(et) + "_push(" + oa + ", &" + gen_place(args[0], names, types, dc, ctx) + ", " + gen_rhs(args[1], names, types, dc, with_owner(dc, ctx, vo)) + ")"
            if name == "pop":                     # pop(arr): remove + return the last element
                pat := type_of(args[0], names, types, dc, ctx)
                if is_soa(pat):
                    return "Soa_" + soa_struct(pat) + "_pop(&" + gen_place(args[0], names, types, dc, ctx) + ")"
                # result is deep-copied into ctx.owner (the array buffer may recycle), so
                # the popped value is independent of the (shrunk) array. Scalars pass through.
                return "Arr_" + mangle(elem_ty(pat)) + "_pop(" + ctx.owner + ", &" + gen_place(args[0], names, types, dc, ctx) + ")"
            if name == "reserve":                 # reserve(arr, n): preallocate exact capacity
                rt := elem_ty(type_of(args[0], names, types, dc, ctx))
                ra := owner_arena_of(args[0], names, types, dc, ctx)
                return "Arr_" + mangle(rt) + "_reserve(" + ra + ", &" + gen_place(args[0], names, types, dc, ctx) + ", " + gen_expr(args[1], names, types, dc, ctx) + ")"
            if name == "len":
                lent := type_of(args[0], names, types, dc, ctx)
                if not (is_array(lent) or lent == "str" or lent == "bytes" or is_map(lent) or is_soa(lent)):   # reject len on a scalar. Was a fail-open: tychoc0 emitted `.len` on a non-aggregate (broken C). Matches tychoc (src/tychoc.c ~4128).
                    die_at(dc, ctx.line, "len(...) takes an array, a string, bytes, a map, or a soa")
                if lent == "str" or lent == "bytes":
                    return "((const long*)(" + gen_expr(args[0], names, types, dc, ctx) + "))[-1]"   # O(1): the length header
                return gen_expr(args[0], names, types, dc, ctx) + ".len"
            if name == "str":
                at := type_of(args[0], names, types, dc, ctx)
                if at == "str":                                  # str(string) is identity (interpolation)
                    return gen_expr(args[0], names, types, dc, ctx)
                if at == "float" or at == "f32":                 # f32 promotes to double
                    return "f2s(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
                if at == "bool":
                    return "b2s(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
                if at == "u32" or at == "u64":
                    return "u2s(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
                if resolve_nt(dc, ctx, at) != "int":   # only int (incl. newtype-of-int) -> i2s; reject char/ptr/enum/etc. so tychoc0 fails closed like tychoc (str(char) was silently printing the byte value)
                    die_at(dc, ctx.line, "str(x) takes an int, a u32/u64/f32, a bool, a float, or a string")
                return "i2s(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "sqrt" or name == "floor" or name == "fabs":
                return name + "(" + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "pow":
                return "pow(" + gen_expr(args[0], names, types, dc, ctx) + ", " + gen_expr(args[1], names, types, dc, ctx) + ")"
            if name == "to_float":
                return "((double)(" + gen_expr(args[0], names, types, dc, ctx) + "))"
            if name == "to_int":
                return "((long)(" + gen_expr(args[0], names, types, dc, ctx) + "))"
            if name == "to_u32":                          # -> u32 (truncate to low 32 bits)
                return "((unsigned int)(" + gen_expr(args[0], names, types, dc, ctx) + "))"
            if name == "to_u64":                          # -> u64
                return "((unsigned long long)(" + gen_expr(args[0], names, types, dc, ctx) + "))"
            if name == "to_f32":                          # -> f32 (single precision)
                return "((float)(" + gen_expr(args[0], names, types, dc, ctx) + "))"
            if name == "to_ptr":                          # FFI: int -> opaque ptr sentinel (e.g. SQLITE_TRANSIENT = (void*)-1); never deref'd in tycho
                return "((void*)(long)(" + gen_expr(args[0], names, types, dc, ctx) + "))"
            if name == "to_i32":                          # FFI: sign-extend a 32-bit C int return (low 32 bits valid; cast recovers the sign)
                return "((long)(int)(" + gen_expr(args[0], names, types, dc, ctx) + "))"
            if name == "to_str" or name == "to_bool" or name == "to_under" or name == "to_bytes":   # zero-cost newtype unwrap / bytes<->str reinterpret (same char* repr)
                return gen_expr(args[0], names, types, dc, ctx)
            if name == "substr":
                return "substr(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ", " + gen_expr(args[1], names, types, dc, ctx) + ", " + gen_expr(args[2], names, types, dc, ctx) + ")"
            if name == "find":
                return "hi_find(" + gen_expr(args[0], names, types, dc, ctx) + ", " + gen_expr(args[1], names, types, dc, ctx) + ")"
            if name == "split":
                return "hi_split(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ", " + gen_expr(args[1], names, types, dc, ctx) + ")"
            if name == "map_set":
                # value built in the map's arena (ctx.owner), NOT owner 0: _set's put deep-copies
                # it into that same arena anyway, so an owner-0 (malloc) source is pure leak -- it's
                # abandoned after the copy. ctx.owner is freed with the map; an escaping map re-copies
                # its values (map_copy/cp_field) so this can't dangle. (in-place self-mapset already
                # uses &_scope; this matches it for the param / non-self case.)
                return mfam(type_of(args[0], names, types, dc, ctx)) + "_set(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ", " + krt(dc, ctx, type_of(args[0], names, types, dc, ctx), gen_expr(args[1], names, types, dc, ctx)) + ", " + gen_rhs(args[2], names, types, dc, ctx) + ")"
            if name == "map_get":
                mt := type_of(args[0], names, types, dc, ctx)
                g := mfam(mt) + "_get(" + gen_expr(args[0], names, types, dc, ctx) + ", " + krt(dc, ctx, mt, gen_expr(args[1], names, types, dc, ctx)) + ", " + gen_expr(args[2], names, types, dc, ctx) + ")"
                return cp_field(dc, ctx, map_val(mt), ctx.owner, g)   # get returns a borrow into the map (or default) -> deep-copy into the caller's arena (passthrough for scalar values)
            if name == "keys":
                return mfam(type_of(args[0], names, types, dc, ctx)) + "_keys(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "map_del":
                return mfam(type_of(args[0], names, types, dc, ctx)) + "_del(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ", " + krt(dc, ctx, type_of(args[0], names, types, dc, ctx), gen_expr(args[1], names, types, dc, ctx)) + ")"
            if name == "map_has":
                return mfam(type_of(args[0], names, types, dc, ctx)) + "_has(" + gen_expr(args[0], names, types, dc, ctx) + ", " + krt(dc, ctx, type_of(args[0], names, types, dc, ctx), gen_expr(args[1], names, types, dc, ctx)) + ")"
            if name == "chr":
                return "hi_chr(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "die":
                return "hi_die(" + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "eprint":
                return "hi_eprint(" + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "read_all":
                return "hi_read_all(" + ctx.owner + ")"
            if name == "clock":                   # monotonic ns; no arena (scalar)
                return "hi_clock()"
            if name == "now":                     # wall-clock seconds
                return "hi_now()"
            if name == "ncpu":                    # parallel-for fan-out width (runtime fn used by gen_parfor)
                return "((long)tycho_ncpu())"
            if name == "read_file":
                return "hi_read_file(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "write_file":              # (path, contents) -> bool; no arena (no alloc)
                return "hi_write_file(" + gen_expr(args[0], names, types, dc, ctx) + ", " + gen_expr(args[1], names, types, dc, ctx) + ")"
            if name == "list_dir":
                return "hi_list_dir(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "args":
                return "hi_args(" + ctx.owner + ")"
            if name == "getenv":                  # env var value, or "" if unset
                return "hi_getenv(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "null":                    # FFI opaque ptr literal
                return "((void*)0)"
            if name == "is_null":                 # FFI: opaque-handle NULL test
                return "((" + gen_expr(args[0], names, types, dc, ctx) + ") == 0)"
            if name == "input":
                return "hi_input(" + ctx.owner + ")"
            if name == "Some":                    # box the payload in the SAME arena as the box, so a
                ct := cty(dc, ctx, type_of(args[0], names, types, dc, ctx))   # heap payload frees with it instead of
                return "hsome(hbox(" + ctx.owner + ", sizeof(" + ct + "), (" + ct + "[]){" + gen_rhs(args[0], names, types, dc, ctx) + "}))"   # leaking at owner-0 (every copy path deep-copies via box_payload)
            if name == "Ok":
                ct := cty(dc, ctx, type_of(args[0], names, types, dc, ctx))
                return "hok(hbox(" + ctx.owner + ", sizeof(" + ct + "), (" + ct + "[]){" + gen_rhs(args[0], names, types, dc, ctx) + "}))"
            if name == "Err":
                ce := cty(dc, ctx, type_of(args[0], names, types, dc, ctx))
                return "herr(hbox(" + ctx.owner + ", sizeof(" + ce + "), (" + ce + "[]){" + gen_rhs(args[0], names, types, dc, ctx) + "}))"
            if has_prefix(name, "channel:"):      # channel(T, cap): create the shared bounded queue (CC-4)
                return "tycho_chan_new(" + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "wait" and len(args) == 1 and is_task(type_of(args[0], names, types, dc, ctx)):
                # join; deep-copy the result out of the task's root arena into the
                # destination (ctx.owner); free the arena tree eagerly. A NAMED handle's
                # struct stays alive to its scope-exit tycho_task_finish (so a second
                # wait dies on the done flag); an anonymous wait(spawn ...) frees all.
                wt := task_inner(type_of(args[0], names, types, dc, ctx))
                wct := cty(dc, ctx, wt)
                wfree := "arena_free(&_tk->root);"
                if evar_name(args[0]) == "":
                    wfree = "tycho_task_free(_tk);"
                return "({ HTask* _tk = " + gen_expr(args[0], names, types, dc, ctx) + "; tycho_task_join(_tk); " + wct + "_w = " + cp_field(dc, ctx, wt, ctx.owner, "(*(" + wct + "*)_tk->ret)") + "; " + wfree + " _w; })"
            if name == "send" and len(args) == 2 and is_chan(type_of(args[0], names, types, dc, ctx)):
                # deep-copy the payload into the CLAIMED cell's arena -- exclusive
                # between claim and commit, no lock held (CC-5); every element type
                sty := chan_inner(type_of(args[0], names, types, dc, ctx))
                sct := cty(dc, ctx, sty)
                return "({ HChan* _ch = " + gen_expr(args[0], names, types, dc, ctx) + "; HCell* _c = tycho_chan_send_cell(_ch); " + sct + "* _p = (" + sct + "*)amem(&_c->arena, sizeof(" + sct + ")); *_p = " + cp_field(dc, ctx, sty, "(&_c->arena)", gen_expr(args[1], names, types, dc, ctx)) + "; tycho_chan_send_commit(_ch, _c, _p); })"
            if name == "recv" and len(args) == 1 and is_chan(type_of(args[0], names, types, dc, ctx)):
                # Option(T): tag 0 (None) = closed and drained; the value deep-copies
                # out of the claimed cell into the destination arena before commit
                rty := chan_inner(type_of(args[0], names, types, dc, ctx))
                rct := cty(dc, ctx, rty)
                return "({ HChan* _ch = " + gen_expr(args[0], names, types, dc, ctx) + "; HOption _co; HCell* _rc = tycho_chan_recv_cell(_ch); if (_rc) { " + rct + " _v = " + cp_field(dc, ctx, rty, ctx.owner, "(*(" + rct + "*)_rc->val)") + "; tycho_chan_recv_commit(_ch, _rc); _co = hsome(hbox(" + ctx.owner + ", sizeof(" + rct + "), &_v)); } else { _co = hnone(); } _co; })"
            if name == "close" and len(args) == 1 and is_chan(type_of(args[0], names, types, dc, ctx)):
                return "tycho_chan_close(" + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "close" and len(args) == 1 and is_handle(dc, type_of(args[0], names, types, dc, ctx)):
                # FFI R2 early close: run the destructor now and NULL the handle so the
                # (null-guarded) scope-exit finalizer is a no-op -- free_fn runs exactly once.
                match args[0]:
                    EVar(vn, _ev):
                        hv := gen_expr(args[0], names, types, dc, ctx)
                        ff := handle_free(dc, type_of(args[0], names, types, dc, ctx))
                        return "({ if (" + hv + ") { " + ff + "(" + hv + "); " + hv + " = 0; } })"
                    _:
                        die("close(h) takes a handle variable")
            if is_newtype(dc, ctx, name):             # X(v) is zero-cost: identity
                return gen_expr(args[0], names, types, dc, ctx)
            if is_variant(dc, ctx, name):             # enum construction -> mk_<enum>_<variant>(ar, ...); node
                if len(args) == 0:                    # nullary variant (e.g. `Leaf$(int)`): no payload args, no trailing comma
                    return gen_mk_name(dc, ctx, name) + "(" + ctx.owner + ")"
                return gen_mk_name(dc, ctx, name) + "(" + ctx.owner + ", " + gen_store_args_owner(args, names, types, dc, ctx, ctx.owner) + ")"   # + payload fields inherit the ambient arena (nested children co-located)
            if is_struct(dc, ctx, name):              # struct construction -> compound literal; fields
                return "(" + ust(name) + "){" + gen_store_args_owner(args, names, types, dc, ctx, ctx.owner) + "}"   # inherit the ambient arena (an array elem -> the array's; a return -> _parent; an enum/box/field-store sets owner 0 first, keeping those immortal)
            if sig_is_extern(dc, name):               # FFI: call the C symbol directly — no arena, no h_ prefix
                edecls := ""                          # single-eval temps for bytes args
                xa := ""
                emitted := 0
                nb := 0
                ai := 0
                for ai < len(args):
                    av := gen_expr(args[ai], names, types, dc, ctx)
                    if emitted > 0:
                        xa = xa + ", "
                    if type_of(args[ai], names, types, dc, ctx) == "bytes":   # bytes -> (const unsigned char* ptr, long len)
                        tv := "_xb" + str(nb)
                        nb = nb + 1
                        edecls = edecls + "char* " + tv + " = " + av + "; "
                        xa = xa + "(const unsigned char*)" + tv + ", ((const long*)" + tv + ")[-1]"
                    else:
                        xa = xa + av                  # tycho str is already char* -> zero-cost arg
                    emitted = emitted + 1
                    ai = ai + 1
                ert := sig_ret(dc, ctx, name)
                if ert == "bytes":                    # out-param shim: call, copy the C buffer into an arena bytes, free it
                    pre := ""
                    if emitted > 0:
                        pre = ", "
                    return "({ " + edecls + "unsigned char* _bo = 0; long _bol = 0; " + name + "(" + xa + pre + "&_bo, &_bol); b_from_c(" + ctx.owner + ", _bo, _bol); })"
                xc := name + "(" + xa + ")"
                if edecls != "":                      # bytes args need single-eval temps -> wrap the call in a stmt-expr
                    xc = "({ " + edecls + name + "(" + xa + "); })"
                if is_option(ert) and option_inner(ert) == "str":   # FFI R3a: NULL -> None, else Some(arena-copied string)
                    return "({ const char* _x = " + xc + "; _x ? hsome(hbox(" + ctx.owner + ", sizeof(char*), (char*[]){ s_from_c(" + ctx.owner + ", _x) })) : hnone(); })"
                if ert == "str":                      # C-owned return -> copy into the arena (NULL -> "")
                    return "s_from_c(" + ctx.owner + ", ({ const char* _x = " + xc + "; _x ? _x : \"\"; }))"
                return xc
            if has_str(names, name) and is_func(var_type(names, types, name)):   # indirect call through a fn value: g.call(g.env, arena, args)
                cl := un(name) + ".call(" + un(name) + ".env, " + ctx.owner
                if len(args) > 0:
                    cl = cl + ", " + gen_call_args(args, names, types, dc, ctx)
                return cl + ")"
            # fail-closed: builtins, ctors (struct/enum/newtype), extern, and
            # fn-value calls are all handled above, so a name that reaches here
            # but is not a known user function is a call to something undefined.
            # (A value-position call is already caught in type_of; this covers
            # the statement position, whose result -- and thus type_of -- is unused.)
            csidx := dc.sigmap.get(name, -1)
            if csidx < 0:
                die_at(dc, ctx.line, "type: unknown function '" + name + "'")
            if len(args) == 0:                    # user call: thread the current scope as the callee's _parent
                return un(name) + "(" + ctx.owner + ")"
            return un(name) + "(" + ctx.owner + ", " + gen_call_args_sink(args, dc.sigs[csidx].ptypes, names, types, dc, ctx) + ")"
        ESpawn(id, nm, sargs, _el):
            # CC-1 spawn site: copy every argument into the task's private root
            # arena (after this, spawner and task share zero bytes), then start
            # the thread on the per-site trampoline emitted by the driver.
            sid := str(id)
            spt := sig_ptypes(dc, nm)
            sout := "({ HTask* _tk = tycho_task_new(); HSpawnA_" + sid + "* _sa = (HSpawnA_" + sid + "*)amem(&_tk->root, sizeof(HSpawnA_" + sid + ")); _sa->t = _tk;"
            sk := 0
            for sk < len(sargs):
                sout = sout + " _sa->a" + str(sk) + " = " + cp_field(dc, ctx, spt[sk], "(&_tk->root)", gen_expr(sargs[sk], names, types, dc, ctx)) + ";"
                sk = sk + 1
            return sout + " tycho_task_start(_tk, tycho_spawn_" + sid + ", _sa); _tk; })"

# Root variable of a place expression (`s.items[i]` -> `s`), or "" if not a
# place rooted in a variable. Used to find which arena a container lives in.
fn root_var(e: Expr) -> string:
    match e:
        EVar(n, _el):
            return n
        EField(b, f, _el):
            return root_var(b)
        EIndex(b, i, _el):
            return root_var(b)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return ""
        ECallV(callee, cargs, _el):
            return ""
        EAddr(x, _el):
            return root_var(x)
        EInt(t, _el):
            return ""
        EBool(t, _el):
            return ""
        EChar(t, _el):
            return ""
        EFloat(f, _el):
            return ""
        EStr(s, _el):
            return ""
        EBin(o, l, r, _el):
            return ""
        ECall(n, a, _el):
            return ""
        EArrLit(es, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        EMapLit(ks, vs, _el):
            return ""
        ETuple(es, _el):
            return ""
        ESlice(b, lo, hi, _el):
            return ""
        ESpawn(id, nm, a, _el):
            return ""

# The arena a container place lives in: a inout-param container is the caller's
# (its buffer must grow in _parent so it survives the call); a local lives in
# this function's _scope. (One scope per function until MM-5 adds per-block.)
# Most recent declaration index of `name` in the env (-1 if absent). Searches
# from the end so a shadowing inner decl wins.
fn var_index(names: [string], name: string) -> int:
    i := len(names) - 1
    for i >= 0:
        if names[i] == name:
            return i
        i = i - 1
    return -1

# The arena a container place lives in (so a push/grow lands where the container
# itself lives). inout-param array/map/soa: its home arena, threaded as the hidden
# `_ina_<name>` param (so the grow frees with the caller's container instead of
# malloc-leaking). inout scalar/struct: malloc ("0", immortal — no _ina_). A var
# declared in the current block (index >= block_base): the block arena, freed at
# block exit / per loop iteration. An outer-scope local: the function _scope.
# Does an array of element type `et` deep-copy its elements (vs shallow memcpy)?
# True for heap element types whose copy fn is reachable from Arr_*_from:
#   - str  -> scopy (preamble; always available).
#   - array (nested [[T]]) -> the inner Arr_*_copy, forward-declared by gen_arr_type.
#   - tuple / heap struct -> Tup_*_copy / Struct_copy, forward-declared (step 5b).
#   - option / result -> re-boxed via hbox/hsome/... (preamble; payload shared,
#     immortal, so shallow). map/non-heap-struct elements stay shallow memcpy.
fn elem_deepcopy(dc: Decls, ctx: Ctx, et: string) -> bool:
    if resolve_nt(dc, ctx, et) == "str" or et == "bytes":   # bytes shares str's heap buffer -> deep-copy on value binding
        return true
    if is_func(et):                                          # a closure element carries an env to re-home on escape
        return true
    if is_array(et):
        return true
    if is_tuple(et):
        return true
    if is_option(et) or is_result(et):                       # re-box into the array's arena
        return true
    if is_enum(dc, ctx, et):                                     # deep-copy the node tree into the arena
        return true
    return is_struct(dc, ctx, et) and struct_is_heap(dc, ctx, et)   # only heap structs have a _copy fn

# The 3rd arg to hbox for an option/result payload of Tycho type `ty`, whose boxed
# value sits at `*(<ct>*)valptr`. A HEAP payload (str/array/struct/nested option…)
# is deep-copied into `ar` so it frees with the box instead of leaking at owner-0
# (the [Option(str)]/[Result([int],_)] element residual); a scalar payload's bytes
# live inside the box already, so a shallow re-box (the raw pointer) is sound.
# Mirrors tychoc's tycho_optN_copy (`if (v.has) v.val = tycho_str_copy(a, v.val)`).
fn box_payload(dc: Decls, ctx: Ctx, ty: string, ar: string, valptr: string) -> string:
    ct := cty(dc, ctx, ty)
    if elem_deepcopy(dc, ctx, ty):
        return "(" + ct + "[]){" + cp_field(dc, ctx, ty, ar, "(*(" + ct + "*)(" + valptr + "))") + "}"
    return valptr

# The C expression that deep-copies one element of type `et` (from `src`) into
# arena `ar`. Only called for elem_deepcopy types: str copies its bytes; a
# nested array / tuple / heap struct recurses through its own _copy (re-homing
# its buffer and, transitively, every str/array/struct/tuple sub-element). The
# copy fns are forward-declared (gen_arr_type for arrays; the struct/tuple copy
# protos emitted before the array fns) so order never matters.
fn elem_copy_expr(dc: Decls, ctx: Ctx, et: string, ar: string, src: string) -> string:
    if resolve_nt(dc, ctx, et) == "str":
        return "scopy(" + ar + ", " + src + ")"
    if is_func(et):                                  # a fn value: re-home its env into `ar` (plain ref env==0 -> no-op)
        return "({ Fn_" + func_suffix(et) + " _t = (" + src + "); if (_t.env) _t.env = _t.copyenv(" + ar + ", _t.env); _t; })"
    if is_array(et):
        return "Arr_" + mangle(elem_ty(et)) + "_copy(" + ar + ", " + src + ")"
    if is_tuple(et):
        return "Tup_" + tup_suffix(et) + "_copy(" + ar + ", " + src + ")"
    if is_option(et):                                # re-box the payload into `ar`; box_payload
        ict := cty(dc, ctx, option_inner(et))            # deep-copies a HEAP inner (else shallow re-box)
        return "(" + src + ".tag ? hsome(hbox(" + ar + ", sizeof(" + ict + "), " + box_payload(dc, ctx, option_inner(et), ar, src + ".val") + ")) : hnone())"
    if is_result(et):
        oct := cty(dc, ctx, result_ok(et))
        ect := cty(dc, ctx, result_err(et))
        return "(" + src + ".tag == 1 ? hok(hbox(" + ar + ", sizeof(" + oct + "), " + box_payload(dc, ctx, result_ok(et), ar, src + ".ok") + ")) : herr(hbox(" + ar + ", sizeof(" + ect + "), " + box_payload(dc, ctx, result_err(et), ar, src + ".err") + ")))"
    return tcopy(dc, ctx, et) + "(" + ar + ", " + src + ")"   # heap struct OR enum: S_/E_ _copy

# Deep-copy a value of Tycho type `ty` from `src` into arena `ar` (the C expr) —
# full type dispatch, used to copy enum payload fields (which may be any type).
# Scalars / non-heap structs pass through; everything heap routes to its _copy.
fn cp_field(dc: Decls, ctx: Ctx, ty: string, ar: string, src: string) -> string:
    rt := resolve_ginst(resolve_nt(dc, ctx, ty), dc, ctx)   # resolve a generic application (Box(int)) to its instance (Box__int) so is_enum/is_struct dispatch picks the real deep-copier; an unresolved app falls through to a fail-open shallow copy (aliases a freed channel cell)
    if rt == "str":
        return "scopy(" + ar + ", " + src + ")"
    if is_func(rt):                                  # a fn value: re-home its env into `ar`
        return "({ Fn_" + func_suffix(rt) + " _t = (" + src + "); if (_t.env) _t.env = _t.copyenv(" + ar + ", _t.env); _t; })"
    if is_array(rt):
        return "Arr_" + mangle(elem_ty(rt)) + "_copy(" + ar + ", " + src + ")"
    if is_map(rt):
        return mfam(rt) + "_copy(" + ar + ", " + src + ")"
    if is_tuple(rt):
        return "Tup_" + tup_suffix(rt) + "_copy(" + ar + ", " + src + ")"
    if is_enum(dc, ctx, rt):
        return tcopy(dc, ctx, rt) + "(" + ar + ", " + src + ")"
    if is_struct(dc, ctx, rt) and struct_is_heap(dc, ctx, rt):
        return tcopy(dc, ctx, rt) + "(" + ar + ", " + src + ")"
    if is_option(rt):
        ict := cty(dc, ctx, option_inner(rt))
        return "(" + src + ".tag ? hsome(hbox(" + ar + ", sizeof(" + ict + "), " + box_payload(dc, ctx, option_inner(rt), ar, src + ".val") + ")) : hnone())"
    if is_result(rt):
        oct := cty(dc, ctx, result_ok(rt))
        ect := cty(dc, ctx, result_err(rt))
        return "(" + src + ".tag == 1 ? hok(hbox(" + ar + ", sizeof(" + oct + "), " + box_payload(dc, ctx, result_ok(rt), ar, src + ".ok") + ")) : herr(hbox(" + ar + ", sizeof(" + ect + "), " + box_payload(dc, ctx, result_err(rt), ar, src + ".err") + ")))"
    if is_soa(rt):
        return "Soa_" + soa_struct(rt) + "_copy(" + ar + ", " + src + ")"
    return src                                              # scalar / bool / non-heap struct

# The block-nesting depth at which env index `vi` was declared: the deepest block
# whose entry index is <= vi (bbases is increasing, so the last match wins). 0 =
# function scope. A var declared in an enclosing block routes to THAT block's arena
# (`&_b<d>`, in scope at any deeper point), not coarsely to `&_scope` — so a
# loop-local grown inside a nested loop still frees per outer-loop iteration.
fn var_block_depth(dc: Decls, ctx: Ctx, vi: int) -> int:
    d := 0
    i := 0
    for i < len(ctx.bbases):
        if ctx.bbases[i] <= vi:
            d = i + 1
        i = i + 1
    return d

fn owner_arena_of(e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    rv := root_var(e)
    if rv == "":
        return "&_scope"
    rvt := var_type(names, types, rv)
    if is_inout(rvt):
        if inout_container_param(dc, ctx, rvt):       # its home arena is threaded as a hidden param
            return "_ina_" + rv
        return "0"                                # inout scalar / struct: no _ina_ (malloc, immortal)
    d := var_block_depth(dc, ctx, var_index(names, rv))
    if d == 0:
        return "&_scope"
    return "&_b" + str(d)

# C zero literal for a scalar map VALUE type, for lowering an rvalue read `m[k]`
# to <family>_get(m, k, <zero>) -- a PURE read (zero on a missing key, NO insert).
# "" => the value is not a scalar (composite/newtype): keep the slot-lvalue path
# (a composite m[k] read still needs an explicit map_get at the source, which the
# C compiler enforces; this stays the find-or-insert slot, as before).
fn map_read_zero(vt: string) -> string:
    if vt == "int":
        return "0"
    elif vt == "bool":
        return "0"
    elif vt == "float":
        return "0.0"
    elif vt == "str":
        return "hi_intern(\"\")"
    return ""

# The slot lvalue for a map place `m[k]`: find-or-insert, deref the value slot
# (#2). A real C lvalue, so it serves a write target / `op=` read-half / push.
# `bt` is the map type of `b`.
fn gen_map_slotptr(b: Expr, i: Expr, bt: string, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    sp := "m" + mtag(map_key(bt)) + "_" + mangle(map_val(bt)) + "_slotptr"
    # the base is a PLACE (gen_place), so a nested map-of-map m1[k1][k2] threads
    # slotptr through, never the read-side map_get from gen_expr.
    return "(*" + sp + "(" + owner_arena_of(b, names, types, dc, ctx) + ", &(" + gen_place(b, names, types, dc, ctx) + "), " + krt(dc, ctx, bt, gen_expr(i, names, types, dc, ctx)) + "))"

# C lvalue for a PLACE (assignment target, or the first arg of push/reserve/pop).
# gen_expr lowers ANY `m[k]` read (scalar OR composite) to a pure map_get, so a
# place must instead take the slot lvalue at every map index. This RECURSES the
# field/index spine so chains like `m[k].f = v`, `m[k][j] = v`, and
# `push(m[k], v)` thread slotptr through the map index instead of map_get. The
# leaf (a variable) and non-map indices/fields are already real lvalues.
fn gen_place(lv: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    match lv:
        EIndex(b, i, _el):
            bt := type_of(b, names, types, dc, ctx)
            if is_map(bt):
                return gen_map_slotptr(b, i, bt, names, types, dc, ctx)
            if is_soa(bt):                          # soa element place: handled via field access (soa[i].f); bare soa[i] target is not a thing
                return gen_expr(lv, names, types, dc, ctx)
            # array element lvalue a[i]: bounds-checked (hi_bchk) like tychoc's _ptr.
            # A pointer stmt-expr keeps the result assignable; &(place) takes the base
            # address ONCE so a side-effecting place (e.g. m[k] slotptr) runs once.
            return "(*({ " + cty(dc, ctx, bt) + "* _a = &(" + gen_place(b, names, types, dc, ctx) + "); &_a->data[hi_bchk(" + gen_expr(i, names, types, dc, ctx) + ", _a->len)]; }))"
        EField(b, f, _el):
            sf := soa_field_access(dc, ctx, b, f, names, types)   # soa[i].f -> (soa).fN[i], a real lvalue
            if sf != "":
                return sf
            if is_tuple(type_of(b, names, types, dc, ctx)):
                return gen_place(b, names, types, dc, ctx) + ".f" + f
            return gen_place(b, names, types, dc, ctx) + "." + uf(f)
        EVar(n, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EInt(t, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EBool(t, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EChar(t, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EFloat(f, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EStr(s, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EBin(o, l, r, _el):
            return gen_expr(lv, names, types, dc, ctx)
        ECall(nm, ar, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EArrLit(es, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EArrEmpty(ty, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EMapEmpty(k, v, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EMapLit(ks, vs, _el):
            return gen_expr(lv, names, types, dc, ctx)
        ETuple(es, _el):
            return gen_expr(lv, names, types, dc, ctx)
        ESlice(b, lo, hi, _el):
            return gen_expr(lv, names, types, dc, ctx)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return gen_expr(lv, names, types, dc, ctx)
        ECallV(callee, cargs, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EAddr(inr, _el):
            return gen_expr(lv, names, types, dc, ctx)
        ESpawn(id, nm, a, _el):
            return gen_expr(lv, names, types, dc, ctx)

# Is `e` a map-place `m[k]` (an EIndex whose base is a map)? Such a place's slot
# lives in the MAP's arena, so a value stored there must be built in that arena —
# NOT at owner 0 (the struct-field/array-element default), where a multi-piece
# map literal's chained `_set` copies leak their abandoned intermediate tables.
fn is_map_index(e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> bool:
    match e:
        EIndex(b, i, _el):
            return is_map(type_of(b, names, types, dc, ctx))
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EVar(n, _el):
            return false
        EBin(o, l, r, _el):
            return false
        ECall(nm, ar, _el):
            return false
        EField(b, f, _el):
            return false
        EArrLit(es, _el):
            return false
        EArrEmpty(ty, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        EMapLit(ks, vs, _el):
            return false
        ETuple(es, _el):
            return false
        ESlice(b, lo, hi, _el):
            return false
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return false
        ECallV(callee, cargs, _el):
            return false
        EAddr(inr, _el):
            return false
        ESpawn(id, nm, a, _el):
            return false

# Is `e` an index into a STRING array (a heap-element slot)? Overwriting such a
# slot can recycle the evicted element back to the array's arena (MM-9), so peak
# RSS tracks the live window not the whole stream. Mirrors tychoc's tycho_arr_str_set.
fn is_str_arr_index(e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> bool:
    match e:
        EIndex(b, i, _el):
            bt := type_of(b, names, types, dc, ctx)
            return is_array(bt) and elem_ty(bt) == "str"
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EVar(n, _el):
            return false
        EBin(o, l, r, _el):
            return false
        ECall(nm, ar, _el):
            return false
        EField(b, f, _el):
            return false
        EArrLit(es, _el):
            return false
        EArrEmpty(ty, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        EMapLit(ks, vs, _el):
            return false
        ETuple(es, _el):
            return false
        ESlice(b, lo, hi, _el):
            return false
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return false
        ECallV(callee, cargs, _el):
            return false
        EAddr(inr, _el):
            return false
        ESpawn(id, nm, a, _el):
            return false

# Is `e` an existing storage location (vs a fresh value)? Assigning FROM a
# place needs a value-semantic deep copy so the two bindings stay independent.
fn is_place(e: Expr) -> bool:
    match e:
        EVar(n, _el):
            return true
        EField(b, f, _el):
            return true
        EIndex(b, i, _el):
            return true
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EBin(o, l, r, _el):
            return false
        ECall(n, a, _el):
            return false
        EArrLit(es, _el):
            return false
        EArrEmpty(t, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        EMapLit(ks, vs, _el):
            return false
        ETuple(es, _el):
            return false
        ESlice(b, lo, hi, _el):
            return true                          # a slice aliases its source; binding it copies
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return false
        ECallV(callee, cargs, _el):
            return false
        EAddr(inner, _el):
            return false
        ESpawn(id, nm, a, _el):
            return false

# A slice expression already MATERIALIZES an owning copy in ctx.owner
# (Arr_*_slice/substr/gen_soa_slice all allocate fresh into ctx.owner), so unlike
# other places it must NOT be deep-copied again on bind -- that double-allocates
# and leaks the intermediate. gen_rhs returns the slice code directly.
fn is_eslice(e: Expr) -> bool:
    match e:
        ESlice(b, lo, hi, _el):
            return true
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EVar(n, _el):
            return false
        EBin(o, l, r, _el):
            return false
        ECall(n, a, _el):
            return false
        EField(b, f, _el):
            return false
        EIndex(b, i, _el):
            return false
        EArrLit(es, _el):
            return false
        EArrEmpty(t, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        EMapLit(ks, vs, _el):
            return false
        ETuple(es, _el):
            return false
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return false
        ECallV(callee, cargs, _el):
            return false
        EAddr(inner, _el):
            return false
        ESpawn(sid, nm, a, _el):
            return false

fn is_evar(e: Expr, name: string) -> bool:
    match e:
        EVar(n, _el):
            return n == name
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EBin(o, l, r, _el):
            return false
        ECall(nm, a, _el):
            return false
        EField(b, f, _el):
            return false
        EIndex(b, i, _el):
            return false
        EArrLit(es, _el):
            return false
        EArrEmpty(t, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        EMapLit(ks, vs, _el):
            return false
        ETuple(es, _el):
            return false
        ESlice(b, lo, hi, _el):
            return false
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return false
        ECallV(callee, cargs, _el):
            return false
        EAddr(x, _el):
            return false
        ESpawn(sid, snm, sa, _el):
            return false

fn is_int_lit(e: Expr) -> bool:           # is `e` a literal int -- the only int that adapts to a float operand (matches tychoc's `kind == E_INT`)
    match e:
        EVar(n, _el):
            return false
        EInt(t, _el):
            return true
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EBin(o, l, r, _el):
            return false
        ECall(nm, a, _el):
            return false
        EField(b, f, _el):
            return false
        EIndex(b, i, _el):
            return false
        EArrLit(es, _el):
            return false
        EArrEmpty(t, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        EMapLit(ks, vs, _el):
            return false
        ETuple(es, _el):
            return false
        ESlice(b, lo, hi, _el):
            return false
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return false
        ECallV(callee, cargs, _el):
            return false
        EAddr(x, _el):
            return false
        ESpawn(sid, snm, sa, _el):
            return false

# Is `e` a float literal -- the only float that adapts to an f32 operand (mirrors tychoc's E_FLOAT).
fn is_float_lit(e: Expr) -> bool:
    match e:
        EFloat(f, _el):
            return true
        _:
            return false

# Is `e` an int literal equal to 0? Catches any zero spelling ("0", "00") so
# `x / 0` / `x % 0` are rejected on the parsed value, not the text. Mirrors
# tychoc's E_INT ival == 0 check (M6, locked by the type-parity lane).
fn is_zero_int_lit(e: Expr) -> bool:
    match e:
        EVar(n, _el):
            return false
        EInt(t, _el):
            if len(t) == 0:
                return false
            k := 0
            for k < len(t):
                if t[k] != 48:                # '0'
                    return false
                k = k + 1
            return true
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EBin(o, l, r, _el):
            return false
        ECall(nm, a, _el):
            return false
        EField(b, f, _el):
            return false
        EIndex(b, i, _el):
            return false
        EArrLit(es, _el):
            return false
        EArrEmpty(t, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        EMapLit(ks, vs, _el):
            return false
        ETuple(es, _el):
            return false
        ESlice(b, lo, hi, _el):
            return false
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return false
        ECallV(callee, cargs, _el):
            return false
        EAddr(x, _el):
            return false
        ESpawn(sid, snm, sa, _el):
            return false

# Deep-copy a C expression `code` of Tycho type `ty` (value semantics for a bind
# whose value may be mutated). Copies the mutable heap containers; scalars,
# strings (immutable), and enum/option/result (immutable) are share-safe.
fn cp_typed(dc: Decls, ctx: Ctx, ty: string, code: string) -> string:
    rt := resolve_nt(dc, ctx, ty)
    if is_array(rt):
        return "Arr_" + mangle(elem_ty(rt)) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_map(rt):
        return mfam(rt) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_tuple(rt):
        return "Tup_" + tup_suffix(rt) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_struct(dc, ctx, rt) and struct_is_heap(dc, ctx, rt):
        return tcopy(dc, ctx, rt) + "(" + ctx.owner + ", " + code + ")"
    return code

# --- move-on-last-use (deep-copy elision) --------------------------------
# `b := a` normally deep-copies a heap value so the two are independent. But if
# `a` is a uniquely-owned local read exactly once in the whole function (so this
# read is its last use, on every path), and that read is not inside a loop (so it
# is a single DYNAMIC read), `b` can take over `a`'s buffer — a move, no copy.
# Mirrors the C compiler's can_move_from. Conditions baked into ctx.movables:
# read-exactly-once + not-in-loop; the rest (heap, not a param, same arena as the
# destination) are checked at the move site. Output-invisible when sound, so the
# fixpoint differential catches any over-aggressive move.
fn evar_name(e: Expr) -> string:
    match e:
        EVar(n, _el):
            return n
        EInt(t, _el):
            return ""
        EBool(t, _el):
            return ""
        EChar(t, _el):
            return ""
        EFloat(f, _el):
            return ""
        EStr(s, _el):
            return ""
        EBin(o, l, r, _el):
            return ""
        ECall(nm, a, _el):
            return ""
        EField(b, f, _el):
            return ""
        EIndex(b, i, _el):
            return ""
        EArrLit(es, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        EMapLit(ks, vs, _el):
            return ""
        ETuple(es, _el):
            return ""
        ESlice(b, lo, hi, _el):
            return ""
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return ""
        ECallV(callee, cargs, _el):
            return ""
        EAddr(x, _el):
            return ""
        ESpawn(sid, snm, sa, _el):
            return ""

fn count_str_occ(xs: [string], s: string) -> int:
    c := 0
    i := 0
    for i < len(xs):
        if xs[i] == s:
            c = c + 1
        i = i + 1
    return c

# ---- push-loop fusion (mirror of tychoc's src/tychoc.c) ---------------------
# A loop whose body uses a local scalar array ONLY as push(arr,...) gets its
# descriptor (data/len/cap) cached in C locals across the loop, so the hot path
# is a register write; a grow hook runs only on overflow; the descriptor is
# written back at loop exit. Sound by construction: fuse only when reads==pushes
# (used solely as push target), the array is a plain non-inout scalar local not
# defined/shadowed in the body, and (while) the condition does not read it.
fn push_target(e: Expr) -> string:        # var name if e is push(EVar, ...), else ""
    match e:
        ECall(nm, a, _el):
            if nm == "push" and len(a) >= 1:
                return evar_name(a[0])
            return ""
        EVar(n, _el):
            return ""
        EInt(t, _el):
            return ""
        EBool(t, _el):
            return ""
        EChar(t, _el):
            return ""
        EFloat(f, _el):
            return ""
        EStr(s, _el):
            return ""
        EBin(o, l, r, _el):
            return ""
        EField(b, f, _el):
            return ""
        EIndex(b, i, _el):
            return ""
        EArrLit(es, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        EMapLit(ks, vs, _el):
            return ""
        ETuple(es, _el):
            return ""
        ESlice(b, lo, hi, _el):
            return ""
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return ""
        ECallV(callee, cargs, _el):
            return ""
        EAddr(x, _el):
            return ""
        ESpawn(sid, snm, sa, _el):
            return ""

fn fuse_pushcount(stmts: [Stmt], name: string) -> int:
    c := 0
    i := 0
    for i < len(stmts):
        match stmts[i]:
            SExpr(e, _sl):
                if push_target(e) == name:
                    c = c + 1
            SIf(cnd, b, els, _sl):
                c = c + fuse_pushcount(b, name) + fuse_pushcount(els, name)
            SWhile(cnd, b, _sl):
                c = c + fuse_pushcount(b, name)
            SForRange(n, a, bb, st, b, _sl):
                c = c + fuse_pushcount(b, name)
            SMatch(subj, vs, bs, bodies, _sl):
                j := 0
                for j < len(bodies):
                    c = c + fuse_pushcount(bodies[j], name)
                    j = j + 1
            SDecl(n, e, _sl):
                i = i
            SAssign(n, e, _sl):
                i = i
            SFieldAssign(lv, r, _sl):
                i = i
            SPrint(e, _sl):
                i = i
            SReturn(e, _sl):
                i = i
            SConst(n, e, _sl):
                i = i
            SReturnVoid:
                i = i
            STypedDecl(n, t, e, _sl):
                i = i
            SOrReturn(n, e, _sl):
                i = i
            SDestructure(ns, e, _sl):
                i = i
            SMultiAssign(ns, e, _sl):
                i = i
            SBreak:
                i = i
            SContinue:
                i = i
            SParFor(v, a, b, body, pid, _sl):
                i = i
            SSelect(uid, svars, schans, sbinds, sbodies, _sl):
                i = i
            SValDecl(n, ty, cc, _sl):
                c = c + fuse_pushcount([cc], name)
        i = i + 1
    return c

fn fuse_gather(stmts: [Stmt], out: inout [string]):
    i := 0
    for i < len(stmts):
        match stmts[i]:
            SExpr(e, _sl):
                t := push_target(e)
                if t != "" and count_str_occ(out, t) == 0:
                    push(out, t)
            SIf(cnd, b, els, _sl):
                fuse_gather(b, &out)
                fuse_gather(els, &out)
            SWhile(cnd, b, _sl):
                fuse_gather(b, &out)
            SForRange(n, a, bb, st, b, _sl):
                fuse_gather(b, &out)
            SMatch(subj, vs, bs, bodies, _sl):
                j := 0
                for j < len(bodies):
                    fuse_gather(bodies[j], &out)
                    j = j + 1
            SDecl(n, e, _sl):
                i = i
            SAssign(n, e, _sl):
                i = i
            SFieldAssign(lv, r, _sl):
                i = i
            SPrint(e, _sl):
                i = i
            SReturn(e, _sl):
                i = i
            SConst(n, e, _sl):
                i = i
            SReturnVoid:
                i = i
            STypedDecl(n, t, e, _sl):
                i = i
            SOrReturn(n, e, _sl):
                i = i
            SDestructure(ns, e, _sl):
                i = i
            SMultiAssign(ns, e, _sl):
                i = i
            SBreak:
                i = i
            SContinue:
                i = i
            SParFor(v, a, b, body, pid, _sl):
                i = i
            SSelect(uid, svars, schans, sbinds, sbodies, _sl):
                i = i
            SValDecl(n, ty, cc, _sl):
                fuse_gather([cc], &out)
        i = i + 1

fn fuse_defines(stmts: [Stmt], name: string) -> bool:
    i := 0
    for i < len(stmts):
        match stmts[i]:
            SDecl(n, e, _sl):
                if n == name:
                    return true
            SAssign(n, e, _sl):
                if n == name:
                    return true
            STypedDecl(n, t, e, _sl):
                if n == name:
                    return true
            SOrReturn(n, e, _sl):
                if n == name:
                    return true
            SDestructure(ns, e, _sl):
                if count_str_occ(ns, name) > 0:
                    return true
            SMultiAssign(ns, e, _sl):
                if count_str_occ(ns, name) > 0:
                    return true
            SForRange(n, a, bb, st, b, _sl):
                if n == name:
                    return true
                if fuse_defines(b, name):
                    return true
            SIf(cnd, b, els, _sl):
                if fuse_defines(b, name):
                    return true
                if fuse_defines(els, name):
                    return true
            SWhile(cnd, b, _sl):
                if fuse_defines(b, name):
                    return true
            SMatch(subj, vs, bs, bodies, _sl):
                j := 0
                for j < len(bodies):
                    if count_str_occ(bs[j], name) > 0:
                        return true
                    if fuse_defines(bodies[j], name):
                        return true
                    j = j + 1
            SFieldAssign(lv, r, _sl):
                i = i
            SPrint(e, _sl):
                i = i
            SReturn(e, _sl):
                i = i
            SConst(n, e, _sl):
                i = i
            SReturnVoid:
                i = i
            SExpr(e, _sl):
                i = i
            SBreak:
                i = i
            SContinue:
                i = i
            SParFor(v, a, b, body, pid, _sl):
                return true   # a parallel for captures arrays by value -- any live fusion cursor would be stale; fail closed
            SSelect(uid, svars, schans, sbinds, sbodies, _sl):
                return true   # select arm bodies run between cursor writes -- fail closed, like parallel for
            SValDecl(n, ty, cc, _sl):
                if n == name:
                    return true
                if fuse_defines([cc], name):
                    return true
        i = i + 1
    return false

fn fuse_envtype(names: [string], types: [string], nm: string) -> string:
    i := len(names) - 1
    for i >= 0:
        if names[i] == nm:
            return types[i]
        i = i - 1
    return ""

fn add_fuse(ctx: Ctx, nm: string, suf: string, ety: string) -> Ctx:
    fa := ctx.fusearr
    fs := ctx.fusesuf
    ft := ctx.fusety
    push(fa, nm)
    push(fs, suf)
    push(ft, ety)
    return Ctx(ctx.vparams, ctx.saccums, ctx.rettype, ctx.owner, ctx.depth, ctx.bbases, ctx.movables, ctx.loopdepth, fa, fs, ft, ctx.line, ctx.curpkg)

# Return the fusible scalar arrays of `body` as parallel (name, cursor-suffix,
# elem-type) lists. A candidate qualifies iff: scalar int/float local (the env
# type is exactly "[int]"/"[float]" -- a inout param reads as "inout [...]" and
# is excluded); not already cached by an enclosing loop; not defined/shadowed in
# the body; used solely as a push target (reads == pushes); and, for a while
# loop, not read by the condition (which re-evaluates each iteration).
fn fuse_detect(body: [Stmt], names: [string], types: [string], dc: Decls, ctx: Ctx, guard: Expr, useguard: bool) -> ([string], [string], [string]):
    cand := []string
    fuse_gather(body, &cand)
    reads := []string
    lr := []string
    rd_block(&reads, &lr, body, false)
    greads := []string
    glr := []string
    if useguard:
        rd_expr(&greads, &glr, guard, false)
    fnm := []string
    fsf := []string
    fty := []string
    i := 0
    for i < len(cand):
        nm := cand[i]
        et := fuse_envtype(names, types, nm)
        ok := true
        if not is_array(et):                          # any array element type (scalar/str/struct/tuple/...); inout + soa excluded by is_array
            ok = false
        if count_str_occ(ctx.fusearr, nm) > 0:
            ok = false
        if fuse_defines(body, nm):
            ok = false
        if count_str_occ(reads, nm) != fuse_pushcount(body, nm):
            ok = false
        if useguard and count_str_occ(greads, nm) > 0:
            ok = false
        if ok:
            push(fnm, nm)
            push(fsf, str(ctx.depth) + "_" + str(len(fnm) - 1))
            push(fty, elem_ty(et))
        i = i + 1
    return (fnm, fsf, fty)

# Collect every variable READ (expression occurrence), and separately those read
# inside a loop body/condition. A name read exactly once and never in a loop is a
# move candidate. (Decl/loop-var/assign-target NAMES are writes — not collected.)
fn rd_expr(reads: inout [string], loopreads: inout [string], e: Expr, inloop: bool):
    match e:
        EVar(n, _el):
            push(reads, n)
            if inloop:
                push(loopreads, n)
        EBin(o, l, r, _el):
            rd_expr(&reads, &loopreads, l, inloop)
            rd_expr(&reads, &loopreads, r, inloop)
        ECall(nm, args, _el):
            di := find(nm, ".")                       # `recv.method()` parses as a dotted-name ECall with the
            if di > 0:                                # receiver IN THE NAME and empty args -- count the receiver's
                rd_expr(&reads, &loopreads, EVar(substr(nm, 0, di), _el), inloop)   # read (a package prefix like json.parse is harmless: not a local)
            j := 0
            for j < len(args):
                rd_expr(&reads, &loopreads, args[j], inloop)
                j = j + 1
        EField(b, f, _el):
            rd_expr(&reads, &loopreads, b, inloop)
        EIndex(b, idx, _el):
            rd_expr(&reads, &loopreads, b, inloop)
            rd_expr(&reads, &loopreads, idx, inloop)
        ESlice(b, lo, hi, _el):
            rd_expr(&reads, &loopreads, b, inloop)
            rd_expr(&reads, &loopreads, lo, inloop)
            rd_expr(&reads, &loopreads, hi, inloop)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            j := 0
            for j < len(cn):
                push(reads, cn[j])
                j = j + 1
        ECallV(callee, cargs, _el):
            rd_expr(&reads, &loopreads, callee, inloop)
            j := 0
            for j < len(cargs):
                rd_expr(&reads, &loopreads, cargs[j], inloop)
                j = j + 1
        EAddr(x, _el):
            rd_expr(&reads, &loopreads, x, inloop)
        EArrLit(es, _el):
            j := 0
            for j < len(es):
                rd_expr(&reads, &loopreads, es[j], inloop)
                j = j + 1
        EMapLit(ks, vs, _el):
            j := 0
            for j < len(vs):
                rd_expr(&reads, &loopreads, ks[j], inloop)
                rd_expr(&reads, &loopreads, vs[j], inloop)
                j = j + 1
        ETuple(es, _el):
            j := 0
            for j < len(es):
                rd_expr(&reads, &loopreads, es[j], inloop)
                j = j + 1
        EInt(t, _el):
            j := 0
        EBool(t, _el):
            j := 0
        EChar(t, _el):
            j := 0
        EFloat(f, _el):
            j := 0
        EStr(s, _el):
            j := 0
        EArrEmpty(t, _el):
            j := 0
        EMapEmpty(k, v, _el):
            j := 0
        ESpawn(sid, snm, sa, _el):
            j := 0                                # spawn args read as if in a loop: never move-eligible (the
            for j < len(sa):                      # site always deep-copies into the task root -- keep it that way)
                rd_expr(&reads, &loopreads, sa[j], true)
                j = j + 1

fn rd_block(reads: inout [string], loopreads: inout [string], stmts: [Stmt], inloop: bool):
    i := 0
    for i < len(stmts):
        rd_stmt(&reads, &loopreads, stmts[i], inloop)
        i = i + 1

fn rd_stmt(reads: inout [string], loopreads: inout [string], s: Stmt, inloop: bool):
    match s:
        SDecl(n, e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SAssign(n, e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SFieldAssign(lv, rhs, _sl):
            rd_expr(&reads, &loopreads, lv, inloop)
            rd_expr(&reads, &loopreads, rhs, inloop)
        SPrint(e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SReturn(e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SConst(n, e, _sl):
            j := 0
        SReturnVoid:
            j := 0
        SBreak:
            j := 0
        SContinue:
            j := 0
        SExpr(e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        STypedDecl(n, t, e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SOrReturn(n, e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SDestructure(dnames, e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SMultiAssign(mnames, e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SIf(c, tb, eb, _sl):
            rd_expr(&reads, &loopreads, c, inloop)
            rd_block(&reads, &loopreads, tb, inloop)
            rd_block(&reads, &loopreads, eb, inloop)
        SWhile(c, body, _sl):
            rd_expr(&reads, &loopreads, c, true)
            rd_block(&reads, &loopreads, body, true)
        SForRange(n, a, b, st, body, _sl):
            rd_expr(&reads, &loopreads, a, inloop)
            rd_expr(&reads, &loopreads, b, inloop)
            rd_expr(&reads, &loopreads, st, inloop)
            rd_block(&reads, &loopreads, body, true)
        SMatch(subj, variants, allbinds, bodies, _sl):
            rd_expr(&reads, &loopreads, subj, inloop)
            j := 0
            for j < len(bodies):
                rd_block(&reads, &loopreads, bodies[j], inloop)
                j = j + 1
        SParFor(v, a, b, body, pid, _sl):
            rd_expr(&reads, &loopreads, a, inloop)
            rd_expr(&reads, &loopreads, b, inloop)
            rd_block(&reads, &loopreads, body, true)   # captured reads run N times across chunks: never move-eligible
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            sk := 0
            for sk < len(svars):
                rd_expr(&reads, &loopreads, schans[sk], true)   # the retry loop re-reads the channel exprs
                rd_block(&reads, &loopreads, sbodies[sk], inloop)
                sk = sk + 1
        SValDecl(n, ty, cc, _sl):            # value if/match decl: tails read variables (move-on-last-use correctness)
            rd_stmt(&reads, &loopreads, cc, inloop)

fn compute_movables(body: [Stmt]) -> [string]:
    reads := []string
    loopreads := []string
    rd_block(&reads, &loopreads, body, false)
    # movable = read exactly once AND never inside a loop. The old form called
    # count_str_occ(reads, n) per element = O(reads^2); a one-pass frequency map
    # + a loopreads set makes it O(reads). (The old `not has_str(mv, n)` guard was
    # redundant: a name read once is pushed at most once.)
    freq := []string: int
    lset := []string: int
    i := 0
    for i < len(loopreads):
        lset[loopreads[i]] = 1
        i = i + 1
    i = 0
    for i < len(reads):
        freq[reads[i]] = freq.get(reads[i], 0) + 1
        i = i + 1
    mv := []string
    i = 0
    for i < len(reads):
        n := reads[i]
        if freq.get(n, 0) == 1 and lset.get(n, 0) == 0:
            push(mv, n)
        i = i + 1
    return mv

# May `gen_rhs(e)` move e's buffer (return it as-is) instead of deep-copying?
# e is a bare local var of heap type, read exactly once and not in a loop
# (ctx.movables), not a param (params borrow the caller's buffer), and its home
# arena equals the destination owner (so the handed-off buffer's lifetime fits).
fn can_move(e: Expr, ty: string, names: [string], types: [string], dc: Decls, ctx: Ctx) -> bool:
    nm := evar_name(e)
    if nm == "":
        return false
    if not has_str(ctx.movables, nm):
        return false
    if var_index(names, nm) < 0:                  # an EVar that is not a local (a bare enum variant
        return false                              # like `Leaf`) — not a movable variable
    rt := resolve_nt(dc, ctx, ty)
    isheap := is_array(rt) or is_map(rt) or is_tuple(rt) or is_enum(dc, ctx, rt) or (is_struct(dc, ctx, rt) and struct_is_heap(dc, ctx, rt))
    if not isheap:
        return false
    if has_str(ctx.vparams, nm) or is_inout(var_type(names, types, nm)):   # never move a param (borrowed)
        return false
    return owner_arena_of(e, names, types, dc, ctx) == ctx.owner

# can_move for a `sink` argument: the callee CONSUMES the value, so adopting a dead
# local needs only (1) the buffer to outlive the call -- true for ANY tracked local,
# whose block/function arena encloses the per-statement call scratch -- and (2) the
# mutation to be unobserved (read once, outside any loop). That is can_move minus the
# same-arena requirement. (Escape is still a copy: returning the param re-homes it.)
fn can_move_into_sink(e: Expr, ty: string, names: [string], types: [string], dc: Decls, ctx: Ctx) -> bool:
    nm := evar_name(e)
    if nm == "":
        return false
    if not has_str(ctx.movables, nm):             # read exactly once, not inside a loop
        return false
    if var_index(names, nm) < 0:
        return false
    rt := resolve_nt(dc, ctx, ty)
    isheap := is_array(rt) or is_map(rt) or is_tuple(rt) or is_enum(dc, ctx, rt) or (is_struct(dc, ctx, rt) and struct_is_heap(dc, ctx, rt))
    if not isheap:
        return false
    if has_str(ctx.vparams, nm) or is_inout(var_type(names, types, nm)):   # never a param (caller-owned)
        return false
    return true                                   # NO arena match -- the relaxation

# Argument to a `sink` parameter: adopt a dead local (from any enclosing arena) or a
# fresh value with no copy; otherwise deep-copy via gen_rhs so the callee's owned
# mutation can never reach back into a still-live caller value.
fn gen_sink_arg(e: Expr, ty: string, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    if can_move_into_sink(e, ty, names, types, dc, ctx):
        return gen_expr(e, names, types, dc, ctx)
    # consume diagnostic: a bare OWNED variable (a local or a sink param) handed to a
    # sink parameter but used again (or inside a loop) cannot be moved into it. Require
    # an explicit copy so move-vs-copy is visible (Hylo-style), rather than silently
    # copying. Borrowed/inout params (which can never move) and field/index args still copy.
    nm := evar_name(e)
    if nm != "" and var_index(names, nm) >= 0:
        rt := resolve_nt(dc, ctx, ty)
        isheap := is_array(rt) or is_map(rt) or is_tuple(rt) or is_enum(dc, ctx, rt) or (is_struct(dc, ctx, rt) and struct_is_heap(dc, ctx, rt))
        if isheap and not has_str(ctx.vparams, nm) and not is_inout(var_type(names, types, nm)):
            die_at(dc, ctx.line, "'" + nm + "' is consumed by a `sink` parameter but used again (or inside a loop); pass a copy you keep (`y := " + nm + "`) or make this its last use")
    return gen_rhs(e, names, types, dc, ctx)

# Like gen_call_args, but routes a `sink` parameter's argument through gen_sink_arg
# (adopt-or-copy). `ptypes` is the callee's parameter type list (from its signature).
fn gen_call_args_sink(args: [Expr], ptypes: [string], names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    out := ""
    i := 0
    for i < len(args):
        if i > 0:
            out = out + ", "
        if i < len(ptypes) and is_sink(ptypes[i]):
            out = out + gen_sink_arg(args[i], base_ty(ptypes[i]), names, types, dc, ctx)
        else:
            out = out + gen_expr(args[i], names, types, dc, ctx) + arg_ina(args[i], names, types, dc, ctx)
        i = i + 1
    return out

# RHS of a whole-value binding: deep-copy an array read from a place so the new
# binding is independent (Tycho value semantics). Fresh arrays (literals, call
# results) already own their buffer; scalars/strings need no copy.
fn gen_rhs(e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    code := gen_expr(e, names, types, dc, ctx)
    ty := type_of(e, names, types, dc, ctx)
    if can_move(e, ty, names, types, dc, ctx):       # move-on-last-use: hand off the buffer, elide the copy
        return code
    if is_eslice(e) and (is_array(ty) or ty == "str"):   # array/str slices already own (Arr_*_slice/substr
        return code                                      # build fresh in ctx.owner) -- no double copy. A SOA slice
                                                         # is a VIEW (cap 0), so it falls through to Soa_*_copy below.
    if is_array(ty) and is_place(e):
        return "Arr_" + mangle(elem_ty(ty)) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_struct(dc, ctx, ty) and struct_is_heap(dc, ctx, ty) and is_place(e):
        return tcopy(dc, ctx, ty) + "(" + ctx.owner + ", " + code + ")"
    if is_map(ty) and is_place(e):               # value-semantic map copy (e.g. snap := counts)
        return mfam(ty) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_tuple(ty) and is_place(e):             # value-semantic tuple copy (b := a)
        return "Tup_" + tup_suffix(ty) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_soa(ty) and is_place(e):               # value-semantic soa copy (bind/pass/return)
        return "Soa_" + soa_struct(ty) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_enum(dc, ctx, ty) and is_place(e) and var_index(names, root_var(e)) >= 0:   # a REAL enum place (var/
        return tcopy(dc, ctx, ty) + "(" + ctx.owner + ", " + code + ")"   # field/elem) escaping -> deep-copy. NOT a bare nullary-variant ctor (`return Leaf`), which is already fresh. Match arms BORROW (cp_typed).
    if (is_option(ty) or is_result(ty)) and is_place(e) and var_index(names, root_var(e)) >= 0:   # a REAL option/result
        return elem_copy_expr(dc, ctx, ty, ctx.owner, code)     # place (var/field/elem, not the bare `None` ctor): re-box into ctx.owner

    if ty == "str" and is_place(e):              # copy a string bound from a place, so an
        return "scopy(" + ctx.owner + ", " + code + ")" # in-place-appended accumulator's snapshot stays independent
    return code

# A scalar (non-heap) result type. When an assignment/decl LHS is scalar, the
# whole RHS value carries no heap, so every heap value built while evaluating it
# is transient (consumed in the statement, never stored) and can be reclaimed.
fn is_scalar_ty(dc: Decls, ctx: Ctx, ty: string) -> bool:
    rt := resolve_nt(dc, ctx, ty)
    return rt == "int" or rt == "float" or rt == "bool"

# Does `e` contain a call anywhere? A call is the only thing that can allocate a
# heap transient, so a call-free scalar RHS (e.g. `i + 1`) needs no transient
# arena — this keeps the hot loop-counter assignments allocation-free.
fn expr_has_call(e: Expr) -> bool:
    match e:
        ECall(n, a, _el):
            return true
        EBin(o, l, r, _el):
            return expr_has_call(l) or expr_has_call(r)
        EField(b, f, _el):
            return expr_has_call(b)
        EIndex(b, i, _el):
            return expr_has_call(b) or expr_has_call(i)
        ESlice(b, lo, hi, _el):
            return expr_has_call(b) or expr_has_call(lo) or expr_has_call(hi)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return false
        ECallV(callee, cargs, _el):
            return true
        EAddr(x, _el):
            return expr_has_call(x)
        EArrLit(es, _el):
            return any_has_call(es)
        EMapLit(ks, vs, _el):
            return any_has_call(ks) or any_has_call(vs)
        ETuple(es, _el):
            return any_has_call(es)
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EVar(n, _el):
            return false
        EArrEmpty(t, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        ESpawn(sid, snm, sa, _el):
            return true                           # a spawn site allocates (task root + arg copies)

fn any_has_call(es: [Expr]) -> bool:
    i := 0
    for i < len(es):
        if expr_has_call(es[i]):
            return true
        i = i + 1
    return false

# Does the expression subtree reference the identifier `name`? Used as the
# alias guard for multi-piece string appends: by value semantics the
# accumulator uniquely owns its buffer, so a piece can only alias it by NAMING
# it. Mirrors expr_has_call's exhaustive structure.
fn expr_refs(e: Expr, name: string) -> bool:
    match e:
        EVar(n, _el):
            return n == name
        EBin(o, l, r, _el):
            return expr_refs(l, name) or expr_refs(r, name)
        ECall(nm, a, _el):
            return any_refs(a, name)
        EField(b, f, _el):
            return expr_refs(b, name)
        EIndex(b, i, _el):
            return expr_refs(b, name) or expr_refs(i, name)
        ESlice(b, lo, hi, _el):
            return expr_refs(b, name) or expr_refs(lo, name) or expr_refs(hi, name)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            j := 0
            for j < len(cn):
                if cn[j] == name:
                    return true
                j = j + 1
            return false
        ECallV(callee, cargs, _el):
            if expr_refs(callee, name):
                return true
            j := 0
            for j < len(cargs):
                if expr_refs(cargs[j], name):
                    return true
                j = j + 1
            return false
        EAddr(x, _el):
            return expr_refs(x, name)
        EArrLit(es, _el):
            return any_refs(es, name)
        EMapLit(ks, vs, _el):
            return any_refs(ks, name) or any_refs(vs, name)
        ETuple(es, _el):
            return any_refs(es, name)
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EArrEmpty(t, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        ESpawn(sid, snm, sa, _el):
            return any_refs(sa, name)

fn any_refs(es: [Expr], name: string) -> bool:
    i := 0
    for i < len(es):
        if expr_refs(es[i], name):
            return true
        i = i + 1
    return false

# A scalar assignment/decl whose RHS makes a call: evaluate the RHS in a fresh
# per-statement arena `_t` and free it after the scalar result is stored — so a
# heap transient (e.g. the tree in `sum = sum + check(make(d))`) is reclaimed at
# the statement, not retained in the enclosing scope. `assign` is the C lvalue +
# " = " (the decl declares it first); stores inside the RHS still route to their
# own arena (owner_arena_of), so only true transients land in `_t`.
fn scalar_transient(dc: Decls, ctx: Ctx, e: Expr, names: [string], types: [string], assign: string) -> string:
    return "    { Arena _t = arena_new(0); " + assign + gen_rhs(e, names, types, dc, with_owner(dc, ctx, "&_t")) + "; arena_free(&_t); }\n"

# names/types are passed BY VALUE so a block's decls never escape to sibling
# or outer scopes (matching C/Tycho block scoping).
fn gen_block(stmts: [Stmt], names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    out := ""
    ns := names                                  # local mutable copies; decls
    ts := types                                  # added here stay block-local
    entry := len(ns)                             # CC-2: finalizer sentinels above this die at block end
    i := 0
    for i < len(stmts):
        out = out + gen_stmt(stmts[i], &ns, &ts, dc, ctx)
        i = i + 1
    fin := conc_finals(ns, entry)                # implicit join / channel free at every normal block exit
    if fin != "":                                # (dead C after a trailing return -- the return path already ran them)
        out = out + "    " + fin + "\n"
    return out

# CC-2 implicit join / CC-4 channel free: SDecl pushes a "!<finalizer-call>"
# sentinel into the names env (with a "!" placeholder type, keeping the arrays
# in lockstep); no user identifier can start with '!' so name lookups never
# collide. Every scope exit emits the pending calls LIFO -- gen_block covers
# block/iteration/proc-body ends, the return paths cover early exits (incl.
# or_return), break/continue cover loop escapes via bbases[loopdepth-1].
fn conc_finals(names: [string], from: int) -> string:
    out := ""
    i := len(names) - 1
    for i >= from:
        if len(names[i]) > 0 and names[i][0] == 33:   # '!' sentinel
            out = out + substr(names[i], 1, len(names[i])) + "; "
        i = i - 1
    return out

fn conc_loop_finals(names: [string], ctx: Ctx) -> string:   # finals since the innermost loop body's entry
    if ctx.loopdepth < 1 or len(ctx.bbases) < ctx.loopdepth:
        return ""
    return conc_finals(names, ctx.bbases[ctx.loopdepth - 1])

# Drop one redundant outer paren layer when a gen_expr result is emitted as an
# if/while condition: `if ((a == b))` -> `if (a == b)`. Mirrors tychoc's
# cond_unwrap. Strips only a single fully-parenthesised group (first byte '('
# whose matching ')' is the last byte), skipping C string/char literals so a
# paren inside a literal (e.g. `s == ")"`) can't fool the matcher. Fail-closed:
# any uncertainty returns s unchanged, so a missed strip is a harmless extra
# paren, never malformed C.
fn cond_unwrap(s: string) -> string:
    n := len(s)
    if n == 0 or s[0] != 40:                      # 40 = '('
        return s
    depth := 0
    i := 0
    for i < n:
        ch := s[i]
        if ch == 34 or ch == 39:                  # 34 = '"', 39 = '\'' : skip a literal
            i = i + 1
            for i < n and s[i] != ch:
                if s[i] == 92 and i + 1 < n:       # 92 = '\\' : skip the escaped byte
                    i = i + 1
                i = i + 1
            if i >= n:                            # unterminated -> bail, unchanged
                return s
            i = i + 1                             # past the closing quote
            continue
        if ch == 40:                              # '('
            depth = depth + 1
        elif ch == 41:                            # ')'
            depth = depth - 1
            if depth == 0:                        # this ')' matches s[0]'s '('
                if i != n - 1:                    # ...but it closes before the end
                    return s
                return s[1:n - 1]                 # drop leading '(' and trailing ')'
        i = i + 1
    return s                                       # unbalanced -> unchanged

# unify the tail-expression types of a value if/match (ROADMAP 2.1). Mirrors
# tychoc's resolve-then-unify: each tail is typed in its branch's bind scope
# (match payloads pushed to a value-copy of names/types), and all must agree.
fn value_ctrl_type(c: Stmt, names: [string], types: [string], dc: Decls, ctx: Ctx, sl: int) -> string:
    match c:
        SIf(cond, body, els, ln):
            t := type_of(branch_tail(body), names, types, dc, ctx)
            et := ""
            if len(els) == 1 and is_sif(els[0]):
                et = value_ctrl_type(els[0], names, types, dc, ctx, sl)
            else:
                et = type_of(branch_tail(els), names, types, dc, ctx)
            if t != et:
                die_at(dc, sl, "if/match branches produce different types (" + t + " and " + et + ")")
            return t
        SMatch(subj, variants, allbinds, bodies, _sl2):
            sty := resolve_ginst(type_of(subj, names, types, dc, ctx), dc, ctx)
            rt := ""
            i := 0
            for i < len(variants):
                vname := variants[i]
                binds := allbinds[i]
                bn := names                       # value copy: arm binds are scoped to the arm
                bt := types
                if vname != "_" and len(binds) > 0:
                    if is_option(sty) or is_result(sty):
                        bty := option_inner(sty)
                        if is_result(sty):
                            if vname == "Ok":
                                bty = result_ok(sty)
                            else:
                                bty = result_err(sty)
                        push(bn, binds[0])
                        push(bt, bty)
                    else:
                        pts := variant_ptypes_in(dc, sty, vname)
                        j := 0
                        for j < len(binds):
                            push(bn, binds[j])
                            push(bt, pts[j])
                            j = j + 1
                ti := type_of(branch_tail(bodies[i]), bn, bt, dc, ctx)
                if rt == "":
                    rt = ti
                elif ti != rt:
                    die_at(dc, sl, "if/match branches produce different types (" + rt + " and " + ti + ")")
                i = i + 1
            return rt
        _:
            return "int"

fn gen_stmt(s: Stmt, names: inout [string], types: inout [string], dc: Decls, ctx: Ctx) -> string:
    _el := 0
    ctx = with_line(ctx, stmt_line(s))            # statement line for any resolve/codegen die() within
    match s:
        SDecl(name, e, _sl):
            di := 0                                   # fail-closed: a same-scope re-`:=` (incl. shadowing a param at the top level, both depth 0) would emit a duplicate C local; nested-block shadowing stays legal (different depth)
            for di < len(names):
                if names[di] == name and var_block_depth(dc, ctx, di) == ctx.depth:
                    die("'" + name + "' is already declared in this scope")
                di = di + 1
            ty := type_of(e, names, types, dc, ctx)
            if ty_has_handle(dc, ctx, ty) and not is_handle(dc, ty):   # FFI R2: a handle nested in a container/aggregate could be aliased into a double-free
                die_at(dc, _sl, "a handle cannot be stored in a container or aggregate -- it is freed at the end of its scope")
            if has_str(ctx.saccums, name):        # string accumulator: buffer in the var's arena + len/cap sidecars
                push(names, name)
                push(types, ty)
                aar := owner_arena_of(EVar(name, _el), names, types, dc, ctx)   # grow in the var's home arena (freed with it, not leaked)
                code := "    char* " + un(name) + " = scopy(" + aar + ", " + gen_expr(e, names, types, dc, ctx) + ");\n    long _len_" + un(name) + " = ((const long*)" + un(name) + ")[-1];\n    long _cap_" + un(name) + " = _len_" + un(name) + " + 1;\n"
                return code
            if is_scalar_ty(dc, ctx, ty) and expr_has_call(e):   # transient placement (see scalar_transient)
                code := "    " + cty(dc, ctx, ty) + un(name) + ";\n" + scalar_transient(dc, ctx, e, names, types, un(name) + " = ")
                if expr_refs(e, name):            # self-referential shadow with a call: temp reads the enclosing binding, then bind (see normal path below)
                    code = "    " + cty(dc, ctx, ty) + "_sh_" + name + ";\n" + scalar_transient(dc, ctx, e, names, types, "_sh_" + name + " = ") + "    " + cty(dc, ctx, ty) + un(name) + " = _sh_" + name + ";\n"
                push(names, name)
                push(types, ty)
                if is_task(ty):                   # CC-2: implicit join at this var's scope exit
                    push(names, "!tycho_task_finish(" + un(name) + ")")
                    push(types, "!")
                if is_handle(dc, ty):             # FFI R2: RAII -- emit the destructor free_fn(h) at this var's scope exit
                    push(names, "!if (" + un(name) + ") " + handle_free(dc, ty) + "(" + un(name) + ")")   # null-guarded so an early close(h) isn't double-freed
                    push(types, "!")
                if is_chan(ty) and expr_has_call(e):   # CC-4: a CREATED channel (not an alias) frees at its scope exit
                    push(names, "!tycho_chan_free(" + un(name) + ")")
                    push(types, "!")
                return code
            rhs := gen_rhs(e, names, types, dc, ctx)
            code := "    " + cty(dc, ctx, ty) + un(name) + " = " + rhs + ";\n"
            if expr_refs(e, name):                # self-referential shadow `y := y + 2`: read the ENCLOSING y (Go/Odin lexical scope + value semantics) via a temp declared BEFORE the new C local, else the initializer reads the uninitialized inner one (UB)
                code = "    " + cty(dc, ctx, ty) + "_sh_" + name + " = " + rhs + ";\n    " + cty(dc, ctx, ty) + un(name) + " = _sh_" + name + ";\n"
            push(names, name)                     # in scope for later stmts
            push(types, ty)
            if is_task(ty):                       # CC-2 (see the transient path above)
                push(names, "!tycho_task_finish(" + un(name) + ")")
                push(types, "!")
            if is_handle(dc, ty):                 # FFI R2: RAII destructor at scope exit (see the transient path above)
                push(names, "!if (" + un(name) + ") " + handle_free(dc, ty) + "(" + un(name) + ")")   # null-guarded so an early close(h) isn't double-freed
                push(types, "!")
            if is_chan(ty) and expr_has_call(e):
                push(names, "!tycho_chan_free(" + un(name) + ")")
                push(types, "!")
            return code
        SValDecl(name, annot, ctrl, _sl):            # `x := if.../match...` (ROADMAP 2.1)
            di := 0
            for di < len(names):
                if names[di] == name and var_block_depth(dc, ctx, di) == ctx.depth:
                    die("'" + name + "' is already declared in this scope")
                di = di + 1
            ty := value_ctrl_type(ctrl, names, types, dc, ctx, _sl)
            if annot != "" and ty != annot:
                die_at(dc, _sl, "declared type " + annot + " but value is " + ty)
            if annot != "":
                ty = annot
            if is_task(ty):
                die_at(dc, _sl, "a value if/match cannot produce a task handle")
            zi := ""                                  # zero-init an array so the reassign-recycle guard reads NULL on the empty slot
            if is_array(ty):
                zi = " = {0}"
            code := "    " + cty(dc, ctx, ty) + un(name) + zi + ";\n"
            push(names, name)                         # in scope before the branch assigns
            push(types, ty)
            ctrl2 := ctrl_rewrite_tails(ctrl, 1, name, EInt("0", 0))   # each tail -> `name = tail`
            return code + gen_stmt(ctrl2, &names, &types, dc, ctx)
        SAssign(name, e, _sl):
            if is_handle(dc, var_type(names, types, name)):   # FFI R2: rebinding orphans the old handle (freed once, at scope exit)
                die_at(dc, _sl, "a handle variable cannot be reassigned -- it is freed once, at the end of its scope")
            lhs := gen_expr(EVar(name, _el), names, types, dc, ctx)
            if is_scalar_ty(dc, ctx, type_of(EVar(name, _el), names, types, dc, ctx)) and expr_has_call(e):   # transient placement
                return scalar_transient(dc, ctx, e, names, types, lhs + " = ")
            if has_str(ctx.saccums, name):        # string accumulator
                aar := owner_arena_of(EVar(name, _el), names, types, dc, ctx)   # the var's home arena (consistent with its decl)
                pieces := sacc_pieces(e, name)
                # multi-piece in-place is sound only if no piece names the
                # accumulator: the first append grows its buffer, so a later
                # piece reading `name` would see the grown value. A single piece
                # passes straight through (runtime handles s=s+s). Otherwise fall
                # back to the pure-concat scopy path below.
                if len(pieces) > 0 and (len(pieces) == 1 or not any_refs(pieces, name)):   # s = s + p1 + ... -> in-place append each piece
                    aout := ""
                    k := 0
                    for k < len(pieces):
                        if type_of(pieces[k], names, types, dc, ctx) == "char":   # one-byte append, no strlen
                            aout = aout + "    hi_append_char(" + aar + ", &" + un(name) + ", &_len_" + un(name) + ", &_cap_" + un(name) + ", " + gen_expr(pieces[k], names, types, dc, ctx) + ");\n"
                        else:
                            aout = aout + "    hi_append(" + aar + ", &" + un(name) + ", &_len_" + un(name) + ", &_cap_" + un(name) + ", " + gen_expr(pieces[k], names, types, dc, ctx) + ");\n"
                        k = k + 1
                    return aout
                # plain reassign of an accumulator: heap-ify + resync the sidecars
                return "    " + un(name) + " = scopy(" + aar + ", " + gen_expr(e, names, types, dc, ctx) + ");\n    _len_" + un(name) + " = ((const long*)" + un(name) + ")[-1];\n    _cap_" + un(name) + " = _len_" + un(name) + " + 1;\n"
            deflt := "    " + lhs + " = " + gen_rhs(e, names, types, dc, with_owner(dc, ctx, owner_arena_of(EVar(name, _el), names, types, dc, ctx))) + ";\n"   # build in the var's home arena (block-local -> block; outer -> &_scope)
            # liveness-driven recycle (ANY array RHS: call / slice / copybind / literal).
            # a's old buffer is dead and -- value semantics -- uniquely owned, GATED on
            # NOT movable so `name` is never a move source whose buffer is shared via
            # `b := a`. The new value is always a DISTINCT fresh buffer (a place RHS is
            # deep-copied by gen_rhs; a call/literal is fresh), enforced by the runtime
            # `.data != .data` guard. Eval the RHS into a { }-scoped temp FIRST (it may
            # read the old buffer), THEN recycle, THEN assign. is_array excludes maps, so
            # the map_set in-place put below is unaffected.
            rnty := type_of(EVar(name, _el), names, types, dc, ctx)
            rown := owner_arena_of(EVar(name, _el), names, types, dc, ctx)
            if is_array(rnty) and not has_str(ctx.vparams, name) and not is_inout(var_type(names, types, name)) and not has_str(ctx.movables, name) and rown != "0":
                return "    { " + cty(dc, ctx, rnty) + "_r = " + gen_rhs(e, names, types, dc, with_owner(dc, ctx, rown)) + "; if (" + lhs + ".data && " + lhs + ".data != _r.data) arena_recycle(" + rown + ", " + lhs + ".data, (size_t)" + lhs + ".cap * sizeof(*" + lhs + ".data)); " + lhs + " = _r; }\n"
            match e:                              # accumulator rewrite: x = map_set(x,k,v) -> in-place put
                # A by-value map PARAM must NOT take the in-place put: it shares
                # the caller's table, so mutating it in place is a value-semantics
                # violation. ctx.vparams holds this func's non-inout params; for
                # those we fall through to `deflt` (pure map_set = deep-copy+put),
                # matching the C compiler (src/tychoc.c:3556 drops non-inout params
                # from accums). Locals and inout map params still grow in place.
                ECall(fname, args, _el):
                    if fname == "map_set" and is_evar(args[0], name) and not has_str(ctx.vparams, name):
                        return "    " + mfam(type_of(EVar(name, _el), names, types, dc, ctx)) + "_put(" + owner_arena_of(EVar(name, _el), names, types, dc, ctx) + ", &" + lhs + ", " + krt(dc, ctx, type_of(EVar(name, _el), names, types, dc, ctx), gen_expr(args[1], names, types, dc, ctx)) + ", " + gen_expr(args[2], names, types, dc, ctx) + ");\n"
                    return deflt
                EInt(t, _el):
                    return deflt
                EBool(t, _el):
                    return deflt
                EChar(t, _el):
                    return deflt
                EFloat(f, _el):
                    return deflt
                EStr(s, _el):
                    return deflt
                EVar(n, _el):
                    return deflt
                EBin(o, l, r, _el):
                    return deflt
                EField(b, f, _el):
                    return deflt
                EIndex(b, i, _el):
                    return deflt
                EArrLit(es, _el):
                    return deflt
                EArrEmpty(t, _el):
                    return deflt
                EMapEmpty(k, v, _el):
                    return deflt
                EMapLit(ks, vs, _el):
                    return deflt
                ETuple(es, _el):
                    return deflt
                ESlice(b, lo, hi, _el):
                    return deflt
                ECallV(callee, cargs, _el):
                    return deflt
                EAddr(x, _el):
                    return deflt
                ELambda(id, ps, pts, ret, body, cn, ct, _el):
                    return deflt
                ESpawn(sid, snm, sa, _el):
                    return deflt
        SFieldAssign(lv, rhs, _sl):
            # storing into a (malloc) struct field / array element: the value must
            # be malloc'd (owner "0"), not left in _scope which frees at return.
            # EXCEPT a map-place m[k]: its slot lives in the map's own arena, so
            # build the value there — owner 0 would leak a multi-piece map literal's
            # chained-_set intermediate tables (the slotptr store doesn't re-home it).
            # MM-9: overwriting a string-array slot. Place the new element in the
            # array's OWN arena (oa) -- not malloc (owner 0), which would leak every
            # evicted record -- and recycle the dead old element so the next store
            # reuses it. Reads deep-copy out (value semantics) so the old buffer is
            # uniquely owned + dead. Build new BEFORE recycling (the rhs may read the
            # slot, e.g. a[k]=a[k]+x); arena_owns gates out literals/cross-arena
            # pointers; _o != slot rules out recycling the freshly-stored buffer.
            if is_str_arr_index(lv, names, types, dc, ctx):
                oa := owner_arena_of(lv, names, types, dc, ctx)
                slot := gen_place(lv, names, types, dc, ctx)   # array element lvalue (checked stmt-expr); gen_expr now lowers a[i] to a non-assignable read
                nv := gen_rhs(rhs, names, types, dc, with_owner(dc, ctx, oa))
                return "    { char* _o = " + slot + "; " + slot + " = " + nv + "; if (_o && _o != " + slot + " && arena_owns(" + oa + ", _o - 8)) arena_recycle(" + oa + ", _o - 8, (size_t)(((const long*)_o)[-1] + 16) & ~(size_t)7); }\n"
            sfo := "0"
            if is_scalar_ty(dc, ctx, type_of(lv, names, types, dc, ctx)):
                sfo = ctx.owner    # a scalar slot stores a value word; build the RHS (and any nested transient, e.g. str() inside len()) in the current scope so it frees, not malloc'd at owner-0 and leaked
            if is_map_index(lv, names, types, dc, ctx):
                sfo = owner_arena_of(lv, names, types, dc, ctx)
            return "    " + gen_place(lv, names, types, dc, ctx) + " = " + gen_rhs(rhs, names, types, dc, with_owner(dc, ctx, sfo)) + ";\n"
        SPrint(e, _sl):
            if type_of(e, names, types, dc, ctx) != "str":
                die_at(dc, ctx.line, "codegen: print expects a string")
            # transient arena: the print arg's string temporaries are consumed by
            # fputs and never escape, so build them in _t and free it right after.
            return "    { Arena _t = arena_new(0); hi_puts(" + gen_expr(e, names, types, dc, with_owner(dc, ctx, "&_t")) + "); arena_free(&_t); }\n"
        SReturn(e, _sl):
            # deep-copy a returned heap PLACE (a field/element/variable): the
            # return value outlives the callee, so it must not alias the source's
            # buffer (`return b.items` then the caller mutates the result must not
            # reach b). gen_rhs copies is_place array/struct/map/tuple; fresh
            # values / scalars / strings pass through. (tests/value_semantics.ty
            # probe 9; the C compiler does this via return-promotion.)
            # return-slot: evaluate into _ret, free this scope, then return _ret.
            # (S1: the value is still malloc'd, so the free reclaims nothing; later
            # sub-steps build the return value in _parent so this stays sound.)
            # build the return value in _parent (the caller's arena, which outlives
            # _scope), then free _scope. Any string the value reaches is either built
            # in _parent here or, if stored into a constructed container, forced to
            # malloc by the store sites (gen_store_args/ETuple/map_set/hbox) — so the
            # returned value never points into the freed _scope.
            # free every enclosing block arena (return_frees), innermost-first,
            # then _scope; the value is in _parent which outlives them all.
            # push-loop fusion: a return leaves before the after-loop flush, so write
            # every live cursor back first (the returned value must see the real length)
            rfl := ""
            fk := 0
            for fk < len(ctx.fusearr):
                rfl = rfl + "    " + un(ctx.fusearr[fk]) + ".data = _fd" + ctx.fusesuf[fk] + "; " + un(ctx.fusearr[fk]) + ".len = _fl" + ctx.fusesuf[fk] + "; " + un(ctx.fusearr[fk]) + ".cap = _fc" + ctx.fusesuf[fk] + ";\n"
                fk = fk + 1
            if is_func(ctx.rettype):              # escaping closure: re-home the captured env into _parent before freeing _scope (its hbox lives in &_scope); plain ref has env==0 -> no-op
                return rfl + "    { " + cty(dc, ctx, ctx.rettype) + "_ret = " + gen_expr(e, names, types, dc, ctx) + "; if (_ret.env) _ret.env = _ret.copyenv(_parent, _ret.env); " + conc_finals(names, 0) + return_frees(dc, ctx) + " return _ret; }\n"
            return rfl + "    { " + cty(dc, ctx, ctx.rettype) + "_ret = " + gen_rhs(e, names, types, dc, with_owner(dc, ctx, "_parent")) + "; " + conc_finals(names, 0) + return_frees(dc, ctx) + " return _ret; }\n"
        SConst(n, e, _sl):
            return ""
        SReturnVoid:
            return "    " + conc_finals(names, 0) + return_frees(dc, ctx) + " return;\n"
        SBreak:
            return "    " + conc_loop_finals(names, ctx) + loop_frees(dc, ctx) + "break;\n"
        SContinue:
            return "    " + conc_loop_finals(names, ctx) + loop_frees(dc, ctx) + "continue;\n"
        SExpr(e, _sl):                                 # MM-10: discarded result -> all transients dead at stmt end; free them in a per-stmt _t arena (matches tychoc S_EXPR + scalar_transient)
            pn := pure_call_name(e)                     # warn on a discarded pure-builtin result (no-op statement)
            if pn != "":
                warn_at(dc, _sl, "result of " + pn + " is discarded; it has no side effects, so this statement does nothing (to change a map, use m[k] = v or delete m[k])")
            return "    { Arena _t = arena_new(0); " + gen_expr(e, names, types, dc, with_owner(dc, ctx, "&_t")) + "; arena_free(&_t); }\n"
        STypedDecl(name, ty, e, _sl):                  # annotation fixes the var's type
            if has_str(ctx.saccums, name):        # string accumulator (annotated): same heap buffer + sidecars
                push(names, name)
                push(types, ty)
                aar := owner_arena_of(EVar(name, _el), names, types, dc, ctx)   # grow in the var's home arena (freed with it, not leaked) — mirrors the SDecl saccum path; scopy(0,...) here was a malloc leak
                code := "    char* " + un(name) + " = scopy(" + aar + ", " + gen_expr(e, names, types, dc, ctx) + ");\n    long _len_" + un(name) + " = ((const long*)" + un(name) + ")[-1];\n    long _cap_" + un(name) + " = _len_" + un(name) + " + 1;\n"
                return code
            if is_scalar_ty(dc, ctx, ty) and expr_has_call(e):   # transient placement
                code := "    " + cty(dc, ctx, ty) + un(name) + ";\n" + scalar_transient(dc, ctx, e, names, types, un(name) + " = ")
                push(names, name)
                push(types, ty)
                return code
            code := "    " + cty(dc, ctx, ty) + un(name) + " = " + gen_rhs(e, names, types, dc, ctx) + ";\n"
            push(names, name)
            push(types, ty)
            return code
        SDestructure(dnames, e, _sl):                  # a, b := tuple_expr
            tt := type_of(e, names, types, dc, ctx)
            if not is_tuple(tt):                       # fail closed: non-tuple RHS (mirrors tychoc)
                die("type: the right side of a destructuring `:=` must be a tuple, got " + tt)
            parts := tuple_parts(tt)
            if len(parts) != len(dnames):
                die("type: destructuring " + str(len(dnames)) + " name(s) from a " + str(len(parts)) + "-element tuple")
            tmp := "_d_" + dnames[0]
            code := "    Tup_" + tup_suffix(tt) + " " + tmp + " = " + gen_expr(e, names, types, dc, ctx) + ";\n"
            j := 0
            for j < len(dnames):
                code = code + "    " + cty(dc, ctx, parts[j]) + un(dnames[j]) + " = " + tmp + ".f" + str(j) + ";\n"
                push(names, dnames[j])
                push(types, parts[j])
                j = j + 1
            return code
        SMultiAssign(mnames, e, _sl):                  # a, b = tuple_expr (existing vars)
            tt := type_of(e, names, types, dc, ctx)
            if not is_tuple(tt):                       # fail closed: non-tuple RHS (mirrors tychoc)
                die("type: the right side of a multi-assign must be a tuple, got " + tt)
            mparts := tuple_parts(tt)
            if len(mparts) != len(mnames):
                die("type: assigning " + str(len(mnames)) + " name(s) from a " + str(len(mparts)) + "-element tuple")
            tmp := "_ma_" + mnames[0]
            # brace-scope the temp: two multi-assigns with the same first target in
            # one block must not redefine it (tychoc names its temp _mt<g_blk++>)
            code := "    { Tup_" + tup_suffix(tt) + " " + tmp + " = " + gen_expr(e, names, types, dc, ctx) + ";\n"
            j := 0
            for j < len(mnames):
                code = code + "    " + un(mnames[j]) + " = " + tmp + ".f" + str(j) + ";\n"
                j = j + 1
            return code + "    }\n"
        SOrReturn(name, e, _sl):                       # unwrap Ok/Some, or propagate Err/None upward
            rty := type_of(e, names, types, dc, ctx)
            tmp := "_or_" + name
            # the early return leaves the function like SReturn does: flush any
            # live push-loop fusion cursors, then free every enclosing block
            # arena + _scope (return_frees) — skipping them leaked every arena
            # on the error path. The Err payload is promoted into _parent BEFORE
            # the frees (it points into a scope we are about to free), exactly
            # like tychoc's E_ORRETURN (src/tychoc.c:4135).
            orfl := ""
            ofk := 0
            for ofk < len(ctx.fusearr):
                orfl = orfl + "    " + un(ctx.fusearr[ofk]) + ".data = _fd" + ctx.fusesuf[ofk] + "; " + un(ctx.fusearr[ofk]) + ".len = _fl" + ctx.fusesuf[ofk] + "; " + un(ctx.fusearr[ofk]) + ".cap = _fc" + ctx.fusesuf[ofk] + ";\n"
                ofk = ofk + 1
            if is_option(rty):                    # Option: unwrap Some, else return None
                cto := cty(dc, ctx, option_inner(rty))
                oc := "    HOption " + tmp + " = " + gen_expr(e, names, types, dc, ctx) + ";\n"
                oc = oc + "    if (" + tmp + ".tag == 0) {\n" + orfl + "    " + conc_finals(names, 0) + return_frees(dc, ctx) + " return hnone(); }\n"
                oc = oc + "    " + cto + un(name) + " = *(" + cto + "*)(" + tmp + ".val);\n"
                push(names, name)
                push(types, option_inner(rty))
                return oc
            ct := cty(dc, ctx, result_ok(rty))
            ect := cty(dc, ctx, result_err(rty))
            code := "    HResult " + tmp + " = " + gen_expr(e, names, types, dc, ctx) + ";\n"
            code = code + "    if (" + tmp + ".tag == 0) {\n" + orfl + "    HResult _re_" + name + " = herr(hbox(_parent, sizeof(" + ect + "), " + box_payload(dc, ctx, result_err(rty), "_parent", tmp + ".err") + ")); " + conc_finals(names, 0) + return_frees(dc, ctx) + " return _re_" + name + "; }\n"
            code = code + "    " + ct + un(name) + " = *(" + ct + "*)(" + tmp + ".ok);\n"
            push(names, name)
            push(types, result_ok(rty))
            return code
        SIf(cond, then_body, else_body, _sl):
            d1 := str(ctx.depth + 1)              # each branch is its own block arena
            bc := enter_block(dc, ctx, len(names))
            op := "        Arena _b" + d1 + " = arena_child(" + cur_arena(dc, ctx) + ");\n"
            fr := "        arena_free(&_b" + d1 + ");\n"
            out := "    if (" + cond_unwrap(gen_expr(cond, names, types, dc, ctx)) + ") {\n" + op + gen_block(then_body, names, types, dc, bc) + fr + "    }"
            if len(else_body) > 0:
                out = out + " else {\n" + op + gen_block(else_body, names, types, dc, bc) + fr + "    }"
            return out + "\n"
        SWhile(cond, body, _sl):
            wl_check(cond, body, _sl, dc)         # warn on a `for COND:` whose cond never advances
            fnm, fsf, fty := fuse_detect(body, names, types, dc, ctx, cond, true)
            d1 := str(ctx.depth + 1)              # per-iteration block arena
            bc := in_loop(enter_block(dc, ctx, len(names)))
            decls := ""
            flush := ""
            k := 0
            for k < len(fnm):
                ct := cty(dc, ctx, fty[k])
                decls = decls + "        " + ct + "* _fd" + fsf[k] + " = " + un(fnm[k]) + ".data; long _fl" + fsf[k] + " = " + un(fnm[k]) + ".len, _fc" + fsf[k] + " = " + un(fnm[k]) + ".cap;\n"
                flush = flush + "        " + un(fnm[k]) + ".data = _fd" + fsf[k] + "; " + un(fnm[k]) + ".len = _fl" + fsf[k] + "; " + un(fnm[k]) + ".cap = _fc" + fsf[k] + ";\n"
                bc = add_fuse(bc, fnm[k], fsf[k], fty[k])
                k = k + 1
            inner := "    while (" + cond_unwrap(gen_expr(cond, names, types, dc, ctx)) + ") {\n        Arena _b" + d1 + " = arena_child(" + cur_arena(dc, ctx) + ");\n" + gen_block(body, names, types, dc, bc) + "        arena_free(&_b" + d1 + ");\n    }\n"
            if len(fnm) == 0:
                return inner
            return "    {\n" + decls + inner + flush + "    }\n"
        SForRange(name, start, stop, step, body, _sl):
            fnm, fsf, fty := fuse_detect(body, names, types, dc, ctx, start, false)
            bn := names                           # loop var is scoped to body
            bt := types
            push(bn, name)
            push(bt, "int")
            d1 := str(ctx.depth + 1)              # per-iteration block arena
            bc := in_loop(enter_block(dc, ctx, len(bn)))
            decls := ""
            flush := ""
            k := 0
            for k < len(fnm):
                ct := cty(dc, ctx, fty[k])
                decls = decls + "        " + ct + "* _fd" + fsf[k] + " = " + un(fnm[k]) + ".data; long _fl" + fsf[k] + " = " + un(fnm[k]) + ".len, _fc" + fsf[k] + " = " + un(fnm[k]) + ".cap;\n"
                flush = flush + "        " + un(fnm[k]) + ".data = _fd" + fsf[k] + "; " + un(fnm[k]) + ".len = _fl" + fsf[k] + "; " + un(fnm[k]) + ".cap = _fc" + fsf[k] + ";\n"
                bc = add_fuse(bc, fnm[k], fsf[k], fty[k])
                k = k + 1
            # bounds eval once, pre-loop; the condition is sign-aware so a negative
            # step counts down (tychoc: _stop/_step temps + step>0 ? < : >)
            sx := "_stop_" + un(name)
            px := "_step_" + un(name)
            header := "    { long " + sx + " = " + gen_expr(stop, names, types, dc, ctx) + ", " + px + " = " + gen_expr(step, names, types, dc, ctx) + ";\n"
            header = header + "    for (long " + un(name) + " = " + gen_expr(start, names, types, dc, ctx) + "; " + px + " > 0 ? " + un(name) + " < " + sx + " : " + un(name) + " > " + sx + "; " + un(name) + " += " + px + ") {\n"
            inner := header + "        Arena _b" + d1 + " = arena_child(" + cur_arena(dc, ctx) + ");\n" + gen_block(body, bn, bt, dc, bc) + "        arena_free(&_b" + d1 + ");\n    } }\n"
            if len(fnm) == 0:
                return inner
            return "    {\n" + decls + inner + flush + "    }\n"
        SMatch(subj, variants, allbinds, bodies, _sl):  # tag-dispatch over an enum value
            # resolve a generic-enum application (Box(Box(int))) to its instance
            # (Box__Box__int) so variant_ptypes_in finds the right instance's payload
            # types; an unresolved app misses and falls back to the wrong enum's $T
            # (-> long binding). (Option/Result have no instance, so they pass through.)
            sty := resolve_ginst(type_of(subj, names, types, dc, ctx), dc, ctx)
            # evaluate the subject ONCE into a brace-scoped temp: a side-effecting
            # subject (match pop(s):) must not run once per arm test (tychoc: _m<id>)
            sv := gen_expr(subj, names, types, dc, ctx)
            scu := "_msub"
            hd := "    { " + cty(dc, ctx, sty) + scu + " = " + sv + ";\n"
            if is_option(sty) or is_result(sty):
                return hd + gen_match_optres(dc, ctx, sty, scu, variants, allbinds, bodies, names, types) + "    }\n"
            out := hd
            wild := -1                            # index of a `_` catch-all arm (tychoc guarantees it last)
            emitted := 0
            i := 0
            for i < len(variants):
                vname := variants[i]
                if vname == "_":
                    wild = i
                    i = i + 1
                    continue
                binds := allbinds[i]
                pts := variant_ptypes_in(dc, sty, vname)   # generics: bind from the scrutinee's instance (shared variant names)
                kw := " else if ("
                if emitted == 0:
                    kw = "    if ("
                out = out + kw + scu + "->tag == " + str(variant_tag(dc, ctx, vname)) + ") {\n"
                bn := names                       # arm bindings are scoped to the arm
                bt := types
                j := 0
                for j < len(binds):
                    out = out + "    " + cty(dc, ctx, pts[j]) + un(binds[j]) + " = " + cp_typed(dc, ctx, pts[j], efield(scu, vname, j)) + ";\n"
                    push(bn, binds[j])
                    push(bt, pts[j])
                    j = j + 1
                out = out + gen_block(bodies[i], bn, bt, dc, ctx) + "    }"
                emitted = emitted + 1
                i = i + 1
            if wild >= 0:                         # `_` catch-all: every unlisted variant
                opener := " else {\n"
                if emitted == 0:
                    opener = "    {\n"
                out = out + opener + gen_block(bodies[wild], names, types, dc, ctx) + "    }"
            else:
                # Exhaustiveness is enforced by tychoc, which gates user programs, so
                # this else is unreachable -- but emit a trap so the generated C
                # provably returns on every path (no -Wreturn-type) and any future
                # non-exhaustive match aborts cleanly instead of falling through.
                out = out + " else { fprintf(stderr, \"tycho: non-exhaustive match\\n\"); exit(1); }"
            return out + "\n    }\n"
        SParFor(v, a, b, body, pid, _sl):
            # CC-3: K = tycho_ncpu() chunk tasks of the lifted __par chunk proc,
            # through the same HSpawnA/tycho_spawn trampolines as CC-1 spawn;
            # captures deep-copy into each task root; partials fold at the
            # in-order join. All tasks join inside this statement (structured).
            pf := dc.pars[pid]
            sid := str(pf.sid)
            rct := cty(dc, ctx, pf.retty)
            out := "    { long _plo = " + gen_expr(a, names, types, dc, ctx) + ", _phi = " + gen_expr(b, names, types, dc, ctx) + ";\n"
            out = out + "    if (_phi < _plo) _phi = _plo;\n"
            out = out + "    long _pk = tycho_ncpu();\n    if (_pk > _phi - _plo) _pk = _phi - _plo;\n    if (_pk < 1) _pk = 1; if (_pk > 64) _pk = 64;\n"
            out = out + "    HTask* _pts[64];\n"
            out = out + "    for (long _pc = 0; _pc < _pk; _pc++) {\n"
            out = out + "        HTask* _tk = tycho_task_new();\n"
            out = out + "        HSpawnA_" + sid + "* _sa = (HSpawnA_" + sid + "*)amem(&_tk->root, sizeof(HSpawnA_" + sid + "));\n"
            out = out + "        _sa->t = _tk;\n        _sa->a0 = _plo + (_phi - _plo) * _pc / _pk;\n        _sa->a1 = _plo + (_phi - _plo) * (_pc + 1) / _pk;\n"
            ck := 0
            for ck < len(pf.capnames):
                out = out + "        _sa->a" + str(ck + 2) + " = " + cp_field(dc, ctx, pf.captypes[ck], "(&_tk->root)", gen_expr(EVar(pf.capnames[ck], _el), names, types, dc, ctx)) + ";\n"
                ck = ck + 1
            out = out + "        tycho_task_start(_tk, tycho_spawn_" + sid + ", _sa);\n        _pts[_pc] = _tk;\n    }\n"
            out = out + "    for (long _pc = 0; _pc < _pk; _pc++) {\n        tycho_task_join(_pts[_pc]);\n        " + rct + "_pp = *(" + rct + "*)_pts[_pc]->ret;\n        tycho_task_free(_pts[_pc]);\n"
            ak := 0
            for ak < len(pf.accnames):
                part := "_pp"
                if len(pf.accnames) > 1:
                    part = "_pp.f" + str(ak)
                out = out + "        " + un(pf.accnames[ak]) + " = " + un(pf.accnames[ak]) + " " + pf.accops[ak] + " " + part + ";\n"
                ak = ak + 1
            return out + "    }\n    }\n"
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            # CC-5: try every recv arm; closed when ALL drain; else default or
            # pause+retry. A goto loop (not for(;;)) so a user break/continue in
            # an arm body binds to the USER'S enclosing loop, never to select's.
            sout := "    { "
            sk := 0
            for sk < len(svars):
                if svars[sk] == "recv":
                    sout = sout + "HChan* _sc" + uid + "_" + str(sk) + " = " + gen_expr(schans[sk], names, types, dc, ctx) + "; "
                sk = sk + 1
            sout = sout + "int _ssp" + uid + " = 0, _open" + uid + " = 0;\n"
            sout = sout + "    _sel_retry_" + uid + ": ;\n    _open" + uid + " = 0;\n"
            sk = 0
            for sk < len(svars):
                if svars[sk] == "recv":
                    cit := chan_inner(type_of(schans[sk], names, types, dc, ctx))
                    cct := cty(dc, ctx, cit)
                    sout = sout + "    { HCell* _tc; int _st = tycho_chan_try_recv(_sc" + uid + "_" + str(sk) + ", &_tc); if (_st == 1) {\n"
                    sout = sout + "    " + cct + un(sbinds[sk]) + " = " + cp_field(dc, ctx, cit, cur_arena(dc, ctx), "(*(" + cct + "*)_tc->val)") + "; tycho_chan_recv_commit(_sc" + uid + "_" + str(sk) + ", _tc);\n"
                    bn := names
                    bt := types
                    push(bn, sbinds[sk])
                    push(bt, cit)
                    sout = sout + gen_block(sbodies[sk], bn, bt, dc, ctx)
                    sout = sout + "    goto _sel_done_" + uid + ";\n    } if (_st == 0) _open" + uid + " = 1; }\n"
                sk = sk + 1
            sout = sout + "    if (!_open" + uid + ") {\n"
            sk = 0
            for sk < len(svars):
                if svars[sk] == "closed":
                    sout = sout + gen_block(sbodies[sk], names, types, dc, ctx)
                sk = sk + 1
            sout = sout + "    goto _sel_done_" + uid + "; }\n"
            hasdef := false
            sk = 0
            for sk < len(svars):
                if svars[sk] == "default":
                    hasdef = true
                    sout = sout + gen_block(sbodies[sk], names, types, dc, ctx)
                    sout = sout + "    goto _sel_done_" + uid + ";\n"
                sk = sk + 1
            if not hasdef:
                sout = sout + "    tycho_select_pause(&_ssp" + uid + ");\n    goto _sel_retry_" + uid + ";\n"
            return sout + "    _sel_done_" + uid + ": ;\n    }\n"

fn ret_cty(dc: Decls, ctx: Ctx, ret: string) -> string:
    if ret == "void":
        return "void "
    return cty(dc, ctx, ret)

# A inout array/map/soa param: its container's home arena is the CALLER's, so
# the callee receives it as a hidden `Arena* _ina_<name>` param and grows/allocs
# into it (instead of malloc-leaking). Inout scalars and inout structs do NOT get
# one (a struct's field-container is a smaller separate residual, still malloc).
fn inout_container_param(dc: Decls, ctx: Ctx, ptype: string) -> bool:
    if not is_inout(ptype):
        return false
    b := base_ty(ptype)
    if resolve_nt(dc, ctx, b) == "str":          # inout string: reassignment bytes build in _ina_
        return true
    return is_array(b) or is_map(b) or is_soa(b) or (is_struct(dc, ctx, b) and struct_is_heap(dc, ctx, b))   # a heap struct's field-containers grow in _ina_

fn gen_params(f: Func, dc: Decls, ctx: Ctx) -> string:
    out := "Arena* _parent"                       # every fn threads the caller's arena
    i := 0
    for i < len(f.params):
        out = out + ", " + cty(dc, ctx, f.ptypes[i]) + un(f.params[i])
        if inout_container_param(dc, ctx, f.ptypes[i]):   # + the container's home arena (keyed by SOURCE name, like owner_arena_of)
            out = out + ", Arena* _ina_" + f.params[i]
        i = i + 1
    return out

fn seed_env(f: Func, names: inout [string], types: inout [string]):
    i := 0
    for i < len(f.params):
        push(names, f.params[i])
        if is_sink(f.ptypes[i]):                  # sink: the body sees a plain, mutable, by-value value
            push(types, base_ty(f.ptypes[i]))
        else:
            push(types, f.ptypes[i])
        i = i + 1

fn gen_proto(f: Func, dc: Decls, ctx: Ctx) -> string:
    return ret_cty(dc, ctx, f.ret) + un(f.name) + "(" + gen_params(f, dc, ctx) + ");\n"

# FFI: is `name` an extern (C) function? Drives the direct-call codegen.
fn sig_is_extern(dc: Decls, name: string) -> bool:
    si := dc.sigmap.get(name, -1)
    if si < 0:
        return false
    return dc.sigs[si].is_extern == 1

# FFI: forward-declare the C symbol with its real C ABI — no arena, no h_ prefix.
fn gen_extern_proto(f: Func, dc: Decls, ctx: Ctx) -> string:
    # bytes crosses as (ptr,len): a bytes param -> two C args (const unsigned char*, long);
    # a bytes return -> a void function with two trailing out-params (out, outlen).
    bret := f.ret == "bytes"
    rc := ffi_sized_cty(f.ret)          # FFI-boundary sized return -> real C ABI type
    if rc == "":
        rc = ret_cty(dc, ctx, f.ret)
    if bret:
        rc = "void "
    if is_option(f.ret) and option_inner(f.ret) == "str":   # FFI R3a: the C symbol returns char*, not HOption (the call site wraps NULL -> None)
        rc = "char* "
    out := "extern " + rc + f.name + "("
    emitted := 0
    i := 0
    for i < len(f.params):
        if emitted > 0:
            out = out + ", "
        if f.ptypes[i] == "bytes":
            out = out + "const unsigned char*, long"
        else:
            psc := ffi_sized_cty(f.ptypes[i])   # FFI-boundary sized param -> real C ABI type
            if psc == "":
                psc = cty(dc, ctx, f.ptypes[i])
            out = out + psc
        emitted = emitted + 1
        i = i + 1
    if bret:
        if emitted > 0:
            out = out + ", "
        out = out + "unsigned char**, long*"
        emitted = emitted + 1
    if emitted == 0:
        out = out + "void"
    return out + ");\n"

# Leftmost-flatten an all-'+' EBin chain into its operands, left to right.
# A non-'+' binop or any leaf is one whole piece. So `a + b + c` -> [a, b, c]
# but `(a - b) + c` -> [(a-b), c].
fn plus_flatten(e: Expr, out: inout [Expr]):
    match e:
        EBin(op, l, r, _el):
            if op == "+":
                plus_flatten(l, &out)
                push(out, r)
            else:
                push(out, e)
        EInt(t, _el):
            push(out, e)
        EBool(t, _el):
            push(out, e)
        EChar(t, _el):
            push(out, e)
        EFloat(f, _el):
            push(out, e)
        EStr(s, _el):
            push(out, e)
        EVar(n, _el):
            push(out, e)
        ECall(nm, args, _el):
            push(out, e)
        EField(b, fl, _el):
            push(out, e)
        EIndex(b, ix, _el):
            push(out, e)
        EArrLit(es, _el):
            push(out, e)
        EArrEmpty(t, _el):
            push(out, e)
        EMapEmpty(k, v, _el):
            push(out, e)
        EMapLit(ks, vs, _el):
            push(out, e)
        ETuple(es, _el):
            push(out, e)
        ESlice(b, lo, hi, _el):
            push(out, e)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            push(out, e)
        ECallV(callee, cargs, _el):
            push(out, e)
        EAddr(x, _el):
            push(out, e)
        ESpawn(sid, snm, sa, _el):
            push(out, e)

# If `e` is `name + p1 + p2 + ...` (an all-'+' chain whose leftmost leaf is the
# variable `name`), return the appended pieces [p1, p2, ...]; else []. Used both
# to DETECT a string self-append accumulator and to emit its in-place appends.
fn sacc_pieces(e: Expr, name: string) -> [Expr]:
    ps := []Expr
    plus_flatten(e, &ps)
    if len(ps) < 2:
        return []Expr
    if not is_evar(ps[0], name):
        return []Expr
    return ps[1:]

# Collect string locals that are self-append accumulators (`s = s + ...`). These
# get a growing heap buffer + len/cap sidecars and in-place hi_append instead of
# the O(n^2) sc()-rebuild. Threads the var env (like collect_stmt) so the type
# guard `var_type == "str"` is accurate; a non-str `c = c + 1` is never flagged.
# Match arms bind payloads as "" (unknown) — at worst an arm-local accumulator is
# missed (stays the safe pure-concat path); a false positive is impossible.
fn sacc_block(acc: inout [string], stmts: [Stmt], names: [string], types: [string], dc: Decls, ctx: Ctx):
    ns := names
    ts := types
    i := 0
    for i < len(stmts):
        sacc_stmt(&acc, stmts[i], &ns, &ts, dc, ctx)
        i = i + 1

fn sacc_stmt(acc: inout [string], s: Stmt, names: inout [string], types: inout [string], dc: Decls, ctx: Ctx):
    match s:
        SDecl(n, e, _sl):
            dty := type_of(e, names, types, dc, ctx)   # compute BEFORE pushing n (keep names/types in sync)
            push(names, n)
            push(types, dty)
        SAssign(n, e, _sl):
            if var_type(names, types, n) == "str":
                if len(sacc_pieces(e, n)) > 0:
                    push(acc, n)
        SFieldAssign(lv, rhs, _sl):
            i := 0
        SPrint(e, _sl):
            i := 0
        SReturn(e, _sl):
            i := 0
        SConst(n, e, _sl):
            i := 0
        SReturnVoid:
            i := 0
        SBreak:
            i := 0
        SContinue:
            i := 0
        SExpr(e, _sl):
            i := 0
        STypedDecl(n, t, e, _sl):
            push(names, n)
            push(types, t)
        SOrReturn(n, e, _sl):
            ety := type_of(e, names, types, dc, ctx)
            ty := ""
            if is_option(ety):
                ty = option_inner(ety)
            else:
                ty = result_ok(ety)
            push(names, n)
            push(types, ty)
        SDestructure(dn, e, _sl):
            parts := tuple_parts(type_of(e, names, types, dc, ctx))
            i := 0
            for i < len(dn):
                push(names, dn[i])
                push(types, parts[i])
                i = i + 1
        SMultiAssign(mn, e, _sl):
            i := 0
        SIf(c, tb, eb, _sl):
            sacc_block(&acc, tb, names, types, dc, ctx)
            sacc_block(&acc, eb, names, types, dc, ctx)
        SWhile(c, body, _sl):
            sacc_block(&acc, body, names, types, dc, ctx)
        SForRange(n, a, b, st, body, _sl):
            bn := names
            bt := types
            push(bn, n)
            push(bt, "int")
            sacc_block(&acc, body, bn, bt, dc, ctx)
        SMatch(subj, variants, allbinds, bodies, _sl):
            sty := type_of(subj, names, types, dc, ctx)
            j := 0
            for j < len(bodies):
                bn := names                       # bind arm payloads with PROPER types so
                bt := types                       # type_of resolves in the arm (mirror collect_stmt)
                binds := allbinds[j]
                if is_option(sty):
                    if len(binds) > 0:
                        push(bn, binds[0])
                        push(bt, option_inner(sty))
                elif is_result(sty):
                    if len(binds) > 0:
                        push(bn, binds[0])
                        if variants[j] == "Ok":
                            push(bt, result_ok(sty))
                        else:
                            push(bt, result_err(sty))
                else:
                    if len(binds) > 0:            # `_` / no-payload arms have no bindings; skip the lookup (which rejects `_`)
                        pts := variant_ptypes(dc, ctx, variants[j])
                        k := 0
                        for k < len(binds):
                            push(bn, binds[k])
                            push(bt, pts[k])
                            k = k + 1
                sacc_block(&acc, bodies[j], bn, bt, dc, ctx)
                j = j + 1
        SParFor(v, a, b, body, pid, _sl):
            np := 0                               # reductions are int/float only -- never a string accumulator
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            j := 0                                # recurse arm bodies so an OUTER-local string accumulator
            for j < len(sbodies):                 # appended inside a select arm grows in place (matches tychoc's
                bn := names                       # register the recv binding (type = channel element) so a
                bt := types                       # `match x` in the arm body types -- mirrors collect_stmt's SSelect
                if j < len(svars) and svars[j] == "recv":
                    push(bn, sbinds[j])
                    push(bt, chan_inner(type_of(schans[j], names, types, dc, ctx)))
                sacc_block(&acc, sbodies[j], bn, bt, dc, ctx)   # collect_accums, which walks select arms
                j = j + 1
        SValDecl(n, annot, cc, _sl):              # register the name+type; the branch tails are a first assignment, never a str accumulator
            dty := annot
            if annot == "":
                dty = value_ctrl_type(cc, names, types, dc, ctx, _sl)
            push(names, n)
            push(types, dty)

fn gen_func(f: Func, dc: Decls, ctx: Ctx) -> string:
    names := []string
    types := []string
    seed_env(f, &names, &types)
    # FFI R2 affine bans: a Tycho fn cannot return a handle (free-then-escape = UAF);
    # a param may be a BARE handle (a borrow) but never a composite carrying one.
    if ty_has_handle(dc, ctx, f.ret):
        die("type: fn '" + f.name + "' cannot return a handle -- a handle is freed at the end of its scope and cannot escape it")
    hpi := 0
    for hpi < len(f.ptypes):
        if ty_has_handle(dc, ctx, f.ptypes[hpi]) and not is_handle(dc, f.ptypes[hpi]):
            die("type: fn '" + f.name + "' parameter '" + f.params[hpi] + "': a handle cannot be nested in a container or aggregate")
        hpi = hpi + 1
    # Record this func's NON-inout param names so the map accumulator pass skips
    # the in-place put on a by-value map param (it would mutate the caller's
    # shared table). Mirrors the C compiler dropping non-inout params from accums
    # (src/tychoc.c:3556). Inout map params are left in (in-place is the wanted
    # mutation). The pure-set fallback rehashes the same way the C compiler does,
    # so key order stays identical (no wordcount divergence).
    vparams := []string
    pi := 0
    for pi < len(f.params):
        if not is_inout(f.ptypes[pi]) and not is_sink(f.ptypes[pi]):   # sink params are OWNED + mutable, not borrowed
            push(vparams, f.params[pi])
        pi = pi + 1
    # String self-append accumulators (locals only — a param has no SDecl, so no
    # sidecars; like the C compiler dropping non-inout params from accums).
    raw := []string
    sn := names
    st := types
    sacc_block(&raw, f.body, sn, st, dc, ctx)
    saccums := []string
    si := 0
    for si < len(raw):
        isp := false
        pj := 0
        for pj < len(f.params):
            if f.params[pj] == raw[si]:
                isp = true
            pj = pj + 1
        if not isp:
            push(saccums, raw[si])
        si = si + 1
    movables := compute_movables(f.body)          # locals read once, not in a loop -> move-on-last-use
    fctx := Ctx(vparams, saccums, f.ret, "&_scope", 0, []int, movables, 0, []string, []string, []string, 0, pkg_prefix_of(f.name))
    if f.name == "main":
        # Emit the user body as a VOID function (h_main) plus a thin `int main`
        # wrapper that calls it -- mirrors tychoc. An early bare `return` in the body
        # then lowers to `return;` inside a void function (valid C); inlining the body
        # into `int main` made it `return;` in an int-returning function (cc error).
        mb := "static void " + un(f.name) + "(Arena* _parent) {\n    Arena _scope = arena_child(_parent);\n" + gen_block(f.body, names, types, dc, fctx) + "    arena_free(&_scope);\n}\n"
        return mb + "int main(int argc, char **argv) {\n    mhash_seed_init();\n    hi_argc = argc; hi_argv = argv;\n    Arena _root = arena_new(0);\n    " + un(f.name) + "(&_root);\n    arena_free(&_root);\n    return 0;\n}\n"
    # open a child scope from the caller's arena; void funcs free it on fall-through
    # (every `return` frees it via the return-slot in gen_stmt).
    tail := ""
    if f.ret == "void":
        tail = "    arena_free(&_scope);\n"
    return ret_cty(dc, fctx, f.ret) + un(f.name) + "(" + gen_params(f, dc, fctx) + ") {\n    Arena _scope = _parent ? arena_child(_parent) : arena_new(0);\n" + gen_block(f.body, names, types, dc, fctx) + tail + "}\n"

fn gen_struct(sd: StructDef, dc: Decls, ctx: Ctx) -> string:
    out := "struct " + ust(sd.name) + " {\n"     # named tag; forward-declared elsewhere
    i := 0
    for i < len(sd.fields):
        out = out + "    " + cty(dc, ctx, sd.fields[i].ty) + uf(sd.fields[i].name) + ";\n"
        i = i + 1
    return out + "};\n"

# Match over a boxed Option/Result value. Some/Ok -> tag 1, None/Err -> tag 0.
# A bound payload is read back from the box: `T x = *(T*)(scrut.val)` (Some),
# `.ok`/`.err` for Result. `scu` is the caller's already-evaluated subject temp
# (SMatch evaluates the subject exactly once before dispatching here).
fn gen_match_optres(dc: Decls, ctx: Ctx, sty: string, scu: string, variants: [string], allbinds: [[string]], bodies: [[Stmt]], names: [string], types: [string]) -> string:
    out := ""
    i := 0
    for i < len(variants):
        vname := variants[i]
        binds := allbinds[i]
        if vname == "_":                          # `_` catch-all: no tag test, no binding; tychoc guarantees it is last
            opener := " else {\n"
            if i == 0:
                opener = "    {\n"
            out = out + opener + gen_block(bodies[i], names, types, dc, ctx) + "    }"
            i = i + 1
            continue
        tag := 0
        if vname == "Some" or vname == "Ok":
            tag = 1
        kw := " else if ("
        if i == 0:
            kw = "    if ("
        out = out + kw + scu +".tag == " + str(tag) + ") {\n"
        bn := names
        bt := types
        if len(binds) > 0:
            bty := option_inner(sty)
            fld := "val"
            if is_result(sty):
                if vname == "Ok":
                    bty = result_ok(sty)
                    fld = "ok"
                else:
                    bty = result_err(sty)
                    fld = "err"
            ct := cty(dc, ctx, bty)
            out = out + "    " + ct + un(binds[0]) + " = " + cp_typed(dc, ctx, bty, "*(" + ct + "*)(" + scu + "." + fld + ")") + ";\n"
            push(bn, binds[0])
            push(bt, bty)
        out = out + gen_block(bodies[i], bn, bt, dc, ctx) + "    }"
        i = i + 1
    return out + "\n"

# Deep copy for a heap-bearing struct: shallow-copy scalars, then dup each
# heap field (string -> fresh bytes, array -> Arr_T_copy, nested heap struct ->
# its own _copy). Source-order emission gives nested copiers before their users.
fn gen_struct_copy(dc: Decls, ctx: Ctx, sd: StructDef) -> string:
    nm := ust(sd.name)
    out := "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " s) {\n    " + nm + " r = s;\n"
    i := 0
    for i < len(sd.fields):
        f := sd.fields[i]
        if f.ty == "str":
            out = out + "    r." + uf(f.name) + " = scopy(ar, s." + uf(f.name) + ");\n"
        elif is_array(f.ty):
            out = out + "    r." + uf(f.name) + " = Arr_" + mangle(elem_ty(f.ty)) + "_copy(ar, s." + uf(f.name) + ");\n"
        elif is_map(f.ty):
            out = out + "    r." + uf(f.name) + " = " + mfam(f.ty) + "_copy(ar, s." + uf(f.name) + ");\n"
        elif is_soa(f.ty):
            out = out + "    r." + uf(f.name) + " = Soa_" + soa_struct(f.ty) + "_copy(ar, s." + uf(f.name) + ");\n"
        elif is_enum(dc, ctx, f.ty):                  # deep-copy the enum node tree into `ar`
            out = out + "    r." + uf(f.name) + " = " + tcopy(dc, ctx, f.ty) + "(ar, s." + uf(f.name) + ");\n"
        elif is_struct(dc, ctx, f.ty) and struct_is_heap(dc, ctx, f.ty):
            out = out + "    r." + uf(f.name) + " = " + tcopy(dc, ctx, f.ty) + "(ar, s." + uf(f.name) + ");\n"
        i = i + 1
    return out + "    return r;\n}\n"

# Structural equality for a struct: AND of per-field equality (recurses through
# nested structs, arrays, enums, and Option/Result fields via eq_field).
fn gen_struct_eq(dc: Decls, ctx: Ctx, sd: StructDef) -> string:
    nm := ust(sd.name)
    out := "static int " + nm + "_eq(" + nm + " a, " + nm + " b) { return "
    if len(sd.fields) == 0:
        out = out + "1"
    else:
        j := 0
        for j < len(sd.fields):
            if j > 0:
                out = out + " && "
            f := sd.fields[j]
            out = out + eq_field(dc, ctx, f.ty, "a." + uf(f.name), "b." + uf(f.name))
            j = j + 1
    return out + "; }\n"

# A tuple is an anonymous struct with positional fields f0, f1, ...
# `typedef R (*Fn_<suffix>)(Arena*, P...)` for a fn(P...) -> R type. Matches every
# tycho function's uniform C ABI (the hidden return arena is always the first param).
fn gen_func_typedef(dc: Decls, ctx: Ctx, ty: string) -> string:
    r := func_ret(ty)
    rc := "void "                                # cty has no "void" case (fns handle it separately)
    if r != "void":
        rc = cty(dc, ctx, r)
    out := "typedef struct { void* env; " + rc + "(*call)(void*, Arena*"   # fat value: env + adapter thunk (closures carry captures in env)
    ps := func_params(ty)
    i := 0
    for i < len(ps):
        out = out + ", " + cty(dc, ctx, ps[i])
        i = i + 1
    return out + "); void* (*copyenv)(Arena*, void*); } Fn_" + func_suffix(ty) + ";\n"   # copyenv re-homes the env on return (0 for a plain ref)

fn fn_value_eligible(f: Func) -> bool:           # usable as a value: no inout params (the fat-ptr call ABI carries none)
    i := 0
    for i < len(f.ptypes):
        if is_inout(f.ptypes[i]):
            return false
        i = i + 1
    return true

# Adapter thunk: a fat-ptr `call` is R(void* env, Arena*, P...); the real C
# function h_<name> is R(Arena*, P...). The thunk ignores env and forwards.
fn gen_fnval_thunk(f: Func, dc: Decls, ctx: Ctx) -> string:
    out := "static " + ret_cty(dc, ctx, f.ret) + un(f.name) + "__clo(void* _e, Arena* _p"
    i := 0
    for i < len(f.ptypes):
        out = out + ", " + cty(dc, ctx, f.ptypes[i]) + "a" + str(i)
        i = i + 1
    out = out + ") { (void)_e; "
    if f.ret != "void":
        out = out + "return "
    out = out + un(f.name) + "(_p"
    i = 0
    for i < len(f.ptypes):
        out = out + ", a" + str(i)
        i = i + 1
    return out + "); }\n"

# Closure thunk for a lifted lambda: unpack the env's captures and forward, with
# the lambda's own args, to h___lam<id>(_p, c0..., a0...). The lifted proc's
# params are [captures...][lambda params...], so this restores that order.
fn gen_lambda_thunk(li: LamInfo, dc: Decls, ctx: Ctx) -> string:
    nm := "__lam" + str(li.id)
    out := "static " + ret_cty(dc, ctx, li.ret) + un(nm) + "__clo(void* _env, Arena* _p"
    j := 0
    for j < len(li.lamptypes):
        out = out + ", " + cty(dc, ctx, li.lamptypes[j]) + "a" + str(j)
        j = j + 1
    out = out + ") { "
    if len(li.capnames) > 0:
        out = out + "Env_" + str(li.id) + "* _e = (Env_" + str(li.id) + "*)_env; "
    else:
        out = out + "(void)_env; "
    if li.ret != "void":
        out = out + "return "
    out = out + un(nm) + "(_p"
    cj := 0
    for cj < len(li.capnames):
        out = out + ", _e->c" + str(cj)
        cj = cj + 1
    j = 0
    for j < len(li.lamptypes):
        out = out + ", a" + str(j)
        j = j + 1
    return out + "); }\n"

fn gen_tuple_struct(dc: Decls, ctx: Ctx, ty: string) -> string:
    parts := tuple_parts(ty)
    nm := "Tup_" + tup_suffix(ty)             # named tag (forward-declared in the driver) so a map
    out := "struct " + nm + "_ { "            # struct holding a Tup_X* member can name it incomplete
    i := 0
    for i < len(parts):
        out = out + cty(dc, ctx, parts[i]) + "f" + str(i) + "; "
        i = i + 1
    return out + "};\n"

fn gen_tuple_copy(dc: Decls, ctx: Ctx, ty: string) -> string:
    nm := "Tup_" + tup_suffix(ty)
    parts := tuple_parts(ty)
    out := "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " s) {\n    " + nm + " r = s;\n"
    i := 0
    for i < len(parts):
        p := parts[i]
        if p == "str":
            out = out + "    r.f" + str(i) + " = scopy(ar, s.f" + str(i) + ");\n"
        elif is_array(p):
            out = out + "    r.f" + str(i) + " = Arr_" + mangle(elem_ty(p)) + "_copy(ar, s.f" + str(i) + ");\n"
        elif is_map(p):
            out = out + "    r.f" + str(i) + " = " + mfam(p) + "_copy(ar, s.f" + str(i) + ");\n"
        elif is_enum(dc, ctx, p):                     # deep-copy the enum node tree into `ar`
            out = out + "    r.f" + str(i) + " = " + tcopy(dc, ctx, p) + "(ar, s.f" + str(i) + ");\n"
        elif is_struct(dc, ctx, p) and struct_is_heap(dc, ctx, p):
            out = out + "    r.f" + str(i) + " = " + tcopy(dc, ctx, p) + "(ar, s.f" + str(i) + ");\n"
        i = i + 1
    return out + "    return r;\n}\n"

fn gen_tuple_eq(dc: Decls, ctx: Ctx, ty: string) -> string:
    nm := "Tup_" + tup_suffix(ty)
    parts := tuple_parts(ty)
    out := "static int " + nm + "_eq(" + nm + " a, " + nm + " b) { return "
    i := 0
    for i < len(parts):
        if i > 0:
            out = out + " && "
        out = out + eq_field(dc, ctx, parts[i], "a.f" + str(i), "b.f" + str(i))
        i = i + 1
    return out + "; }\n"

# Deep-hash body for a tuple used as a (nested) composite map key. Tuple == is a
# function here (Tup_*_eq), so the hash is too; same seeded FNV fold as gen_struct_hash.
fn gen_tuple_hash(dc: Decls, ctx: Ctx, ty: string) -> string:
    nm := "Tup_" + tup_suffix(ty)
    parts := tuple_parts(ty)
    out := "static unsigned long " + nm + "_hash(" + nm + " v) { unsigned long h = hash_k0;"
    i := 0
    for i < len(parts):
        out = out + " h = h * 1099511628211UL ^ " + hash_field(dc, ctx, parts[i], "v.f" + str(i)) + ";"
        i = i + 1
    return out + " return h; }\n"

# Order-sensitive deep hash for an array used as a (nested) composite map key. Folds
# element hashes left-to-right (the multiply runs before the xor), seeded from hash_k0.
fn gen_arr_hash(dc: Decls, ctx: Ctx, et: string) -> string:
    nm := "Arr_" + mangle(et)
    return "static unsigned long " + nm + "_hash(" + nm + " x) { unsigned long h = hash_k0; for (long i = 0; i < x.len; i++) h = h * 1099511628211UL ^ " + hash_field(dc, ctx, et, "x.data[i]") + "; return h; }\n"

# Struct/tuple types directly embedded BY VALUE in struct/tuple `ty` (its fields/elements).
# Those bodies must precede ty's. Enum/array/map/scalar fields are by pointer or emitted in
# earlier phases, so they are not dependencies.
fn comp_dep_types(dc: Decls, ctx: Ctx, ty: string) -> [string]:
    deps := []string
    b := resolve_nt(dc, ctx, ty)
    if is_struct(dc, ctx, b):
        i := 0
        for i < len(dc.structs):
            if dc.structs[i].name == b:
                j := 0
                for j < len(dc.structs[i].fields):
                    ft := resolve_nt(dc, ctx, dc.structs[i].fields[j].ty)
                    if is_struct(dc, ctx, ft) or is_tuple(ft):
                        push(deps, ft)
                    j = j + 1
            i = i + 1
    elif is_tuple(b):
        parts := tuple_parts(b)
        j := 0
        for j < len(parts):
            pt := resolve_nt(dc, ctx, parts[j])
            if is_struct(dc, ctx, pt) or is_tuple(pt):
                push(deps, pt)
            j = j + 1
    return deps

# Emit a struct/tuple body in topological order: its by-value struct/tuple dependencies
# first (so a struct embedding a tuple -- or a tuple embedding a struct -- sees a complete
# type). `emitted` carries the dedup set across the whole pass. By-value recursion is
# forbidden upstream, so the graph is a DAG.
fn emit_comp_body(dc: Decls, ctx: Ctx, ty: string, emitted: inout [string]) -> string:
    b := resolve_nt(dc, ctx, ty)
    if has_str(emitted, b):
        return ""
    push(emitted, b)
    out := ""
    deps := comp_dep_types(dc, ctx, b)
    i := 0
    for i < len(deps):
        out = out + emit_comp_body(dc, ctx, deps[i], &emitted)
        i = i + 1
    if is_tuple(b):
        return out + gen_tuple_struct(dc, ctx, b)
    i = 0
    for i < len(dc.structs):
        if dc.structs[i].name == b:
            out = out + gen_struct(dc.structs[i], dc, ctx)
        i = i + 1
    return out

fn eq_field(dc: Decls, ctx: Ctx, ty: string, a: string, b: string) -> string:
    if ty == "str" or ty == "bytes":
        return "str_cmp(" + a + ", " + b + ") == 0"
    if is_array(ty):
        return "Arr_" + mangle(elem_ty(ty)) + "_eq(" + a + ", " + b + ")"
    if is_enum(dc, ctx, ty):
        return teq(dc, ctx, ty) + "(" + a + ", " + b + ")"
    if is_struct(dc, ctx, ty):
        return teq(dc, ctx, ty) + "(" + a + ", " + b + ")"
    if is_tuple(ty):
        return "Tup_" + tup_suffix(ty) + "_eq(" + a + ", " + b + ")"
    if is_map(ty):
        return mfam(ty) + "_eq(" + a + ", " + b + ")"
    if is_soa(ty):
        return "Soa_" + soa_struct(ty) + "_eq(" + a + ", " + b + ")"
    if is_option(ty):                            # tags equal, and (if Some) payloads equal
        ct := cty(dc, ctx, option_inner(ty))
        # parenthesize the dereffed payload: when the payload is itself an
        # Option/Result, the recursion appends `.tag`/`.val` to this expr, and
        # `.` binds tighter than `*` -- without the parens `*(T*)(x.val).tag`
        # mis-parses as `*((T*)(x.val).tag)`.
        pa := "(*(" + ct + "*)(" + a + ".val))"
        pb := "(*(" + ct + "*)(" + b + ".val))"
        return "(" + a + ".tag == " + b + ".tag && (" + a + ".tag == 0 || " + eq_field(dc, ctx, option_inner(ty), pa, pb) + "))"
    if is_result(ty):
        ct := cty(dc, ctx, result_ok(ty))
        ce := cty(dc, ctx, result_err(ty))
        oa := "(*(" + ct + "*)(" + a + ".ok))"
        ob := "(*(" + ct + "*)(" + b + ".ok))"
        ea := "(*(" + ce + "*)(" + a + ".err))"
        eb := "(*(" + ce + "*)(" + b + ".err))"
        okeq := eq_field(dc, ctx, result_ok(ty), oa, ob)
        ereq := eq_field(dc, ctx, result_err(ty), ea, eb)
        return "(" + a + ".tag == " + b + ".tag && (" + a + ".tag == 1 ? " + okeq + " : " + ereq + "))"
    if is_func(ty):                              # fn values: identity equality (same thunk + env) — closures aren't structurally comparable
        return "((" + a + ").call == (" + b + ").call && (" + a + ").env == (" + b + ").env)"
    return "(" + a + " == " + b + ")"            # int/bool/float by value

# Recursive deep-copy of an enum node into arena `ar`: fresh node, same tag, and
# each present variant's payload fields copied by type (cp_field recurses through
# nested enums / arrays / structs / strings). The value-semantic mirror of the
# arena-allocating mk_ ctors — so a returned/stored/copied enum owns its subtree
# in the destination arena instead of aliasing a freed scope.
fn gen_enum_copy(ed: EnumDef, dc: Decls, ctx: Ctx) -> string:
    nm := uet(ed.name)
    out := "static " + nm + "* " + nm + "_copy(Arena* ar, " + nm + "* s) {\n"
    i := 0
    for i < len(ed.variants):
        v := ed.variants[i]
        if len(v.ptypes) > 0:                 # allocate a cell sized to THIS variant, not the union max
            out = out + "    if (s->tag == " + str(i) + ") {\n"
            out = out + "        " + nm + "* r = amem(ar, offsetof(" + nm + ", u) + sizeof(((" + nm + "*)0)->u." + v.name + "));\n        r->tag = " + str(i) + ";\n"
            j := 0
            for j < len(v.ptypes):
                out = out + "        " + efield("r", v.name, j) + " = " + cp_field(dc, ctx, v.ptypes[j], "ar", efield("s", v.name, j)) + ";\n"
                j = j + 1
            out = out + "        return r;\n    }\n"
        i = i + 1
    return out + "    return s;\n}\n"           # nullary variant: shared immortal singleton

# C lvalue for variant `vn`'s payload field j of enum node `base` (a pointer).
# The compact layout nests payloads in a union (one struct per payload-bearing
# variant), so a node is only as big as its ACTIVE variant -- not the flat sum of
# every variant's fields. (Tree node 24B; the compiler's Expr/Stmt shrink ~5-8x.)
fn efield(base: string, vn: string, j: int) -> string:
    return base + "->u." + vn + ".f" + str(j)

fn gen_enum_decl(ed: EnumDef, dc: Decls, ctx: Ctx) -> string:
    out := "struct " + uet(ed.name) + " {\n    int tag;\n"
    members := ""
    i := 0
    for i < len(ed.variants):
        v := ed.variants[i]
        if len(v.ptypes) > 0:
            members = members + "        struct {"
            j := 0
            for j < len(v.ptypes):
                members = members + " " + cty(dc, ctx, v.ptypes[j]) + "f" + str(j) + ";"
                j = j + 1
            members = members + " } " + v.name + ";\n"
        i = i + 1
    if members != "":
        out = out + "    union {\n" + members + "    } u;\n"
    return out + "};\n"

fn gen_enum_ctors(ed: EnumDef, dc: Decls, ctx: Ctx) -> string:
    out := ""
    i := 0
    for i < len(ed.variants):
        v := ed.variants[i]
        if len(v.ptypes) == 0:                    # nullary variant: one shared immortal singleton,
            sg := "_sing_" + ed.name + "_" + str(i)   # no per-construction allocation (no payload, and
            out = out + "static " + uet(ed.name) + " " + sg + " = { " + str(i) + " };\n"   # enum values are immutable)
            out = out + "static " + uet(ed.name) + "* mk_" + ed.name + "_" + v.name + "(Arena* ar) { (void)ar; return &" + sg + "; }\n"
        else:
            params := "Arena* ar"                 # the node lives in `ar` (the ambient arena)
            j := 0
            for j < len(v.ptypes):
                params = params + ", " + cty(dc, ctx, v.ptypes[j]) + "f" + str(j)
                j = j + 1
            out = out + "static " + uet(ed.name) + "* mk_" + ed.name + "_" + v.name + "(" + params + ") {\n"
            out = out + "    " + uet(ed.name) + "* n = amem(ar, offsetof(" + uet(ed.name) + ", u) + sizeof(((" + uet(ed.name) + "*)0)->u." + v.name + "));\n"
            out = out + "    n->tag = " + str(i) + ";\n"
            j = 0
            for j < len(v.ptypes):
                out = out + "    " + efield("n", v.name, j) + " = f" + str(j) + ";\n"
                j = j + 1
            out = out + "    return n;\n}\n"
        i = i + 1
    return out

fn gen_enum_eq(ed: EnumDef, dc: Decls, ctx: Ctx) -> string:
    out := "static int " + uet(ed.name) + "_eq(" + uet(ed.name) + "* a, " + uet(ed.name) + "* b) {\n"
    out = out + "    if (a->tag != b->tag) return 0;\n"
    i := 0
    for i < len(ed.variants):
        v := ed.variants[i]
        out = out + "    if (a->tag == " + str(i) + ") return "
        if len(v.ptypes) == 0:
            out = out + "1"
        else:
            j := 0
            for j < len(v.ptypes):
                if j > 0:
                    out = out + " && "
                out = out + eq_field(dc, ctx, v.ptypes[j], efield("a", v.name, j), efield("b", v.name, j))
                j = j + 1
        out = out + ";\n"
        i = i + 1
    return out + "    return 0;\n}\n"

fn preamble() -> string:
    out := "#ifndef _DEFAULT_SOURCE\n#define _DEFAULT_SOURCE\n#endif\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <stddef.h>\n#include <dirent.h>\n#include <pthread.h>\n#include <unistd.h>\n#include <stdatomic.h>\n#include <sched.h>\n#include <time.h>\n"
    # Math builtins (sqrt/pow/floor/fabs): declare ONLY these four with their
    # exact libc prototypes rather than `#include <math.h>`. The full header
    # drops dozens of names into the global namespace (yn, y0, j0, gamma, ...)
    # that collide with bare user-function names tychoc0 emits (e.g. maps.ty's
    # `fn yn`). -lm at link still provides the definitions.
    out = out + "double sqrt(double); double pow(double, double); double floor(double); double fabs(double);\n"
    # map-hash seed (hash-flooding hardening): a random per-process key read once
    # from the OS in main(), before any map. keys() iterate in insertion order, so
    # the seed is output-invisible. Defined here (always emitted) so main can call
    # mhash_seed_init() whether or not the program uses maps.
    out = out + "static unsigned long hash_k0 = 0x736f6d6570736575UL;\n"
    out = out + "static unsigned long hash_k1 = 0x646f72616e646f6dUL;\n"
    out = out + "static unsigned long ik_seed = 0;\n"
    out = out + "static void mhash_seed_init(void) { unsigned long buf[3]; FILE* f = fopen(\"/dev/urandom\", \"rb\"); int ok = (f && fread(buf, sizeof buf, 1, f) == 1); if (f) fclose(f); if (ok) { hash_k0 = buf[0]; hash_k1 = buf[1]; ik_seed = buf[2]; } else { unsigned long t = (unsigned long)time(NULL) ^ ((unsigned long)getpid() << 16); hash_k0 ^= t; hash_k1 ^= t * 0x9e3779b97f4a7c15UL; ik_seed = t; } }\n"
    # Block-list arena, 8-byte aligned. A process-global block FREE-LIST (g_pool)
    # makes the per-scope/per-loop-iteration arena_child/free O(1) pointer ops:
    # arena_free hands blocks to the pool (not the OS) and arena_alloc takes from
    # it first, so allocation-heavy/deeply-recursive workloads (the self-compile)
    # stop paying malloc/free per scope. Peak live memory is unchanged (the pool
    # holds at most what a scope just released; reclaimed by the OS at exit).
    out = out + "typedef struct ABlk { struct ABlk* next; size_t used, cap; char* mem; } ABlk;\n"
    # Per-arena object free-list for liveness-driven recycling: when the compiler
    # proves a buffer is dead + uniquely owned (value semantics ⇒ no aliasing), it
    # is handed back via arena_recycle and the next same-size arena_alloc reuses it
    # (best-fit). FBIP-style reuse from STATIC value semantics, no refcount. Sound
    # because arena_alloc only bumps FORWARD, so a recycled region never overlaps a
    # fresh bump; arena_free drops the list (its chunks live in pooled blocks).
    out = out + "typedef struct FreeNode { struct FreeNode* next; size_t size; } FreeNode;\n"
    # Tiny objects recycle through a SEGREGATED free-list (one LIFO per 8-byte size
    # class, bkt[16] = sizes 8..120B): O(1) push/pop, NO cap -- a sliding-window
    # eviction needs the per-class list to grow to the window size, which a single
    # capped best-fit list cannot. Larger chunks keep the capped best-fit `freelist`.
    out = out + "typedef struct { ABlk* head; size_t blocksz; FreeNode* bkt[16]; FreeNode* freelist; int nfree; } Arena;\n"
    # THREAD-LOCAL (CC-0): each thread owns a private pool -- allocation never
    # contends or races. Blocks may be freed on a different thread than they
    # were allocated on (wait() frees the task tree on the waiting thread);
    # that's fine, a block is just malloc'd memory and lands in the releasing
    # thread's pool. A spawned thread flushes its pool before exiting.
    out = out + "static __thread ABlk* g_pool = 0;\n"
    out = out + "static ABlk* blk_get(size_t cap) { if (g_pool && g_pool->cap >= cap) { ABlk* b = g_pool; g_pool = b->next; b->used = 0; b->next = 0; return b; } for (ABlk** link = &g_pool; *link; link = &(*link)->next) if ((*link)->cap >= cap) { ABlk* b = *link; *link = b->next; b->used = 0; b->next = 0; return b; } ABlk* b = malloc(sizeof(ABlk)); b->mem = malloc(cap); b->cap = cap; b->used = 0; b->next = 0; return b; }\n"
    out = out + "static void blk_release(ABlk* b) { while (b) { ABlk* nx = b->next; b->next = g_pool; g_pool = b; b = nx; } }\n"
    out = out + "static Arena arena_new(size_t bs) { Arena a; a.head = 0; a.blocksz = bs ? bs : 65536; for (int i = 0; i < 16; i++) a.bkt[i] = 0; a.freelist = 0; a.nfree = 0; return a; }\n"
    out = out + "static void arena_recycle(Arena* a, void* p, size_t n) { if (!a || !p || n < sizeof(FreeNode)) return; n = (n + 7) & ~(size_t)7; size_t k = n >> 3; FreeNode* fn = (FreeNode*)p; fn->size = n; if (k < 16) { fn->next = a->bkt[k]; a->bkt[k] = fn; return; } if (a->nfree >= 32) return; fn->next = a->freelist; a->freelist = fn; a->nfree++; }\n"
    out = out + "static Arena arena_child(Arena* p) { return arena_new(p->blocksz); }\n"
    out = out + "static void* arena_alloc(Arena* a, size_t n) { n = (n + 7) & ~(size_t)7; size_t k = n >> 3; if (k < 16) { if (a->bkt[k]) { FreeNode* fn = a->bkt[k]; a->bkt[k] = fn->next; return (void*)fn; } } else if (a->freelist) { FreeNode** link = &a->freelist; FreeNode** best = 0; size_t bestsz = (size_t)-1; for (; *link; link = &(*link)->next) if ((*link)->size >= n && (*link)->size <= 2*n && (*link)->size < bestsz) { best = link; bestsz = (*link)->size; } if (best) { FreeNode* fn = *best; *best = fn->next; a->nfree--; return (void*)fn; } } if (!a->head || a->head->used + n > a->head->cap) { size_t cap = a->blocksz; if (cap < n) cap = n; ABlk* b = blk_get(cap); b->next = a->head; a->head = b; } void* p = a->head->mem + a->head->used; a->head->used += n; return p; }\n"
    out = out + "static int arena_owns(Arena* a, const void* p) { for (ABlk* b = a->head; b; b = b->next) if ((const char*)p >= b->mem && (const char*)p < b->mem + b->cap) return 1; return 0; }\n"
    out = out + "static void arena_free(Arena* a) { for (int i = 0; i < 16; i++) a->bkt[i] = 0; a->freelist = 0; a->nfree = 0; blk_release(a->head); a->head = 0; }\n"
    # ---- concurrency runtime (CC-0..CC-4), mirroring runtime/tycho_rt.c ----
    # A task is one OS thread running one call against a private arena tree;
    # arguments deep-copy IN before the thread starts, the result copies OUT at
    # wait. The done flag makes a double wait a defined loud failure (the named
    # handle's struct lives to its scope-exit finish). tycho_pool_flush frees a
    # spawned thread's TLS block pool before it exits (the TLS dies with it).
    out = out + "static void tycho_pool_flush(void) { while (g_pool) { ABlk* b = g_pool; g_pool = b->next; free(b->mem); free(b); } }\n"
    out = out + "typedef struct { pthread_t th; Arena root; void* ret; int done; } HTask;\n"
    out = out + "static HTask* tycho_task_new(void) { HTask* t = malloc(sizeof(HTask)); t->root = arena_new(0); t->ret = 0; t->done = 0; return t; }\n"
    # Bounded concurrency: cap concurrently-live tasks (started, not yet joined) and fail closed.
    # A hard ceiling, not a pool -- admitted tasks run immediately, so a task blocking on a channel
    # for another task never starves. Default 1024; TYCHO_MAX_TASKS overrides. Mirrors runtime/tycho_rt.c.
    # Declared before task_join/task_finish (which decrement it) so the emitted C has no use-before-decl.
    out = out + "static _Atomic long g_live_tasks = 0;\n"
    out = out + "static long tycho_max_tasks(void) { static long m = 0; if (m == 0) { const char* e = getenv(\"TYCHO_MAX_TASKS\"); m = (e && *e && atol(e) >= 1) ? atol(e) : 1024; } return m; }\n"
    out = out + "static void tycho_task_join(HTask* t) { if (t->done) { fprintf(stderr, \"tycho: task already waited\\n\"); exit(1); } pthread_join(t->th, 0); t->done = 1; atomic_fetch_sub(&g_live_tasks, 1); }\n"
    out = out + "static void tycho_task_free(HTask* t) { arena_free(&t->root); free(t); }\n"
    out = out + "static void tycho_task_finish(HTask* t) { if (!t->done) { pthread_join(t->th, 0); t->done = 1; atomic_fetch_sub(&g_live_tasks, 1); } arena_free(&t->root); free(t); }\n"
    out = out + "static void tycho_task_start(HTask* t, void* (*fn)(void*), void* arg) { if (atomic_fetch_add(&g_live_tasks, 1) + 1 > tycho_max_tasks()) { atomic_fetch_sub(&g_live_tasks, 1); fprintf(stderr, \"tycho: too many concurrent tasks (max %ld); raise TYCHO_MAX_TASKS to override\\n\", tycho_max_tasks()); exit(1); } if (pthread_create(&t->th, 0, fn, arg) != 0) { atomic_fetch_sub(&g_live_tasks, 1); fprintf(stderr, \"tycho: spawn failed (cannot create thread)\\n\"); exit(1); } }\n"
    # Channels (CC-5): a Vyukov bounded MPMC ring. Each cell has a sequence
    # counter and its OWN arena -- a sender claims a cell with one CAS, deep-
    # copies the payload in with NO lock held (cell-exclusive until the seq
    # store publishes), receivers claim/copy-out/recycle symmetrically. The
    # spin -> yield -> timed-park ladder plus the parked-waiter count means the
    # uncontended fast path does zero syscalls. Capacity rounds up to a power
    # of two. Mirrors runtime/tycho_rt.c byte-for-byte in semantics + messages.
    # HCell is line-aligned and HChan pads enq/deq onto their own cache lines (Vyukov's
    # layout): the producer CASes enq while every consumer CASes deq -- packed together
    # they false-share one line and the ping-pong throttles both sides (measured 3.3x
    # on the pipeline bench). aligned_alloc backs the cells' 64-byte alignment.
    out = out + "typedef struct __attribute__((aligned(64))) { _Atomic long seq; long pos; void* val; Arena arena; } HCell;\n"
    out = out + "typedef struct { HCell* cells; long cap; char _pad0[64]; _Atomic long enq; char _pad1[64]; _Atomic long deq; char _pad2[64]; _Atomic int closed; _Atomic int waiters; pthread_mutex_t mu; pthread_cond_t cv; } HChan;\n"
    out = out + "static HChan* tycho_chan_new(long cap) { if (cap < 1) { fprintf(stderr, \"tycho: channel capacity must be >= 1\\n\"); exit(1); } long c2 = 2; /* min ring 2: one cell makes published (pos+1) == recycled (pos+cap) and a 2nd send overwrites the unreceived value */ while (c2 < cap) c2 <<= 1; HChan* ch = malloc(sizeof(HChan)); ch->cells = aligned_alloc(64, c2 * sizeof(HCell)); for (long i = 0; i < c2; i++) { atomic_store_explicit(&ch->cells[i].seq, i, memory_order_relaxed); ch->cells[i].pos = 0; ch->cells[i].val = 0; ch->cells[i].arena = arena_new(0); } ch->cap = c2; atomic_store_explicit(&ch->enq, 0, memory_order_relaxed); atomic_store_explicit(&ch->deq, 0, memory_order_relaxed); atomic_store_explicit(&ch->closed, 0, memory_order_relaxed); atomic_store_explicit(&ch->waiters, 0, memory_order_relaxed); pthread_mutex_init(&ch->mu, 0); pthread_cond_init(&ch->cv, 0); return ch; }\n"
    out = out + "static void tycho_chan_park(HChan* ch) { pthread_mutex_lock(&ch->mu); atomic_fetch_add_explicit(&ch->waiters, 1, memory_order_relaxed); struct timespec ts; clock_gettime(CLOCK_REALTIME, &ts); ts.tv_nsec += 1000000; if (ts.tv_nsec >= 1000000000) { ts.tv_sec++; ts.tv_nsec -= 1000000000; } pthread_cond_timedwait(&ch->cv, &ch->mu, &ts); atomic_fetch_sub_explicit(&ch->waiters, 1, memory_order_relaxed); pthread_mutex_unlock(&ch->mu); }\n"
    # signal ONE waiter per commit (one cell published); close() still broadcasts; the
    # 1ms timed park self-heals any wake the signal/park race drops.
    out = out + "static void tycho_chan_wake(HChan* ch) { if (atomic_load_explicit(&ch->waiters, memory_order_relaxed) > 0) { pthread_mutex_lock(&ch->mu); pthread_cond_signal(&ch->cv); pthread_mutex_unlock(&ch->mu); } }\n"
    out = out + "static HCell* tycho_chan_send_cell(HChan* ch) { long pos = atomic_load_explicit(&ch->enq, memory_order_relaxed); int spins = 0; for (;;) { HCell* c = &ch->cells[pos & (ch->cap - 1)]; long d = atomic_load_explicit(&c->seq, memory_order_acquire) - pos; if (d == 0) { if (atomic_compare_exchange_weak_explicit(&ch->enq, &pos, pos + 1, memory_order_relaxed, memory_order_relaxed)) { if (atomic_load_explicit(&ch->closed, memory_order_acquire)) { fprintf(stderr, \"tycho: send on a closed channel\\n\"); exit(1); } arena_free(&c->arena); c->pos = pos; return c; } } else if (d < 0) { if (atomic_load_explicit(&ch->closed, memory_order_acquire)) { fprintf(stderr, \"tycho: send on a closed channel\\n\"); exit(1); } if (++spins < 256) { } else if (spins < 512) sched_yield(); else { tycho_chan_park(ch); spins = 0; } pos = atomic_load_explicit(&ch->enq, memory_order_relaxed); } else { pos = atomic_load_explicit(&ch->enq, memory_order_relaxed); } } }\n"
    out = out + "static void tycho_chan_send_commit(HChan* ch, HCell* c, void* val) { c->val = val; atomic_store_explicit(&c->seq, c->pos + 1, memory_order_release); tycho_chan_wake(ch); }\n"
    out = out + "static HCell* tycho_chan_recv_cell(HChan* ch) { long pos = atomic_load_explicit(&ch->deq, memory_order_relaxed); int spins = 0; for (;;) { HCell* c = &ch->cells[pos & (ch->cap - 1)]; long d = atomic_load_explicit(&c->seq, memory_order_acquire) - (pos + 1); if (d == 0) { if (atomic_compare_exchange_weak_explicit(&ch->deq, &pos, pos + 1, memory_order_relaxed, memory_order_relaxed)) { c->pos = pos; return c; } } else if (d < 0) { if (atomic_load_explicit(&ch->closed, memory_order_acquire) && atomic_load_explicit(&ch->enq, memory_order_acquire) == pos) return 0; if (++spins < 256) { } else if (spins < 512) sched_yield(); else { tycho_chan_park(ch); spins = 0; } pos = atomic_load_explicit(&ch->deq, memory_order_relaxed); } else { pos = atomic_load_explicit(&ch->deq, memory_order_relaxed); } } }\n"
    out = out + "static void tycho_chan_recv_commit(HChan* ch, HCell* c) { atomic_store_explicit(&c->seq, c->pos + ch->cap, memory_order_release); tycho_chan_wake(ch); }\n"
    out = out + "static int tycho_chan_try_recv(HChan* ch, HCell** out) { long pos = atomic_load_explicit(&ch->deq, memory_order_relaxed); for (;;) { HCell* c = &ch->cells[pos & (ch->cap - 1)]; long d = atomic_load_explicit(&c->seq, memory_order_acquire) - (pos + 1); if (d == 0) { if (atomic_compare_exchange_weak_explicit(&ch->deq, &pos, pos + 1, memory_order_relaxed, memory_order_relaxed)) { c->pos = pos; *out = c; return 1; } } else if (d < 0) { if (atomic_load_explicit(&ch->closed, memory_order_acquire) && atomic_load_explicit(&ch->enq, memory_order_acquire) == pos) return 2; return 0; } else { pos = atomic_load_explicit(&ch->deq, memory_order_relaxed); } } }\n"
    out = out + "static void tycho_select_pause(int* spins) { (*spins)++; if (*spins < 64) return; if (*spins < 256) { sched_yield(); return; } struct timespec ts = { 0, 50000 }; nanosleep(&ts, 0); }\n"
    out = out + "static void tycho_chan_close(HChan* ch) { pthread_mutex_lock(&ch->mu); if (atomic_load_explicit(&ch->closed, memory_order_relaxed)) { fprintf(stderr, \"tycho: channel already closed\\n\"); exit(1); } atomic_store_explicit(&ch->closed, 1, memory_order_release); pthread_cond_broadcast(&ch->cv); pthread_mutex_unlock(&ch->mu); }\n"
    out = out + "static void tycho_chan_free(HChan* ch) { for (long i = 0; i < ch->cap; i++) arena_free(&ch->cells[i].arena); free(ch->cells); pthread_mutex_destroy(&ch->mu); pthread_cond_destroy(&ch->cv); free(ch); }\n"
    out = out + "static long tycho_ncpu(void) { const char* e = getenv(\"TYCHO_THREADS\"); if (e && *e) { long v = atol(e); if (v >= 1) return v; } long n = sysconf(_SC_NPROCESSORS_ONLN); return n > 0 ? n : 1; }\n"
    # String allocators take an arena; a NULL arena means malloc (the safe
    # fallback for not-yet-migrated contexts). owner-threading (ctx.owner) flips
    # provably-safe contexts (e.g. print args) to a real arena. hi_append is NOT
    # arena-based: accumulator buffers are realloc-grown, so they must be malloc.
    out = out + "static void* amem(Arena* a, size_t n) { return a ? arena_alloc(a, n) : malloc(n); }\n"
    # Length-carrying strings: an 8-byte length header sits just before the
    # returned char* (hidden behind it, so printf/strcmp are unaffected); arena
    # blocks are 8-aligned so the header word is aligned. len(s)/s[i] read it in
    # O(1) -- s[i] is bounds-checked (hi_sidx). Mirrors tychoc's tycho_str_alloc.
    out = out + "static char* hs(Arena* ar, long n) { char* base = (char*)amem(ar, (size_t)(8 + n + 1)); *(long*)base = n; char* d = base + 8; d[n] = 0; return d; }\n"
    out = out + "static char* hi_intern(const char* s) { long n = (long)strlen(s); char* base = (char*)malloc((size_t)(8 + n + 1)); *(long*)base = n; char* d = base + 8; memcpy(d, s, (size_t)n + 1); return d; }\n"
    out = out + "static long hi_sidx(const char* s, long i) { long n = ((const long*)s)[-1]; if (i < 0 || i >= n) { fprintf(stderr, \"tycho: string index %ld out of bounds (len %ld)\\n\", i, n); exit(1); } return (long)(unsigned char)s[i]; }\n"
    # Array index bounds check: returns i when in range, else aborts with the same
    # message as runtime/tycho_rt.c (tycho_arr_*_get) and tychoc. Used by both the
    # read stmt-expr and the write pointer stmt-expr so a[i] is checked everywhere.
    out = out + "static long hi_bchk(long i, long n) { if (i < 0 || i >= n) { fprintf(stderr, \"tycho: index %ld out of bounds (len %ld)\\n\", i, n); exit(1); } return i; }\n"
    # Integer division/modulo guard: -fwrapv wraps signed overflow, but x/0, x%0 and
    # LONG_MIN/-1 still trap (SIGFPE). Abort cleanly with the same tycho: messages as
    # runtime/tycho_rt.c (tycho_idiv/tycho_imod). LONG_MIN literal avoids a limits.h
    # dependency; LONG_MIN % -1 is mathematically 0, returned directly (no trap).
    out = out + "static long hi_idiv(long a, long b) { if (b == 0) { fprintf(stderr, \"tycho: division by zero\\n\"); exit(1); } if (a == (-9223372036854775807L - 1L) && b == -1) { fprintf(stderr, \"tycho: division overflow\\n\"); exit(1); } return a / b; }\n"
    out = out + "static long hi_imod(long a, long b) { if (b == 0) { fprintf(stderr, \"tycho: modulo by zero\\n\"); exit(1); } if (a == (-9223372036854775807L - 1L) && b == -1) return 0; return a % b; }\n"
    out = out + "static unsigned long long hi_udiv(unsigned long long a, unsigned long long b) { if (b == 0) { fprintf(stderr, \"tycho: division by zero\\n\"); exit(1); } return a / b; }\n"
    out = out + "static unsigned long long hi_umod(unsigned long long a, unsigned long long b) { if (b == 0) { fprintf(stderr, \"tycho: modulo by zero\\n\"); exit(1); } return a % b; }\n"
    out = out + "static char* sc(Arena* ar, const char* a, const char* b) { long la = ((const long*)a)[-1], lb = ((const long*)b)[-1]; char* r = hs(ar, la + lb); memcpy(r, a, (size_t)la); memcpy(r + la, b, (size_t)lb); return r; }\n"
    out = out + "static char* sc3(Arena* ar, const char* a, const char* b, const char* c) { long la = ((const long*)a)[-1], lb = ((const long*)b)[-1], lc = ((const long*)c)[-1]; char* r = hs(ar, la + lb + lc); char* p = r; memcpy(p, a, (size_t)la); p += la; memcpy(p, b, (size_t)lb); p += lb; memcpy(p, c, (size_t)lc); return r; }\n"
    out = out + "static char* sc4(Arena* ar, const char* a, const char* b, const char* c, const char* d) { long la = ((const long*)a)[-1], lb = ((const long*)b)[-1], lc = ((const long*)c)[-1], ld = ((const long*)d)[-1]; char* r = hs(ar, la + lb + lc + ld); char* p = r; memcpy(p, a, (size_t)la); p += la; memcpy(p, b, (size_t)lb); p += lb; memcpy(p, c, (size_t)lc); p += lc; memcpy(p, d, (size_t)ld); return r; }\n"
    out = out + "static char* sc5(Arena* ar, const char* a, const char* b, const char* c, const char* d, const char* e) { long la = ((const long*)a)[-1], lb = ((const long*)b)[-1], lc = ((const long*)c)[-1], ld = ((const long*)d)[-1], le = ((const long*)e)[-1]; char* r = hs(ar, la + lb + lc + ld + le); char* p = r; memcpy(p, a, (size_t)la); p += la; memcpy(p, b, (size_t)lb); p += lb; memcpy(p, c, (size_t)lc); p += lc; memcpy(p, d, (size_t)ld); p += ld; memcpy(p, e, (size_t)le); return r; }\n"
    out = out + "static char* sc6(Arena* ar, const char* a, const char* b, const char* c, const char* d, const char* e, const char* f) { long la = ((const long*)a)[-1], lb = ((const long*)b)[-1], lc = ((const long*)c)[-1], ld = ((const long*)d)[-1], le = ((const long*)e)[-1], lf = ((const long*)f)[-1]; char* r = hs(ar, la + lb + lc + ld + le + lf); char* p = r; memcpy(p, a, (size_t)la); p += la; memcpy(p, b, (size_t)lb); p += lb; memcpy(p, c, (size_t)lc); p += lc; memcpy(p, d, (size_t)ld); p += ld; memcpy(p, e, (size_t)le); p += le; memcpy(p, f, (size_t)lf); return r; }\n"
    out = out + "static char* sc_char(Arena* ar, const char* a, long c) { long la = ((const long*)a)[-1]; char* r = hs(ar, la + 1); memcpy(r, a, (size_t)la); r[la] = (char)c; return r; }\n"
    out = out + "static char* i2s(Arena* ar, long n) { char t[24]; int i = (int)sizeof t; unsigned long u = n < 0 ? -(unsigned long)n : (unsigned long)n; do { t[--i] = (char)('0' + u % 10); u /= 10; } while (u); if (n < 0) t[--i] = '-'; int m = (int)sizeof t - i; char* r = hs(ar, m); memcpy(r, t + i, (size_t)m); return r; }\n"
    out = out + "static char* u2s(Arena* ar, unsigned long long u) { char t[24]; int i = (int)sizeof t; do { t[--i] = (char)('0' + u % 10); u /= 10; } while (u); int m = (int)sizeof t - i; char* r = hs(ar, m); memcpy(r, t + i, (size_t)m); return r; }\n"
    out = out + "static char* b2s(Arena* ar, long b) { const char* s = b ? \"true\" : \"false\"; long m = (long)strlen(s); char* r = hs(ar, m); memcpy(r, s, (size_t)m); return r; }\n"
    out = out + "static char* scopy(Arena* ar, const char* s) { long n = ((const long*)s)[-1]; char* r = hs(ar, n); memcpy(r, s, (size_t)n); return r; }\n"
    out = out + "static int str_cmp(const char* a, const char* b) { long la = ((const long*)a)[-1], lb = ((const long*)b)[-1]; long n = la < lb ? la : lb; int c = n ? memcmp(a, b, (size_t)n) : 0; if (c != 0) return c < 0 ? -1 : 1; return la < lb ? -1 : (la > lb ? 1 : 0); }\n"
    out = out + "static char* s_from_c(Arena* ar, const char* s) { long n = (long)strlen(s); char* r = hs(ar, n); memcpy(r, s, (size_t)n); return r; }\n"
    # FFI: copy a C-owned (ptr,len) byte buffer (extern returning bytes, out-param shim) into an arena bytes, then free it. Length-carried, so interior 0x00 survives.
    out = out + "static char* b_from_c(Arena* ar, unsigned char* p, long n) { if (n < 0) n = 0; char* r = hs(ar, p ? n : 0); if (p) { if (n > 0) memcpy(r, p, (size_t)n); free(p); } return r; }\n"
    out = out + "static void hi_puts(const char* s) { fwrite(s, 1, (size_t)((const long*)s)[-1], stdout); }\n"
    out = out + "static void hi_append(Arena* a, char** s, long* len, long* cap, const char* e) { long le = ((const long*)e)[-1]; if (*len + le + 1 > *cap) { long nc = *cap > 0 ? *cap : 16; while (nc < *len + le + 1) nc *= 2; char* base = (char*)amem(a, (size_t)(8 + nc)); char* nb = base + 8; memcpy(nb, *s, (size_t)*len); *s = nb; *cap = nc; } memmove(*s + *len, e, (size_t)le); *len += le; (*s)[*len] = 0; ((long*)(*s))[-1] = *len; }\n"
    out = out + "static void hi_append_char(Arena* a, char** s, long* len, long* cap, long c) { if (*len + 2 > *cap) { long nc = *cap > 0 ? *cap : 16; while (nc < *len + 2) nc *= 2; char* base = (char*)amem(a, (size_t)(8 + nc)); char* nb = base + 8; memcpy(nb, *s, (size_t)*len); *s = nb; *cap = nc; } (*s)[*len] = (char)c; *len += 1; (*s)[*len] = 0; ((long*)(*s))[-1] = *len; }\n"
    out = out + "static char* f2s(Arena* ar, double x) { char t[64]; int m = snprintf(t, sizeof t, \"%.15g\", x); int fl = 0; for (int i = 0; i < m; i++) { char c = t[i]; if (c == '.' || c == 'e' || c == 'E' || c == 'n' || c == 'N' || c == 'i' || c == 'I') { fl = 1; break; } } if (!fl) { t[m++] = '.'; t[m++] = '0'; t[m] = 0; } char* r = hs(ar, m); memcpy(r, t, (size_t)m); return r; }\n"
    out = out + "static char* substr(Arena* ar, const char* s, long a, long b) { long n = ((const long*)s)[-1]; if (a < 0) a = 0; if (b > n) b = n; if (b < a) b = a; long m = b - a; char* r = hs(ar, m); memcpy(r, s + a, (size_t)m); return r; }\n"
    out = out + "static long hi_find(const char* s, const char* sub) { long ls = ((const long*)s)[-1], lsub = ((const long*)sub)[-1]; if (lsub == 0) return 0; for (long i = 0; i + lsub <= ls; i++) if (memcmp(s + i, sub, (size_t)lsub) == 0) return i; return -1; }\n"
    out = out + "static char* hi_input(Arena* ar) { size_t cap = 128, len = 0; char* b = malloc(cap); int c; fflush(stdout); while ((c = getchar()) != EOF && c != '\\n') { if (len + 1 >= cap) { cap *= 2; b = realloc(b, cap); } b[len++] = (char)c; } char* r = hs(ar, (long)len); memcpy(r, b, len); free(b); return r; }\n"
    out = out + "static char* hi_chr(Arena* ar, long n) { char* r = hs(ar, 1); r[0] = (char)(n & 0xff); return r; }\n"
    out = out + "static char* hi_getenv(Arena* ar, const char* name) { const char* v = getenv(name); return s_from_c(ar, v ? v : \"\"); }\n"
    out = out + "static void hi_die(const char* m) { fputs(m, stderr); fputc('\\n', stderr); exit(1); }\n"
    out = out + "static void hi_eprint(const char* m) { fputs(m, stderr); }\n"
    out = out + "static char* hi_read_all(Arena* ar) { size_t cap = 4096, len = 0; char* b = malloc(cap); int c; while ((c = getchar()) != EOF) { if (len + 1 >= cap) { cap *= 2; b = realloc(b, cap); } b[len++] = (char)c; } char* r = hs(ar, (long)len); memcpy(r, b, len); free(b); return r; }\n"
    out = out + "static long hi_clock(void) { struct timespec ts; clock_gettime(CLOCK_MONOTONIC, &ts); return (long)ts.tv_sec * 1000000000L + (long)ts.tv_nsec; }\n"
    out = out + "static long hi_now(void) { return (long)time(NULL); }\n"
    out = out + "static char* hi_read_file(Arena* ar, const char* path) { FILE* f = fopen(path, \"rb\"); if (!f) return s_from_c(ar, \"\"); size_t cap = 4096, len = 0, n; char* b = amem(ar, cap); while ((n = fread(b + len, 1, cap - len, f)) > 0) { len += n; if (len == cap) { size_t nc = cap * 2; char* nb = amem(ar, nc); memcpy(nb, b, len); b = nb; cap = nc; } } fclose(f); char* r = hs(ar, (long)len); memcpy(r, b, len); return r; }\n"
    out = out + "static long hi_write_file(const char* path, const char* data) { FILE* f = fopen(path, \"wb\"); if (!f) return 0; long n = ((const long*)data)[-1]; size_t w = fwrite(data, 1, (size_t)n, f); fclose(f); return (w == (size_t)n) ? 1 : 0; }\n"
    out = out + "static int hi_argc = 0;\nstatic char** hi_argv = 0;\n"
    out = out + "typedef struct { int tag; void* val; } HOption;\n"
    out = out + "typedef struct { int tag; void* ok; void* err; } HResult;\n"
    out = out + "static void* hbox(Arena* ar, unsigned long n, void* src) { void* p = amem(ar, n); memcpy(p, src, n); return p; }\n"
    out = out + "static HOption hsome(void* v) { HOption o; o.tag = 1; o.val = v; return o; }\n"
    out = out + "static HOption hnone(void) { HOption o; o.tag = 0; o.val = 0; return o; }\n"
    out = out + "static HResult hok(void* v) { HResult r; r.tag = 1; r.ok = v; r.err = 0; return r; }\n"
    out = out + "static HResult herr(void* v) { HResult r; r.tag = 0; r.ok = 0; r.err = v; return r; }\n"
    return out

# One monomorphized value-array family per element type T: Arr_T holds a
# CTY* buffer; copy is a deep copy (value semantics). The struct definition is
# split from the functions so the element struct's full body can be emitted in
# between (the functions need sizeof(T) / by-value assignment, but the Arr_T
# struct itself only needs T as a pointer — this is what lets [P] and recursive
# structs like `struct Node { kids: [Node] }` compile).
fn gen_arr_type(dc: Decls, ctx: Ctx, et: string) -> string:
    nm := "Arr_" + mangle(et)                    # named-tag body; the typedef is forward-declared in the driver
    ct := cty(dc, ctx, et)                           # (so a fn value whose param/ret is [T] can name Arr_T incomplete)
    out := "struct " + nm + "_ { " + ct + "* data; long len; long cap; };\n"
    out = out + "static int " + nm + "_eq(" + nm + " a, " + nm + " b);\n"
    out = out + "static " + nm + " " + nm + "_from(Arena* ar, " + ct + "* s, long n);\n"
    return out + "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " a);\n"

fn gen_arr_fns(dc: Decls, ctx: Ctx, et: string) -> string:
    nm := "Arr_" + mangle(et)
    ct := cty(dc, ctx, et)                           # element C type, trailing space
    out := "static " + nm + " " + nm + "_new(void) { " + nm + " a; a.data = 0; a.len = 0; a.cap = 0; return a; }\n"
    # buffer lives in arena `ar` (NULL=malloc). push ARENA-GROWS (no realloc on
    # arena memory): allocate a doubled buffer and copy; the old one is dead and
    # reclaimed at arena_free. Elements are malloc'd by the store-copy at every
    # store site, so copy/slice stay SHALLOW (element pointers) and remain valid.
    if elem_deepcopy(dc, ctx, et):
        # heap elements live in the array's arena: _from (hence _copy/_slice)
        # deep-copies each element into `ar`, so a copied/returned/sliced array
        # fully owns its elements and frees them with its arena (closes the
        # element-residual leak). push grows the buffer shallowly (same array
        # identity, same arena) so it does NOT route through _from.
        out = out + "static " + nm + " " + nm + "_from(Arena* ar, " + ct + "* s, long n) { " + nm + " a; a.len = n; a.cap = n > 0 ? n : 0; a.data = n ? amem(ar, sizeof(" + ct + ") * n) : 0; for (long i = 0; i < n; i++) a.data[i] = " + elem_copy_expr(dc, ctx, et, "ar", "s[i]") + "; return a; }\n"
    else:
        out = out + "static " + nm + " " + nm + "_from(Arena* ar, " + ct + "* s, long n) { " + nm + " a; a.len = n; a.cap = n > 0 ? n : 0; a.data = n ? amem(ar, sizeof(" + ct + ") * n) : 0; if (n) memcpy(a.data, s, sizeof(" + ct + ") * n); return a; }\n"
    out = out + "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " a) { return " + nm + "_from(ar, a.data, a.len); }\n"
    out = out + "static void " + nm + "_push(Arena* ar, " + nm + "* a, " + ct + "v) { if (a->len == a->cap) { long nc = a->cap ? a->cap * 2 : 4; " + ct + "* nd = amem(ar, sizeof(" + ct + ") * nc); if (a->len) memcpy(nd, a->data, sizeof(" + ct + ") * a->len); if (ar && a->cap) arena_recycle(ar, a->data, sizeof(" + ct + ") * (size_t)a->cap); a->data = nd; a->cap = nc; } a->data[a->len++] = v; }\n"
    # push-loop fusion grow hook (every element type: shallow spine memcpy; the
    # element heap was already deep-copied into `ar` at each fused store)
    out = out + "static void " + nm + "_grow(Arena* ar, " + ct + "** data, long* cap, long len) { long nc = *cap ? *cap * 2 : 4; " + ct + "* nd = amem(ar, sizeof(" + ct + ") * nc); if (len) memcpy(nd, *data, sizeof(" + ct + ") * len); if (ar && *cap) arena_recycle(ar, *data, sizeof(" + ct + ") * (size_t)*cap); *data = nd; *cap = nc; }\n"
    popv := "a->data[a->len]"                        # scalar: the value; heap: a deep copy into `ar`
    if elem_deepcopy(dc, ctx, et):                   # (so the popped value outlives a later array recycle)
        popv = elem_copy_expr(dc, ctx, et, "ar", "a->data[a->len]")
    out = out + "static " + ct + nm + "_pop(Arena* ar, " + nm + "* a) { if (a->len == 0) { fprintf(stderr, \"tycho: pop from an empty array\\n\"); exit(1); } a->len--; return " + popv + "; }\n"
    out = out + "static void " + nm + "_reserve(Arena* ar, " + nm + "* a, long n) { if (n <= a->cap) return; " + ct + "* nd = amem(ar, sizeof(" + ct + ") * n); if (a->len) memcpy(nd, a->data, sizeof(" + ct + ") * a->len); if (ar && a->cap) arena_recycle(ar, a->data, sizeof(" + ct + ") * (size_t)a->cap); a->data = nd; a->cap = n; }\n"
    out = out + "static " + nm + " " + nm + "_slice(Arena* ar, " + nm + " a, long lo, long hi) { return " + nm + "_from(ar, a.data + lo, hi - lo); }\n"
    # _eq for every element type (eq_field handles scalar/str/enum/struct/array/
    # option/result); the gen_arr_type forward decl lets composite eq cross-ref.
    out = out + "static int " + nm + "_eq(" + nm + " a, " + nm + " b) { if (a.len != b.len) return 0; for (long i = 0; i < a.len; i++) if (!(" + eq_field(dc, ctx, et, "a.data[i]", "b.data[i]") + ")) return 0; return 1; }\n"
    return out

# SOA typedef + helper forward decls — emitted BEFORE struct bodies so a struct
# may embed a soa by value, and before struct copy/eq so they can call the soa
# helpers. (Bodies are gen_soa, emitted after struct bodies for sizeof.)
fn gen_soa_decl(dc: Decls, ctx: Ctx, ty: string) -> string:
    sn := soa_struct(ty)
    nm := "Soa_" + sn
    si := 0
    for si < len(dc.structs):
        if dc.structs[si].name == sn:
            flds := dc.structs[si].fields
            out := "typedef struct {"
            i := 0
            for i < len(flds):
                out = out + " " + cty(dc, ctx, flds[i].ty) + "* f" + str(i) + ";"
                i = i + 1
            out = out + " long len; long cap; } " + nm + ";\n"
            out = out + "static void " + nm + "_push(Arena* ar, " + nm + "* s, " + ust(sn) + " v);\n"
            out = out + "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " s);\n"
            out = out + "static int " + nm + "_eq(" + nm + " a, " + nm + " b);\n"
            return out
        si = si + 1
    return ""

# SOA family for `soa [Struct]`: one growable buffer per struct field (f0, f1,
# ...) + a shared len/cap, instead of an array of records. Arena-backed (each
# field buffer lives in the owner arena, freed with its scope) like the Arr
# families -- earlier this was naive realloc/malloc and LEAKED (the leak fuzzer
# found it). push grows each buffer and scatters the struct's (scalar) fields.
fn gen_soa(dc: Decls, ctx: Ctx, ty: string) -> string:
    sn := soa_struct(ty)
    nm := "Soa_" + sn
    si := 0
    for si < len(dc.structs):
        if dc.structs[si].name == sn:
            flds := dc.structs[si].fields       # typedef + decls emitted by gen_soa_decl (early)
            out := "static void " + nm + "_push(Arena* ar, " + nm + "* s, " + ust(sn) + " v) {\n"
            out = out + "    if (s->len == s->cap) { long nc = s->cap ? s->cap * 2 : 4;\n"
            i := 0
            for i < len(flds):
                ct := cty(dc, ctx, flds[i].ty)
                out = out + "        " + ct + "* n" + str(i) + " = amem(ar, sizeof(" + ct + ") * nc); for (long j = 0; j < s->len; j = j + 1) n" + str(i) + "[j] = s->f" + str(i) + "[j]; if (ar && s->cap) arena_recycle(ar, s->f" + str(i) + ", sizeof(" + ct + ") * (size_t)s->cap); s->f" + str(i) + " = n" + str(i) + ";\n"
                i = i + 1
            out = out + "        s->cap = nc;\n    }\n"
            i = 0
            for i < len(flds):
                out = out + "    s->f" + str(i) + "[s->len] = v." + uf(flds[i].name) + ";\n"
                i = i + 1
            out = out + "    s->len = s->len + 1;\n}\n"
            # copy: deep-copy each field buffer (value semantics on bind/pass/return)
            out = out + "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " s) {\n"
            out = out + "    " + nm + " r; r.len = s.len; r.cap = s.len;\n"
            i = 0
            for i < len(flds):
                ct := cty(dc, ctx, flds[i].ty)
                out = out + "    r.f" + str(i) + " = s.len ? amem(ar, sizeof(" + ct + ") * s.len) : 0;\n"
                out = out + "    for (long j = 0; j < s.len; j = j + 1) r.f" + str(i) + "[j] = s.f" + str(i) + "[j];\n"
                i = i + 1
            out = out + "    return r;\n}\n"
            # structural eq: same length + every field equal elementwise
            out = out + "static int " + nm + "_eq(" + nm + " a, " + nm + " b) {\n"
            out = out + "    if (a.len != b.len) return 0;\n"
            out = out + "    for (long j = 0; j < a.len; j = j + 1) {\n"
            i = 0
            for i < len(flds):
                out = out + "        if (!(" + eq_field(dc, ctx, flds[i].ty, "a.f" + str(i) + "[j]", "b.f" + str(i) + "[j]") + ")) return 0;\n"
                i = i + 1
            out = out + "    }\n    return 1;\n}\n"
            # pop: shrink len, gather the (new) last element, deep-copy it into `ar`
            # (heap fields outlive a later push that overwrites the freed slot).
            out = out + "static " + ust(sn) + " " + nm + "_pop(" + nm + "* s) {\n"
            out = out + "    if (s->len == 0) { fprintf(stderr, \"tycho: pop from an empty array\\n\"); exit(1); }\n"
            out = out + "    s->len = s->len - 1;\n"
            out = out + "    return " + gen_soa_gather(dc, ctx, ty, "(*s)", "s->len") + ";\n}\n"
            return out
        si = si + 1
    die("codegen: soa of unknown struct")
    return ""

# Runtime that depends on Arr_str (so it is emitted after the array families,
# not in the preamble): split a string on a separator into a [string].
fn gen_strlib() -> string:
    # buffer AND substrings in `ar` (the result's owner): Arr_str now deep-copies
    # str elements on copy/return, so the substrings can live in the array's arena
    # and free with it instead of leaking.
    out := "static Arr_str hi_split(Arena* ar, const char* s, const char* sep) {\n"
    out = out + "    Arr_str r = Arr_str_new();\n"
    out = out + "    long n = ((const long*)s)[-1], sl = ((const long*)sep)[-1];\n"
    out = out + "    if (sl == 0) { Arr_str_push(ar, &r, substr(ar, s, 0, n)); return r; }\n"
    out = out + "    long start = 0, i = 0;\n"
    out = out + "    while (i + sl <= n) {\n"
    out = out + "        if (memcmp(s + i, sep, (size_t)sl) == 0) { Arr_str_push(ar, &r, substr(ar, s, start, i)); i += sl; start = i; }\n"
    out = out + "        else i = i + 1;\n"
    out = out + "    }\n"
    out = out + "    Arr_str_push(ar, &r, substr(ar, s, start, n));\n"
    out = out + "    return r;\n}\n"
    out = out + "static Arr_str hi_list_dir(Arena* ar, const char* path) {\n"
    out = out + "    Arr_str r = Arr_str_new();\n"
    out = out + "    DIR* d = opendir(path); if (!d) return r;\n"
    out = out + "    struct dirent* de;\n"
    out = out + "    while ((de = readdir(d)) != 0) {\n"
    out = out + "        if (de->d_name[0] == '.' && (de->d_name[1] == 0 || (de->d_name[1] == '.' && de->d_name[2] == 0))) continue;\n"
    out = out + "        Arr_str_push(ar, &r, s_from_c(ar, de->d_name));\n"   # bare C d_name -> headered (also survives readdir's buffer reuse)
    out = out + "    }\n"
    out = out + "    closedir(d);\n    return r;\n}\n"
    out = out + "static Arr_str hi_args(Arena* ar) {\n"
    out = out + "    Arr_str r = Arr_str_new();\n"
    out = out + "    for (int i = 0; i < hi_argc; i++) Arr_str_push(ar, &r, s_from_c(ar, hi_argv[i]));\n"
    out = out + "    return r;\n}\n"
    return out

# String-keyed int map (the one map type the examples use). A faithful mirror
# of the C runtime's open-addressing table (runtime/tycho_rt.c): keyed SipHash-1-3 hash,
# power-of-2 capacity (min 8), linear probing, rehash past 1/2 load, deep-copy
# value semantics. keys()/`for k in m` iterate in INSERTION ORDER via a per-map
# `ord` vector (live keys in first-insert order), not bucket order -- so the order
# is independent of the hash/representation and matches tychoc trivially (and stays
# stable under a future random hash seed). delete rebuilds the map, reinserting
# survivors in ord order. Depends on Arr_str.
fn gen_mhash() -> string:                        # keyed SipHash-1-3 (strings) + seeded SplitMix64 (ints)
    # seed globals + mhash_seed_init live in preamble() (always emitted, so main
    # can call it unconditionally); the hashes below reference them.
    out := "#define SIPR(v0,v1,v2,v3) do { v0 += v1; v1 = (v1 << 13) | (v1 >> 51); v1 ^= v0; v0 = (v0 << 32) | (v0 >> 32); v2 += v3; v3 = (v3 << 16) | (v3 >> 48); v3 ^= v2; v0 += v3; v3 = (v3 << 21) | (v3 >> 43); v3 ^= v0; v2 += v1; v1 = (v1 << 17) | (v1 >> 47); v1 ^= v2; v2 = (v2 << 32) | (v2 >> 32); } while (0)\n"
    out = out + "static unsigned long siphash13(const unsigned char* in, unsigned long inlen) { unsigned long v0 = 0x736f6d6570736575UL ^ hash_k0; unsigned long v1 = 0x646f72616e646f6dUL ^ hash_k1; unsigned long v2 = 0x6c7967656e657261UL ^ hash_k0; unsigned long v3 = 0x7465646279746573UL ^ hash_k1; unsigned long b = inlen << 56; unsigned long whole = inlen - (inlen % 8); const unsigned char* end = in + whole; for (; in != end; in += 8) { unsigned long m = (unsigned long)in[0] | ((unsigned long)in[1] << 8) | ((unsigned long)in[2] << 16) | ((unsigned long)in[3] << 24) | ((unsigned long)in[4] << 32) | ((unsigned long)in[5] << 40) | ((unsigned long)in[6] << 48) | ((unsigned long)in[7] << 56); v3 ^= m; SIPR(v0,v1,v2,v3); v0 ^= m; } for (unsigned long i = 0; i < inlen % 8; i++) b |= (unsigned long)in[i] << (8 * i); v3 ^= b; SIPR(v0,v1,v2,v3); v0 ^= b; v2 ^= 0xff; SIPR(v0,v1,v2,v3); SIPR(v0,v1,v2,v3); SIPR(v0,v1,v2,v3); return v0 ^ v1 ^ v2 ^ v3; }\n"
    out = out + "static unsigned long mhash(const char* s) { long n = ((const long*)s)[-1]; return siphash13((const unsigned char*)s, (unsigned long)n); }\n"
    out = out + "static unsigned long ikhash(long k) { unsigned long x = ((unsigned long)k ^ ik_seed) + 0x9e3779b97f4a7c15UL; x = (x ^ (x >> 30)) * 0xbf58476d1ce4e5b9UL; x = (x ^ (x >> 27)) * 0x94d049bb133111ebUL; return x ^ (x >> 31); }\n"
    # insertion-order vector helpers: append on a new key, shift-remove (keep order) on delete.
    out = out + "static inline void ord_push_s(Arena* ar, char*** ord, long* nord, long* ocap, char* k) { if (*nord == *ocap) { long nc = *ocap ? *ocap * 2 : 8; char** nb = amem(ar, sizeof(char*) * nc); for (long i = 0; i < *nord; i++) nb[i] = (*ord)[i]; *ord = nb; *ocap = nc; } (*ord)[(*nord)++] = k; }\n"
    out = out + "static inline void ord_del_s(char** ord, long* nord, char* k) { for (long i = 0; i < *nord; i++) if (ord[i] == k) { for (long j = i + 1; j < *nord; j++) ord[j-1] = ord[j]; (*nord)--; return; } }\n"
    out = out + "static inline void ord_push_i(Arena* ar, long** ord, long* nord, long* ocap, long k) { if (*nord == *ocap) { long nc = *ocap ? *ocap * 2 : 8; long* nb = amem(ar, sizeof(long) * nc); for (long i = 0; i < *nord; i++) nb[i] = (*ord)[i]; *ord = nb; *ocap = nc; } (*ord)[(*nord)++] = k; }\n"
    out = out + "static inline void ord_del_i(long* ord, long* nord, long k) { for (long i = 0; i < *nord; i++) if (ord[i] == k) { for (long j = i + 1; j < *nord; j++) ord[j-1] = ord[j]; (*nord)--; return; } }\n"
    return out

# A composite (struct) map key. Rides the int-key occupancy scheme but stores the
# struct by value and hashes/compares it deeply.
fn mapkey_composite(dc: Decls, ctx: Ctx, k: string) -> bool:
    b := resolve_nt(dc, ctx, k)
    return is_struct(dc, ctx, b) or is_tuple(b) or is_array(b)

# A type usable as (a field of) a composite key: every leaf must have a stable deep
# hash. Scalars + bytes + (recursively) a struct of those qualify; arrays/maps/enums/
# tuples/functions do not yet (a later stage). Must match tychoc's key_hashable exactly.
fn key_hashable(dc: Decls, ctx: Ctx, ty: string) -> bool:
    b := resolve_nt(dc, ctx, ty)
    if b == "int" or b == "float" or b == "bool" or b == "char" or b == "str" or b == "bytes":
        return true
    if is_struct(dc, ctx, b):
        i := 0
        for i < len(dc.structs):
            if dc.structs[i].name == b:
                j := 0
                for j < len(dc.structs[i].fields):
                    if not key_hashable(dc, ctx, dc.structs[i].fields[j].ty):
                        return false
                    j = j + 1
                return true
            i = i + 1
        return false
    if is_tuple(b):
        parts := tuple_parts(b)
        j := 0
        for j < len(parts):
            if not key_hashable(dc, ctx, parts[j]):
                return false
            j = j + 1
        return true
    if is_array(b):
        return key_hashable(dc, ctx, elem_ty(b))   # an array key hashes element-wise (order-sensitive)
    return false

# hashable(T): T is usable as a map key -- string, int (through newtypes), a
# fieldless enum, or a composite (struct/tuple/array) of all-hashable leaves.
# Mirrors the standalone map-key validity check (8458) and tychoc's key_type_ok
# exactly. ctx is inert here (the predicate helpers read only dc).
fn key_type_ok(dc: Decls, ctx: Ctx, ty: string) -> bool:
    b := resolve_nt(dc, ctx, ty)
    if b == "str" or b == "int":
        return true
    if enum_fieldless(dc, ctx, ty):
        return true
    return mapkey_composite(dc, ctx, ty) and key_hashable(dc, ctx, ty)

# Is composite type `want` (a struct name or a tuple type string) reachable inside key
# type kt -- the key, a struct field, or a tuple element of it, recursively?
fn struct_in_key(dc: Decls, ctx: Ctx, want: string, kt: string) -> bool:
    b := resolve_nt(dc, ctx, kt)
    if b == want:
        return true
    if is_struct(dc, ctx, b):
        i := 0
        for i < len(dc.structs):
            if dc.structs[i].name == b:
                j := 0
                for j < len(dc.structs[i].fields):
                    if struct_in_key(dc, ctx, want, dc.structs[i].fields[j].ty):
                        return true
                    j = j + 1
                return false
            i = i + 1
        return false
    if is_tuple(b):
        parts := tuple_parts(b)
        i := 0
        for i < len(parts):
            if struct_in_key(dc, ctx, want, parts[i]):
                return true
            i = i + 1
        return false
    if is_array(b):
        return struct_in_key(dc, ctx, want, elem_ty(b))
    return false

# Does any composite-keyed map (in the emitted type list) use struct `sname` as its
# key or a nested key field? Only such structs get a _hash emitted -- the hash calls
# ikhash/mhash, which exist only when the program uses maps. Must match tychoc.
fn struct_keyused(dc: Decls, ctx: Ctx, ets: [string], sname: string) -> bool:
    i := 0
    for i < len(ets):
        if is_map(ets[i]) and mapkey_composite(dc, ctx, map_key(ets[i])) and struct_in_key(dc, ctx, sname, map_key(ets[i])):
            return true
        i = i + 1
    return false

# Deep hash of a field value `v` of type ty (mirrors eq_field + tychoc's gen_hash).
fn hash_field(dc: Decls, ctx: Ctx, ty: string, v: string) -> string:
    r := resolve_nt(dc, ctx, ty)
    if r == "str" or r == "bytes":
        return "mhash(" + v + ")"
    if r == "float":
        return "ikhash((long)((union { double _d; long _l; }){ ._d = (" + v + ") })._l)"
    if is_struct(dc, ctx, r):
        return ust(r) + "_hash(" + v + ")"
    if is_tuple(r):
        return "Tup_" + tup_suffix(r) + "_hash(" + v + ")"
    if is_array(r):
        return "Arr_" + mangle(elem_ty(r)) + "_hash(" + v + ")"
    return "ikhash((long)(" + v + "))"            # int / bool / char

# Deep-hash body for a hashable struct used as a map key. Seeded from hash_k0 (the
# per-process hash-flood seed), FNV-folds field hashes; field order matters so a
# struct and its field-swapped twin hash differently. Pairs with <nm>_eq.
fn gen_struct_hash(dc: Decls, ctx: Ctx, sd: StructDef) -> string:
    nm := ust(sd.name)
    out := "static unsigned long " + nm + "_hash(" + nm + " v) { unsigned long h = hash_k0;"
    j := 0
    for j < len(sd.fields):
        out = out + " h = h * 1099511628211UL ^ " + hash_field(dc, ctx, sd.fields[j].ty, "v." + uf(sd.fields[j].name)) + ";"
        j = j + 1
    return out + " return h; }\n"

fn gen_map_type(dc: Decls, ctx: Ctx, ty: string) -> string:
    k := map_key(ty)
    if resolve_nt(dc, ctx, k) != "int" and resolve_nt(dc, ctx, k) != "str" and not enum_fieldless(dc, ctx, k) and not (mapkey_composite(dc, ctx, k) and key_hashable(dc, ctx, k)):
        die_at(dc, ctx.line, "type: map keys must be string, int (directly or through a newtype), a fieldless enum, or a struct of hashable fields")   # fail-closed: a payload enum / float / non-hashable-field key fell through and would emit broken C
    v := map_val(ty)
    cvs := cty(dc, ctx, v)                        # value C type (has a trailing space)
    cv := substr(cvs, 0, len(cvs) - 1)
    M := "Map_" + mangle(k) + "_" + mangle(v)            # named-tag body; typedef forward-declared in the driver (fn([K:V])->R)
    if mapkey_composite(dc, ctx, k):             # struct keys: stored by value, deep hash/eq, occupancy array (no null sentinel, like int keys)
        cks := cty(dc, ctx, k)
        ck := substr(cks, 0, len(cks) - 1)
        return "struct " + M + "_ { " + ck + "* keys; " + cv + "* vals; unsigned char* occ; long len; long cap; " + ck + "* ord; long nord; long ocap; };\n"
    if resolve_nt(dc, ctx, k) == "int" or enum_fieldless(dc, ctx, k):   # int(-rep) keys incl. enum tags: a value array + occupancy bytes (0 is a real key)
        return "struct " + M + "_ { long* keys; " + cv + "* vals; unsigned char* occ; long len; long cap; long* ord; long nord; long ocap; };\n"
    return "struct " + M + "_ { char** keys; " + cv + "* vals; long len; long cap; char** ord; long nord; long ocap; };\n"

# Map family monomorphized over key k (str/int) and value v (int/float). The C
# value type cv is long/double. String keys use mhash + strcmp + a NULL-empty key
# array (key bytes copied in); int keys use ikhash + == + a separate occupancy
# byte array (0 is a real key, so there is no free empty marker). Neither uses
# tombstones — map delete rebuilds — so the probe stops at the first empty slot.
fn gen_map_fns(dc: Decls, ctx: Ctx, ty: string) -> string:
    k := map_key(ty)
    v := map_val(ty)
    cvs := cty(dc, ctx, v)                        # value C type (has a trailing space)
    cv := substr(cvs, 0, len(cvs) - 1)
    M := "Map_" + mangle(k) + "_" + mangle(v)
    f := "map_" + mangle(k) + "_" + mangle(v)
    s := "m" + mtag(k) + "_" + mangle(v)
    ka := "Arr_" + mangle(k)                     # keys() returns [K] (a newtype/enum key stays wrapped)
    kv := "m.ord[i]"                             # the value keys() pushes (walked in insertion order)
    pre := ""
    if enum_fieldless(dc, ctx, k):               # enum key: tags are stored; keys() rebuilds the
        ei := 0                                  # wrapped values from a tag -> singleton table.
        for ei < len(dc.enums):                  # Tentative decls first: the singletons' initialized
            if dc.enums[ei].name == k:           # definitions are emitted later (enum fns step).
                tab := "static " + uet(k) + "* const " + f + "_ktab[] = {"
                vj := 0
                for vj < len(dc.enums[ei].variants):
                    pre = pre + "static " + uet(k) + " _sing_" + k + "_" + str(vj) + ";\n"
                    if vj > 0:
                        tab = tab + ","
                    tab = tab + " &_sing_" + k + "_" + str(vj)
                    vj = vj + 1
                pre = pre + tab + " };\n"
            ei = ei + 1
        kv = f + "_ktab[m.ord[i]]"
    vcopy := cp_field(dc, ctx, v, "ar", "val")   # deep-copy the value into ar (passthrough for scalars)
    vcmp := " || !(" + eq_field(dc, ctx, v, "b.vals[t]", "a.vals[i]") + ")"   # heap value: deep equality
    if v == "int" or v == "float" or v == "char":
        vcmp = " || b.vals[t] != a.vals[i]"      # scalar: byte-identical to before
    if mapkey_composite(dc, ctx, k):             # struct keys: occupancy scheme like int keys, but K stored by value, deep-hashed and deep-compared; key deep-copied on put
        cks := cty(dc, ctx, k)
        ck := substr(cks, 0, len(cks) - 1)        # struct C type
        rk := resolve_nt(dc, ctx, k)
        heq := teq(dc, ctx, k)                    # deep-eq fn name (struct/enum via teq; tuple below)
        hh := ust(rk) + "_hash"                   # deep-hash fn name
        if is_tuple(rk):                          # tuples name their eq/hash by suffix, not ust
            heq = "Tup_" + tup_suffix(rk) + "_eq"
            hh = "Tup_" + tup_suffix(rk) + "_hash"
        if is_array(rk):                          # arrays name their eq/hash by mangled element
            heq = "Arr_" + mangle(elem_ty(rk)) + "_eq"
            hh = "Arr_" + mangle(elem_ty(rk)) + "_hash"
        kcopy := cp_field(dc, ctx, k, "ar", "k")  # deep-copy the key into ar (passthrough for scalar-field structs/tuples)
        out := "static " + M + " " + s + "_cap(Arena* ar, long cap) { " + M + " m; long c = 4; while (c < cap) c *= 2; if (cap == 0) c = 0; m.cap = c; m.len = 0; m.ord = 0; m.nord = 0; m.ocap = 0; if (c == 0) { m.keys = 0; m.vals = 0; m.occ = 0; return m; } m.keys = amem(ar, sizeof(" + ck + ") * c); m.vals = amem(ar, sizeof(" + cv + ") * c); m.occ = amem(ar, c); for (long i = 0; i < c; i++) m.occ[i] = 0; return m; }\n"
        out = out + "static " + M + " " + f + "_new(void) { return " + s + "_cap(0, 0); }\n"
        out = out + "static void " + s + "_op(Arena* ar, " + ck + "** ord, long* nord, long* ocap, " + ck + " k) { if (*nord == *ocap) { long nc = *ocap ? *ocap * 2 : 8; " + ck + "* nb = amem(ar, sizeof(" + ck + ") * nc); for (long i = 0; i < *nord; i++) nb[i] = (*ord)[i]; *ord = nb; *ocap = nc; } (*ord)[(*nord)++] = k; }\n"
        out = out + "static long " + s + "_slot(" + M + " m, " + ck + " k) { unsigned long mask = (unsigned long)m.cap - 1; long i = (long)(" + hh + "(k) & mask); while (m.occ[i] != 0) { if (" + heq + "(m.keys[i], k)) return i; i = (long)((i + 1) & mask); } return i; }\n"
        out = out + "static void " + f + "_put(Arena* ar, " + M + "* m, " + ck + " k, " + cv + " val) { if (m->cap == 0 || (m->len + 1) * 2 > m->cap) { long nc = m->cap ? m->cap * 2 : 4; " + M + " n = " + s + "_cap(ar, nc); for (long i = 0; i < m->cap; i++) if (m->occ[i]) { long t = " + s + "_slot(n, m->keys[i]); n.keys[t] = m->keys[i]; n.vals[t] = m->vals[i]; n.occ[t] = 1; n.len++; } n.ord = m->ord; n.nord = m->nord; n.ocap = m->ocap; *m = n; } long t = " + s + "_slot(*m, k); if (!m->occ[t]) { m->occ[t] = 1; m->keys[t] = " + kcopy + "; m->len++; " + s + "_op(ar, &m->ord, &m->nord, &m->ocap, m->keys[t]); } m->vals[t] = " + vcopy + "; }\n"
        out = out + "static inline " + cv + "* " + s + "_slotptr(Arena* ar, " + M + "* m, " + ck + " k) { if (m->cap == 0 || (m->len + 1) * 2 > m->cap) { long nc = m->cap ? m->cap * 2 : 4; " + M + " n = " + s + "_cap(ar, nc); for (long i = 0; i < m->cap; i++) if (m->occ[i]) { long t = " + s + "_slot(n, m->keys[i]); n.keys[t] = m->keys[i]; n.vals[t] = m->vals[i]; n.occ[t] = 1; n.len++; } n.ord = m->ord; n.nord = m->nord; n.ocap = m->ocap; *m = n; } long t = " + s + "_slot(*m, k); if (!m->occ[t]) { m->occ[t] = 1; m->keys[t] = " + kcopy + "; m->len++; " + s + "_op(ar, &m->ord, &m->nord, &m->ocap, m->keys[t]); m->vals[t] = (" + cv + "){0}; } return &m->vals[t]; }\n"
        out = out + "static " + M + " " + f + "_copy(Arena* ar, " + M + " m) { " + M + " r = " + s + "_cap(ar, m.len ? m.len * 2 : 0); for (long i = 0; i < m.nord; i++) { long t = " + s + "_slot(m, m.ord[i]); " + f + "_put(ar, &r, m.ord[i], m.vals[t]); } return r; }\n"
        out = out + "static " + M + " " + f + "_set(Arena* ar, " + M + " m, " + ck + " k, " + cv + " val) { " + M + " r = " + f + "_copy(ar, m); " + f + "_put(ar, &r, k, val); return r; }\n"
        out = out + "static " + cv + " " + f + "_get(" + M + " m, " + ck + " k, " + cv + " def) { if (m.cap == 0) return def; long t = " + s + "_slot(m, k); return m.occ[t] ? m.vals[t] : def; }\n"
        out = out + "static int " + f + "_has(" + M + " m, " + ck + " k) { if (m.cap == 0) return 0; long t = " + s + "_slot(m, k); return m.occ[t] != 0; }\n"
        out = out + "static " + M + " " + f + "_del(Arena* ar, " + M + " m, " + ck + " k) { " + M + " r = " + f + "_new(); for (long i = 0; i < m.nord; i++) if (!" + heq + "(m.ord[i], k)) { long t = " + s + "_slot(m, m.ord[i]); " + f + "_put(ar, &r, m.ord[i], m.vals[t]); } return r; }\n"
        out = out + "static " + ka + " " + f + "_keys(Arena* ar, " + M + " m) { " + ka + " r = " + ka + "_new(); for (long i = 0; i < m.nord; i++) " + ka + "_push(ar, &r, " + cp_field(dc, ctx, k, "ar", "m.ord[i]") + "); return r; }\n"
        out = out + "static int " + f + "_eq(" + M + " a, " + M + " b) { if (a.len != b.len) return 0; for (long i = 0; i < a.cap; i++) if (a.occ[i]) { long t = " + s + "_slot(b, a.keys[i]); if (b.occ[t] == 0" + vcmp + ") return 0; } return 1; }\n"
        return out
    if resolve_nt(dc, ctx, k) == "int" or enum_fieldless(dc, ctx, k):
        out := pre + "static " + M + " " + s + "_cap(Arena* ar, long cap) { " + M + " m; long c = 4; while (c < cap) c *= 2; if (cap == 0) c = 0; m.cap = c; m.len = 0; m.ord = 0; m.nord = 0; m.ocap = 0; if (c == 0) { m.keys = 0; m.vals = 0; m.occ = 0; return m; } m.keys = amem(ar, sizeof(long) * c); m.vals = amem(ar, sizeof(" + cv + ") * c); m.occ = amem(ar, c); for (long i = 0; i < c; i++) m.occ[i] = 0; return m; }\n"
        out = out + "static " + M + " " + f + "_new(void) { return " + s + "_cap(0, 0); }\n"
        out = out + "static long " + s + "_slot(" + M + " m, long k) { unsigned long mask = (unsigned long)m.cap - 1; long i = (long)(ikhash(k) & mask); while (m.occ[i] != 0) { if (m.keys[i] == k) return i; i = (long)((i + 1) & mask); } return i; }\n"
        out = out + "static void " + f + "_put(Arena* ar, " + M + "* m, long k, " + cv + " val) { if (m->cap == 0 || (m->len + 1) * 2 > m->cap) { long nc = m->cap ? m->cap * 2 : 4; " + M + " n = " + s + "_cap(ar, nc); for (long i = 0; i < m->cap; i++) if (m->occ[i]) { long t = " + s + "_slot(n, m->keys[i]); n.keys[t] = m->keys[i]; n.vals[t] = m->vals[i]; n.occ[t] = 1; n.len++; } n.ord = m->ord; n.nord = m->nord; n.ocap = m->ocap; *m = n; } long t = " + s + "_slot(*m, k); if (!m->occ[t]) { m->occ[t] = 1; m->keys[t] = k; m->len++; ord_push_i(ar, &m->ord, &m->nord, &m->ocap, k); } m->vals[t] = " + vcopy + "; }\n"
        # in-place value projection: find-or-insert, return &slot value (#2). dormant until step 2 routes m[k] here.
        out = out + "static inline " + cv + "* " + s + "_slotptr(Arena* ar, " + M + "* m, long k) { if (m->cap == 0 || (m->len + 1) * 2 > m->cap) { long nc = m->cap ? m->cap * 2 : 4; " + M + " n = " + s + "_cap(ar, nc); for (long i = 0; i < m->cap; i++) if (m->occ[i]) { long t = " + s + "_slot(n, m->keys[i]); n.keys[t] = m->keys[i]; n.vals[t] = m->vals[i]; n.occ[t] = 1; n.len++; } n.ord = m->ord; n.nord = m->nord; n.ocap = m->ocap; *m = n; } long t = " + s + "_slot(*m, k); if (!m->occ[t]) { m->occ[t] = 1; m->keys[t] = k; m->len++; ord_push_i(ar, &m->ord, &m->nord, &m->ocap, k); m->vals[t] = (" + cv + "){0}; } return &m->vals[t]; }\n"
        out = out + "static " + M + " " + f + "_copy(Arena* ar, " + M + " m) { " + M + " r = " + s + "_cap(ar, m.len ? m.len * 2 : 0); for (long i = 0; i < m.nord; i++) { long t = " + s + "_slot(m, m.ord[i]); " + f + "_put(ar, &r, m.ord[i], m.vals[t]); } return r; }\n"
        out = out + "static " + M + " " + f + "_set(Arena* ar, " + M + " m, long k, " + cv + " val) { " + M + " r = " + f + "_copy(ar, m); " + f + "_put(ar, &r, k, val); return r; }\n"
        out = out + "static " + cv + " " + f + "_get(" + M + " m, long k, " + cv + " def) { if (m.cap == 0) return def; long t = " + s + "_slot(m, k); return m.occ[t] ? m.vals[t] : def; }\n"
        out = out + "static int " + f + "_has(" + M + " m, long k) { if (m.cap == 0) return 0; long t = " + s + "_slot(m, k); return m.occ[t] != 0; }\n"
        out = out + "static " + M + " " + f + "_del(Arena* ar, " + M + " m, long k) { " + M + " r = " + f + "_new(); for (long i = 0; i < m.nord; i++) if (m.ord[i] != k) { long t = " + s + "_slot(m, m.ord[i]); " + f + "_put(ar, &r, m.ord[i], m.vals[t]); } return r; }\n"
        out = out + "static " + ka + " " + f + "_keys(Arena* ar, " + M + " m) { " + ka + " r = " + ka + "_new(); for (long i = 0; i < m.nord; i++) " + ka + "_push(ar, &r, " + kv + "); return r; }\n"
        out = out + "static int " + f + "_eq(" + M + " a, " + M + " b) { if (a.len != b.len) return 0; for (long i = 0; i < a.cap; i++) if (a.occ[i]) { long t = " + s + "_slot(b, a.keys[i]); if (b.occ[t] == 0" + vcmp + ") return 0; } return 1; }\n"
        return out
    out := "static " + M + " " + s + "_cap(Arena* ar, long cap) { " + M + " m; long c = 4; while (c < cap) c *= 2; if (cap == 0) c = 0; m.cap = c; m.len = 0; m.ord = 0; m.nord = 0; m.ocap = 0; if (c == 0) { m.keys = 0; m.vals = 0; return m; } m.keys = amem(ar, sizeof(char*) * c); m.vals = amem(ar, sizeof(" + cv + ") * c); for (long i = 0; i < c; i++) m.keys[i] = 0; return m; }\n"
    out = out + "static " + M + " " + f + "_new(void) { return " + s + "_cap(0, 0); }\n"
    out = out + "static long " + s + "_slot(" + M + " m, const char* k) { unsigned long mask = (unsigned long)m.cap - 1; long i = (long)(mhash(k) & mask); while (m.keys[i] != 0) { if (str_cmp(m.keys[i], k) == 0) return i; i = (long)((i + 1) & mask); } return i; }\n"
    out = out + "static void " + f + "_put(Arena* ar, " + M + "* m, char* k, " + cv + " val) { if (m->cap == 0 || (m->len + 1) * 2 > m->cap) { long nc = m->cap ? m->cap * 2 : 4; " + M + " n = " + s + "_cap(ar, nc); for (long i = 0; i < m->cap; i++) if (m->keys[i] != 0) { long t = " + s + "_slot(n, m->keys[i]); n.keys[t] = m->keys[i]; n.vals[t] = m->vals[i]; n.len++; } n.ord = m->ord; n.nord = m->nord; n.ocap = m->ocap; *m = n; } long t = " + s + "_slot(*m, k); if (m->keys[t] == 0) { m->keys[t] = scopy(ar, k); m->len++; ord_push_s(ar, &m->ord, &m->nord, &m->ocap, m->keys[t]); } m->vals[t] = " + vcopy + "; }\n"
    # in-place value projection: find-or-insert, return &slot value (#2). dormant until step 2 routes m[k] here.
    out = out + "static inline " + cv + "* " + s + "_slotptr(Arena* ar, " + M + "* m, const char* k) { if (m->cap == 0 || (m->len + 1) * 2 > m->cap) { long nc = m->cap ? m->cap * 2 : 4; " + M + " n = " + s + "_cap(ar, nc); for (long i = 0; i < m->cap; i++) if (m->keys[i] != 0) { long t = " + s + "_slot(n, m->keys[i]); n.keys[t] = m->keys[i]; n.vals[t] = m->vals[i]; n.len++; } n.ord = m->ord; n.nord = m->nord; n.ocap = m->ocap; *m = n; } long t = " + s + "_slot(*m, k); if (m->keys[t] == 0) { m->keys[t] = scopy(ar, k); m->len++; ord_push_s(ar, &m->ord, &m->nord, &m->ocap, m->keys[t]); m->vals[t] = (" + cv + "){0}; } return &m->vals[t]; }\n"
    out = out + "static " + M + " " + f + "_copy(Arena* ar, " + M + " m) { " + M + " r = " + s + "_cap(ar, m.len ? m.len * 2 : 0); for (long i = 0; i < m.nord; i++) { long t = " + s + "_slot(m, m.ord[i]); " + f + "_put(ar, &r, m.ord[i], m.vals[t]); } return r; }\n"
    out = out + "static " + M + " " + f + "_set(Arena* ar, " + M + " m, char* k, " + cv + " val) { " + M + " r = " + f + "_copy(ar, m); " + f + "_put(ar, &r, k, val); return r; }\n"
    out = out + "static " + cv + " " + f + "_get(" + M + " m, char* k, " + cv + " def) { if (m.cap == 0) return def; long t = " + s + "_slot(m, k); return m.keys[t] ? m.vals[t] : def; }\n"
    out = out + "static int " + f + "_has(" + M + " m, char* k) { if (m.cap == 0) return 0; long t = " + s + "_slot(m, k); return m.keys[t] != 0; }\n"
    out = out + "static " + M + " " + f + "_del(Arena* ar, " + M + " m, char* k) { " + M + " r = " + f + "_new(); for (long i = 0; i < m.nord; i++) if (str_cmp(m.ord[i], k) != 0) { long t = " + s + "_slot(m, m.ord[i]); " + f + "_put(ar, &r, m.ord[i], m.vals[t]); } return r; }\n"
    out = out + "static " + ka + " " + f + "_keys(Arena* ar, " + M + " m) { " + ka + " r = " + ka + "_new(); for (long i = 0; i < m.nord; i++) " + ka + "_push(ar, &r, scopy(ar, m.ord[i])); return r; }\n"
    # structural equality: same length, and every live key in a present in b with
    # an equal value (same len + a's keys ⊆ b with equal values ⟹ equal).
    out = out + "static int " + f + "_eq(" + M + " a, " + M + " b) { if (a.len != b.len) return 0; for (long i = 0; i < a.cap; i++) if (a.keys[i] != 0) { long t = " + s + "_slot(b, a.keys[i]); if (b.keys[t] == 0" + vcmp + ") return 0; } return 1; }\n"
    return out

fn has_str(xs: [string], s: string) -> bool:
    i := 0
    for i < len(xs):
        if xs[i] == s:
            return true
        i = i + 1
    return false

# Record the array element types a type needs, recursively (so [[int]] also
# pulls in [int], and Option/Result element types are descended into).
fn note_arr_types(acc: inout [string], ty: string):
    b := base_ty(ty)
    if is_array(b):
        et := elem_ty(b)
        if not has_str(acc, et):
            push(acc, et)
        note_arr_types(&acc, et)
    elif is_option(b):
        note_arr_types(&acc, option_inner(b))
    elif is_result(b):
        note_arr_types(&acc, result_ok(b))
        note_arr_types(&acc, result_err(b))
    elif is_soa(b):                              # collect the soa family (Soa_<Struct>)
        if not has_str(acc, b):
            push(acc, b)
    elif is_tuple(b):
        parts := tuple_parts(b)                        # element families FIRST: a tuple that embeds
        i := 0                                         # another tuple by value needs the inner tuple's
        for i < len(parts):                            # body before its own (dependency order)
            note_arr_types(&acc, parts[i])
            i = i + 1
        if not has_str(acc, b):
            push(acc, b)
    elif is_map(b):
        note_arr_types(&acc, map_key(b))               # bare composite key (struct/tuple) FIRST: the map struct holds a K* member, so K must be typedef'd before it
        note_arr_types(&acc, map_val(b))               # value family next: a map-valued map's
        note_arr_types(&acc, "[" + map_key(b) + "]")   # inner map must be typedef'd before the outer
        if not has_str(acc, b):                        # (its struct holds an inner-map pointer member);
            push(acc, b)                               # keys(m) -> [K] array family also emitted
    elif is_func(b):                                   # fn(P...) -> R : collect param/ret families first
        ps := func_params(b)
        i := 0
        for i < len(ps):
            note_arr_types(&acc, ps[i])
            i = i + 1
        note_arr_types(&acc, func_ret(b))
        if not has_str(acc, b):
            push(acc, b)

# Walk an expression collecting composite array element types from literals
# (array literals / empty arrays that no annotation would reveal).
# The body walkers thread the var env (names/types), mirroring gen, so that
# type_of resolves variables inside tuple/array literals (e.g. t := (a, b)).
# --- Newtype identity (parity with tychoc) ----------------------------------
# tychoc0 erases newtypes to their base in the emitted C (zero-cost) and resolves
# them in type_of at every var read, so the C compiler -- which does tychoc0's type
# checking -- can't see a newtype mismatch (`Ids` vs raw `[int]`, two distinct
# newtypes mixed, a newtype where its base is wanted). These checks recover the
# identity from the UNRESOLVED sources (var_type / field_type / sig.ret) and reject
# the mismatch up front, exactly as tychoc does. Strictness only: every program this
# rejects is correct at the base level.

# The newtype NAME `t` carries, or "" if `t` is not a newtype.
fn nt_or_empty(dc: Decls, ctx: Ctx, t: string) -> string:
    if is_newtype(dc, ctx, t):
        return t
    return ""

# The newtype an expression's VALUE carries ("" = none). Mirrors the newtype-
# producing leaves of type_of but without resolving, so identity survives. Must be
# complete over the forms that can yield a newtype, else a valid newtype value reads
# as "" and a correct program is wrongly rejected.
fn nt_skin_of(e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    match e:
        EVar(nm, _el):
            if not has_str(names, nm):                     # a bare enum variant / non-local (not a newtype-typed local) -- var_type would die
                return ""
            return nt_or_empty(dc, ctx, base_ty(var_type(names, types, nm)))
        ECall(nm, args, _el):
            if is_newtype(dc, ctx, nm):
                return nm                                  # Nt(v) constructor
            si := dc.sigmap.get(nm, -1)
            if si >= 0:
                return nt_or_empty(dc, ctx, dc.sigs[si].ret)   # a fn returning a newtype
            return ""
        EField(b, f, _el):
            bt := type_of(b, names, types, dc, ctx)        # struct shape (newtype-over-struct already resolved)
            if is_struct(dc, ctx, bt):
                return nt_or_empty(dc, ctx, field_type(dc, ctx, bt, f))
            return ""
        EIndex(b, _idx, _el):
            bt := type_of(b, names, types, dc, ctx)
            if is_map(bt):
                return nt_or_empty(dc, ctx, map_val(bt))
            if is_array(bt):
                return nt_or_empty(dc, ctx, elem_ty(bt))
            return ""
        EBin(op, l, r, _el):
            ls := nt_skin_of(l, names, types, dc, ctx)     # M+M -> M; base op base -> ""
            rs := nt_skin_of(r, names, types, dc, ctx)
            if ls == rs:
                return ls
            return ""
        EAddr(inner, _el):
            return nt_skin_of(inner, names, types, dc, ctx)
        _:
            return ""

# Reject if `e`'s newtype identity does not match the `expected` type. Generic
# (typaram-bearing) expected types are exempt -- typaram binding handles those.
fn nt_check(dc: Decls, ctx: Ctx, expected: string, e: Expr, names: [string], types: [string], where: string, el: int):
    if ty_is_generic(expected):
        return
    es := nt_or_empty(dc, ctx, base_ty(expected))
    ask := nt_skin_of(e, names, types, dc, ctx)
    if es != ask:
        got := ask
        if got == "":
            got = "a plain " + resolve_nt(dc, ctx, base_ty(expected)) + " value"
        die_at(dc, el, where + " expects " + base_ty(expected) + ", got " + got + " (newtype identity differs)")

# Compare the newtype identity carried by two expressions (a place vs the value
# stored into it). Rejects e.g. `ids_field = raw_int_array`.
fn nt_check_e(dc: Decls, ctx: Ctx, le: Expr, re: Expr, names: [string], types: [string], where: string, el: int):
    ls := nt_skin_of(le, names, types, dc, ctx)
    rs := nt_skin_of(re, names, types, dc, ctx)
    if ls != rs:
        lo := ls
        if lo == "":
            lo = "a non-newtype value"
        ro := rs
        if ro == "":
            ro = "a non-newtype value"
        die_at(dc, el, where + " expects " + lo + ", got " + ro)

# A place assignment `lv = rhs`: the stored value must match the place's newtype, and
# a map index `m[k] = v` additionally requires k to match the map's key type.
fn check_place_assign(dc: Decls, ctx: Ctx, lv: Expr, rhs: Expr, names: [string], types: [string], el: int):
    nt_check_e(dc, ctx, lv, rhs, names, types, "assignment", el)
    match lv:
        EIndex(b, k, _il):
            bt := type_of(b, names, types, dc, ctx)
            if is_map(bt):
                nt_check(dc, ctx, map_key(bt), k, names, types, "map key", el)
        _:
            return

# A struct constructor `S(args...)`: each argument must match the field's declared type
# (newtype-wise). Generic field types are exempt (handled by nt_check / typaram binding).
fn check_struct_ctor(dc: Decls, ctx: Ctx, nm: string, args: [Expr], names: [string], types: [string], el: int):
    i := 0
    for i < len(dc.structs):
        if dc.structs[i].name == nm:
            k := 0
            for k < len(args) and k < len(dc.structs[i].fields):
                nt_check(dc, ctx, dc.structs[i].fields[k].ty, args[k], names, types, "field '" + dc.structs[i].fields[k].name + "'", el)
                k = k + 1
            return
        i = i + 1

# Is `e` an `&place` argument (the only valid form for a `inout`/inout parameter)?
fn is_eaddr(e: Expr) -> bool:
    match e:
        EAddr(x, _el):
            return true
        _:
            return false

# A `inout` (inout) parameter must be passed `&variable`; tychoc rejects a bare
# argument there, but tychoc0 used to accept it and emit C that passes the value
# where a pointer is expected (won't compile -- a fuzz-reject fail-open). Check
# every user call: collect_elem_types walks every body, so this is universal.
fn check_call_args(dc: Decls, ctx: Ctx, nm: string, args: [Expr], names: [string], types: [string], el: int):
    si := dc.sigmap.get(nm, -1)                  # user fn? (builtins/ctors aren't in sigmap)
    if si < 0:
        return
    pp := dc.sigs[si].ptypes
    k := 0
    for k < len(args) and k < len(pp):
        if is_inout(pp[k]) and not is_eaddr(args[k]):
            die_at(dc, el, "argument " + str(k + 1) + " of '" + nm + "' is inout; pass it as '&variable'")
        elif not is_inout(pp[k]) and not is_sink(pp[k]):
            nt_check(dc, ctx, pp[k], args[k], names, types, "argument " + str(k + 1) + " of '" + nm + "'", el)
        k = k + 1

# The variant names of enum `ename` (the bare name "E" or a generic instance
# "Tree__int"; falls back to the generic base "Tree" of an application form).
# Empty if `ename` is not a known enum.
fn enum_variant_names(dc: Decls, ename: string) -> [string]:
    out := []string
    base := ename
    pp := find(ename, "(")
    if pp > 0:
        base = substr(ename, 0, pp)
    i := 0
    for i < len(dc.enums):
        if dc.enums[i].name == ename or dc.enums[i].name == base:
            j := 0
            for j < len(dc.enums[i].variants):
                push(out, dc.enums[i].variants[j].name)
                j = j + 1
            return out
        i = i + 1
    return out

# Compile-time `match` validation (parity with tychoc): every arm must name a real
# variant of the scrutinee, and every variant must be covered unless a `_` wildcard
# is present. tychoc0 used to accept a non-exhaustive match -- safe at RUNTIME (the
# emitted C aborts with "tycho: non-exhaustive match"), but a COMPILE error in tychoc,
# so an uncovered case shipped instead of being caught. `sty` should be resolve_ginst'd.
fn check_match(dc: Decls, ctx: Ctx, sty: string, vars: [string], el: int):
    wild := has_str(vars, "_")
    if is_option(sty):
        j := 0
        for j < len(vars):
            v := vars[j]
            if v != "Some" and v != "None" and v != "_":
                die_at(dc, el, "an Option's arms are Some(x), None, and _, not '" + v + "'")
            j = j + 1
        if not wild and (not has_str(vars, "Some") or not has_str(vars, "None")):
            die_at(dc, el, "non-exhaustive match on Option: arms must cover Some and None (or add `_`)")
        return
    if is_result(sty):
        j := 0
        for j < len(vars):
            v := vars[j]
            if v != "Ok" and v != "Err" and v != "_":
                die_at(dc, el, "a Result's arms are Ok(x), Err(e), and _, not '" + v + "'")
            j = j + 1
        if not wild and (not has_str(vars, "Ok") or not has_str(vars, "Err")):
            die_at(dc, el, "non-exhaustive match on Result: arms must cover Ok and Err (or add `_`)")
        return
    vn := enum_variant_names(dc, sty)
    if len(vn) == 0:
        return                                        # not a known enum: nothing to check
    j := 0
    for j < len(vars):
        v := vars[j]
        if v != "_" and not has_str(vn, v):
            die_at(dc, el, "'" + v + "' is not a variant of " + sty)
        j = j + 1
    if not wild:
        k := 0
        for k < len(vn):
            if not has_str(vars, vn[k]):
                die_at(dc, el, "non-exhaustive match: missing variant " + vn[k] + " of " + sty)
            k = k + 1

fn collect_expr(acc: inout [string], e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx):
    match e:
        EArrLit(elems, _el):
            note_arr_types(&acc, type_of(e, names, types, dc, ctx))
            j := 0
            for j < len(elems):
                collect_expr(&acc, elems[j], names, types, dc, ctx)
                j = j + 1
        EArrEmpty(ety, _el):
            note_arr_types(&acc, "[" + ety + "]")
        EMapEmpty(k, v, _el):
            note_arr_types(&acc, "{" + k + ":" + v + "}")
        EMapLit(keys, vals, _el):
            note_arr_types(&acc, type_of(e, names, types, dc, ctx))
            j := 0
            for j < len(vals):
                collect_expr(&acc, keys[j], names, types, dc, ctx)
                collect_expr(&acc, vals[j], names, types, dc, ctx)
                j = j + 1
        ETuple(elems, _el):
            note_arr_types(&acc, type_of(e, names, types, dc, ctx))
            j := 0
            for j < len(elems):
                collect_expr(&acc, elems[j], names, types, dc, ctx)
                j = j + 1
        EBin(op, l, r, _el):
            collect_expr(&acc, l, names, types, dc, ctx)
            collect_expr(&acc, r, names, types, dc, ctx)
        ECall(nm, args, _el):
            check_call_args(dc, ctx, nm, args, names, types, _el)   # reject `inout` arg not `&variable` + newtype-identity arg mismatch (matches tychoc)
            if is_struct(dc, ctx, nm):                  # struct constructor: each field init must match the field's newtype
                check_struct_ctor(dc, ctx, nm, args, names, types, _el)
            j := 0
            for j < len(args):
                collect_expr(&acc, args[j], names, types, dc, ctx)
                j = j + 1
        EField(b, f, _el):
            collect_expr(&acc, b, names, types, dc, ctx)
        EIndex(b, idx, _el):
            collect_expr(&acc, b, names, types, dc, ctx)
            collect_expr(&acc, idx, names, types, dc, ctx)
        ESlice(b, lo, hi, _el):
            collect_expr(&acc, b, names, types, dc, ctx)
            collect_expr(&acc, lo, names, types, dc, ctx)
            collect_expr(&acc, hi, names, types, dc, ctx)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            note_arr_types(&acc, mk_functype(pts, ret))   # dedups + collects param/ret families
        ECallV(callee, cargs, _el):
            collect_expr(&acc, callee, names, types, dc, ctx)
            j := 0
            for j < len(cargs):
                collect_expr(&acc, cargs[j], names, types, dc, ctx)
                j = j + 1
        EAddr(inner, _el):
            collect_expr(&acc, inner, names, types, dc, ctx)
        EInt(t, _el):
            j := 0
        EBool(t, _el):
            j := 0
        EChar(t, _el):
            j := 0
        EFloat(f, _el):
            j := 0
        EStr(s, _el):
            j := 0
        EVar(n, _el):
            if not has_str(names, n):              # a bare top-level fn name used as a value: collect its fn type
                note_arr_types(&acc, type_of(e, names, types, dc, ctx))
        ESpawn(sid, snm, sa, _el):
            j := 0
            for j < len(sa):
                collect_expr(&acc, sa[j], names, types, dc, ctx)
                j = j + 1

fn collect_block(acc: inout [string], stmts: [Stmt], names: [string], types: [string], dc: Decls, ctx: Ctx):
    ns := names
    ts := types
    i := 0
    for i < len(stmts):
        collect_stmt(&acc, stmts[i], &ns, &ts, dc, ctx)
        i = i + 1

fn collect_stmt(acc: inout [string], s: Stmt, names: inout [string], types: inout [string], dc: Decls, ctx: Ctx):
    match s:
        SDecl(n, e, _sl):
            # reject a bare untyped `x := Ok(v)` / `x := Err(v)`: the constructor fixes only
            # ONE of Result's two type params, and (unlike None, which a later use can ground)
            # the other is never inferred -- tychoc requires the annotation. Without this,
            # type_of returns a partial `Result(T,)` that a later `match` then mis-handles.
            # collect_elem_types walks EVERY function body unconditionally, so it catches the
            # simple/generic-free/lambda-free case that lift and mono both skip. STypedDecl,
            # `return Ok(..)`, and `Ok(..)` as an argument are a different node / supply E.
            okerr := call_callee(e)
            if okerr == "Ok" or okerr == "Err":
                die("type: cannot infer the Result type of " + okerr + "(...) -- annotate it (x : Result(T, E) = " + okerr + "(...))")
            collect_expr(&acc, e, names, types, dc, ctx)
            ty := type_of(e, names, types, dc, ctx)
            push(names, n)
            push(types, ty)
        SAssign(n, e, _sl):
            collect_expr(&acc, e, names, types, dc, ctx)
            if has_str(names, n):                       # newtype identity: RHS must match the variable's type
                nt_check(dc, ctx, var_type(names, types, n), e, names, types, "assignment to '" + n + "'", _sl)
        SFieldAssign(lv, rhs, _sl):
            collect_expr(&acc, lv, names, types, dc, ctx)
            collect_expr(&acc, rhs, names, types, dc, ctx)
            check_place_assign(dc, ctx, lv, rhs, names, types, _sl)   # newtype identity of the stored value + a map key
        SPrint(e, _sl):
            collect_expr(&acc, e, names, types, dc, ctx)
        SReturn(e, _sl):
            collect_expr(&acc, e, names, types, dc, ctx)
            nt_check(dc, ctx, ctx.rettype, e, names, types, "return value", _sl)   # newtype identity vs the declared return type
        SConst(n, e, _sl):
            j := 0
        SReturnVoid:
            j := 0
        SBreak:
            j := 0
        SContinue:
            j := 0
        SExpr(e, _sl):
            collect_expr(&acc, e, names, types, dc, ctx)
        STypedDecl(n, t, e, _sl):
            note_arr_types(&acc, t)
            collect_expr(&acc, e, names, types, dc, ctx)
            nt_check(dc, ctx, t, e, names, types, "'" + n + "'", _sl)   # newtype identity: RHS must match the annotation
            push(names, n)
            push(types, t)
        SOrReturn(n, e, _sl):
            collect_expr(&acc, e, names, types, dc, ctx)
            ety := type_of(e, names, types, dc, ctx)
            ty := ""
            if is_option(ety):                    # Option or_return binds the inner type
                ty = option_inner(ety)
            else:
                ty = result_ok(ety)               # (result_ok on a non-Result substrs out of range)
            push(names, n)
            push(types, ty)
        SDestructure(dnames, e, _sl):
            collect_expr(&acc, e, names, types, dc, ctx)
            parts := tuple_parts(type_of(e, names, types, dc, ctx))
            j := 0
            for j < len(dnames):
                push(names, dnames[j])
                push(types, parts[j])
                j = j + 1
        SMultiAssign(mnames, e, _sl):                  # vars already exist; just collect the RHS
            collect_expr(&acc, e, names, types, dc, ctx)
        SIf(c, tb, eb, _sl):
            collect_expr(&acc, c, names, types, dc, ctx)
            collect_block(&acc, tb, names, types, dc, ctx)
            collect_block(&acc, eb, names, types, dc, ctx)
        SWhile(c, body, _sl):
            collect_expr(&acc, c, names, types, dc, ctx)
            collect_block(&acc, body, names, types, dc, ctx)
        SForRange(n, a, b, st, body, _sl):
            collect_expr(&acc, a, names, types, dc, ctx)
            collect_expr(&acc, b, names, types, dc, ctx)
            collect_expr(&acc, st, names, types, dc, ctx)
            bn := names
            bt := types
            push(bn, n)
            push(bt, "int")
            collect_block(&acc, body, bn, bt, dc, ctx)
        SMatch(subj, variants, allbinds, bodies, _sl):
            collect_expr(&acc, subj, names, types, dc, ctx)
            sty := type_of(subj, names, types, dc, ctx)
            check_match(dc, ctx, resolve_ginst(sty, dc, ctx), variants, _sl)   # reject non-exhaustive / bad-arm-name matches at compile time (parity with tychoc)
            j := 0
            for j < len(bodies):
                bn := names                       # bind arm payloads so type_of resolves them
                bt := types                       # in the arm body (mirrors gen_stmt's match)
                binds := allbinds[j]
                if is_option(sty):
                    if len(binds) > 0:
                        push(bn, binds[0])
                        push(bt, option_inner(sty))
                elif is_result(sty):
                    if len(binds) > 0:
                        push(bn, binds[0])
                        if variants[j] == "Ok":
                            push(bt, result_ok(sty))
                        else:
                            push(bt, result_err(sty))
                else:
                    if len(binds) > 0:            # `_` / no-payload arms have no bindings; skip the lookup (which rejects `_`)
                        pts := variant_ptypes(dc, ctx, variants[j])
                        k := 0
                        for k < len(binds):
                            push(bn, binds[k])
                            push(bt, pts[k])
                            k = k + 1
                collect_block(&acc, bodies[j], bn, bt, dc, ctx)
                j = j + 1
        SParFor(v, a, b, body, pid, _sl):              # the chunk proc (and its partial type) is a lifted Func,
            collect_expr(&acc, a, names, types, dc, ctx)   # walked separately; only the site's bounds remain here
            collect_expr(&acc, b, names, types, dc, ctx)
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            sk := 0
            for sk < len(svars):
                collect_expr(&acc, schans[sk], names, types, dc, ctx)
                bn := names
                bt := types
                if svars[sk] == "recv":
                    push(bn, sbinds[sk])
                    push(bt, chan_inner(type_of(schans[sk], names, types, dc, ctx)))
                collect_block(&acc, sbodies[sk], bn, bt, dc, ctx)
                sk = sk + 1
        SValDecl(n, annot, cc, _sl):              # walk the ctrl (array-type noting, check_match exhaustiveness) with n NOT yet in scope, then register it
            collect_stmt(&acc, cc, &names, &types, dc, ctx)
            dty := annot
            if annot == "":
                dty = value_ctrl_type(cc, names, types, dc, ctx, _sl)
            push(names, n)
            push(types, dty)

# Element types needing an Arr_T family: int/str (cover every literal seen in
# practice) plus every array element type that appears in an annotation.
fn collect_elem_types(prog: Program, dc: Decls, ctx: Ctx) -> [string]:
    acc := []string
    push(acc, "int")
    push(acc, "str")
    push(acc, "float")
    i := 0                                       # seed every struct/enum name so a
    for i < len(prog.structs):                   # literal-only [Struct]/[Enum] (no annotation
        push(acc, prog.structs[i].name)          # to scan) still gets its Arr_T family
        i = i + 1
    i = 0
    for i < len(prog.enums):
        push(acc, prog.enums[i].name)
        i = i + 1
    i = 0
    for i < len(prog.funcs):
        f := prog.funcs[i]
        j := 0
        for j < len(f.ptypes):
            note_arr_types(&acc, f.ptypes[j])
            j = j + 1
        note_arr_types(&acc, f.ret)
        en := []string                           # seed the body walk with the params
        et := []string
        k := 0
        for k < len(f.params):
            push(en, f.params[k])
            push(et, f.ptypes[k])
            k = k + 1
        cf := Ctx(ctx.vparams, ctx.saccums, f.ret, ctx.owner, ctx.depth, ctx.bbases, ctx.movables, ctx.loopdepth, ctx.fusearr, ctx.fusesuf, ctx.fusety, ctx.line, ctx.curpkg)   # set rettype so SReturn's newtype check sees the declared return type
        collect_block(&acc, f.body, en, et, dc, cf)   # composite types from literals
        i = i + 1
    i = 0
    for i < len(prog.structs):
        j := 0
        for j < len(prog.structs[i].fields):
            note_arr_types(&acc, prog.structs[i].fields[j].ty)
            j = j + 1
        i = i + 1
    i = 0
    for i < len(prog.enums):
        j := 0
        for j < len(prog.enums[i].variants):
            k := 0
            for k < len(prog.enums[i].variants[j].ptypes):
                note_arr_types(&acc, prog.enums[i].variants[j].ptypes[k])
                k = k + 1
            j = j + 1
        i = i + 1
    return acc

# ---- standalone package driver -------------------------------------------
# With the filesystem builtins (read_file/list_dir/args) tychoc0 can compile a
# package program directly from disk — `tychoc0 path/to/main.ty` — instead of
# being fed `tychoc --bundle ... | tychoc0`. bundle() reproduces that bundler in
# Tycho: it walks the import graph (dependencies first, deduped/cycle-safe via
# `seen`), concatenates each package's .ty files (sorted for determinism), and
# rewrites the ENTRY package's header to `package main` so it keeps the empty
# mangling prefix. No argument => read stdin (the bootstrap path, unchanged).

fn has_suffix(s: string, suf: string) -> bool:
    ls := len(s)
    lf := len(suf)
    if ls < lf:
        return false
    return substr(s, ls - lf, ls) == suf

fn str_lt(a: string, b: string) -> bool:           # byte-wise less-than (no string < in Tycho)
    i := 0
    la := len(a)
    lb := len(b)
    for i < la and i < lb:
        if a[i] < b[i]:
            return true
        if a[i] > b[i]:
            return false
        i = i + 1
    return la < lb

fn insert_sorted(sorted: [string], v: string) -> [string]:   # no array index-set: rebuild
    out := []string
    placed := false
    i := 0
    for i < len(sorted):
        if not placed and str_lt(v, sorted[i]):
            push(out, v)
            placed = true
        push(out, sorted[i])
        i = i + 1
    if not placed:
        push(out, v)
    return out

fn sort_strs(xs: [string]) -> [string]:            # insertion sort (file lists are small)
    out := []string
    i := 0
    for i < len(xs):
        out = insert_sorted(out, xs[i])
        i = i + 1
    return out

fn dir_of(path: string) -> string:                 # "a/b/main.ty" -> "a/b" ; no slash -> "."
    i := len(path) - 1
    for i >= 0:
        if path[i] == 47:
            return substr(path, 0, i)
        i = i - 1
    return "."

fn rewrite_header(content: string) -> string:      # the leading `package X` line -> `package main`
    start := -1
    if has_prefix(content, "package "):
        start = 0
    else:
        idx := find(content, "\npackage ")
        if idx >= 0:
            start = idx + 1
    if start < 0:
        return content
    e := start
    for e < len(content) and content[e] != 10:
        e = e + 1
    return substr(content, 0, start) + "package main" + substr(content, e, len(content))

fn scan_imports(toks: [Token]) -> [string]:        # the file header's import paths (no full parse)
    out := []string
    i := 0
    for toks[i].kind == TNewline:
        i = i + 1
    if toks[i].kind == TIdent and toks[i].text == "package":
        i = i + 1
        if toks[i].kind == TIdent:
            i = i + 1
    running := true
    for running:
        for toks[i].kind == TNewline:
            i = i + 1
        if toks[i].kind == TIdent and toks[i].text == "import":
            i = i + 1
            if toks[i].kind == TIdent:
                i = i + 1
            if toks[i].kind == TStr:
                push(out, toks[i].text)
                i = i + 1
        else:
            running = false
    return out

fn is_package(toks: [Token]) -> bool:              # does the source open with a `package` decl?
    i := 0
    for toks[i].kind == TNewline:
        i = i + 1
    return toks[i].kind == TIdent and toks[i].text == "package"

# Index of the last '/' in s, or -1 if none. (tycho's find() returns the first.)
fn last_slash(s: string) -> int:
    last := 0 - 1
    i := 0
    for i < len(s):
        if substr(s, i, i + 1) == "/":
            last = i
        i = i + 1
    return last

# Directory containing the running tychoc0 binary, from argv[0]. "." when the
# invocation has no directory component.
fn exe_dir() -> string:
    a := args()
    p := ""
    if len(a) > 0:
        p = a[0]
    s := last_slash(p)
    if s < 0:
        return "."
    if s == 0:
        return "/"
    return substr(p, 0, s)

# The corelib search root. TYCHO_CORELIB overrides; otherwise look next to the
# tychoc0 binary (so `./tychoc0 prog.ty` finds `./corelib` with no setup), then in
# an installed share/tycho/corelib layout. Empty if none is found.
fn corelib_root() -> string:
    env := getenv("TYCHO_CORELIB")
    if env != "":
        return env
    ed := exe_dir()
    c1 := ed + "/corelib"
    if len(list_dir(c1)) > 0:
        return c1
    c2 := ed + "/../share/tycho/corelib"
    if len(list_dir(c2)) > 0:
        return c2
    return ""

# Resolve an import path to a package directory. `core:<name>` is a corelib
# import -> <corelib>/<name> (a library importable from any program); anything
# else is relative to the importing package's dir. Mirrors tychoc's resolve_pkg_dir.
fn resolve_import_dir(dir: string, imp: string) -> string:
    if has_prefix(imp, "core:"):
        root := corelib_root()
        if root == "":
            die("tychoc0: cannot find the corelib for import \"" + imp + "\" (looked next to the binary at " + exe_dir() + "/corelib); set TYCHO_CORELIB to override")
        return root + "/" + substr(imp, 5, len(imp))
    return dir + "/" + imp

fn bundle(dir: string, is_entry: bool, seen: inout [string]) -> string:
    k := 0
    for k < len(seen):
        if seen[k] == dir:
            return ""                              # already merged (shared dep / cycle)
        k = k + 1
    push(seen, dir)
    all := list_dir(dir)
    files := []string
    fi := 0
    for fi < len(all):
        if has_suffix(all[fi], ".ty"):
            push(files, all[fi])
        fi = fi + 1
    files = sort_strs(files)
    out := ""
    fj := 0                                         # dependencies first (post-order)
    for fj < len(files):
        imps := scan_imports(lex(read_file(dir + "/" + files[fj])))
        ij := 0
        for ij < len(imps):
            out = out + bundle(resolve_import_dir(dir, imps[ij]), false, &seen)
            ij = ij + 1
        fj = fj + 1
    fk := 0                                         # then this package's files
    for fk < len(files):
        c := read_file(dir + "/" + files[fk])
        if is_entry:
            c = rewrite_header(c)
        out = out + c + "\n"
        fk = fk + 1
    return out

# --- lambda lift pass -------------------------------------------------------
# Lambdas are parsed as ELambda nodes. Before typing/codegen, this scope-aware
# pass walks every function body, assigns each lambda a unique id, runs capture
# analysis (a free var that is an enclosing local is captured BY VALUE), and
# emits a top-level `__lam<id>` Func whose params are [captures...][lambda
# params...] (so its body codegen stays ordinary). The ELambda node is stamped
# with its id + capture names/types so gen_expr can build the closure value
# (env + thunk) at the use site. A LamInfo per lambda drives env-struct + thunk
# emission. tychoc0 has NO mutable globals, so the lifted funcs, the capture
# counter, and the LamInfo list are all threaded by inout.
fn mk_functype(ptypes: [string], ret: string) -> string:   # fn(...) type string, byte-identical to sig_functype's format
    out := "fn("
    i := 0
    for i < len(ptypes):
        if i > 0:
            out = out + ","
        out = out + ptypes[i]
        i = i + 1
    return out + "->" + ret + ")"

# Gather every EVar name appearing in `e` (descending into nested lambda bodies,
# so an outer lambda transitively sees a var its inner lambda needs from an
# enclosing scope). Used for capture analysis (free-var scan).
fn collect_evars(e: Expr, out: inout [string]):
    match e:
        EVar(n, _el):
            push(out, n)
        EBin(o, l, r, _el):
            collect_evars(l, &out)
            collect_evars(r, &out)
        ECall(n, a, _el):
            push(out, n)                           # callee may be a captured fn-value local (g(x) where g is a closure); the lift filter keeps only enclosing locals
            j := 0
            for j < len(a):
                collect_evars(a[j], &out)
                j = j + 1
        EField(b, f, _el):
            collect_evars(b, &out)
        EIndex(b, ix, _el):
            collect_evars(b, &out)
            collect_evars(ix, &out)
        EArrLit(es, _el):
            j := 0
            for j < len(es):
                collect_evars(es[j], &out)
                j = j + 1
        EMapLit(ks, vs, _el):
            j := 0
            for j < len(ks):
                collect_evars(ks[j], &out)
                collect_evars(vs[j], &out)
                j = j + 1
        ETuple(es, _el):
            j := 0
            for j < len(es):
                collect_evars(es[j], &out)
                j = j + 1
        ESlice(b, lo, hi, _el):
            collect_evars(b, &out)
            collect_evars(lo, &out)
            collect_evars(hi, &out)
        ECallV(callee, cargs, _el):
            collect_evars(callee, &out)
            j := 0
            for j < len(cargs):
                collect_evars(cargs[j], &out)
                j = j + 1
        EAddr(x, _el):
            collect_evars(x, &out)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            collect_evars(body, &out)
        EInt(t, _el):
            return
        EBool(t, _el):
            return
        EChar(t, _el):
            return
        EFloat(t, _el):
            return
        EStr(s, _el):
            return
        EArrEmpty(t, _el):
            return
        EMapEmpty(k, v, _el):
            return
        ESpawn(sid, snm, sa, _el):
            j := 0
            for j < len(sa):
                collect_evars(sa[j], &out)
                j = j + 1

# Free-var scan over a parallel-for BODY (CC-3 capture analysis): every EVar
# occurrence, via the lambda free-var scan; body-local shadowing only yields a
# harmless extra chunk-proc param. (Reject-grade analysis -- acc-read audits,
# outer-write rejection -- stays in the C compiler, which gates user programs.)
fn pf_body_evars(stmts: [Stmt], out: inout [string]):
    i := 0
    for i < len(stmts):
        match stmts[i]:
            SDecl(n, e, _sl):
                collect_evars(e, &out)
            SAssign(n, e, _sl):
                collect_evars(e, &out)
            SFieldAssign(lv, r, _sl):
                collect_evars(lv, &out)
                collect_evars(r, &out)
            SPrint(e, _sl):
                collect_evars(e, &out)
            SReturn(e, _sl):
                collect_evars(e, &out)
            SConst(n, e, _sl):
                i = i
            SReturnVoid:
                i = i
            SBreak:
                i = i
            SContinue:
                i = i
            SIf(c, t, el, _sl):
                collect_evars(c, &out)
                pf_body_evars(t, &out)
                pf_body_evars(el, &out)
            SWhile(c, b, _sl):
                collect_evars(c, &out)
                pf_body_evars(b, &out)
            SForRange(v, a, b, st, body, _sl):
                collect_evars(a, &out)
                collect_evars(b, &out)
                collect_evars(st, &out)
                pf_body_evars(body, &out)
            SExpr(e, _sl):
                collect_evars(e, &out)
            STypedDecl(n, ty, e, _sl):
                collect_evars(e, &out)
            SOrReturn(n, e, _sl):
                collect_evars(e, &out)
            SDestructure(ns, e, _sl):
                collect_evars(e, &out)
            SMultiAssign(ns, e, _sl):
                collect_evars(e, &out)
            SMatch(subj, vars, binds, bodies, _sl):
                collect_evars(subj, &out)
                k := 0
                for k < len(bodies):
                    pf_body_evars(bodies[k], &out)
                    k = k + 1
            SParFor(v, a, b, body, pid, _sl):
                collect_evars(a, &out)
                collect_evars(b, &out)
                pf_body_evars(body, &out)
            SSelect(uid, svars, schans, sbinds, sbodies, _sl):
                # A channel select inside a parallel-for chunk: each recv arm's
                # channel expr is a free var of the body (so it becomes a shared
                # by-value capture -- a Channel is a scalar handle, never deep-
                # copied), and each arm body is scanned like a match arm. pf_accs
                # already descends select arms, so reductions inside an arm fold
                # at the join just like anywhere else. (matches tychoc.)
                sk := 0
                for sk < len(svars):
                    if svars[sk] == "recv":
                        collect_evars(schans[sk], &out)
                    pf_body_evars(sbodies[sk], &out)
                    sk = sk + 1
            SValDecl(n, annot, cc, _sl):          # value if/match decl: its tails free-reference captured vars
                pf_body_evars([cc], &out)
        i = i + 1

# Reduction accumulators of a parallel-for body: assignments `n = n OP rest`
# (OP in +,*) to a variable bound in the ENCLOSING env. These become identity-
# initialized locals of the chunk proc, folded at the in-order join.
fn pf_accs(stmts: [Stmt], outer: [string], accn: inout [string], accop: inout [string]):
    i := 0
    for i < len(stmts):
        match stmts[i]:
            SAssign(n, e, _sl):
                if has_str(outer, n) and not has_str(accn, n):
                    match e:
                        EBin(op, l, r, _el):
                            if (op == "+" or op == "*") and is_evar(l, n):
                                push(accn, n)
                                push(accop, op)
                        EInt(t, _el):
                            i = i
                        EBool(t, _el):
                            i = i
                        EChar(t, _el):
                            i = i
                        EFloat(f, _el):
                            i = i
                        EStr(s, _el):
                            i = i
                        EVar(vn, _el):
                            i = i
                        ECall(cn, ca, _el):
                            i = i
                        EField(b, f, _el):
                            i = i
                        EIndex(b, ix, _el):
                            i = i
                        EArrLit(es, _el):
                            i = i
                        EArrEmpty(t, _el):
                            i = i
                        EMapEmpty(k, v, _el):
                            i = i
                        EMapLit(ks, vs, _el):
                            i = i
                        ETuple(es, _el):
                            i = i
                        ESlice(b, lo, hi, _el):
                            i = i
                        EAddr(x, _el):
                            i = i
                        ELambda(lid, ps, pts, ret, bx, cn2, ct2, _el):
                            i = i
                        ECallV(c, a, _el):
                            i = i
                        ESpawn(sid, snm, sa, _el):
                            i = i
            SDecl(n, e, _sl):
                i = i
            SFieldAssign(lv, r, _sl):
                i = i
            SPrint(e, _sl):
                i = i
            SReturn(e, _sl):
                i = i
            SConst(n, e, _sl):
                i = i
            SReturnVoid:
                i = i
            SBreak:
                i = i
            SContinue:
                i = i
            SIf(c, t, el, _sl):
                pf_accs(t, outer, &accn, &accop)
                pf_accs(el, outer, &accn, &accop)
            SWhile(c, b, _sl):
                pf_accs(b, outer, &accn, &accop)
            SForRange(v, a, b, st, body, _sl):
                pf_accs(body, outer, &accn, &accop)
            SExpr(e, _sl):
                i = i
            STypedDecl(n, ty, e, _sl):
                i = i
            SOrReturn(n, e, _sl):
                i = i
            SDestructure(ns, e, _sl):
                i = i
            SMultiAssign(ns, e, _sl):
                i = i
            SMatch(subj, vars, binds, bodies, _sl):
                k := 0
                for k < len(bodies):
                    pf_accs(bodies[k], outer, &accn, &accop)
                    k = k + 1
            SParFor(v, a, b, body, pid, _sl):
                pf_accs(body, outer, &accn, &accop)
            SSelect(uid, svars, schans, sbinds, sbodies, _sl):
                sk := 0
                for sk < len(svars):
                    pf_accs(sbodies[sk], outer, &accn, &accop)
                    sk = sk + 1
            SValDecl(n, annot, cc, _sl):          # a fresh local; its only assignment target is n, never an outer reduction var
                i = i
        i = i + 1

# --- parallel-for body GATES (parity with tychoc's pf_scan_stmt + the
# resolve_parfor read-count post-check) -----------------------------------------
# A chunk proc is spawned N ways, so its body may NOT early-exit (return / break
# applying to the parfor / or_return), may NOT mutate or inout-pass a CAPTURED
# (outer) variable, and may update a captured scalar ONLY as a consistent +/*
# reduction whose accumulator is read nowhere else. `locals` = names bound INSIDE
# the chunk (loop var, decls, match/select/for binds); a name in the outer env
# (`names`) but not in `locals` is a capture. tychoc0 resolve errors are message-
# only -- the wording need not match tychoc, only the accept/reject verdict (the
# fuzz/run_parforparity.py lane locks that parity).

fn find_str(xs: [string], s: string) -> int:
    i := 0
    for i < len(xs):
        if xs[i] == s:
            return i
        i = i + 1
    return 0 - 1

# base identifier of a place (v / v[i] / v.f / v[i].f); "" if not a plain place
fn place_root(e: Expr) -> string:
    match e:
        EVar(n, _el):
            return n
        EField(b, f, _el):
            return place_root(b)
        EIndex(b, ix, _el):
            return place_root(b)
        EInt(t, _el):
            return ""
        EBool(t, _el):
            return ""
        EChar(t, _el):
            return ""
        EFloat(t, _el):
            return ""
        EStr(t, _el):
            return ""
        EBin(o, l, r, _el):
            return ""
        ECall(cn, a, _el):
            return ""
        EArrLit(es, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        EMapLit(ks, vs, _el):
            return ""
        ETuple(es, _el):
            return ""
        ESlice(b, lo, hi, _el):
            return ""
        EAddr(x, _el):
            return ""
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return ""
        ECallV(callee, cargs, _el):
            return ""
        ESpawn(sid, snm, sa, _el):
            return ""

fn count_reads_expr(e: Expr, nm: string) -> int:
    match e:
        EVar(n, _el):
            if n == nm:
                return 1
            return 0
        EBin(o, l, r, _el):
            return count_reads_expr(l, nm) + count_reads_expr(r, nm)
        ECall(cn, a, _el):
            c := 0
            j := 0
            for j < len(a):
                c = c + count_reads_expr(a[j], nm)
                j = j + 1
            return c
        EField(b, f, _el):
            return count_reads_expr(b, nm)
        EIndex(b, ix, _el):
            return count_reads_expr(b, nm) + count_reads_expr(ix, nm)
        EArrLit(es, _el):
            c := 0
            j := 0
            for j < len(es):
                c = c + count_reads_expr(es[j], nm)
                j = j + 1
            return c
        EMapLit(ks, vs, _el):
            c := 0
            j := 0
            for j < len(ks):
                c = c + count_reads_expr(ks[j], nm) + count_reads_expr(vs[j], nm)
                j = j + 1
            return c
        ETuple(es, _el):
            c := 0
            j := 0
            for j < len(es):
                c = c + count_reads_expr(es[j], nm)
                j = j + 1
            return c
        ESlice(b, lo, hi, _el):
            return count_reads_expr(b, nm) + count_reads_expr(lo, nm) + count_reads_expr(hi, nm)
        EAddr(x, _el):
            return count_reads_expr(x, nm)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return count_reads_expr(body, nm)
        ECallV(callee, cargs, _el):
            c := count_reads_expr(callee, nm)
            j := 0
            for j < len(cargs):
                c = c + count_reads_expr(cargs[j], nm)
                j = j + 1
            return c
        ESpawn(sid, snm, sa, _el):
            c := 0
            j := 0
            for j < len(sa):
                c = c + count_reads_expr(sa[j], nm)
                j = j + 1
            return c
        EInt(t, _el):
            return 0
        EBool(t, _el):
            return 0
        EChar(t, _el):
            return 0
        EFloat(t, _el):
            return 0
        EStr(t, _el):
            return 0
        EArrEmpty(t, _el):
            return 0
        EMapEmpty(k, v, _el):
            return 0

fn count_reads_body(stmts: [Stmt], nm: string) -> int:
    c := 0
    i := 0
    for i < len(stmts):
        match stmts[i]:
            SDecl(n, e, _sl):
                c = c + count_reads_expr(e, nm)
            SAssign(n, e, _sl):
                c = c + count_reads_expr(e, nm)
            SFieldAssign(lv, r, _sl):
                c = c + count_reads_expr(lv, nm) + count_reads_expr(r, nm)
            SPrint(e, _sl):
                c = c + count_reads_expr(e, nm)
            SReturn(e, _sl):
                c = c + count_reads_expr(e, nm)
            SConst(n, e, _sl):
                c = c
            SReturnVoid:
                c = c
            SIf(cnd, t, el, _sl):
                c = c + count_reads_expr(cnd, nm) + count_reads_body(t, nm) + count_reads_body(el, nm)
            SWhile(cnd, b, _sl):
                c = c + count_reads_expr(cnd, nm) + count_reads_body(b, nm)
            SForRange(v, a, b, st, body, _sl):
                c = c + count_reads_expr(a, nm) + count_reads_expr(b, nm) + count_reads_expr(st, nm) + count_reads_body(body, nm)
            SExpr(e, _sl):
                c = c + count_reads_expr(e, nm)
            STypedDecl(n, ty, e, _sl):
                c = c + count_reads_expr(e, nm)
            SOrReturn(n, e, _sl):
                c = c + count_reads_expr(e, nm)
            SDestructure(ns, e, _sl):
                c = c + count_reads_expr(e, nm)
            SMultiAssign(ns, e, _sl):
                c = c + count_reads_expr(e, nm)
            SMatch(subj, vars, binds, bodies, _sl):
                c = c + count_reads_expr(subj, nm)
                k := 0
                for k < len(bodies):
                    c = c + count_reads_body(bodies[k], nm)
                    k = k + 1
            SBreak:
                c = c
            SContinue:
                c = c
            SSelect(uid, svars, schans, sbinds, sbodies, _sl):
                k := 0
                for k < len(svars):
                    if svars[k] == "recv":
                        c = c + count_reads_expr(schans[k], nm)
                    c = c + count_reads_body(sbodies[k], nm)
                    k = k + 1
            SParFor(v, a, b, body, pid, _sl):
                c = c + count_reads_expr(a, nm) + count_reads_expr(b, nm) + count_reads_body(body, nm)
            SValDecl(n, annot, cc, _sl):          # value if/match decl: tails read variables (recycle/move correctness)
                c = c + count_reads_body([cc], nm)
        i = i + 1
    return c

# "+"/"*" if e is `n + rest` / `n * rest` with rest not reading n; "" otherwise.
fn reduction_op(e: Expr, n: string) -> string:
    match e:
        EBin(o, l, r, _el):
            if (o == "+" or o == "*") and is_evar(l, n) and count_reads_expr(r, n) == 0:
                return o
            return ""
        EVar(vn, _el):
            return ""
        EInt(t, _el):
            return ""
        EBool(t, _el):
            return ""
        EChar(t, _el):
            return ""
        EFloat(t, _el):
            return ""
        EStr(t, _el):
            return ""
        ECall(cn, a, _el):
            return ""
        EField(b, f, _el):
            return ""
        EIndex(b, ix, _el):
            return ""
        EArrLit(es, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        EMapLit(ks, vs, _el):
            return ""
        ETuple(es, _el):
            return ""
        ESlice(b, lo, hi, _el):
            return ""
        EAddr(x, _el):
            return ""
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return ""
        ECallV(callee, cargs, _el):
            return ""
        ESpawn(sid, snm, sa, _el):
            return ""

# reject a captured `&v` (inout-pass) or push/pop(capturedAggregate, ...) anywhere
# in an expression; recurse into every sub-expression.
fn pf_gate_expr(e: Expr, locals: [string], names: [string]):
    match e:
        EAddr(x, _el):
            r := place_root(x)
            if r != "" and has_str(names, r) and not has_str(locals, r):
                die("parallel for cannot pass a captured variable as inout")
            pf_gate_expr(x, locals, names)
        ECall(cn, a, _el):
            if (cn == "push" or cn == "pop") and len(a) >= 1:
                r := place_root(a[0])
                if r != "" and has_str(names, r) and not has_str(locals, r):
                    die("parallel for cannot mutate captured variable in place")
            j := 0
            for j < len(a):
                pf_gate_expr(a[j], locals, names)
                j = j + 1
        EBin(o, l, r, _el):
            pf_gate_expr(l, locals, names)
            pf_gate_expr(r, locals, names)
        EField(b, f, _el):
            pf_gate_expr(b, locals, names)
        EIndex(b, ix, _el):
            pf_gate_expr(b, locals, names)
            pf_gate_expr(ix, locals, names)
        EArrLit(es, _el):
            j := 0
            for j < len(es):
                pf_gate_expr(es[j], locals, names)
                j = j + 1
        EMapLit(ks, vs, _el):
            j := 0
            for j < len(ks):
                pf_gate_expr(ks[j], locals, names)
                pf_gate_expr(vs[j], locals, names)
                j = j + 1
        ETuple(es, _el):
            j := 0
            for j < len(es):
                pf_gate_expr(es[j], locals, names)
                j = j + 1
        ESlice(b, lo, hi, _el):
            pf_gate_expr(b, locals, names)
            pf_gate_expr(lo, locals, names)
            pf_gate_expr(hi, locals, names)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            ll := locals
            j := 0
            for j < len(ps):
                push(ll, ps[j])
                j = j + 1
            pf_gate_expr(body, ll, names)
        ECallV(callee, cargs, _el):
            pf_gate_expr(callee, locals, names)
            j := 0
            for j < len(cargs):
                pf_gate_expr(cargs[j], locals, names)
                j = j + 1
        ESpawn(sid, snm, sa, _el):
            j := 0
            for j < len(sa):
                pf_gate_expr(sa[j], locals, names)
                j = j + 1
        EVar(n, _el):
            return
        EInt(t, _el):
            return
        EBool(t, _el):
            return
        EChar(t, _el):
            return
        EFloat(t, _el):
            return
        EStr(t, _el):
            return
        EArrEmpty(t, _el):
            return
        EMapEmpty(k, v, _el):
            return

fn pf_gate_body(stmts: [Stmt], locals0: [string], names: [string], accn: inout [string], accop: inout [string], accnt: inout [int], loopdepth: int):
    locals := locals0     # block-scoped local copy; caller's set is unaffected
    i := 0
    for i < len(stmts):
        match stmts[i]:
            SReturn(e, _sl):
                die("return cannot cross a parallel for")
            SConst(n, e, _sl):
                push(locals, n)
            SReturnVoid:
                die("return cannot cross a parallel for")
            SBreak:
                if loopdepth == 0:
                    die("break cannot apply to a parallel for (chunks cannot stop each other)")
            SContinue:
                i = i
            SOrReturn(n, e, _sl):
                die("or_return cannot cross a parallel for (no early exit from a chunk)")
            SDecl(n, e, _sl):
                pf_gate_expr(e, locals, names)
                push(locals, n)
            STypedDecl(n, ty, e, _sl):
                pf_gate_expr(e, locals, names)
                push(locals, n)
            SDestructure(ns, e, _sl):
                pf_gate_expr(e, locals, names)
                k := 0
                for k < len(ns):
                    push(locals, ns[k])
                    k = k + 1
            SAssign(n, e, _sl):
                if has_str(locals, n):
                    pf_gate_expr(e, locals, names)
                else:
                    rop := reduction_op(e, n)
                    if rop == "":
                        die("parallel for may update an outer variable only as a reduction (n = n + e or n = n * e)")
                    ai := find_str(accn, n)
                    if ai >= 0:
                        if accop[ai] != rop:
                            die("parallel for accumulator must use one reduction op consistently")
                        accnt[ai] = accnt[ai] + 1
                    else:
                        push(accn, n)
                        push(accop, rop)
                        push(accnt, 1)
                    pf_gate_expr(e, locals, names)
            SMultiAssign(ns, e, _sl):
                k := 0
                for k < len(ns):
                    if not has_str(locals, ns[k]):
                        die("parallel for cannot assign to captured variable")
                    k = k + 1
                pf_gate_expr(e, locals, names)
            SFieldAssign(lv, r, _sl):
                root := place_root(lv)
                if root != "" and has_str(names, root) and not has_str(locals, root):
                    die("parallel for cannot mutate captured variable in place")
                pf_gate_expr(lv, locals, names)
                pf_gate_expr(r, locals, names)
            SPrint(e, _sl):
                pf_gate_expr(e, locals, names)
            SExpr(e, _sl):
                pf_gate_expr(e, locals, names)
            SIf(cnd, t, el, _sl):
                pf_gate_expr(cnd, locals, names)
                pf_gate_body(t, locals, names, &accn, &accop, &accnt, loopdepth)
                pf_gate_body(el, locals, names, &accn, &accop, &accnt, loopdepth)
            SWhile(cnd, b, _sl):
                pf_gate_expr(cnd, locals, names)
                pf_gate_body(b, locals, names, &accn, &accop, &accnt, loopdepth + 1)
            SForRange(v, a, b, st, body, _sl):
                pf_gate_expr(a, locals, names)
                pf_gate_expr(b, locals, names)
                pf_gate_expr(st, locals, names)
                fl := locals
                push(fl, v)
                pf_gate_body(body, fl, names, &accn, &accop, &accnt, loopdepth + 1)
            SMatch(subj, vars, binds, bodies, _sl):
                pf_gate_expr(subj, locals, names)
                k := 0
                for k < len(bodies):
                    ml := locals
                    bj := 0
                    for bj < len(binds[k]):
                        push(ml, binds[k][bj])
                        bj = bj + 1
                    pf_gate_body(bodies[k], ml, names, &accn, &accop, &accnt, loopdepth)
                    k = k + 1
            SSelect(uid, svars, schans, sbinds, sbodies, _sl):
                k := 0
                for k < len(svars):
                    if svars[k] == "recv":
                        pf_gate_expr(schans[k], locals, names)
                    sl := locals
                    if svars[k] == "recv" and sbinds[k] != "":
                        push(sl, sbinds[k])
                    pf_gate_body(sbodies[k], sl, names, &accn, &accop, &accnt, loopdepth)
                    k = k + 1
            SParFor(v, a, b, body, pid, _sl):
                # nested parallel for: its OWN lift gates its body; here only the
                # bound exprs are evaluated in the enclosing chunk's scope.
                pf_gate_expr(a, locals, names)
                pf_gate_expr(b, locals, names)
            SValDecl(n, annot, cc, _sl):          # value if/match decl: n is loop-local; gate its branch tails
                push(locals, n)
                pf_gate_body([cc], locals, names, &accn, &accop, &accnt, loopdepth)
        i = i + 1

# "fn(a,b->r)" -> fills `parts` with the param types, returns the return type.
# Depth-aware over nested ([{ so a nested fn-type's own , and -> don't split.
fn fnty_split(ft: string, parts: inout [string]) -> string:
    inner := substr(ft, 3, len(ft) - 1)
    d := 0
    st := 0
    i := 0
    for i < len(inner):
        c := inner[i]
        if c == 40 or c == 91 or c == 123:        # ( [ {
            d = d + 1
        if c == 41 or c == 93 or c == 125:        # ) ] }
            d = d - 1
        if d == 0 and c == 44:                    # top-level comma
            push(parts, substr(inner, st, i))
            st = i + 1
        if d == 0 and c == 45 and i + 1 < len(inner) and inner[i + 1] == 62:   # top-level ->
            if i > st:
                push(parts, substr(inner, st, i))
            return substr(inner, i + 2, len(inner))
        i = i + 1
    return "void"

# Pierce-Turner checking mode (bidirectional inference), the pre-lift grounding: a
# known destination type `want` ("" = none) flows into the expressions that
# can consume one -- bare [] empties, int literals in float contexts, lambdas
# with elided param/return types -- BEFORE the lift, so capture analysis and
# codegen only ever see ground types. Mirrors tychoc's resolve_exp head.
fn ground_pre(dc: Decls, ctx: Ctx, want: string, e: Expr) -> Expr:
    if want == "":
        return e
    match e:
        EArrEmpty(t, _el):
            if t != "":
                return e
            if is_map(want):
                return EMapEmpty(map_key(want), map_val(want), _el)
            if is_soa(want):
                return EArrEmpty(want, _el)
            if is_array(want):
                return EArrEmpty(elem_ty(want), _el)
            return e
        EInt(s, _el):
            if want == "float":
                return EFloat(s + ".0", _el)
            return e
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            if not is_func(want):
                return e
            wp := []string
            wr := fnty_split(want, &wp)
            if len(wp) != len(ps):
                return e
            npts := []string
            k := 0
            for k < len(pts):
                if pts[k] == "":
                    push(npts, wp[k])
                else:
                    push(npts, pts[k])
                k = k + 1
            nret := ret
            if ret == "void" and wr != "void":
                nret = wr
            return ELambda(id, ps, npts, nret, body, cn, ct, _el)
        EBool(t, _el):
            return e
        EChar(t, _el):
            return e
        EFloat(t, _el):
            return e
        EStr(t, _el):
            return e
        EVar(n, _el):
            return e
        EBin(o, l, r, _el):
            return e
        ECall(cn2, ca, _el):
            return e
        EField(b, f, _el):
            return e
        EIndex(b, ix, _el):
            return e
        EArrLit(es, _el):
            return e
        EMapEmpty(k2, v2, _el):
            return e
        EMapLit(ks, vs, _el):
            return e
        ETuple(es, _el):
            return e
        ESlice(b, lo, hi, _el):
            return e
        EAddr(x, _el):
            return e
        ECallV(c2, a2, _el):
            return e
        ESpawn(sid, snm, sa, _el):
            return e

# The destination type of argument `i` of a call to `nm`: user-fn params
# (from the pre-lift Sig table), struct fields, enum payloads, and the typed
# builtins (push/map_set/send). "" when nothing supplies one (Some/Ok/Err
# supply nothing, as in tychoc). Shared by ground_args and the B-3 seek.
fn arg_want(dc: Decls, ctx: Ctx, names: [string], types: [string], nm: string, a: [Expr], i: int) -> string:
    if nm == "push" and i == 1:
        return elem_ty(type_of(a[0], names, types, dc, ctx))
    if nm == "map_set" and i == 2:
        return map_val(type_of(a[0], names, types, dc, ctx))
    if nm == "send" and i == 1:
        at := type_of(a[0], names, types, dc, ctx)
        if is_chan(at):
            return chan_inner(at)
        return ""
    if is_builtin_call(nm):
        return ""
    if has_str(names, nm):                        # indirect call through a fn-typed VAR: its param types
        ft := base_ty(var_type(names, types, nm))
        if is_func(ft):
            fp := []string
            fr := fnty_split(ft, &fp)
            if i < len(fp):
                return fp[i]
        return ""
    if is_newtype(dc, ctx, nm):                   # X(v): the underlying type grounds the wrapped literal
        return resolve_nt(dc, ctx, nm)
    si := dc.sigmap.get(nm, 0 - 1)
    if si >= 0 and i < len(dc.sigs[si].ptypes):
        return base_ty(dc.sigs[si].ptypes[i])
    sj := 0
    for sj < len(dc.structs):
        if dc.structs[sj].name == nm and i < len(dc.structs[sj].fields):
            return dc.structs[sj].fields[i].ty
        sj = sj + 1
    ej := 0
    for ej < len(dc.enums):
        vk := 0
        for vk < len(dc.enums[ej].variants):
            if dc.enums[ej].variants[vk].name == nm and i < len(dc.enums[ej].variants[vk].ptypes):
                return dc.enums[ej].variants[vk].ptypes[i]
            vk = vk + 1
        ej = ej + 1
    return ""

# Ground every argument of a call against its destination type (B-0/B-2).
fn ground_args(dc: Decls, ctx: Ctx, names: [string], types: [string], nm: string, a: [Expr]) -> [Expr]:
    out := []Expr
    i := 0
    for i < len(a):
        push(out, ground_pre(dc, ctx, arg_want(dc, ctx, names, types, nm, a, i), a[i]))
        i = i + 1
    return out

fn lift_exprs(es: [Expr], lifted: inout [Func], ctr: inout int, lams: inout [LamInfo], spawns: inout [SpawnInfo], pars: inout [ParInfo], names: inout [string], types: inout [string], dc: Decls, ctx: Ctx) -> [Expr]:
    out := []Expr
    i := 0
    for i < len(es):
        push(out, lift_expr(es[i], &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx))
        i = i + 1
    return out

fn lift_expr(e: Expr, lifted: inout [Func], ctr: inout int, lams: inout [LamInfo], spawns: inout [SpawnInfo], pars: inout [ParInfo], names: inout [string], types: inout [string], dc: Decls, ctx: Ctx) -> Expr:
    _sl := 0
    match e:
        EInt(t, _el):
            return e
        EBool(t, _el):
            return e
        EChar(t, _el):
            return e
        EFloat(t, _el):
            return e
        EStr(s, _el):
            return e
        EVar(n, _el):
            return e
        EArrEmpty(t, _el):
            return e
        EMapEmpty(k, v, _el):
            return e
        EBin(o, l, r, _el):
            return EBin(o, lift_expr(l, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_expr(r, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        ECall(n, a, _el):
            ga := ground_args(dc, ctx, names, types, n, a)   # B: per-arg destination types ground empties/literals/lambdas
            return ECall(n, lift_exprs(ga, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        EField(b, f, _el):
            return EField(lift_expr(b, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), f, _el)
        EIndex(b, ix, _el):
            return EIndex(lift_expr(b, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_expr(ix, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        EArrLit(es, _el):
            ges := []Expr                          # B-0: later elements take the first element's type
            ew := ""
            ek := 0
            for ek < len(es):
                ge := es[ek]
                if ek > 0:
                    if ew == "":
                        ew = type_of(es[0], names, types, dc, ctx)
                    ge = ground_pre(dc, ctx, ew, ge)
                push(ges, ge)
                ek = ek + 1
            return EArrLit(lift_exprs(ges, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        EMapLit(ks, vs, _el):
            return EMapLit(lift_exprs(ks, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_exprs(vs, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        ETuple(es, _el):
            return ETuple(lift_exprs(es, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        ESlice(b, lo, hi, _el):
            return ESlice(lift_expr(b, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_expr(lo, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_expr(hi, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        ECallV(callee, cargs, _el):
            # B: a call-on-expression's params ground its args too. EField
            # callees are method forms (UFCS / ch.send) -- their dispatch
            # resolves later, and type_of on the field would die; skip those.
            gca := cargs
            cvt := "void"
            if efield_fname(callee) == "":
                cvt = type_of(callee, names, types, dc, ctx)
            if is_func(cvt):
                cvp := []string
                cvr := fnty_split(cvt, &cvp)
                gc2 := []Expr
                gk := 0
                for gk < len(cargs):
                    cw := ""
                    if gk < len(cvp):
                        cw = cvp[gk]
                    push(gc2, ground_pre(dc, ctx, cw, cargs[gk]))
                    gk = gk + 1
                gca = gc2
            return ECallV(lift_expr(callee, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_exprs(gca, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        EAddr(x, _el):
            return EAddr(lift_expr(x, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            kp0 := 0                              # B-2: an untyped param needed an expected fn type by now
            for kp0 < len(pts):
                if pts[kp0] == "":
                    die("type: lambda parameter '" + ps[kp0] + "' needs a type here -- no expected fn type supplies it")
                kp0 = kp0 + 1
            # push the lambda's own params so a nested lambda in the body can capture them
            mark := len(names)
            kp := 0
            for kp < len(ps):
                push(names, ps[kp])
                push(types, pts[kp])
                kp = kp + 1
            nb := lift_expr(body, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)   # lift nested lambdas first
            # capture analysis: a free var that is an ENCLOSING local (not an own
            # param, not a top-level fn/enum) is captured by value.
            fvs := []string
            collect_evars(nb, &fvs)
            capnames := []string
            captypes := []string
            fi := 0
            for fi < len(fvs):
                fv := fvs[fi]
                if has_str(ps, fv):
                    fv = fv                          # own param: in scope but not a capture
                elif has_str(capnames, fv):
                    fv = fv                          # already captured
                elif has_str(names, fv):             # an enclosing local -> capture by value (heap: deep-copied at creation)
                    if is_handle(dc, var_type(names, types, fv)):   # FFI R2: capturing a handle would alias it into the env, outliving its destructor
                        die("type: a closure cannot capture a handle -- it is freed at the end of its scope")
                    push(capnames, fv)
                    push(captypes, var_type(names, types, fv))
                # else: a top-level fn / enum / None -> resolves inside the lifted proc, not a capture
                fi = fi + 1
            names = names[0:mark]                     # pop own params
            types = types[0:mark]
            myid := ctr
            ctr = ctr + 1
            # lifted proc params = [captures...][lambda params...]
            lparams := []string
            lptypes := []string
            ci := 0
            for ci < len(capnames):
                push(lparams, capnames[ci])
                push(lptypes, captypes[ci])
                ci = ci + 1
            pj := 0
            for pj < len(ps):
                push(lparams, ps[pj])
                push(lptypes, pts[pj])
                pj = pj + 1
            lbody := []Stmt
            if ret == "void":
                push(lbody, SExpr(nb, _sl))
            else:
                push(lbody, SReturn(nb, _sl))
            push(lifted, Func("__lam" + str(myid), lparams, lptypes, ret, lbody, 0, "", ""))
            push(lams, LamInfo(myid, mk_functype(pts, ret), capnames, captypes, pts, ret))
            return ELambda(myid, ps, pts, ret, nb, capnames, captypes, _el)
        ESpawn(id, nm, sargs, _el):
            # CC-1: assign the spawn-site id and record the SpawnInfo that drives
            # the HSpawnA_<id> args-struct + tycho_spawn_<id> trampoline emission.
            nsa := lift_exprs(sargs, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            si := dc.sigmap.get(nm, -1)
            if si < 0:
                die("type: spawn of unknown function '" + nm + "'")
            if dc.sigs[si].is_extern == 1:
                die("type: cannot spawn an extern (FFI) function")
            if dc.sigs[si].ret == "void":
                die("type: a spawned function must return a value (wait(t) yields it)")
            sj := 0
            for sj < len(dc.sigs[si].ptypes):
                if is_inout(dc.sigs[si].ptypes[sj]):
                    die("type: cannot spawn a function with inout parameters (no shared state across threads)")
                sj = sj + 1
            sid := len(spawns)
            push(spawns, SpawnInfo(nm, dc.sigs[si].ptypes, dc.sigs[si].ret))
            return ESpawn(sid, nm, nsa, _el)

# B-3 (bidirectional inference): is `e` a bare incomplete initializer? 1 = bare [],
# 2 = bare None, 0 = neither. (tychoc parses None as an E_NONE node; tychoc0
# parses it as the 0-arg builtin call ECall("None", [], _el).)
fn pend_init_kind(e: Expr) -> int:
    match e:
        EArrEmpty(t, _el):
            if t == "":
                return 1
            return 0
        ECall(nm, a, _el):
            if nm == "None" and len(a) == 0:
                return 2
            return 0
        EInt(s, _el):
            return 0
        EBool(s, _el):
            return 0
        EChar(s, _el):
            return 0
        EFloat(s, _el):
            return 0
        EStr(s, _el):
            return 0
        EVar(s, _el):
            if s == "None":                       # a bare None parses as EVar("None", _el) in tychoc0
                return 2
            return 0
        EBin(o, l, r, _el):
            return 0
        EField(b, f, _el):
            return 0
        EIndex(b, ix, _el):
            return 0
        EArrLit(es, _el):
            return 0
        EMapEmpty(k, v, _el):
            return 0
        EMapLit(ks, vs, _el):
            return 0
        ETuple(es, _el):
            return 0
        ESlice(b, lo, hi, _el):
            return 0
        EAddr(x, _el):
            return 0
        ELambda(id, ps, pts, ret, bx, cn, ct, _el):
            return 0
        ECallV(c, a2, _el):
            return 0
        ESpawn(sid, snm, sa, _el):
            return 0

# B-3 probe: the declared name if `s` is an untyped decl with a bare
# initializer ("" otherwise), with the initializer handed back via `ex`.
fn pend_probe(s: Stmt, ex: inout Expr) -> string:
    match s:
        SDecl(n, e, _sl):
            if pend_init_kind(e) != 0:
                ex = e
                return n
            return ""
        SAssign(n, e, _sl):
            return ""
        SFieldAssign(lv, r, _sl):
            return ""
        SPrint(e, _sl):
            return ""
        SReturn(e, _sl):
            return ""
        SConst(n, e, _sl):
            return ""
        SReturnVoid:
            return ""
        SIf(c, t, el, _sl):
            return ""
        SWhile(c, b, _sl):
            return ""
        SForRange(v, a, b, st, body, _sl):
            return ""
        SExpr(e, _sl):
            return ""
        STypedDecl(n, ty, e, _sl):
            return ""
        SOrReturn(n, e, _sl):
            return ""
        SDestructure(ns, e, _sl):
            return ""
        SMultiAssign(ns, e, _sl):
            return ""
        SMatch(subj, vars, binds, bodies, _sl):
            return ""
        SBreak:
            return ""
        SContinue:
            return ""
        SParFor(v, a, b, body, pid, _sl):
            return ""
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            return ""
        SValDecl(n, annot, cc, _sl):              # value if/match always infers a concrete type (never a bare []/None)
            return ""

# B-3 seek, expression half: the first typed use of pending var `nm` inside
# `e` -- an argument position whose destination type is known (arg_want).
# A use anywhere else is tychoc's "used before its type can be inferred"
# error; tychoc gates programs, so here we just keep seeking.
fn pend_seek_expr(dc: Decls, ctx: Ctx, n2: [string], t2: [string], nm: string, e: Expr) -> string:
    match e:
        ECall(cn, a, _el):
            if cn == "push" and len(a) == 2 and evar_name(a[0]) == nm:        # push(xs, v) -> [typeof v]
                return "[" + type_of(a[1], n2, t2, dc, ctx) + "]"
            if cn == "map_set" and len(a) == 3 and evar_name(a[0]) == nm:     # map_set(m, k, v) -> {K:V}
                return "{" + type_of(a[1], n2, t2, dc, ctx) + ":" + type_of(a[2], n2, t2, dc, ctx) + "}"
            j := 0
            for j < len(a):
                if evar_name(a[j]) == nm:
                    w := arg_want(dc, ctx, n2, t2, cn, a, j)
                    if w != "":
                        return w
                else:
                    r := pend_seek_expr(dc, ctx, n2, t2, nm, a[j])
                    if r != "":
                        return r
                j = j + 1
            return ""
        EBin(o, l, r, _el):
            lr := pend_seek_expr(dc, ctx, n2, t2, nm, l)
            if lr != "":
                return lr
            return pend_seek_expr(dc, ctx, n2, t2, nm, r)
        EField(b, f, _el):
            return pend_seek_expr(dc, ctx, n2, t2, nm, b)
        EIndex(b, ix, _el):
            br := pend_seek_expr(dc, ctx, n2, t2, nm, b)
            if br != "":
                return br
            return pend_seek_expr(dc, ctx, n2, t2, nm, ix)
        EArrLit(es, _el):
            j := 0
            for j < len(es):
                if j > 0 and evar_name(es[j]) == nm and evar_name(es[0]) != nm:
                    return type_of(es[0], n2, t2, dc, ctx)   # an element checks against the FIRST element's type
                r := pend_seek_expr(dc, ctx, n2, t2, nm, es[j])
                if r != "":
                    return r
                j = j + 1
            return ""
        EMapLit(ks, vs, _el):
            j := 0
            for j < len(ks):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, ks[j])
                if r != "":
                    return r
                r = pend_seek_expr(dc, ctx, n2, t2, nm, vs[j])
                if r != "":
                    return r
                j = j + 1
            return ""
        ETuple(es, _el):
            j := 0
            for j < len(es):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, es[j])
                if r != "":
                    return r
                j = j + 1
            return ""
        ESlice(b, lo, hi, _el):
            return pend_seek_expr(dc, ctx, n2, t2, nm, b)
        EAddr(x, _el):
            return pend_seek_expr(dc, ctx, n2, t2, nm, x)
        ECallV(c, a, _el):
            cvt := "void"                         # a call-on-expression's param types ground a pending arg;
            if efield_fname(c) == "":             # EField callees are method forms -- type_of would die there
                cvt = type_of(c, n2, t2, dc, ctx)
            j := 0
            for j < len(a):
                if evar_name(a[j]) == nm and is_func(cvt):
                    cvp := []string
                    cvr := fnty_split(cvt, &cvp)
                    if j < len(cvp):
                        return cvp[j]
                r := pend_seek_expr(dc, ctx, n2, t2, nm, a[j])
                if r != "":
                    return r
                j = j + 1
            return ""
        ESpawn(sid, snm, sa, _el):
            j := 0
            for j < len(sa):
                if evar_name(sa[j]) == nm:
                    si := dc.sigmap.get(snm, 0 - 1)
                    if si >= 0 and j < len(dc.sigs[si].ptypes):
                        return base_ty(dc.sigs[si].ptypes[j])
                else:
                    r := pend_seek_expr(dc, ctx, n2, t2, nm, sa[j])
                    if r != "":
                        return r
                j = j + 1
            return ""
        EInt(s, _el):
            return ""
        EBool(s, _el):
            return ""
        EChar(s, _el):
            return ""
        EFloat(s, _el):
            return ""
        EStr(s, _el):
            return ""
        EVar(s, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        ELambda(id, ps, pts, ret, bx, cn, ct, _el):
            return ""

# B-3 seek, statement half: walk forward from a pending decl maintaining a
# COPY of the env (so a grounding value's type resolves with everything
# declared in between), returning the type the first grounding use implies:
# `nm = e` (typeof e), `return nm` (the fn's return type), `place = nm`
# (typeof place), or a typed argument position (pend_seek_expr). A shadowing
# redeclaration of `nm` ends the search. Recurses into nested blocks.
fn pend_seek(dc: Decls, ctx: Ctx, n2: inout [string], t2: inout [string], nm: string, stmts: [Stmt], from: int, fret: string) -> string:
    i := from
    for i < len(stmts):
        match stmts[i]:
            SAssign(x, e, _sl):
                if x == nm:
                    r0 := pend_seek_expr(dc, ctx, n2, t2, nm, e)   # m = map_set(m, k, v): the rhs READS nm --
                    if r0 != "":                                   # the call form grounds, not the (pending) type
                        return r0
                    return type_of(e, n2, t2, dc, ctx)
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
            SReturn(e, _sl):
                if evar_name(e) == nm:
                    return fret
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
            SFieldAssign(lv, rhs, _sl):
                if evar_name(rhs) == nm:
                    return type_of(lv, n2, t2, dc, ctx)
                r := pend_seek_expr(dc, ctx, n2, t2, nm, rhs)
                if r != "":
                    return r
            SDecl(x, e, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
                if x == nm:
                    return ""                     # shadowed before grounding
                push(n2, x)
                if pend_init_kind(e) != 0:
                    push(t2, "?")
                else:
                    push(t2, type_of(e, n2, t2, dc, ctx))
            STypedDecl(x, ty, e, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
                if x == nm:
                    return ""
                push(n2, x)
                push(t2, ty)
            SOrReturn(x, e, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
                rt2 := type_of(e, n2, t2, dc, ctx)
                push(n2, x)
                if is_option(rt2):
                    push(t2, option_inner(rt2))
                else:
                    push(t2, result_ok(rt2))
            SDestructure(ns, e, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
                dt := type_of(e, n2, t2, dc, ctx)
                dp := tuple_parts(dt)
                dk := 0
                for dk < len(ns):
                    push(n2, ns[dk])
                    push(t2, dp[dk])
                    dk = dk + 1
            SMultiAssign(ns, e, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
            SPrint(e, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
            SExpr(e, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
            SIf(c, t, el, _sl):
                bn := n2
                bt := t2
                r := pend_seek(dc, ctx, &bn, &bt, nm, t, 0, fret)
                if r != "":
                    return r
                bn2 := n2
                bt2 := t2
                r = pend_seek(dc, ctx, &bn2, &bt2, nm, el, 0, fret)
                if r != "":
                    return r
            SWhile(c, b, _sl):
                bn := n2
                bt := t2
                r := pend_seek(dc, ctx, &bn, &bt, nm, b, 0, fret)
                if r != "":
                    return r
            SForRange(v, a, b, st, body, _sl):
                if v != nm:
                    bn := n2
                    bt := t2
                    push(bn, v)
                    push(bt, "int")
                    r := pend_seek(dc, ctx, &bn, &bt, nm, body, 0, fret)
                    if r != "":
                        return r
            SMatch(subj, vars, binds, bodies, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, subj)
                if r != "":
                    return r
                mk := 0
                for mk < len(bodies):
                    bn := n2
                    bt := t2
                    mt := type_of(subj, n2, t2, dc, ctx)
                    if len(binds[mk]) > 0:
                        push(bn, binds[mk][0])
                        if is_option(mt):
                            push(bt, option_inner(mt))
                        elif vars[mk] == "Ok":
                            push(bt, result_ok(mt))
                        elif vars[mk] == "Err":
                            push(bt, result_err(mt))
                        else:
                            push(bt, "int")       # enum payload binds: rare in a seek; conservative
                    r = pend_seek(dc, ctx, &bn, &bt, nm, bodies[mk], 0, fret)
                    if r != "":
                        return r
                    mk = mk + 1
            SSelect(uid, svars, schans, sbinds, sbodies, _sl):
                sk := 0
                for sk < len(svars):
                    bn := n2
                    bt := t2
                    if svars[sk] == "recv":
                        push(bn, sbinds[sk])
                        push(bt, chan_inner(type_of(schans[sk], n2, t2, dc, ctx)))
                    r := pend_seek(dc, ctx, &bn, &bt, nm, sbodies[sk], 0, fret)
                    if r != "":
                        return r
                    sk = sk + 1
            SParFor(v, a, b, body, pid, _sl):
                if v != nm:
                    bn := n2
                    bt := t2
                    push(bn, v)
                    push(bt, "int")
                    r := pend_seek(dc, ctx, &bn, &bt, nm, body, 0, fret)
                    if r != "":
                        return r
            SConst(n, e, _sl):
                i = i
            SReturnVoid:
                i = i
            SBreak:
                i = i
            SContinue:
                i = i
            SValDecl(x, annot, cc, _sl):          # seek nm in the branch tails, then register the new local (mirror SDecl + SIf)
                bn := n2
                bt := t2
                r := pend_seek(dc, ctx, &bn, &bt, nm, [cc], 0, fret)
                if r != "":
                    return r
                if x == nm:
                    return ""
                push(n2, x)
                dty := annot
                if annot == "":
                    dty = value_ctrl_type(cc, n2, t2, dc, ctx, _sl)
                push(t2, dty)
        i = i + 1
    return ""

fn lift_block(stmts: [Stmt], lifted: inout [Func], ctr: inout int, lams: inout [LamInfo], spawns: inout [SpawnInfo], pars: inout [ParInfo], names: inout [string], types: inout [string], dc: Decls, ctx: Ctx, fret: string) -> [Stmt]:
    _el := 0
    _sl := 0
    mark := len(names)                                # block-local decls don't leak to the enclosing scope
    out := []Stmt
    i := 0
    for i < len(stmts):
        st := stmts[i]
        pe := EInt("0", _el)
        pn := pend_probe(st, &pe)
        if pn != "":                                  # B-3: a bare decl grounds from its first use in this block
            sn := names
            stt := types
            pty := pend_seek(dc, ctx, &sn, &stt, pn, stmts, i + 1, fret)
            if pty == "":
                die("type: could not infer the type of '" + pn + "' -- no grounding use in its block (annotate the declaration)")
            st = STypedDecl(pn, pty, pe, _sl)              # the annotated form; ground_pre types the initializer
        push(out, lift_stmt(st, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret))
        i = i + 1
    names = names[0:mark]
    types = types[0:mark]
    return out

fn lift_stmt(s: Stmt, lifted: inout [Func], ctr: inout int, lams: inout [LamInfo], spawns: inout [SpawnInfo], pars: inout [ParInfo], names: inout [string], types: inout [string], dc: Decls, ctx: Ctx, fret: string) -> Stmt:
    _el := 0
    match s:
        SDecl(n, e, _sl):
            ne := lift_expr(e, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            nty := type_of(e, names, types, dc, ctx)  # type BEFORE pushing the name (sacc_stmt order):
            push(names, n)                            # a shadowing `y := y + 2` must resolve y to the
            push(types, nty)                          # OUTER decl, and names/types must stay in lockstep
            return SDecl(n, ne, _sl)
        SAssign(n, e, _sl):
            aw := ""                              # B: the existing var's type checks the RHS
            if has_str(names, n):
                aw = base_ty(var_type(names, types, n))
            return SAssign(n, lift_expr(ground_pre(dc, ctx, aw, e), &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        SFieldAssign(lv, rhs, _sl):
            fw := type_of(lv, names, types, dc, ctx)   # B: the place's type checks the stored value
            return SFieldAssign(lift_expr(lv, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_expr(ground_pre(dc, ctx, fw, rhs), &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        SPrint(e, _sl):
            return SPrint(lift_expr(e, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        SReturn(e, _sl):
            # A closure MAY escape: gen_stmt's SReturn re-homes its captured env into
            # _parent via copyenv (value semantics, sound). rule (a) lifted.
            return SReturn(lift_expr(ground_pre(dc, ctx, fret, e), &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        SConst(n, e, _sl):
            return s
        SReturnVoid:
            return s
        SIf(c, th, el, _sl):
            return SIf(lift_expr(c, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_block(th, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret), lift_block(el, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret), _sl)
        SWhile(c, b, _sl):
            return SWhile(lift_expr(c, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_block(b, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret), _sl)
        SForRange(nm, a, b, st, body, _sl):
            na := lift_expr(a, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            nbb := lift_expr(b, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            nst := lift_expr(st, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            mark := len(names)                        # the loop var is in scope for the body only
            push(names, nm)
            push(types, "int")
            nbody := lift_block(body, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret)
            names = names[0:mark]
            types = types[0:mark]
            return SForRange(nm, na, nbb, nst, nbody, _sl)
        SExpr(e, _sl):
            return SExpr(lift_expr(e, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        STypedDecl(nm, ty, e, _sl):
            ne := lift_expr(ground_pre(dc, ctx, ty, e), &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            push(names, nm)
            push(types, ty)
            return STypedDecl(nm, ty, ne, _sl)
        SOrReturn(nm, e, _sl):
            return SOrReturn(nm, lift_expr(e, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        SDestructure(nms, e, _sl):
            return SDestructure(nms, lift_expr(e, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        SMultiAssign(nms, e, _sl):
            return SMultiAssign(nms, lift_expr(e, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        SMatch(subj, vars, binds, bodies, _sl):
            ns := lift_expr(subj, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            nb := [][Stmt]
            k := 0
            for k < len(bodies):
                push(nb, lift_block(bodies[k], &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret))
                k = k + 1
            return SMatch(ns, vars, binds, nb, _sl)
        SBreak:
            return s
        SContinue:
            return s
        SParFor(v, a, b, body, pid0, _sl):
            if pid0 == 0 - 2:
                # deferred `parallel for x in EXPR` (the parser couldn't see the
                # type): type-branch the source identifier now (types are present
                # here) and re-lift the concrete form — channel drain or array index.
                psrc := type_of(a, names, types, dc, ctx)
                if is_chan(psrc):
                    # K=ncpu() workers draining until closed:
                    #   parallel for __pw in range(0, ncpu()):
                    #       for true: select { recv(a, x): BODY ; closed: break }
                    svs := []string
                    push(svs, "recv")
                    push(svs, "closed")
                    schs := []Expr
                    push(schs, a)
                    push(schs, EInt("0", _sl))
                    sbs := []string
                    push(sbs, v)
                    push(sbs, "")
                    cbrk := []Stmt
                    push(cbrk, SBreak)
                    sbods := [][Stmt]
                    push(sbods, body)
                    push(sbods, cbrk)
                    seluid := "pfc" + str(len(pars)) + "_" + str(_sl)
                    whbody := []Stmt
                    push(whbody, SSelect(seluid, svs, schs, sbs, sbods, _sl))
                    dbody := []Stmt
                    push(dbody, SWhile(EBool("1", _sl), whbody, _sl))
                    nca := []Expr
                    realc := SParFor("__pw", EInt("0", _sl), ECall("ncpu", nca, _sl), dbody, 0 - 1, _sl)
                    return lift_stmt(realc, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret)
                if not (is_array(psrc) or psrc == "str"):
                    die("parallel for expects an array, string, or channel")
                # array/string: parallel for __fe in range(0, len(a)): x := a[__fe] ; BODY
                fiv := "__fe" + str(len(pars)) + "_" + str(_sl)
                ibody := []Stmt
                push(ibody, SDecl(v, EIndex(a, EVar(fiv, _sl), _sl), _sl))
                ik := 0
                for ik < len(body):
                    push(ibody, body[ik])
                    ik = ik + 1
                lna := []Expr
                push(lna, a)
                reala := SParFor(fiv, EInt("0", _sl), ECall("len", lna, _sl), ibody, 0 - 1, _sl)
                return lift_stmt(reala, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret)
            # CC-3: lift the body to a chunk proc __par<pid>(__plo, __phi,
            # captures...) -> partial(s); register its spawn site (the driver
            # emits the trampoline) and the ParInfo the site codegen reads.
            # GATE the body first (parity with tychoc's pf_scan_stmt): reject an
            # early exit, a captured-variable mutation/inout-pass, or a non-reduction
            # outer update -- a chunk that does any of these silently miscompiles.
            gloc := []string
            push(gloc, v)
            gacc := []string
            gaccop := []string
            gaccnt := []int
            pf_gate_body(body, gloc, names, &gacc, &gaccop, &gaccnt, 0)
            # precise (not heuristic): tychoc0's own type inference has full types
            # here -- sigs are collected before the lift pass -- so any non-int
            # bound shape (a float var, `n * 2.0`, a float-returning call) is
            # caught, matching tychoc's resolve_exp == T_INT check exactly.
            if base_ty(type_of(a, names, types, dc, ctx)) != "int" or base_ty(type_of(b, names, types, dc, ctx)) != "int":
                die("parallel for needs an int range")
            gci := 0
            for gci < len(gacc):
                if count_reads_body(body, gacc[gci]) != gaccnt[gci]:
                    die("parallel for reduction accumulator may only be updated, not read")
                gci = gci + 1
            na := lift_expr(a, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            nbb := lift_expr(b, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            raw := []string
            pf_body_evars(body, &raw)
            accn := []string
            accop := []string
            pf_accs(body, names, &accn, &accop)
            capn := []string
            capt := []string
            j := 0
            for j < len(raw):
                if has_str(names, raw[j]) and not has_str(accn, raw[j]) and not has_str(capn, raw[j]) and raw[j] != v:
                    push(capn, raw[j])
                    push(capt, base_ty(var_type(names, types, raw[j])))
                j = j + 1
            pid := len(pars)
            accty := []string
            j = 0
            for j < len(accn):
                push(accty, base_ty(var_type(names, types, accn[j])))
                j = j + 1
            rty := "int"
            if len(accn) == 1:
                rty = accty[0]
            if len(accn) > 1:
                rty = "("
                j = 0
                for j < len(accn):
                    if j > 0:
                        rty = rty + ","
                    rty = rty + accty[j]
                    j = j + 1
                rty = rty + ")"
            cps := []string
            cpt := []string
            push(cps, "__plo")
            push(cpt, "int")
            push(cps, "__phi")
            push(cpt, "int")
            j = 0
            for j < len(capn):
                push(cps, capn[j])
                push(cpt, capt[j])
                j = j + 1
            cbody := []Stmt
            j = 0
            for j < len(accn):
                idv := EInt("0", _el)
                if accop[j] == "*":
                    idv = EInt("1", _el)
                if accty[j] == "float":
                    idv = EFloat("0.0", _el)
                    if accop[j] == "*":
                        idv = EFloat("1.0", _el)
                push(cbody, SDecl(accn[j], idv, _sl))
                j = j + 1
            push(cbody, SForRange(v, EVar("__plo", _el), EVar("__phi", _el), EInt("1", _el), body, _sl))
            if len(accn) == 0:
                push(cbody, SReturn(EInt("0", _el), _sl))
            if len(accn) == 1:
                push(cbody, SReturn(EVar(accn[0], _el), _sl))
            if len(accn) > 1:
                tup := []Expr
                j = 0
                for j < len(accn):
                    push(tup, EVar(accn[j], _el))
                    j = j + 1
                push(cbody, SReturn(ETuple(tup, _el), _sl))
            cn2 := cps
            ct2 := cpt
            cbody = lift_block(cbody, &lifted, &ctr, &lams, &spawns, &pars, &cn2, &ct2, dc, ctx, rty)
            push(lifted, Func("__par" + str(pid), cps, cpt, rty, cbody, 0, "", ""))
            sid := len(spawns)
            push(spawns, SpawnInfo("__par" + str(pid), cpt, rty))
            push(pars, ParInfo(sid, capn, capt, accn, accop, rty))
            return SParFor("", na, nbb, []Stmt, pid, _sl)
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            nch := []Expr
            nb := [][Stmt]
            sk := 0
            for sk < len(svars):
                push(nch, lift_expr(schans[sk], &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx))
                mark := len(names)
                if svars[sk] == "recv":
                    bty := chan_inner(type_of(schans[sk], names, types, dc, ctx))
                    push(names, sbinds[sk])
                    push(types, bty)
                push(nb, lift_block(sbodies[sk], &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret))
                names = names[0:mark]
                types = types[0:mark]
                sk = sk + 1
            return SSelect(uid, svars, nch, sbinds, nb, _sl)
        SValDecl(n, annot, cc, _sl):              # lift lambdas/spawns in the branch tails, then register the local (mirror SDecl order)
            nty := annot
            if annot == "":
                nty = value_ctrl_type(cc, names, types, dc, ctx, _sl)
            ncc := lift_stmt(cc, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret)
            push(names, n)
            push(types, nty)
            return SValDecl(n, annot, ncc, _sl)

# Does an expr / stmt / block contain a lambda anywhere? Used to skip the
# scope-aware lift (which calls type_of) for lambda-free functions — keeping a
# lambda-free program (incl. tychoc0.ty itself) byte-identical and crash-free.
fn expr_has_lambda(e: Expr) -> bool:
    match e:
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return true
        EBin(o, l, r, _el):
            return expr_has_lambda(l) or expr_has_lambda(r)
        ECall(n, a, _el):
            if has_prefix(n, "channel:"):         # channel creation gates the lift (its decl needs gen support)
                return true
            j := 0
            for j < len(a):
                if expr_has_lambda(a[j]):
                    return true
                j = j + 1
            return false
        EField(b, f, _el):
            return expr_has_lambda(b)
        EIndex(b, ix, _el):
            return expr_has_lambda(b) or expr_has_lambda(ix)
        EArrLit(es, _el):
            j := 0
            for j < len(es):
                if expr_has_lambda(es[j]):
                    return true
                j = j + 1
            return false
        EMapLit(ks, vs, _el):
            j := 0
            for j < len(ks):
                if expr_has_lambda(ks[j]) or expr_has_lambda(vs[j]):
                    return true
                j = j + 1
            return false
        ETuple(es, _el):
            j := 0
            for j < len(es):
                if expr_has_lambda(es[j]):
                    return true
                j = j + 1
            return false
        ESlice(b, lo, hi, _el):
            return expr_has_lambda(b) or expr_has_lambda(lo) or expr_has_lambda(hi)
        ECallV(callee, cargs, _el):
            if expr_has_lambda(callee):
                return true
            j := 0
            for j < len(cargs):
                if expr_has_lambda(cargs[j]):
                    return true
                j = j + 1
            return false
        EAddr(x, _el):
            return expr_has_lambda(x)
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(t, _el):
            return false
        EStr(s, _el):
            return false
        EVar(n, _el):
            return false
        EArrEmpty(t, _el):
            return t == ""                        # a bare [] gates the lift: ground_pre runs there (B-0)
        EMapEmpty(k, v, _el):
            return false
        ESpawn(sid, snm, sa, _el):
            return true                           # conc gates the lift too: spawn sites get their ids there

fn block_has_lambda(stmts: [Stmt]) -> bool:
    i := 0
    for i < len(stmts):
        if stmt_has_lambda(stmts[i]):
            return true
        i = i + 1
    return false

fn stmt_has_lambda(s: Stmt) -> bool:
    match s:
        SDecl(n, e, _sl):
            if pend_init_kind(e) != 0:            # B-3: a bare decl gates the lift (pend_seek runs there);
                return true                       # decl-position ONLY -- `return None` etc never re-gates
            return expr_has_lambda(e)
        SAssign(n, e, _sl):
            return expr_has_lambda(e)
        SFieldAssign(lv, rhs, _sl):
            return expr_has_lambda(lv) or expr_has_lambda(rhs)
        SPrint(e, _sl):
            return expr_has_lambda(e)
        SReturn(e, _sl):
            return expr_has_lambda(e)
        SConst(n, e, _sl):
            return false
        SReturnVoid:
            return false
        SIf(c, th, el, _sl):
            return expr_has_lambda(c) or block_has_lambda(th) or block_has_lambda(el)
        SWhile(c, b, _sl):
            return expr_has_lambda(c) or block_has_lambda(b)
        SForRange(nm, a, b, st, body, _sl):
            return expr_has_lambda(a) or expr_has_lambda(b) or expr_has_lambda(st) or block_has_lambda(body)
        SExpr(e, _sl):
            return expr_has_lambda(e)
        STypedDecl(nm, ty, e, _sl):
            return expr_has_lambda(e)
        SOrReturn(nm, e, _sl):
            return expr_has_lambda(e)
        SDestructure(nms, e, _sl):
            return expr_has_lambda(e)
        SMultiAssign(nms, e, _sl):
            return expr_has_lambda(e)
        SMatch(subj, vars, binds, bodies, _sl):
            if expr_has_lambda(subj):
                return true
            k := 0
            for k < len(bodies):
                if block_has_lambda(bodies[k]):
                    return true
                k = k + 1
            return false
        SBreak:
            return false
        SContinue:
            return false
        SParFor(v, a, b, body, pid, _sl):
            return true                           # a parallel for IS a lift job (chunk-proc extraction)
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            sk := 0
            for sk < len(svars):
                if expr_has_lambda(schans[sk]) or block_has_lambda(sbodies[sk]):
                    return true
                sk = sk + 1
            return false
        SValDecl(n, annot, cc, _sl):
            return stmt_has_lambda(cc)

# ---------------------------------------------------- generics: monomorphize --
# Stage 1: a `$T` function template is monomorphized into one concrete instance
# per distinct argument-type tuple. A pre-codegen pass walks every concrete
# function's body, infers each `$T` from the call's argument types, interns one
# instance Func (sharing the template body — tychoc0 recomputes types per func, so
# sharing is sound), and rewrites the call to the instance's mangled name. Mirrors
# the C compiler's instantiate_generic; the mangled name MUST match it byte-for-
# byte for the fixpoint differential ("str" -> "string", like type_mangle_ident).
fn find_generic(gens: [Func], name: string) -> int:
    i := 0
    for i < len(gens):
        if gens[i].name == name:
            return i
        i = i + 1
    return -1

fn gen_inst_mangle(ty: string) -> string:
    if ty == "str":
        return "string"
    n := len(ty)
    if n > 1 and ty[0] == 91 and ty[n - 1] == 93:    # "[E]" array -> arr_<E> (C-identifier-safe)
        return "arr_" + gen_inst_mangle(substr(ty, 1, n - 1))
    if n > 1 and ty[0] == 123 and ty[n - 1] == 125:  # "{K:V}" map -> map_<K>_<V>
        inner := substr(ty, 1, n - 1)
        col := find_top_colon(inner)
        if col >= 0:
            return "map_" + gen_inst_mangle(substr(inner, 0, col)) + "_" + gen_inst_mangle(substr(inner, col + 1, len(inner)))
    if has_prefix(ty, "fn(") and ty[n - 1] == 41:    # "fn(P...->R)" -> C-identifier-safe fn_<P>..._ret_<R> (must precede the Name(args) arm, which would keep the "->")
        fin := func_inner(ty)
        far := func_arrow(fin)
        if far >= 0:
            fout := "fn"
            fps := split_type_args(substr(fin, 0, far))
            fj := 0
            for fj < len(fps):
                fout = fout + "_" + gen_inst_mangle(fps[fj])
                fj = fj + 1
            return fout + "_ret_" + gen_inst_mangle(substr(fin, far + 2, len(fin)))
    p := -1
    i := 0
    for i < n:
        if ty[i] == 40 and p < 0:                    # first '('
            p = i
        i = i + 1
    if p > 0 and ty[n - 1] == 41:                    # "Option(T)" / "Result(T,E)" -> Name_<arg>...
        out := substr(ty, 0, p)
        args := split_type_args(substr(ty, p + 1, n - 1))
        j := 0
        for j < len(args):
            out = out + "_" + gen_inst_mangle(args[j])
            j = j + 1
        return out
    return ty                                   # int/float/bool/char and bare struct/enum names map to themselves

fn inst_name(base: string, ptypes: [string]) -> string:
    nm := base
    i := 0
    for i < len(ptypes):
        nm = nm + "__" + gen_inst_mangle(ptypes[i])
        i = i + 1
    return nm

# Name-only resolution of a generic-struct APPLICATION type (`Box(int)`) to its instance
# name (`Box__int`), matching instantiate_struct. Unlike resolve_gtype it instantiates
# nothing (read-only, no sinsts) -- the instance already exists from construction; this just
# NAMES it. cty uses it as a fallback for type positions resolve_gtype's call sites don't
# reach (a channel's element type, a generic-fn call result). Recurses into [..]/{..} + args.
fn resolve_ginst(ty: string, dc: Decls, ctx: Ctx) -> string:
    n := len(ty)
    if n == 0:
        return ty
    if is_array(ty):
        return "[" + resolve_ginst(elem_ty(ty), dc, ctx) + "]"
    if is_map(ty):
        return "{" + map_key(ty) + ":" + resolve_ginst(map_val(ty), dc, ctx) + "}"
    pp := find(ty, "(")
    if pp > 0 and ty[n - 1] == 41:
        args := split_type_args(substr(ty, pp + 1, n - 1))
        rargs := []string
        j := 0
        for j < len(args):
            push(rargs, resolve_ginst(args[j], dc, ctx))
            j = j + 1
        cand := inst_name(substr(ty, 0, pp), rargs)    # candidate instance name ("Box__int"). The generic TEMPLATE is gone from dc by emission time, so accept this only if the INSTANCE actually exists (created by construction).
        if cand != ty and (is_struct(dc, ctx, cand) or is_enum(dc, ctx, cand)):   # enums too: a generic-enum channel element / fn-return application (Box(int)) must resolve to its instance so cp_field's deep-copy dispatch (is_enum) selects the right copier, not a fail-open shallow copy
            return cand
    return ty

# Index of the first top-level ':' (depth 0 w.r.t. {}/[]/()), or -1. Splits a
# map type's "{K:V}" inner into key and value.
fn find_top_colon(s: string) -> int:
    depth := 0
    i := 0
    for i < len(s):
        c := s[i]
        if c == 123 or c == 91 or c == 40:           # { [ (
            depth = depth + 1
        elif c == 125 or c == 93 or c == 41:         # } ] )
            depth = depth - 1
        elif c == 58 and depth == 0:                 # : at top level
            return i
        i = i + 1
    return -1

# Stage 3: structurally match a parameter-type PATTERN against a concrete argument
# type string, binding each "$X". Handles "$T", "[$T]", "{$K:$V}", "Option($T)",
# "Result($T,$E)" (recursing). 0 on a constructor mismatch or bind conflict.
fn match_typaram_str(pat: string, concrete: string, bnames: inout [string], btypes: inout [string]) -> bool:
    pn := len(pat)
    cn := len(concrete)
    if pn > 0 and pat[0] == 36:                  # "$X" -> bind X = concrete
        bn := substr(pat, 1, pn)
        j := 0
        for j < len(bnames):
            if bnames[j] == bn:
                return btypes[j] == concrete     # already bound -> must agree
            j = j + 1
        push(bnames, bn)
        push(btypes, concrete)
        return true
    if pn > 1 and cn > 1 and pat[0] == 91 and concrete[0] == 91 and pat[pn - 1] == 93 and concrete[cn - 1] == 93:
        return match_typaram_str(substr(pat, 1, pn - 1), substr(concrete, 1, cn - 1), &bnames, &btypes)   # "[E]" array
    if pn > 1 and cn > 1 and pat[0] == 123 and concrete[0] == 123 and pat[pn - 1] == 125 and concrete[cn - 1] == 125:   # "{K:V}" map
        pin := substr(pat, 1, pn - 1)
        cin := substr(concrete, 1, cn - 1)
        pcol := find_top_colon(pin)
        ccol := find_top_colon(cin)
        if pcol >= 0 and ccol >= 0:
            return match_typaram_str(substr(pin, 0, pcol), substr(cin, 0, ccol), &bnames, &btypes) and match_typaram_str(substr(pin, pcol + 1, len(pin)), substr(cin, ccol + 1, len(cin)), &bnames, &btypes)
    if has_prefix(pat, "fn(") and has_prefix(concrete, "fn(") and pat[pn - 1] == 41 and concrete[cn - 1] == 41:   # "fn(P...->R)" function type: match the param + return types (higher-order generics)
        fpin := func_inner(pat)
        fcin := func_inner(concrete)
        fpa := func_arrow(fpin)
        fca := func_arrow(fcin)
        if fpa >= 0 and fca >= 0:
            if not match_typaram_str(substr(fpin, fpa + 2, len(fpin)), substr(fcin, fca + 2, len(fcin)), &bnames, &btypes):
                return false
            fpps := split_type_args(substr(fpin, 0, fpa))
            fcps := split_type_args(substr(fcin, 0, fca))
            if len(fpps) != len(fcps):
                return false
            fok := true
            fi := 0
            for fi < len(fpps):
                if not match_typaram_str(fpps[fi], fcps[fi], &bnames, &btypes):
                    fok = false
                fi = fi + 1
            return fok
    pp := -1
    cp := -1
    i := 0
    for i < pn:
        if pat[i] == 40 and pp < 0:
            pp = i
        i = i + 1
    i = 0
    for i < cn:
        if concrete[i] == 40 and cp < 0:
            cp = i
        i = i + 1
    if pp > 0 and cp > 0 and pat[pn - 1] == 41 and concrete[cn - 1] == 41:   # "Name(args)"
        if substr(pat, 0, pp) != substr(concrete, 0, cp):
            return false                         # different type constructors
        pargs := split_type_args(substr(pat, pp + 1, pn - 1))
        cargs := split_type_args(substr(concrete, cp + 1, cn - 1))
        if len(pargs) != len(cargs):
            return false
        ok := true
        i = 0
        for i < len(pargs):
            if not match_typaram_str(pargs[i], cargs[i], &bnames, &btypes):
                ok = false
            i = i + 1
        return ok
    return pat == concrete

# generics: substitute every typaram type in an instance body. The instance body
# is a deep copy (value semantics), so this rewrites only the instance. Only the
# explicit type carriers (EArrEmpty/EMapEmpty/STypedDecl/ELambda) need it; every
# other node derives its type from the now-concrete params at codegen. A body type
# string carries the BARE typaram (`[T]`, not `[$T]` -- the bare->$ rewrite ran only
# on the signature), so re-apply it before the $-keyed concrete substitution.
fn subst_body_type(ty: string, bn: [string], bt: [string]) -> string:
    return subst_field_type(subst_bare_typaram(ty, bn), bn, bt)

fn subst_types_list(ts: [string], bn: [string], bt: [string]) -> [string]:
    out := []string
    i := 0
    for i < len(ts):
        push(out, subst_body_type(ts[i], bn, bt))
        i = i + 1
    return out

fn subst_exprs_t(es: [Expr], bn: [string], bt: [string]) -> [Expr]:
    out := []Expr
    i := 0
    for i < len(es):
        push(out, subst_expr_t(es[i], bn, bt))
        i = i + 1
    return out

fn subst_expr_t(e: Expr, bn: [string], bt: [string]) -> Expr:
    match e:
        EInt(s, el):
            return e
        EBool(s, el):
            return e
        EChar(s, el):
            return e
        EFloat(s, el):
            return e
        EStr(s, el):
            return e
        EVar(s, el):
            return e
        EBin(o, l, r, el):
            return EBin(o, subst_expr_t(l, bn, bt), subst_expr_t(r, bn, bt), el)
        ECall(nm, a, el):
            nm2 := nm                                # substitute typarams inside an explicit type-arg encoding (`zero$<T>` -> `zero$<int>`); no-op for concrete/absent encodings
            mk := find(nm, "$<")
            if mk >= 0:
                base := substr(nm, 0, mk)
                parts := split(substr(nm, mk + 2, len(nm) - 1), ";")
                newenc := ""
                pi := 0
                for pi < len(parts):
                    if pi > 0:
                        newenc = newenc + ";"
                    newenc = newenc + subst_body_type(parts[pi], bn, bt)
                    pi = pi + 1
                nm2 = base + "$<" + newenc + ">"
            return ECall(nm2, subst_exprs_t(a, bn, bt), el)
        EField(b, f, el):
            return EField(subst_expr_t(b, bn, bt), f, el)
        EIndex(b, ix, el):
            return EIndex(subst_expr_t(b, bn, bt), subst_expr_t(ix, bn, bt), el)
        EArrLit(es2, el):
            return EArrLit(subst_exprs_t(es2, bn, bt), el)
        EArrEmpty(t, el):
            return EArrEmpty(subst_body_type(t, bn, bt), el)
        EMapEmpty(k, v, el):
            return EMapEmpty(subst_body_type(k, bn, bt), subst_body_type(v, bn, bt), el)
        EMapLit(ks, vs, el):
            return EMapLit(subst_exprs_t(ks, bn, bt), subst_exprs_t(vs, bn, bt), el)
        ETuple(es2, el):
            return ETuple(subst_exprs_t(es2, bn, bt), el)
        ESlice(b, lo, hi, el):
            return ESlice(subst_expr_t(b, bn, bt), subst_expr_t(lo, bn, bt), subst_expr_t(hi, bn, bt), el)
        EAddr(x, el):
            return EAddr(subst_expr_t(x, bn, bt), el)
        ELambda(id, ps, pts, ret, body, cn, ct, el):
            return ELambda(id, ps, subst_types_list(pts, bn, bt), subst_body_type(ret, bn, bt), subst_expr_t(body, bn, bt), cn, ct, el)
        ECallV(c, a, el):
            return ECallV(subst_expr_t(c, bn, bt), subst_exprs_t(a, bn, bt), el)
        ESpawn(id, nm, a, el):
            return ESpawn(id, nm, subst_exprs_t(a, bn, bt), el)

fn subst_blocks_t(bs: [[Stmt]], bn: [string], bt: [string]) -> [[Stmt]]:
    out := [][Stmt]
    i := 0
    for i < len(bs):
        push(out, subst_block_t(bs[i], bn, bt))
        i = i + 1
    return out

fn subst_block_t(ss: [Stmt], bn: [string], bt: [string]) -> [Stmt]:
    out := []Stmt
    i := 0
    for i < len(ss):
        push(out, subst_stmt_t(ss[i], bn, bt))
        i = i + 1
    return out

fn subst_stmt_t(s: Stmt, bn: [string], bt: [string]) -> Stmt:
    match s:
        SDecl(n, e, ln):
            return SDecl(n, subst_expr_t(e, bn, bt), ln)
        SAssign(n, e, ln):
            return SAssign(n, subst_expr_t(e, bn, bt), ln)
        SFieldAssign(lv, rhs, ln):
            return SFieldAssign(subst_expr_t(lv, bn, bt), subst_expr_t(rhs, bn, bt), ln)
        SPrint(e, ln):
            return SPrint(subst_expr_t(e, bn, bt), ln)
        SReturn(e, ln):
            return SReturn(subst_expr_t(e, bn, bt), ln)
        SConst(n, e, ln):
            return s
        SReturnVoid:
            return s
        SIf(c, th, el, ln):
            return SIf(subst_expr_t(c, bn, bt), subst_block_t(th, bn, bt), subst_block_t(el, bn, bt), ln)
        SWhile(c, b, ln):
            return SWhile(subst_expr_t(c, bn, bt), subst_block_t(b, bn, bt), ln)
        SForRange(v, a, b, st, body, ln):
            return SForRange(v, subst_expr_t(a, bn, bt), subst_expr_t(b, bn, bt), subst_expr_t(st, bn, bt), subst_block_t(body, bn, bt), ln)
        SExpr(e, ln):
            return SExpr(subst_expr_t(e, bn, bt), ln)
        STypedDecl(n, ty, e, ln):
            return STypedDecl(n, subst_body_type(ty, bn, bt), subst_expr_t(e, bn, bt), ln)
        SOrReturn(n, e, ln):
            return SOrReturn(n, subst_expr_t(e, bn, bt), ln)
        SDestructure(ns, e, ln):
            return SDestructure(ns, subst_expr_t(e, bn, bt), ln)
        SMultiAssign(ns, e, ln):
            return SMultiAssign(ns, subst_expr_t(e, bn, bt), ln)
        SMatch(subj, vars, binds, bodies, ln):
            return SMatch(subst_expr_t(subj, bn, bt), vars, binds, subst_blocks_t(bodies, bn, bt), ln)
        SBreak:
            return s
        SContinue:
            return s
        SSelect(uid, kinds, chans, binds, bodies, ln):
            return SSelect(uid, kinds, subst_exprs_t(chans, bn, bt), binds, subst_blocks_t(bodies, bn, bt), ln)
        SParFor(v, a, b, body, pid, fl):
            return SParFor(v, subst_expr_t(a, bn, bt), subst_expr_t(b, bn, bt), subst_block_t(body, bn, bt), pid, fl)
        SValDecl(n, ty, cc, ln):
            return SValDecl(n, subst_body_type(ty, bn, bt), subst_stmt_t(cc, bn, bt), ln)

# generics: resolve a type to its ultimate newtype base (a newtype over int
# satisfies numeric, matching tychoc's base_of + the newtype-arithmetic rule).
fn nt_base_of(ty: string, dc: Decls) -> string:
    b := ty
    changed := true
    for changed:
        changed = false
        i := 0
        for i < len(dc.ntnames):
            if dc.ntnames[i] == b:
                b = dc.ntunder[i]
                changed = true
            i = i + 1
    return b

# the fixed compiler-known `where` predicate set; each is exactly the resolver's
# capability over the base type ("str" is tychoc0's spelling of string).
fn constraint_ok_str(pred: string, ty: string, dc: Decls) -> bool:
    b := nt_base_of(ty, dc)
    if pred == "numeric":
        return b == "int" or b == "float"
    if pred == "comparable":
        return b == "int" or b == "char" or b == "float" or b == "str"
    if pred == "has_str":
        return b == "int" or b == "bool" or b == "float" or b == "str"
    if pred == "hashable":
        ctx0 := Ctx([]string, []string, "", "0", 0, []int, []string, 0, []string, []string, []string, 0, "")
        return key_type_ok(dc, ctx0, ty)
    if pred == "defaultable":                        # zero$(T) -- exact scalars (no newtype); matches tychoc
        return ty == "int" or ty == "float" or ty == "bool" or ty == "str"
    return true

fn mono_instantiate(gt: Func, argtypes: [string], insts: inout [Func], ln: int, dc: Decls, explicit: [string]) -> string:
    if len(argtypes) != len(gt.ptypes):
        die("generics: '" + gt.name + "' takes " + str(len(gt.ptypes)) + " argument(s), got " + str(len(argtypes)))
    bnames := []string
    btypes := []string
    i := 0
    if len(explicit) > 0:                         # explicit call-site type args bind the params in declaration order
        tps := []string
        ci0 := 0
        for ci0 < len(gt.ptypes):
            collect_dollar_names(gt.ptypes[ci0], &tps)
            ci0 = ci0 + 1
        collect_dollar_names(gt.ret, &tps)
        uniq := []string                          # distinct typaram names, first-appearance order
        ui := 0
        for ui < len(tps):
            seen := false
            uj := 0
            for uj < len(uniq):
                if uniq[uj] == tps[ui]:
                    seen = true
                uj = uj + 1
            if not seen:
                push(uniq, tps[ui])
            ui = ui + 1
        if len(explicit) != len(uniq):
            die("generics: '" + gt.name + "' has " + str(len(uniq)) + " type parameter(s), but " + str(len(explicit)) + " explicit type argument(s) were given")
        ei := 0
        for ei < len(uniq):
            push(bnames, uniq[ei])
            push(btypes, explicit[ei])
            ei = ei + 1
    else:
        i = 0
        for i < len(gt.ptypes):                  # infer: structurally match each pattern against the arg type
            if not match_typaram_str(gt.ptypes[i], argtypes[i], &bnames, &btypes):
                die("generics: argument " + str(i + 1) + " of '" + gt.name + "' is " + argtypes[i] + ", which does not fit the parameter pattern")
            i = i + 1
    # generics: enforce `where` constraints up front (clear signature error, not a deep body error)
    if gt.constraints != "":
        cons := split(gt.constraints, "#")
        ci := 0
        for ci < len(cons):
            entry := cons[ci]
            eq := find(entry, "=")               # `=` marks a type-set entry `T=t1|t2`; else a predicate `pred:T`
            ctp := ""
            if eq >= 0:
                ctp = substr(entry, 0, eq)
            else:
                pp := split(entry, ":")
                ctp = pp[1]
            cty := ""
            found := false
            bj := 0
            for bj < len(bnames):
                if bnames[bj] == ctp:
                    cty = btypes[bj]
                    found = true
                bj = bj + 1
            if found:
                if eq >= 0:                       # type-set: cty's base must be one of the listed types
                    members := split(substr(entry, eq + 1, len(entry)), "|")
                    cb := nt_base_of(cty, dc)
                    inset := false
                    setstr := ""
                    mi := 0
                    for mi < len(members):
                        if nt_base_of(members[mi], dc) == cb:
                            inset = true
                        if mi > 0:
                            setstr = setstr + " | "
                        setstr = setstr + members[mi]
                        mi = mi + 1
                    if not inset:
                        die("generics: '" + gt.name + "' instantiated with " + ctp + " = " + cty + ", which is not in the type set { " + setstr + " }")
                else:                             # predicate
                    cpred := split(entry, ":")[0]
                    if not constraint_ok_str(cpred, cty, dc):
                        die("generics: '" + gt.name + "' instantiated with " + ctp + " = " + cty + ", which does not satisfy `" + cpred + "(" + ctp + ")`")
            ci = ci + 1
    cparams := []string                          # substitute "$X" -> concrete in the signature
    i = 0
    for i < len(gt.ptypes):
        push(cparams, subst_field_type(gt.ptypes[i], bnames, btypes))
        i = i + 1
    cret := subst_field_type(gt.ret, bnames, btypes)
    if ty_is_generic(cret):
        die("generics: the return type of '" + gt.name + "' has a type parameter not fixed by any argument")
    nm := inst_name(gt.name, cparams)
    # generics: a return-only typaram (one no parameter mentions) isn't in cparams;
    # add its binding so `empty$(int)` and `empty$(string)` are distinct instances.
    di := 0
    for di < len(bnames):
        pinned := false
        pj := 0
        for pj < len(gt.ptypes):
            if find(gt.ptypes[pj], "$" + bnames[di]) >= 0:
                pinned = true
            pj = pj + 1
        if not pinned:
            nm = nm + "__" + gen_inst_mangle(btypes[di])
        di = di + 1
    e := 0
    for e < len(insts):
        if insts[e].name == nm:
            return nm                            # already instantiated
        e = e + 1
    push(insts, Func(nm, gt.params, cparams, cret, subst_block_t(gt.body, bnames, btypes), 0, "", ""))
    if len(insts) > 1024:                        # runaway guard: recursive generic at a growing type
        die("generics: too many instantiations (> 1024) -- a recursive generic at a growing type?")
    return nm

# Generics (structs): a struct with type parameters is a template; each
# construction infers the type arguments from the field values and interns one
# concrete StructDef (Box($T) + Box(5) -> struct Box__int with $T->int).
fn find_generic_struct(structs: [StructDef], name: string) -> int:
    i := 0
    for i < len(structs):
        if structs[i].name == name and len(structs[i].typeparams) > 0:
            return i
        i = i + 1
    return -1

# Replace each "$X" in a field-type string with its bound concrete type.
fn subst_field_type(ty: string, bnames: [string], btypes: [string]) -> string:
    out := ""
    i := 0
    for i < len(ty):
        if ty[i] == 36:                          # '$'
            j := i + 1
            for j < len(ty) and is_alnum(ty[j]):
                j = j + 1
            nm := substr(ty, i + 1, j)
            rep := "$" + nm
            k := 0
            for k < len(bnames):
                if bnames[k] == nm:
                    rep = btypes[k]
                k = k + 1
            out = out + rep
            i = j
        else:
            out = out + substr(ty, i, i + 1)
            i = i + 1
    return out

# Intern the concrete instance of generic struct `t` for the bindings
# (typeparam name -> concrete type); append the new StructDef to `sinsts`,
# return its mangled name. Mangle matches tychoc (header typeparam order).
fn instantiate_struct(t: StructDef, bnames: [string], btypes: [string], sinsts: inout [StructDef]) -> string:
    nm := t.name
    iargs := []string
    i := 0
    for i < len(t.typeparams):
        ct := ""
        k := 0
        for k < len(bnames):
            if bnames[k] == t.typeparams[i]:
                ct = btypes[k]
            k = k + 1
        push(iargs, ct)                          # record the concrete type arg in typeparam order (for recover_struct_binds)
        nm = nm + "__" + gen_inst_mangle(ct)
        i = i + 1
    e := 0
    for e < len(sinsts):
        if sinsts[e].name == nm:
            return nm                            # already instantiated
        e = e + 1
    fs := []Field
    i = 0
    for i < len(t.fields):
        push(fs, Field(t.fields[i].name, subst_field_type(t.fields[i].ty, bnames, btypes)))
        i = i + 1
    push(sinsts, StructDef(nm, fs, []string, iargs))
    return nm

fn find_generic_enum(enums: [EnumDef], name: string) -> int:
    i := 0
    for i < len(enums):
        if enums[i].name == name and len(enums[i].typeparams) > 0:
            return i
        i = i + 1
    return -1

# Intern the concrete instance of generic enum `t` for the bindings (typeparam
# name -> concrete type); append the new EnumDef to `einsts`, return its mangled
# name. Variant payloads keep generic-application form (e.g. "Tree(int)") until a
# later resolve pass; instantiate dedups before substituting, so recursion ends.
fn instantiate_enum(t: EnumDef, bnames: [string], btypes: [string], einsts: inout [EnumDef]) -> string:
    nm := t.name
    iargs := []string                            # concrete type args, in typeparam order (provenance)
    i := 0
    for i < len(t.typeparams):
        ct := ""
        k := 0
        for k < len(bnames):
            if bnames[k] == t.typeparams[i]:
                ct = btypes[k]
            k = k + 1
        push(iargs, ct)
        nm = nm + "__" + gen_inst_mangle(ct)
        i = i + 1
    e := 0
    for e < len(einsts):
        if einsts[e].name == nm:
            return nm                            # already instantiated
        e = e + 1
    vs := []Variant
    i = 0
    for i < len(t.variants):
        npt := []string
        pj := 0
        for pj < len(t.variants[i].ptypes):
            push(npt, subst_field_type(t.variants[i].ptypes[pj], bnames, btypes))
            pj = pj + 1
        push(vs, Variant(t.variants[i].name, npt))
        i = i + 1
    push(einsts, EnumDef(nm, vs, []string, iargs))
    return nm

# When a generic-enum-application pattern (e.g. "Tree($T)") is matched against a
# concrete instance ("Tree__int") that has no parens to recurse into,
# match_typaram_str fails. Recover the bindings from the instance's recorded type
# args, so a recursive enum constructor whose payloads are all self-references
# (no bare $T to pin T), like `Node(Tree($T), Tree($T))`, still infers T.
fn recover_enum_binds(pat: string, concrete: string, enums: [EnumDef], einsts: [EnumDef], bnames: inout [string], btypes: inout [string]) -> bool:
    # Descend through container wrappers first: a recursive generic enum whose
    # payload holds the enum inside a container (`Node([Tree($T)])`, `[Tree($T)]`
    # vs `[Tree__int]`) gives match_typaram_str nothing to bind (the inner
    # application "Tree($T)" can't structurally match its mangled instance
    # "Tree__int"), so recover $T from the element's provenance. (Gap 3.)
    pn := len(pat)
    cn := len(concrete)
    if pn > 1 and cn > 1 and pat[0] == 91 and concrete[0] == 91 and pat[pn - 1] == 93 and concrete[cn - 1] == 93:   # "[E]" array
        return recover_enum_binds(substr(pat, 1, pn - 1), substr(concrete, 1, cn - 1), enums, einsts, &bnames, &btypes)
    if pn > 1 and cn > 1 and pat[0] == 123 and concrete[0] == 123 and pat[pn - 1] == 125 and concrete[cn - 1] == 125:   # "{K:V}" map: the self-ref can ride either side
        pin := substr(pat, 1, pn - 1)
        cin := substr(concrete, 1, cn - 1)
        pcol := find_top_colon(pin)
        ccol := find_top_colon(cin)
        if pcol >= 0 and ccol >= 0:
            if recover_enum_binds(substr(pin, pcol + 1, len(pin)), substr(cin, ccol + 1, len(cin)), enums, einsts, &bnames, &btypes):
                return true
            return recover_enum_binds(substr(pin, 0, pcol), substr(cin, 0, ccol), enums, einsts, &bnames, &btypes)
        return false
    pp := find(pat, "(")
    if pp <= 0 or pat[len(pat) - 1] != 41:       # ')'
        return false
    gi := find_generic_enum(enums, substr(pat, 0, pp))
    if gi < 0:
        return false
    pargs := split_type_args(substr(pat, pp + 1, len(pat) - 1))
    tps := enums[gi].typeparams
    if len(pargs) != len(tps):
        return false
    e := 0
    for e < len(einsts):
        if einsts[e].name == concrete and len(einsts[e].inst_args) == len(tps):
            mb := true
            i := 0
            for i < len(tps):
                mb = match_typaram_str(pargs[i], einsts[e].inst_args[i], &bnames, &btypes)
                i = i + 1
            mb = mb
            return true
        e = e + 1
    return false

# The callee name of a direct ECall (e.g. a mono'd generic-struct instance constructor
# `Box__int(..)`), else "". type_of returns the bare base name "Box" for a struct
# constructor, but the mono'd arg already names its instance, so recover keys off this.
fn call_callee(e: Expr) -> string:
    match e:
        ECall(nm, _a, _el):
            return nm
        _:
            return ""

# Recover a generic-struct field's typaram from a nested-instance arg, mirroring
# recover_enum_binds: a field `inner: Box($T)` constructed with a `Box(..)` arg sees the
# arg's type as the mangled instance name `Box__int` (not `Box(int)`), which doesn't
# structurally match `Box($T)`. Find that instance in sinsts and bind $T from its recorded
# inst_args. Only needed when the typaram has no other (bare/container) binding source.
fn recover_struct_binds(pat: string, concrete: string, structs: [StructDef], sinsts: [StructDef], bnames: inout [string], btypes: inout [string]) -> bool:
    pp := find(pat, "(")
    if pp <= 0 or pat[len(pat) - 1] != 41:       # ')'
        return false
    gi := find_generic_struct(structs, substr(pat, 0, pp))
    if gi < 0:
        return false
    pargs := split_type_args(substr(pat, pp + 1, len(pat) - 1))
    tps := structs[gi].typeparams
    if len(pargs) != len(tps):
        return false
    e := 0
    for e < len(sinsts):
        if sinsts[e].name == concrete and len(sinsts[e].inst_args) == len(tps):
            i := 0
            for i < len(tps):
                match_typaram_str(pargs[i], sinsts[e].inst_args[i], &bnames, &btypes)
                i = i + 1
            return true
        e = e + 1
    return false

# Split a type-argument string at top-level commas (respecting nested ()/[]).
fn split_type_args(s: string) -> [string]:
    out := []string
    depth := 0
    start := 0
    i := 0
    for i < len(s):
        c := s[i]
        if c == 40 or c == 91:                   # ( or [
            depth = depth + 1
        elif c == 41 or c == 93:                 # ) or ]
            depth = depth - 1
        elif c == 44 and depth == 0:             # , at top level
            push(out, substr(s, start, i))
            start = i + 1
        i = i + 1
    push(out, substr(s, start, len(s)))
    return out

# Stage 2b: resolve generic-struct instances in a type string ("Box(int)" ->
# "Box__int", interning the concrete StructDef). Recurses into parametric args
# ("Option(Box(int))" -> "Option(Box__int)"). Scalars/bare names, arrays, maps,
# tuples and fn-types pass through (their inner generic structs are Stage 3).
fn resolve_gtype(ty: string, structs: [StructDef], enums: [EnumDef], sinsts: inout [StructDef], einsts: inout [EnumDef]) -> string:
    n := len(ty)
    if n == 0:
        return ty
    if is_array(ty):                              # "[E]" -> "[resolve(E)]" (recursive generics: `[LL(int)]` -> `[LL__int]`)
        return "[" + resolve_gtype(elem_ty(ty), structs, enums, &sinsts, &einsts) + "]"
    if is_soa(ty):                                # "soa[E]" -> "soa[resolve(E)]"
        return "soa[" + resolve_gtype(soa_struct(ty), structs, enums, &sinsts, &einsts) + "]"
    if is_map(ty):                                # "{K:V}" -> "{K:resolve(V)}" (keys are scalar)
        return "{" + map_key(ty) + ":" + resolve_gtype(map_val(ty), structs, enums, &sinsts, &einsts) + "}"
    paren := -1
    i := 0
    for i < n:
        if ty[i] == 40 and paren < 0:            # first '('
            paren = i
        i = i + 1
    if paren > 0 and ty[n - 1] == 41:            # "Name(args)" (tuples start with '(' -> paren==0, excluded)
        name := substr(ty, 0, paren)
        args := split_type_args(substr(ty, paren + 1, n - 1))
        rargs := []string
        changed := false
        j := 0
        for j < len(args):
            r := resolve_gtype(args[j], structs, enums, &sinsts, &einsts)
            push(rargs, r)
            if r != args[j]:
                changed = true
            j = j + 1
        gi := find_generic_struct(structs, name)
        if gi >= 0:
            return instantiate_struct(structs[gi], structs[gi].typeparams, rargs, &sinsts)
        ei := find_generic_enum(enums, name)
        if ei >= 0:
            return instantiate_enum(enums[ei], enums[ei].typeparams, rargs, &einsts)
        if not changed:
            return ty
        out := name + "("
        j = 0
        for j < len(rargs):
            if j > 0:
                out = out + ","
            out = out + rargs[j]
            j = j + 1
        return out + ")"
    return ty

# Collect the struct names a field type embeds BY VALUE (so they must be emitted
# first). Names inside `[...]` (arrays/maps) are held by pointer -> not a by-value
# dep; names inside `(...)` (Option/Result/tuple) are by value -> a dep.
fn struct_byval_deps(ty: string, isstruct: [string], out: inout [string]):
    i := 0
    bdepth := 0
    n := len(ty)
    for i < n:
        c := ty[i]
        if c == 91:                              # [
            bdepth = bdepth + 1
            i = i + 1
        elif c == 93:                            # ]
            bdepth = bdepth - 1
            i = i + 1
        elif is_alpha(c):
            j := i
            for j < n and is_alnum(ty[j]):
                j = j + 1
            word := substr(ty, i, j)
            if bdepth == 0 and has_str(isstruct, word):
                push(out, word)
            i = j
        else:
            i = i + 1

# Stable topological sort: a struct embedding another by value is emitted after
# it. Ties break by input order, so a program already in dependency order is
# unchanged. Only called for generic programs (instances can land out of order),
# never for tychoc0.ty itself -> B==C byte-identical is preserved.
fn topo_structs(structs: [StructDef]) -> [StructDef]:
    isstruct := []string
    i := 0
    for i < len(structs):
        push(isstruct, structs[i].name)
        i = i + 1
    out := []StructDef
    done := []string
    pass := 0
    for pass <= len(structs):
        i = 0
        for i < len(structs):
            nm := structs[i].name
            if not has_str(done, nm):
                deps := []string
                f := 0
                for f < len(structs[i].fields):
                    struct_byval_deps(structs[i].fields[f].ty, isstruct, &deps)
                    f = f + 1
                ok := true
                d := 0
                for d < len(deps):
                    if deps[d] != nm and not has_str(done, deps[d]):
                        ok = false
                    d = d + 1
                if ok:
                    push(out, structs[i])
                    push(done, nm)
            i = i + 1
        pass = pass + 1
    i = 0
    for i < len(structs):                        # cycle fallback (invalid programs): append leftovers as-is
        if not has_str(done, structs[i].name):
            push(out, structs[i])
        i = i + 1
    return out

# UFCS x generics: does generic `gt`'s first parameter PATTERN accept a receiver
# of type `rty`? Feasibility check; binds are recomputed at instantiation.
fn ufcs_gen_matches(gt: Func, rty: string) -> bool:
    if len(gt.ptypes) < 1:
        return false
    bn := []string
    bt := []string
    return match_typaram_str(gt.ptypes[0], rty, &bn, &bt)

fn mono_exprs(es: [Expr], names: [string], types: [string], gens: [Func], insts: inout [Func], sinsts: inout [StructDef], einsts: inout [EnumDef], dc: Decls, ctx: Ctx) -> [Expr]:
    out := []Expr
    i := 0
    for i < len(es):
        push(out, mono_expr(es[i], names, types, gens, &insts, &sinsts, &einsts, dc, ctx))
        i = i + 1
    return out

fn mono_expr(e: Expr, names: [string], types: [string], gens: [Func], insts: inout [Func], sinsts: inout [StructDef], einsts: inout [EnumDef], dc: Decls, ctx: Ctx) -> Expr:
    match e:
        EInt(s, el):
            return e
        EBool(s, el):
            return e
        EChar(s, el):
            return e
        EFloat(s, el):
            return e
        EStr(s, el):
            return e
        EVar(s, el):
            return e
        EArrEmpty(t, el):
            return EArrEmpty(resolve_gtype(t, dc.structs, dc.enums, &sinsts, &einsts), el)   # generics: `[]LL(int)` -> `[]LL__int`
        EMapEmpty(k, v, el):
            return EMapEmpty(resolve_gtype(k, dc.structs, dc.enums, &sinsts, &einsts), resolve_gtype(v, dc.structs, dc.enums, &sinsts, &einsts), el)
        EBin(o, l, r, el):
            return EBin(o, mono_expr(l, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_expr(r, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), el)
        ECall(nm, a, el):
            margs := mono_exprs(a, names, types, gens, &insts, &sinsts, &einsts, dc, ctx)
            rn := nm                                  # generics: decode `name$<T;...>` explicit type args
            explicit := []string
            mk := find(nm, "$<")
            if mk >= 0:
                rn = substr(nm, 0, mk)
                explicit = split(substr(nm, mk + 2, len(nm) - 1), ";")
            if mk >= 0 and rn == "zero":              # zero$<T> is a builtin, not a generic -- leave the encoded name for gen_expr/type_of
                return ECall(nm, margs, el)
            di := find(nm, ".")                       # UFCS x generics, dotted form `recv.method` (parse_atom builds these as one ECall name)
            if mk < 0 and di >= 0:
                rcv := substr(nm, 0, di)
                meth := substr(nm, di + 1, len(nm))
                ug := find_generic(gens, meth)
                if ug >= 0 and has_str(names, rcv) and ufcs_gen_matches(gens[ug], var_type(names, types, rcv)):
                    allargs := []Expr
                    push(allargs, EVar(rcv, el))
                    ai := 0
                    for ai < len(margs):
                        push(allargs, margs[ai])
                        ai = ai + 1
                    at := []string
                    k := 0
                    for k < len(allargs):
                        push(at, type_of(allargs[k], names, types, dc, ctx))
                        k = k + 1
                    newnm := mono_instantiate(gens[ug], at, &insts, el, dc, []string)
                    return ECall(newnm, allargs, el)
            gi := find_generic(gens, rn)
            if gi >= 0:
                at := []string
                k := 0
                for k < len(a):
                    push(at, type_of(a[k], names, types, dc, ctx))   # type the ORIGINAL args: a nested generic call resolves to its concrete return via type_of, whereas the mono'd arg names its instance (not yet in dc)
                    k = k + 1
                newnm := mono_instantiate(gens[gi], at, &insts, el, dc, explicit)
                return ECall(newnm, margs, el)
            geni := -1                                # generic enum constructor: a variant of a generic enum
            gevi := -1
            gk := 0
            for gk < len(dc.enums):
                if len(dc.enums[gk].typeparams) > 0 and geni < 0:
                    vk := 0
                    for vk < len(dc.enums[gk].variants):
                        if dc.enums[gk].variants[vk].name == rn:
                            geni = gk
                            gevi = vk
                        vk = vk + 1
                gk = gk + 1
            if geni >= 0:
                gten := dc.enums[geni]
                bnames := []string
                btypes := []string
                if len(explicit) > 0:                 # `Leaf$(int)`: explicit type args (the only way to fix a nullary variant)
                    ek := 0
                    for ek < len(gten.typeparams):
                        if ek < len(explicit):
                            push(bnames, gten.typeparams[ek])
                            push(btypes, explicit[ek])
                        ek = ek + 1
                pk := 0                               # infer $T from each payload value
                gotm := false
                for pk < len(margs):
                    if pk < len(gten.variants[gevi].ptypes):
                        pat := gten.variants[gevi].ptypes[pk]
                        aty := type_of(margs[pk], names, types, dc, ctx)
                        gotm = match_typaram_str(pat, aty, &bnames, &btypes)
                        if not gotm:                  # a self-reference payload ("Tree($T)" vs a "Tree__int" arg) doesn't structurally match -- recover $T from the instance's provenance
                            gotm = recover_enum_binds(pat, aty, dc.enums, einsts, &bnames, &btypes)
                    pk = pk + 1
                gotm = gotm
                inste := instantiate_enum(gten, bnames, btypes, &einsts)
                return ECall(rn + "#" + inste, margs, el)   # encode the instance so codegen emits mk_<inste>_<rn> (variants are shared across instances)
            if mk >= 0:
                die("generics: explicit type arguments given, but '" + rn + "' is not a generic function")
            gsi := find_generic_struct(dc.structs, nm)   # generic struct construction: infer from field values
            if gsi >= 0 and len(margs) == len(dc.structs[gsi].fields):
                bnames := []string
                btypes := []string
                k := 0
                for k < len(margs):
                    ft := dc.structs[gsi].fields[k].ty
                    ct := type_of(a[k], names, types, dc, ctx)    # type the ORIGINAL arg a[k], NOT the mono'd margs[k]: a nested generic constructor in margs names its instance (e.g. Box__int), not yet in dc -> type_of would fail. (Same reason the generic-function case above uses a[k].)
                    cn := call_callee(margs[k])                   # if the mono'd arg is a generic-struct INSTANCE constructor (`Box__int(..)`), its instance name IS the concrete type. type_of of a generic constructor returns only the bare base name "Box", which binds a BARE `$T` field WRONG (`Box(Box(5))` -> T="Box" -> "unknown type 'Box'"); prefer the instance name.
                    cnok := cn != "" and is_struct(dc, ctx, cn)
                    if cn != "" and not cnok:                     # mid-mono the instance lives in sinsts, not yet in dc.structs
                        csi := 0
                        for csi < len(sinsts):
                            if sinsts[csi].name == cn:
                                cnok = true
                            csi = csi + 1
                    if cnok:
                        ct = cn
                    if not match_typaram_str(ft, ct, &bnames, &btypes):   # unify the field PATTERN against the concrete type; recurses into [$V] / {string:$V} / fn(...). On a structural miss (a sole nested-generic field "Box($T)" vs a "Box__int" arg), recover $T from the instance's recorded inst_args (mirrors the enum path).
                        recover_struct_binds(ft, cn, dc.structs, sinsts, &bnames, &btypes)
                    k = k + 1
                newnm := instantiate_struct(dc.structs[gsi], bnames, btypes, &sinsts)
                return ECall(newnm, margs, el)
            return ECall(nm, margs, el)
        EField(b, f, el):
            return EField(mono_expr(b, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), f, el)
        EIndex(b, ix, el):
            return EIndex(mono_expr(b, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_expr(ix, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), el)
        EArrLit(es, el):
            return EArrLit(mono_exprs(es, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), el)
        EMapLit(ks, vs, el):
            return EMapLit(mono_exprs(ks, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_exprs(vs, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), el)
        ETuple(es, el):
            return ETuple(mono_exprs(es, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), el)
        ESlice(b, lo, hi, el):
            return ESlice(mono_expr(b, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_expr(lo, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_expr(hi, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), el)
        EAddr(x, el):
            return EAddr(mono_expr(x, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), el)
        ELambda(id, ps, pts, r, bx, cn, ct, el):
            return e                              # lambda bodies with generic calls are 1c
        ECallV(c, a, el):
            fn0 := efield_fname(c)                 # UFCS x generics: x.foo(args), foo a generic free fn -> foo(x, args)
            if fn0 != "":
                ug := find_generic(gens, fn0)
                if ug >= 0:
                    origrecv := efield_base(c)
                    rty := type_of(origrecv, names, types, dc, ctx)   # concrete (via the substitute path), even for a nested generic call
                    if ufcs_gen_matches(gens[ug], rty):
                        allargs := []Expr
                        at := []string
                        push(allargs, mono_expr(origrecv, names, types, gens, &insts, &sinsts, &einsts, dc, ctx))   # instantiate a nested generic receiver
                        push(at, rty)
                        ai := 0
                        for ai < len(a):
                            push(allargs, mono_expr(a[ai], names, types, gens, &insts, &sinsts, &einsts, dc, ctx))
                            push(at, type_of(a[ai], names, types, dc, ctx))
                            ai = ai + 1
                        newnm := mono_instantiate(gens[ug], at, &insts, el, dc, []string)
                        return ECall(newnm, allargs, el)
            return ECallV(mono_expr(c, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_exprs(a, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), el)
        ESpawn(id, nm, a, el):
            return ESpawn(id, nm, mono_exprs(a, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), el)

fn mono_stmt(s: Stmt, names: inout [string], types: inout [string], gens: [Func], insts: inout [Func], sinsts: inout [StructDef], einsts: inout [EnumDef], dc: Decls, ctx: Ctx) -> Stmt:
    match s:
        SDecl(nm, rhs, ln):
            mr := mono_expr(rhs, names, types, gens, &insts, &sinsts, &einsts, dc, ctx)
            # type the ORIGINAL rhs: its generic calls resolve via the template
            # sigs (still in dc) to "$T" — a harmless env placeholder. The rewritten
            # `mr` names instances not yet in dc; the final codegen recomputes the
            # real type from the instance-bearing dc.
            ty := type_of(rhs, names, types, dc, ctx)
            push(names, nm)
            push(types, ty)
            return SDecl(nm, mr, ln)
        STypedDecl(nm, ty, rhs, ln):
            mr := mono_expr(rhs, names, types, gens, &insts, &sinsts, &einsts, dc, ctx)
            rty := resolve_gtype(ty, dc.structs, dc.enums, &sinsts, &einsts)   # Stage 2b: `x: Box(int)` annotation
            push(names, nm)
            push(types, rty)
            return STypedDecl(nm, rty, mr, ln)
        SAssign(nm, rhs, ln):
            return SAssign(nm, mono_expr(rhs, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), ln)
        SFieldAssign(lv, rhs, ln):
            return SFieldAssign(mono_expr(lv, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_expr(rhs, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), ln)
        SPrint(e, ln):
            return SPrint(mono_expr(e, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), ln)
        SReturn(e, ln):
            return SReturn(mono_expr(e, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), ln)
        SConst(nm, rhs, ln):
            return s
        SReturnVoid:
            return s
        SIf(c, th, el, ln):
            return SIf(mono_expr(c, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_block(th, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_block(el, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), ln)
        SWhile(c, body, ln):
            return SWhile(mono_expr(c, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_block(body, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), ln)
        SForRange(v, a, b, st, body, ln):
            nn := names
            tt := types
            push(nn, v)
            push(tt, "int")
            return SForRange(v, mono_expr(a, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_expr(b, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_expr(st, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_block(body, nn, tt, gens, &insts, &sinsts, &einsts, dc, ctx), ln)
        SExpr(e, ln):
            return SExpr(mono_expr(e, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), ln)
        SOrReturn(nm, e, ln):
            mr := mono_expr(e, names, types, gens, &insts, &sinsts, &einsts, dc, ctx)
            push(names, nm)
            push(types, "int")                    # precise unwrap type is 1c; unused by 1a
            return SOrReturn(nm, mr, ln)
        SDestructure(nms, e, ln):
            return SDestructure(nms, mono_expr(e, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), ln)
        SMultiAssign(nms, e, ln):
            return SMultiAssign(nms, mono_expr(e, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), ln)
        SMatch(subj, vars, binds, bodies, ln):
            # register each arm's payload bindings (kids in `Node(kids)`) before
            # walking the arm body, so a binding referenced by a mono'd decl (a
            # foreach's `_fc := kids`) types instead of dying `unknown variable`.
            # Rough types are fine here (mono uses placeholders; final codegen
            # recomputes from the instance-bearing dc).
            msty := resolve_ginst(type_of(subj, names, types, dc, ctx), dc, ctx)
            nb := [][Stmt]
            i := 0
            for i < len(bodies):
                bn := names
                bt := types
                if i < len(vars):
                    pts := match_arm_ptypes(dc, ctx, msty, vars[i])
                    j := 0
                    for j < len(binds[i]):
                        push(bn, binds[i][j])
                        if j < len(pts):
                            push(bt, pts[j])
                        else:
                            push(bt, "int")
                        j = j + 1
                push(nb, mono_block(bodies[i], bn, bt, gens, &insts, &sinsts, &einsts, dc, ctx))
                i = i + 1
            return SMatch(mono_expr(subj, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), vars, binds, nb, ln)
        SBreak:
            return s
        SContinue:
            return s
        SSelect(uid, kinds, chans, bnds, bodies, ln):
            # register each `recv(ch, x)` arm's binding (type = the channel element)
            # before walking the arm body, so a `match x` (or any decl referencing x)
            # in the body types instead of dying `unknown variable` -- same need as
            # SMatch above, on the select path.
            nb := [][Stmt]
            i := 0
            for i < len(bodies):
                bn := names
                bt := types
                if i < len(kinds) and kinds[i] == "recv" and i < len(bnds) and bnds[i] != "":
                    cit := resolve_ginst(chan_inner(type_of(chans[i], names, types, dc, ctx)), dc, ctx)
                    push(bn, bnds[i])
                    push(bt, cit)
                push(nb, mono_block(bodies[i], bn, bt, gens, &insts, &sinsts, &einsts, dc, ctx))
                i = i + 1
            return SSelect(uid, kinds, mono_exprs(chans, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), bnds, nb, ln)
        SParFor(v, a, b, body, pid, fl):
            nn := names
            tt := types
            push(nn, v)
            push(tt, "int")
            return SParFor(v, mono_expr(a, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_expr(b, names, types, gens, &insts, &sinsts, &einsts, dc, ctx), mono_block(body, nn, tt, gens, &insts, &sinsts, &einsts, dc, ctx), pid, fl)
        SValDecl(nm, annot, cc, ln):
            mcc := mono_stmt(cc, &names, &types, gens, &insts, &sinsts, &einsts, dc, ctx)   # mono the branch tails (n not yet in scope)
            if annot == "":
                ty := value_ctrl_type(cc, names, types, dc, ctx, ln)   # rough type from the ORIGINAL ctrl (final codegen recomputes)
                push(names, nm)
                push(types, ty)
                return SValDecl(nm, "", mcc, ln)
            rty := resolve_gtype(annot, dc.structs, dc.enums, &sinsts, &einsts)   # Stage 2b generic annotation
            push(names, nm)
            push(types, rty)
            return SValDecl(nm, rty, mcc, ln)

fn mono_block(stmts: [Stmt], names: [string], types: [string], gens: [Func], insts: inout [Func], sinsts: inout [StructDef], einsts: inout [EnumDef], dc: Decls, ctx: Ctx) -> [Stmt]:
    nm := names                                   # by-value copy -> a block's decls don't leak to the caller (scope)
    ty := types
    out := []Stmt
    i := 0
    for i < len(stmts):
        push(out, mono_stmt(stmts[i], &nm, &ty, gens, &insts, &sinsts, &einsts, dc, ctx))
        i = i + 1
    return out

fn monomorphize_program(prog: Program, dc: Decls, ctx: Ctx) -> Program:
    gens := []Func
    concrete := []Func
    i := 0
    for i < len(prog.funcs):
        if func_is_generic(prog.funcs[i]):
            push(gens, prog.funcs[i])
        else:
            push(concrete, prog.funcs[i])
        i = i + 1
    has_gstruct := false
    gs := 0
    for gs < len(prog.structs):
        if len(prog.structs[gs].typeparams) > 0:
            has_gstruct = true
        gs = gs + 1
    has_genum := false
    ge := 0
    for ge < len(prog.enums):
        if len(prog.enums[ge].typeparams) > 0:
            has_genum = true
        ge = ge + 1
    if len(gens) == 0 and not has_gstruct and not has_genum:
        return prog                               # no templates: program unchanged (byte-identical)
    insts := []Func
    sinsts := []StructDef
    einsts := []EnumDef
    out := []Func
    i = 0
    for i < len(concrete):
        f := concrete[i]
        names := []string
        types := []string
        seed_env(f, &names, &types)
        nbody := mono_block(f.body, names, types, gens, &insts, &sinsts, &einsts, dc, ctx)
        rpt := []string                           # Stage 2b: resolve `Box(int)` type-position in the signature
        j := 0
        for j < len(f.ptypes):
            push(rpt, resolve_gtype(f.ptypes[j], dc.structs, dc.enums, &sinsts, &einsts))
            j = j + 1
        rret := resolve_gtype(f.ret, dc.structs, dc.enums, &sinsts, &einsts)
        push(out, Func(f.name, f.params, rpt, rret, nbody, f.is_extern, f.lib, f.constraints))
        i = i + 1
    # Stage-2 (#3): re-drive each instance body through mono_block to discover and
    # rename NESTED generic calls (a generic calling another generic). An instance
    # body came from subst_block_t, which substituted TYPES but left a nested call
    # under its template name; mono_block (via mono_expr's ECall -> mono_instantiate)
    # renames it and appends any newly-needed instance. The index re-reads
    # len(insts) each iteration, so the worklist drains to a fixpoint; mono_instantiate
    # dedups by name, so non-recursive and same-type-recursive chains terminate
    # (a growing-type recursion would not -- that guard is a later step).
    wi := 0
    for wi < len(insts):
        inst := insts[wi]
        inames := []string
        itypes := []string
        seed_env(inst, &inames, &itypes)
        ibody := mono_block(inst.body, inames, itypes, gens, &insts, &sinsts, &einsts, dc, ctx)
        insts[wi] = Func(inst.name, inst.params, inst.ptypes, inst.ret, ibody, inst.is_extern, inst.lib, inst.constraints)
        wi = wi + 1
    i = 0
    for i < len(insts):                           # instances last, in first-encounter order (matches tychoc)
        push(out, insts[i])
        i = i + 1
    rconcrete := []StructDef                      # drop generic templates; resolve concrete field types
    i = 0
    for i < len(prog.structs):
        if len(prog.structs[i].typeparams) == 0:
            rf := []Field                         # Stage 2b: resolve `Box(int)` type-position in fields
            j := 0
            for j < len(prog.structs[i].fields):
                push(rf, Field(prog.structs[i].fields[j].name, resolve_gtype(prog.structs[i].fields[j].ty, dc.structs, dc.enums, &sinsts, &einsts)))
                j = j + 1
            push(rconcrete, StructDef(prog.structs[i].name, rf, []string, prog.structs[i].inst_args))
        i = i + 1
    renums := []EnumDef                           # drop generic enum templates; resolve concrete payload types
    i = 0
    for i < len(prog.enums):
        if len(prog.enums[i].typeparams) == 0:
            rvs := []Variant
            vj := 0
            for vj < len(prog.enums[i].variants):
                npts := []string
                pk := 0
                for pk < len(prog.enums[i].variants[vj].ptypes):
                    push(npts, resolve_gtype(prog.enums[i].variants[vj].ptypes[pk], dc.structs, dc.enums, &sinsts, &einsts))
                    pk = pk + 1
                push(rvs, Variant(prog.enums[i].variants[vj].name, npts))
                vj = vj + 1
            push(renums, EnumDef(prog.enums[i].name, rvs, []string, []string))
        i = i + 1
    # Resolve generic references inside instance fields/payloads so nested/recursive
    # generics work: LL__int.tail "[LL(int)]" -> "[LL__int]"; Tree__int.Node payload
    # "Tree(int)" -> "Tree__int". struct and enum instances can reference each other,
    # so loop until neither list grows; instantiate_* dedups, so recursion terminates.
    sdone := 0
    edone := 0
    for sdone < len(sinsts) or edone < len(einsts):
        for sdone < len(sinsts):
            rf2 := []Field
            fj := 0
            for fj < len(sinsts[sdone].fields):
                push(rf2, Field(sinsts[sdone].fields[fj].name, resolve_gtype(sinsts[sdone].fields[fj].ty, dc.structs, dc.enums, &sinsts, &einsts)))
                fj = fj + 1
            sinsts[sdone] = StructDef(sinsts[sdone].name, rf2, []string, sinsts[sdone].inst_args)
            sdone = sdone + 1
        for edone < len(einsts):
            rvs2 := []Variant
            vj2 := 0
            for vj2 < len(einsts[edone].variants):
                npt2 := []string
                pk2 := 0
                for pk2 < len(einsts[edone].variants[vj2].ptypes):
                    push(npt2, resolve_gtype(einsts[edone].variants[vj2].ptypes[pk2], dc.structs, dc.enums, &sinsts, &einsts))
                    pk2 = pk2 + 1
                push(rvs2, Variant(einsts[edone].variants[vj2].name, npt2))
                vj2 = vj2 + 1
            einsts[edone] = EnumDef(einsts[edone].name, rvs2, []string, einsts[edone].inst_args)
            edone = edone + 1
    i = 0
    for i < len(einsts):                          # enum instances after the concrete enums
        push(renums, einsts[i])
        i = i + 1
    # tychoc0 emits struct bodies in list order (no topo sort). A struct instance can
    # depend on a concrete struct (Box(Point)) or vice versa, so topologically sort
    # them by by-value embedding (stable: ties keep input order).
    allstructs := []StructDef
    i = 0
    for i < len(rconcrete):
        push(allstructs, rconcrete[i])
        i = i + 1
    i = 0
    for i < len(sinsts):
        push(allstructs, sinsts[i])
        i = i + 1
    return Program(topo_structs(allstructs), renums, out, prog.ntnames, prog.ntunder, prog.handles)

# Run the lift over a whole program: returns the program with ELambda nodes
# stamped + lifted `__lam<id>` funcs appended, and fills `lams` (one per lambda)
# for env-struct + thunk emission. `dc` carries the ORIGINAL function sigs (built
# before the lift) so capture-type lookups resolve; rebuilt afterwards by main.
fn lift_program(prog: Program, dc: Decls, ctx: Ctx, lams: inout [LamInfo], spawns: inout [SpawnInfo], pars: inout [ParInfo]) -> Program:
    lifted := []Func
    ctr := 0
    nfuncs := []Func
    i := 0
    for i < len(prog.funcs):
        f := prog.funcs[i]
        if block_has_lambda(f.body):                  # only lambda-bearing funcs need the scope-aware lift (which
            names := []string                         # calls type_of); a lambda-free func is left UNCHANGED, so a
            types := []string                         # lambda-free program (incl. tychoc0.ty) is byte-identical.
            seed_env(f, &names, &types)
            push(nfuncs, Func(f.name, f.params, f.ptypes, f.ret, lift_block(f.body, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, f.ret), f.is_extern, f.lib, f.constraints))
        else:
            push(nfuncs, f)
        i = i + 1
    i = 0
    for i < len(lifted):
        push(nfuncs, lifted[i])
        i = i + 1
    return Program(prog.structs, prog.enums, nfuncs, prog.ntnames, prog.ntunder, prog.handles)

# Fail-closed declaration checks (parity with the C compiler's parse-time
# guards): reject duplicate type names (struct/enum/newtype share one
# namespace), duplicate variant names (package-scoped), duplicate function
# names (no overloading), and duplicate struct field names. Without these,
# tychoc0 accepted such programs and emitted C with duplicate symbols/members
# that cc then rejected (a fail-open). Message-only: the decl AST carries no
# position. Never fires on valid input, so fixpoint output is unchanged.
# fall-off-the-end lint: does every path through `body` end in a return? An
# exhaustive match returns iff every arm does; an if returns iff it has an else
# and both sides return (an elif chain is a nested SIf handled by recursion).
# Mirrors block_ends_in_return in src/tychoc.c.
fn block_ends_in_return(body: [Stmt]) -> bool:
    if len(body) == 0:
        return false
    s := body[len(body) - 1]
    match s:
        SReturn(_e, _l):
            return true
        SReturnVoid:
            return true
        SIf(_c, t, el, _l):
            return len(el) > 0 and block_ends_in_return(t) and block_ends_in_return(el)
        SMatch(_subj, _vars, _binds, bodies, _l):
            allret := len(bodies) > 0
            i := 0
            for i < len(bodies):
                if not block_ends_in_return(bodies[i]):
                    allret = false
                i = i + 1
            return allret
        _:
            return false

fn check_dups(prog: Program):
    tnames := []string
    i := 0
    for i < len(prog.structs):
        nm := prog.structs[i].name
        if has_str(tnames, nm):
            die("type '" + nm + "' is already defined")
        push(tnames, nm)
        fnames := []string
        j := 0
        for j < len(prog.structs[i].fields):
            fnm := prog.structs[i].fields[j].name
            if has_str(fnames, fnm):
                die("duplicate field '" + fnm + "' in struct '" + nm + "'")
            push(fnames, fnm)
            j = j + 1
        i = i + 1
    i = 0
    for i < len(prog.enums):
        nm := prog.enums[i].name
        if has_str(tnames, nm):
            die("type '" + nm + "' is already defined")
        push(tnames, nm)
        i = i + 1
    i = 0
    for i < len(prog.ntnames):
        if has_str(tnames, prog.ntnames[i]):
            die("type '" + prog.ntnames[i] + "' is already defined")
        push(tnames, prog.ntnames[i])
        i = i + 1
    vnames := []string
    i = 0
    for i < len(prog.enums):
        j := 0
        for j < len(prog.enums[i].variants):
            vn := prog.enums[i].variants[j].name
            if has_str(vnames, vn):
                die("variant name '" + vn + "' is already used in this package")
            push(vnames, vn)
            j = j + 1
        i = i + 1
    fns := []string
    i = 0
    for i < len(prog.funcs):
        nm := prog.funcs[i].name
        if has_str(fns, nm):
            die("'" + nm + "' is already defined")
        push(fns, nm)
        pnames := []string                            # duplicate parameter name -> duplicate C param
        j := 0
        for j < len(prog.funcs[i].params):
            pn := prog.funcs[i].params[j]
            if has_str(pnames, pn):
                die("duplicate parameter '" + pn + "' in function '" + nm + "'")
            push(pnames, pn)
            j = j + 1
        # fall-off-the-end lint (parity with src/tychoc.c): a non-void concrete
        # proc whose body can reach its end without a return silently yields a
        # zero value. Warn, don't reject (a body ending in an infinite loop is
        # total yet not provably so). Extern (no body) and generic templates skip.
        f := prog.funcs[i]
        if f.ret != "void" and f.is_extern == 0 and not func_is_generic(f) and not block_ends_in_return(f.body):
            ln := 0
            if len(f.body) > 0:
                ln = stmt_line(f.body[0]) / 100000
            eprint("line " + str(ln) + ": warning: not all paths of '" + nm + "' return a value (a fall-off-the-end yields a zero value)" + chr(10))
        i = i + 1
    if not has_str(fns, "main"):                  # fail-closed: a program with no main emits main-less C (parity with tychoc)
        die("no 'main' procedure")

fn main():
    a := args()
    src := ""
    if len(a) > 1:                                  # `tychoc0 path` : compile that file or package
        content := read_file(a[1])
        if is_package(lex(content)):
            seen := []string
            src = bundle(dir_of(a[1]), true, &seen)
        else:
            src = content
    else:                                           # no argument : read stdin (the bootstrap path)
        src = read_all()
    toks := lex(src)
    pos := 0
    prog0 := parse_program(toks, &pos)
    check_dups(prog0)                                 # fail-closed: reject duplicate decls before codegen
    sigs0 := []Sig                                    # sigs over the ORIGINAL funcs: capture-type lookups during the lift
    sigmap0 := []string: int
    i := 0
    for i < len(prog0.funcs):
        push(sigs0, mk_sig(prog0.funcs[i].name, prog0.funcs[i].ret, prog0.funcs[i].ptypes, prog0.funcs[i].is_extern))
        if sigmap0.get(prog0.funcs[i].name, -1) < 0:
            sigmap0[prog0.funcs[i].name] = i
        i = i + 1
    src_lines := split(src, chr(10))                  # for die_at diagnostics (snippet + caret)
    dc0 := Decls(sigs0, prog0.structs, prog0.enums, prog0.ntnames, prog0.ntunder, sigmap0, []ParInfo, src_lines, build_vmap(prog0.enums), prog0.handles)
    ctx0 := Ctx([]string, []string, "", "0", 0, []int, []string, 0, []string, []string, []string, 0, "")
    lams := []LamInfo
    spawns := []SpawnInfo                             # CC: spawn sites (incl. parallel-for chunks)
    pars := []ParInfo                                 # CC-3: parallel-for sites
    prog := lift_program(prog0, dc0, ctx0, &lams, &spawns, &pars)     # stamp lambdas + capture analysis + lifted __lam funcs
    funcs := prog.funcs
    sigs := []Sig
    sigmap := []string: int
    i = 0
    for i < len(funcs):
        push(sigs, mk_sig(funcs[i].name, funcs[i].ret, funcs[i].ptypes, funcs[i].is_extern))
        if sigmap.get(funcs[i].name, -1) < 0:        # first-match wins (matches the old scan)
            sigmap[funcs[i].name] = i
        i = i + 1
    dc := Decls(sigs, prog.structs, prog.enums, prog.ntnames, prog.ntunder, sigmap, pars, src_lines, build_vmap(prog.enums), prog.handles)
    ctx := Ctx([]string, []string, "", "0", 0, []int, []string, 0, []string, []string, []string, 0, "")
    # generics: expand `$T` templates into concrete instances, then rebuild the
    # sig tables from the monomorphized program (templates dropped, instances added)
    prog = monomorphize_program(prog, dc, ctx)
    funcs = prog.funcs
    sigs = []Sig
    sigmap = []string: int
    i = 0
    for i < len(funcs):
        push(sigs, mk_sig(funcs[i].name, funcs[i].ret, funcs[i].ptypes, funcs[i].is_extern))
        if sigmap.get(funcs[i].name, -1) < 0:
            sigmap[funcs[i].name] = i
        i = i + 1
    dc = Decls(sigs, prog.structs, prog.enums, prog.ntnames, prog.ntunder, sigmap, pars, src_lines, build_vmap(prog.enums), prog.handles)
    ets := collect_elem_types(prog, dc, ctx)
    out := preamble()
    # Emission order is carefully staged so every C type is complete before use,
    # supporting arrays-of-structs, recursive structs, and mutual struct/enum refs:
    i = 0                                        # 1a. forward-declare struct tags
    for i < len(prog.structs):
        out = out + "typedef struct " + ust(prog.structs[i].name) + " " + ust(prog.structs[i].name) + ";\n"
        i = i + 1
    i = 0                                        # 1b. forward-declare enum tags
    for i < len(prog.enums):
        out = out + "typedef struct " + uet(prog.enums[i].name) + " " + uet(prog.enums[i].name) + ";\n"
        i = i + 1
    i = 0                                        # 1b'. forward-declare composite array/map tags so a fn value whose
    for i < len(ets):                            #      param/ret is [T]/[K:V] (fn([T])->R) can name it incomplete
        if not is_soa(ets[i]):   # array-of-X forward typedef for every element kind incl. MAPS (array-of-map) and tuples; a harmless extra family if that element type is never actually arrayed
            out = out + "typedef struct Arr_" + mangle(ets[i]) + "_ Arr_" + mangle(ets[i]) + ";\n"
        i = i + 1
    i = 0
    for i < len(ets):
        if is_map(ets[i]):
            mt := mstruct(ets[i])
            out = out + "typedef struct " + mt + "_ " + mt + ";\n"
        i = i + 1
    i = 0                                        # 1b''. tuple forward typedefs: a composite-keyed map struct holds a Tup_X* (keys/ord), so Tup_X must be a known (incomplete) type before the map struct bodies
    for i < len(ets):
        if is_tuple(ets[i]):
            out = out + "typedef struct Tup_" + tup_suffix(ets[i]) + "_ Tup_" + tup_suffix(ets[i]) + ";\n"
        i = i + 1
    i = 0                                        # 1c. function-value typedefs FIRST — a container may hold a fn
    has_fnval := false                           #     value (array elem / struct field), so Fn_<suffix> must be
    for i < len(ets):                            #     complete before the array/struct bodies that embed it.
        if is_func(ets[i]):                      #     Common param/ret types (scalars/strings) are complete here.
            out = out + gen_func_typedef(dc, ctx, ets[i])
            has_fnval = true
        i = i + 1
    i = 0                                        # 2. array STRUCT bodies (element types
    for i < len(ets):                            #    only appear as pointers here, so fwd decls suffice)
        if not is_soa(ets[i]):   # array-of-X struct body for every element kind incl. MAPS; the element appears only as a pointer here, so its forward typedef suffices
            out = out + gen_arr_type(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # 2c. soa typedefs + helper fwd decls (before struct
    for i < len(ets):                            #     bodies, so a struct may embed a soa by value)
        if is_soa(ets[i]):
            out = out + gen_soa_decl(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # map struct(s), one per value type used
    for i < len(ets):
        if is_map(ets[i]):
            out = out + gen_map_type(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # 3. enum + struct eq prototypes (mutual recursion)
    for i < len(prog.enums):
        out = out + "static int " + uet(prog.enums[i].name) + "_eq(" + uet(prog.enums[i].name) + "* a, " + uet(prog.enums[i].name) + "* b);\n"
        i = i + 1
    i = 0
    for i < len(prog.structs):
        out = out + "static int " + ust(prog.structs[i].name) + "_eq(" + ust(prog.structs[i].name) + " a, " + ust(prog.structs[i].name) + " b);\n"
        if struct_keyused(dc, ctx, ets, prog.structs[i].name):   # composite map key: forward-declare the deep hash so map slot fns (emitted earlier) can call it
            out = out + "static unsigned long " + ust(prog.structs[i].name) + "_hash(" + ust(prog.structs[i].name) + " v);\n"
        i = i + 1
    i = 0                                        # tuple deep-hash protos (keyed tuples): before any hash body, so struct/tuple hashes can reference each other
    for i < len(ets):
        if is_tuple(ets[i]) and struct_keyused(dc, ctx, ets, ets[i]):
            out = out + "static unsigned long Tup_" + tup_suffix(ets[i]) + "_hash(Tup_" + tup_suffix(ets[i]) + " v);\n"
        i = i + 1
    i = 0                                        # array deep-hash protos (arrays used as keys): before any hash body
    for i < len(ets):
        if not is_map(ets[i]) and not is_soa(ets[i]) and struct_keyused(dc, ctx, ets, "[" + ets[i] + "]"):
            out = out + "static unsigned long Arr_" + mangle(ets[i]) + "_hash(Arr_" + mangle(ets[i]) + " x);\n"
        i = i + 1
    # 4 + 5a. struct AND tuple bodies in topological order — a struct may embed a tuple by
    # value and a tuple may embed a struct, so a single dependency-ordered pass (not two
    # fixed phases) is needed. emit_comp_body recurses into by-value struct/tuple deps first.
    emitted_comp := []string
    i = 0
    for i < len(prog.structs):
        out = out + emit_comp_body(dc, ctx, prog.structs[i].name, &emitted_comp)
        i = i + 1
    i = 0
    for i < len(ets):
        if is_tuple(ets[i]):
            out = out + emit_comp_body(dc, ctx, ets[i], &emitted_comp)
        i = i + 1
    i = 0                                        # 5. enum bodies AFTER structs/tuples (a payload may embed a value struct/tuple, now complete; nothing embeds an enum by value -- it's always a pointer)
    for i < len(prog.enums):
        out = out + gen_enum_decl(prog.enums[i], dc, ctx)
        i = i + 1
    i = 0                                        # 5a''. closure env structs (one per capturing lambda)
    for i < len(lams):
        if len(lams[i].capnames) > 0:
            out = out + "typedef struct {"
            cj := 0
            for cj < len(lams[i].captypes):
                out = out + " " + cty(dc, ctx, lams[i].captypes[cj]) + "c" + str(cj) + ";"
                cj = cj + 1
            out = out + " } Env_" + str(lams[i].id) + ";\n"
        i = i + 1
    i = 0                                        # 5b. struct/tuple copy PROTOTYPES, so the array
    for i < len(prog.structs):                   #     _from bodies below can deep-copy struct/tuple
        sn := prog.structs[i].name               #     elements regardless of copy-fn definition order
        if struct_is_heap(dc, ctx, sn):
            out = out + "static " + ust(sn) + " " + ust(sn) + "_copy(Arena* ar, " + ust(sn) + " s);\n"
        i = i + 1
    i = 0
    for i < len(ets):
        if is_tuple(ets[i]):
            tn := "Tup_" + tup_suffix(ets[i])
            out = out + "static " + tn + " " + tn + "_copy(Arena* ar, " + tn + " s);\n"
            out = out + "static int " + tn + "_eq(" + tn + " a, " + tn + " b);\n"   # composite map fns (emitted before tuple eq bodies) call this
        i = i + 1
    i = 0                                        # 5c. enum copy protos (mutual recursion + array/
    for i < len(prog.enums):                     #     struct/tuple copy may deep-copy enum members)
        en := prog.enums[i].name
        out = out + "static " + uet(en) + "* " + uet(en) + "_copy(Arena* ar, " + uet(en) + "* s);\n"
        i = i + 1
    i = 0                                        # 6. array FUNCTIONS (need element bodies
    for i < len(ets):                            #    complete for sizeof / by-value moves)
        if not is_map(ets[i]) and not is_soa(ets[i]):   # tuples included: a [tuple] array (e.g. keys() of a tuple key) needs Arr_<tuple>; harmless extra family if the tuple is never arrayed
            out = out + gen_arr_fns(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # 6b. soa families (after struct bodies: push takes S_X by value)
    for i < len(ets):
        if is_soa(ets[i]):
            out = out + gen_soa(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # shared hash + per-value-type map families
    has_map := false
    for i < len(ets):
        if is_map(ets[i]):
            has_map = true
        i = i + 1
    if has_map:
        out = out + gen_mhash()
    i = 0                                        # array deep-hash bodies (keyed arrays): AFTER gen_mhash (they call ikhash/mhash) but the protos are early so map fns can call them
    for i < len(ets):
        if not is_map(ets[i]) and not is_soa(ets[i]) and struct_keyused(dc, ctx, ets, "[" + ets[i] + "]"):
            out = out + gen_arr_hash(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # map _copy/_eq FORWARD DECLS: an outer map's put/copy deep-copies its inner-map VALUES via the inner map's _copy/_eq, but map families are emitted in ets order, not dependency order (e.g. an array branch pushes a map element before recursing into its value map), so a container map can precede its value map. Forward-declare so emission order never matters (mirrors the array/struct copy protos).
    for i < len(ets):
        if is_map(ets[i]):
            mm := mstruct(ets[i])
            out = out + "static " + mm + " " + mangle(ets[i]) + "_copy(Arena* ar, " + mm + " m);\n"
            out = out + "static int " + mangle(ets[i]) + "_eq(" + mm + " a, " + mm + " b);\n"
        i = i + 1
    i = 0
    for i < len(ets):
        if is_map(ets[i]):
            out = out + gen_map_fns(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # array-of-map FUNCTIONS: after gen_map_fns so Arr_<map>_from/_copy/_eq can call map_*_copy/_eq (their struct + fwd decls were emitted with the other array families above)
    for i < len(ets):
        if is_map(ets[i]):
            out = out + gen_arr_fns(dc, ctx, ets[i])
        i = i + 1
    out = out + gen_strlib()
    i = 0                                        # 6b. tuple copy + equality (may call array fns above)
    for i < len(ets):
        if is_tuple(ets[i]):
            out = out + gen_tuple_copy(dc, ctx, ets[i])
            out = out + gen_tuple_eq(dc, ctx, ets[i])
            if struct_keyused(dc, ctx, ets, ets[i]):   # tuple used as a composite map key: deep hash
                out = out + gen_tuple_hash(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # 7. enum constructors + copy + equality
    for i < len(prog.enums):
        out = out + gen_enum_ctors(prog.enums[i], dc, ctx)
        i = i + 1
    i = 0
    for i < len(prog.enums):
        out = out + gen_enum_copy(prog.enums[i], dc, ctx)
        i = i + 1
    i = 0
    for i < len(prog.enums):
        out = out + gen_enum_eq(prog.enums[i], dc, ctx)
        i = i + 1
    i = 0                                        # 8. struct equality + deep-copy fns
    for i < len(prog.structs):
        out = out + gen_struct_eq(dc, ctx, prog.structs[i])
        if struct_keyused(dc, ctx, ets, prog.structs[i].name):   # composite map key: deep hash, paired with _eq, emitted before any map that uses it
            out = out + gen_struct_hash(dc, ctx, prog.structs[i])
        if struct_is_heap(dc, ctx, prog.structs[i].name):
            out = out + gen_struct_copy(dc, ctx, prog.structs[i])
        i = i + 1
    i = 0                                        # 9. prototypes
    for i < len(funcs):
        if funcs[i].is_extern == 1:              # FFI: real C ABI decl, not the h_/arena proto
            out = out + gen_extern_proto(funcs[i], dc, ctx)
        elif funcs[i].name != "main":
            out = out + gen_proto(funcs[i], dc, ctx)
        i = i + 1
    i = 0                                        # 9a'. CC spawn sites: per-site args struct + thread trampoline.
    for i < len(spawns):                         #      The trampoline runs the call with the task's root arena as
        si := str(i)                             #      _parent, parks the result in a root-allocated slot, then
        out = out + "typedef struct { HTask* t;"  #     flushes this thread's block pool (TLS dies with the thread).
        j := 0
        for j < len(spawns[i].argtypes):
            out = out + " " + cty(dc, ctx, spawns[i].argtypes[j]) + "a" + str(j) + ";"
            j = j + 1
        out = out + " } HSpawnA_" + si + ";\n"
        rct := cty(dc, ctx, spawns[i].retty)
        out = out + "static void* tycho_spawn_" + si + "(void* _p) { HSpawnA_" + si + "* _a = (HSpawnA_" + si + "*)_p; " + rct + "_r = " + un(spawns[i].fname) + "(&_a->t->root"
        j = 0
        for j < len(spawns[i].argtypes):
            out = out + ", _a->a" + str(j)
            j = j + 1
        out = out + "); " + rct + "* _s = (" + rct + "*)amem(&_a->t->root, sizeof(" + rct + ")); *_s = _r; _a->t->ret = _s; tycho_pool_flush(); return 0; }\n"
        i = i + 1
    if has_fnval:                                # 9b. fn-value adapter thunks (after protos: each forwards to h_<name>)
        i = 0
        for i < len(funcs):
            if funcs[i].name != "main" and funcs[i].is_extern == 0 and fn_value_eligible(funcs[i]) and not has_prefix(funcs[i].name, "__lam"):
                out = out + gen_fnval_thunk(funcs[i], dc, ctx)   # lifted lambdas get a capture-aware thunk instead (below); externs have no h_ wrapper
            i = i + 1
    i = 0                                        # 9c. closure thunks: unpack the env, call the lifted __lam proc
    for i < len(lams):
        out = out + gen_lambda_thunk(lams[i], dc, ctx)
        i = i + 1
    i = 0                                        # 9c'. env-copy thunks (after the copy fns above): re-home the env on closure return
    for i < len(lams):
        if len(lams[i].capnames) > 0:
            eid := str(lams[i].id)
            out = out + "static void* Env_" + eid + "_copy(Arena* a, void* _s) { Env_" + eid + "* s = (Env_" + eid + "*)_s; Env_" + eid + "* d = (Env_" + eid + "*)hbox(a, sizeof(Env_" + eid + "), s);"
            cj := 0
            for cj < len(lams[i].captypes):
                if elem_deepcopy(dc, ctx, lams[i].captypes[cj]):   # heap capture: deep-copy into `a` (scalars keep the hbox shallow copy)
                    out = out + " d->c" + str(cj) + " = " + cp_field(dc, ctx, lams[i].captypes[cj], "a", "s->c" + str(cj)) + ";"
                cj = cj + 1
            out = out + " return d; }\n"
        i = i + 1
    i = 0
    for i < len(funcs):
        if funcs[i].is_extern == 0:              # FFI externs have no body
            out = out + gen_func(funcs[i], dc, ctx)
        i = i + 1
    print(out)
