# str(bool) prints the words true/false (not 1/0). A bool is a distinct type:
# comparisons, `and`/`or`/`not`, the `true`/`false` literals, bool vars, bool
# params and bool-returning fns all carry it. Both compilers must agree (the
# differential + fixpoint check this), so bool is structurally an int (one C
# long) that only str() treats specially.

fn even(n: int) -> bool:
    return n % 2 == 0

fn main():
    x := 5

    # comparisons
    println(str(x > 3) + " " + str(x == 5) + " " + str(x < 0))   # true true false
    # and / or / not
    println(str(x > 0 and x < 10) + " " + str(x > 9 or x == 5) + " " + str(not (x == 5)))  # true true false
    # literals
    println(str(true) + " " + str(false))                        # true false
    # a bool variable, reassigned
    b := true
    println(str(b))                                              # true
    b = (x > 100)
    println(str(b))                                              # false
    # a bool-returning fn
    println(str(even(4)) + " " + str(even(7)))                   # true false
    # inside an f-string hole
    println(f"x even? {even(x)}; positive? {x > 0}")                  # x even? false; positive? true
