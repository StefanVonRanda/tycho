# Recursive output collector: a [string] threaded through `inout` accumulates
# across call frames. The buffer regrows in the *caller's* arena (carried as
# _ina_out), so every push survives the nested return — past Wall #3's
# shared-mutable-output case.

fn collect(out: inout [string], n: int):
    if n == 0:
        return
    push(out, "item-" + str(n))
    collect(&out, n - 1)

fn main():
    acc := []string
    collect(&acc, 5)
    println("collected " + str(len(acc)) + ":")
    for i in range(len(acc)):
        println(acc[i])
