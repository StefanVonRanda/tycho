fn sq(n: int) -> int:
    return n * n

fn main():
    println("squares:")
    println("sq(2) = " + str(sq(2)))
    println("sq(3) = " + str(sq(3)))
    x := 7
    println("x = " + str(x) + ", x*x = " + str(x * x))
    if x > 5:
        println("big")
    else:
        println("small")
    println("done")
