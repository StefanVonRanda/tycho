# String interpolation (f-strings). f"...{expr}..." desugars to ("..." + str(expr) +
# "..."); {{ and }} are literal braces; plain "..." is unaffected (literal braces stay
# literal). str() coerces the hole: identity on a string, i2s/f2s on int/float. tychoc
# and tychoc0 must agree (make bootstrap diffs them).
struct P:
    x: int
    y: int

fn wrap(s: string) -> string:
    return "[" + s + "]"

fn main():
    n := 5
    name := "Ada"
    p := P(3, 4)
    f := 2.5

    println(f"n={n} name={name}")                       # n=5 name=Ada
    println(f"sum={n + 10} prod={n * n}")               # sum=15 prod=25
    println(f"point=({p.x},{p.y})")                     # point=(3,4)
    println(f"float={f}")                               # float=2.5
    println(f"nested str: {str(n)}")                    # nested str: 5
    println(f"literal {{braces}} around {n}")           # literal {braces} around 5
    println(f"{n}{name}{p.x}")                          # 5Ada3  (adjacent holes, empty literals)
    println(f"leading {n} trailing")                    # leading 5 trailing
    println("plain string with {braces} stays literal") # plain string with {braces} stays literal
    g := f"built={n}"                                   # f-string into a variable
    print(g + "!\n")                                    # built=5!

    # nested string literal inside a hole (the inner " no longer ends the f-string)
    println(f"wrapped={wrap("hi")}")                    # wrapped=[hi]
    println(f"sep={wrap(", ")}")                        # sep=[, ]
    println(f"both {wrap("a")} and {wrap("b")}")        # both [a] and [b]
    # a hole holding a string with braces in it (braces inside a nested string are literal)
    println(f"braces={wrap("{x}")}")                    # braces=[{x}]
    # nested f-string inside a hole (brace balancing finds the right closing })
    println(f"outer({f"inner={n}"})")                   # outer(inner=5)
