fn main():
    s := 0
    for i in range(5):              # 0..5
        s = s + i
    println("sum0to4 = " + str(s))          # 10
    t := 0
    for i in range(1, 6):           # 1..6
        t = t + i
    println("sum1to5 = " + str(t))          # 15
    for k in range(0, 10, 2):       # 0,2,4,6,8
        print(str(k) + " ")
    println("")
