fn sq(n: int) -> int:
    return n * n

fn main():
    println("squares:")
    i := 1
    for i < 6:
        println("sq(" + str(i) + ") = " + str(sq(i)))
        i = i + 1
    total := 0
    j := 1
    for j < 101:
        total = total + j
        j = j + 1
    println("sum 1..100 = " + str(total))
