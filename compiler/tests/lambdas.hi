# Lambdas / first-class function values (no-capture, stage 4b). A lambda
# `fn(p: T) -> R: expr` is lifted to a top-level `__lam<id>` and reified as a
# fat value {env, thunk}; with no captures env is 0. hierc and hierc0 must agree
# (make bootstrap diffs them; make fixpoint runs hierc0 over this fixture).

fn apply(f: fn(int) -> int, x: int) -> int:
    return f(x)

fn apply2(f: fn(int, int) -> int, a: int, b: int) -> int:
    return f(a, b)

fn map_int(xs: [int], f: fn(int) -> int) -> [int]:
    out := []int
    for v in xs:
        push(out, f(v))
    return out

fn twice(f: fn(int) -> int, x: int) -> int:
    return f(f(x))

fn main():
    # a lambda bound to a local, then called through a fn-typed parameter
    sq := fn(x: int) -> int: x * x
    print(str(apply(sq, 6)) + "\n")                 # 36

    # a lambda passed inline as an argument
    print(str(apply(fn(x: int) -> int: x + 100, 1)) + "\n")    # 101

    # multi-parameter lambda
    print(str(apply2(fn(a: int, b: int) -> int: a * b + 1, 3, 4)) + "\n")   # 13

    # higher-order over an array
    ys := map_int([1, 2, 3, 4, 5], fn(x: int) -> int: x * 10)
    print(str(ys[0]) + "," + str(ys[4]) + "\n")     # 10,50

    # composed application (f of f)
    print(str(twice(fn(x: int) -> int: x + 3, 10)) + "\n")     # 16

    # a nested lambda: the inner lambda is lifted too
    inc_via := fn(x: int) -> int: apply(fn(y: int) -> int: y + 1, x)
    print(str(inc_via(41)) + "\n")                  # 42

    # store a fn value in a variable, reassign, call indirectly
    g := sq
    print(str(g(9)) + "\n")                         # 81
    g = fn(x: int) -> int: 0 - x
    print(str(g(9)) + "\n")                         # -9
