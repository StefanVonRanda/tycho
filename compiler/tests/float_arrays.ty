fn scale(xs: inout [float], k: float):
    for i in range(len(xs)):
        xs[i] = xs[i] * k

fn total(xs: [float]) -> float:
    s := 0.0
    for i in range(len(xs)):
        s = s + xs[i]
    return s

fn make(n: int) -> [float]:
    r := []float
    for i in range(n):
        push(r, to_float(i) * 0.5)
    return r

fn main():
    xs := [1.5, 2.5, 3.0]
    println("len=" + str(len(xs)) + " sum=" + str(total(xs)))   # 3, 7.0
    xs[0] = 10.0
    println("set0=" + str(xs[0]))                               # 10.0
    ys := xs                      # value-semantic copy
    push(ys, 99.0)
    println("xs_len=" + str(len(xs)) + " ys_len=" + str(len(ys)))  # 3, 4 (independent)
    scale(&xs, 2.0)               # inout mutation
    println("scaled0=" + str(xs[0]) + " scaled_sum=" + str(total(xs)))  # 20.0, 31.0
    zs := make(4)                 # returned [float]
    println("made=" + str(zs[0]) + "," + str(zs[1]) + "," + str(zs[3]) + " sum=" + str(total(zs)))  # 0,0.5,1.5 sum 3
    a := [1.0, 2.0]
    b := [1.0, 2.0]
    if a == b:
        println("eq-ok")
