# pop(arr): remove and return the last element of a mutable array (variable or
# field). Mirrors push. The result is deep-copied out for heap element types
# (string / struct / array / nested), so a popped value stays valid even after a
# later push recycles the array's buffer (value semantics, RULE 5). Popping an
# empty array dies. Both compilers must agree (differential + fixpoint).
#
# Note: pop MUTATES, so bind its result before reading len() of the same array in
# the same statement -- operand evaluation order within one expression is
# unspecified (as in C), so `str(pop(a)) + str(len(a))` would be order-sensitive.

struct P:
    x: int
    y: int

fn main():
    # scalar elements
    a := [10, 20, 30]
    i := pop(a)
    println("int=" + str(i) + " len=" + str(len(a)))              # int=30 len=2
    fs := [1.5, 2.5]
    f := pop(fs)
    println("flt=" + str(f))                                     # flt=2.5

    # string elements (deep-copied out)
    ss := ["alpha", "beta", "gamma"]
    s := pop(ss)
    println("str=" + s + " len=" + str(len(ss)))                 # str=gamma len=2

    # struct elements
    ps := [P(1, 10), P(2, 20), P(3, 30)]
    p := pop(ps)
    println("struct=" + str(p.x) + "," + str(p.y))               # struct=3,30

    # nested-array elements (composite Arr family)
    m := [[1, 2], [3, 4], [5, 6]]
    row := pop(m)
    println("row=" + str(row[0]) + "," + str(row[1]) + " len=" + str(len(m)))  # row=5,6 len=2

    # value semantics: a popped heap value survives later pushes that regrow the buffer
    held := pop(ss)                                                    # held=beta, ss=["alpha"]
    push(ss, "x1")
    push(ss, "x2")
    push(ss, "x3")
    println("held=" + held + " now=" + str(len(ss)))            # held=beta now=4

    # pop down then refill (drives the empty/grow boundary)
    b := [7, 8]
    one := pop(b)
    two := pop(b)
    push(b, 99)
    three := pop(b)
    println("drained=" + str(one) + "," + str(two) + " refill=" + str(three))  # drained=8,7 refill=99
