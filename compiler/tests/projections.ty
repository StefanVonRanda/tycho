# Projections: mutate a composite-array element in place (Hylo-style yield).
# arr[i].f = v, push(arr[i].tags, v), m[i][j] = v, and &arr[i].x as mut all
# reach the element's slot in the backing buffer -- no pointer exposed to Tycho,
# and value semantics still holds (a copy is independent of the mutation).

struct Point:
    x: int
    y: int

struct Bag:
    name: string
    tags: [string]

fn bump(n: mut int):
    n = n + 1

fn main():
    # 1. value-field projection: arr[i].f = v
    ps := [Point(1, 2), Point(3, 4)]
    ps[0].x = 10
    ps[1].y = 40
    print("p0=" + str(ps[0].x) + "," + str(ps[0].y) + " p1=" + str(ps[1].x) + "," + str(ps[1].y) + "\n")

    # 2. value semantics: a copy is independent of in-place mutation
    qs := ps
    ps[0].x = 99
    print("ps0x=" + str(ps[0].x) + " qs0x=" + str(qs[0].x) + "\n")

    # 3. heap-field projection: arr[i].name = string
    bs := [Bag("a", ["t1"]), Bag("b", ["t2"])]
    bs[0].name = "alpha"
    print("name0=" + bs[0].name + "\n")

    # 4. push through a projected array field: push(arr[i].tags, v)
    push(bs[0].tags, "extra")
    print("tags0_len=" + str(len(bs[0].tags)) + " last=" + bs[0].tags[1] + "\n")

    # 5. nested-array index-set: m[i][j] = v
    grid := [[1, 2, 3], [4, 5, 6]]
    grid[1][2] = 60
    print("g12=" + str(grid[1][2]) + " g00=" + str(grid[0][0]) + "\n")

    # 6. mut through a projected element: &arr[i].x
    bump(&ps[1].x)
    print("p1x_after_bump=" + str(ps[1].x) + "\n")
