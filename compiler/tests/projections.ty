# Projections: mutate a composite-array element in place (Hylo-style yield).
# arr[i].f = v, push(arr[i].tags, v), m[i][j] = v, and &arr[i].x as inout all
# reach the element's slot in the backing buffer -- no pointer exposed to Tycho,
# and value semantics still holds (a copy is independent of the mutation).

struct Point:
    x: int
    y: int

struct Bag:
    name: string
    tags: [string]

fn bump(n: inout int):
    n = n + 1

fn main():
    # 1. value-field projection: arr[i].f = v
    ps := [Point(1, 2), Point(3, 4)]
    ps[0].x = 10
    ps[1].y = 40
    println("p0=" + str(ps[0].x) + "," + str(ps[0].y) + " p1=" + str(ps[1].x) + "," + str(ps[1].y))

    # 2. value semantics: a copy is independent of in-place mutation
    qs := ps
    ps[0].x = 99
    println("ps0x=" + str(ps[0].x) + " qs0x=" + str(qs[0].x))

    # 3. heap-field projection: arr[i].name = string
    bs := [Bag("a", ["t1"]), Bag("b", ["t2"])]
    bs[0].name = "alpha"
    println("name0=" + bs[0].name)

    # 4. push through a projected array field: push(arr[i].tags, v)
    push(bs[0].tags, "extra")
    println("tags0_len=" + str(len(bs[0].tags)) + " last=" + bs[0].tags[1])

    # 5. nested-array index-set: m[i][j] = v
    grid := [[1, 2, 3], [4, 5, 6]]
    grid[1][2] = 60
    println("g12=" + str(grid[1][2]) + " g00=" + str(grid[0][0]))

    # 6. inout through a projected element: &arr[i].x
    bump(&ps[1].x)
    println("p1x_after_bump=" + str(ps[1].x))
