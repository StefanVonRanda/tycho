fn sq(n: int) -> int:
    return n * n

fn main():
    print("squares:\n")
    print("sq(2) = " + str(sq(2)) + "\n")
    print("sq(3) = " + str(sq(3)) + "\n")
    x := 7
    print("x = " + str(x) + ", x*x = " + str(x * x) + "\n")
    if x > 5:
        print("big\n")
    else:
        print("small\n")
    print("done\n")
