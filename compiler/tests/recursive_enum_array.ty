# Regression: an enum with an array-of-ITSELF payload (an n-ary AST node) must
# have its descriptor typedef emitted BEFORE the [Enum] array typedef that holds
# `E_Foo *data`. Surfaced by the self-hosting bootstrap (tychoc0's
# `enum Stmt: ... SIf(Expr, [Stmt], [Stmt])`).
enum Tree:
    Leaf(int)
    Branch([Tree])

fn sum(t: Tree) -> int:
    match t:
        Leaf(n):
            return n
        Branch(kids):
            total := 0
            i := 0
            for i < len(kids):
                total = total + sum(kids[i])
                i = i + 1
            return total

fn main():
    a := Branch([Leaf(1), Leaf(2), Branch([Leaf(3), Leaf(4)])])
    println("sum=" + str(sum(a)))        # 1+2+3+4 = 10
