# Stage 2B: string-typed variables — declared, reassigned, and concatenated
# with int->str (str(...)) across loop iterations.
fn main():
    total := ""
    for i in range(1, 6):
        total = total + str(i)
        if i < 5:
            total = total + ", "
    print("counted: " + total + "\n")
    greeting := "hi"
    greeting = greeting + " there"
    print(greeting + "\n")
