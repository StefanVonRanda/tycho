enum Color:
    Red
    Green
    Blue

enum Tok:
    Num(float)
    Op(string)
    LParen
    RParen

struct Cell:
    color: Color
    label: string

fn name(c: Color) -> string:
    match c:
        Red:
            return "red"
        Green:
            return "green"
        Blue:
            return "blue"

fn show(t: Tok) -> string:
    match t:
        Num(n):
            return "num " + str(n)
        Op(s):
            return "op " + s
        LParen:
            return "("
        RParen:
            return ")"

fn main():
    println(name(Green))
    println(show(Num(42.0)) + " / " + show(Op("+")) + " / " + show(LParen))
    cells := [Cell(Red, "a"), Cell(Blue, "b")]
    println(name(cells[1].color) + "=" + cells[1].label)
