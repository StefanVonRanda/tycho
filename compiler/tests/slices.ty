# Slices: xs[a:b] is a sub-range that ALIASES xs's buffer when passed to a
# read-only array parameter (zero copy), but deep-copies (owning) when stored,
# returned, or pushed -- a non-storable borrow. Bounds default: xs[a:], xs[:b],
# xs[:].

fn sum(s: [int]) -> int:
    t := 0
    for i in range(len(s)):
        t = t + s[i]
    return t

fn first(words: [string]) -> string:
    return words[0]

struct P:
    x: int
    y: int

fn sumx(ps: [P]) -> int:
    t := 0
    for i in range(len(ps)):
        t = t + ps[i].x
    return t

fn main():
    xs := [10, 20, 30, 40, 50]

    # zero-copy views passed to a read-only parameter
    println("mid=" + str(sum(xs[1:4])))       # 20+30+40 = 90
    println("from2=" + str(sum(xs[2:])))      # 30+40+50 = 120
    println("upto3=" + str(sum(xs[:3])))      # 10+20+30 = 60
    println("all=" + str(sum(xs[:])))         # 150
    println("empty=" + str(sum(xs[2:2])))     # 0

    # a stored slice is an owning copy: independent of later mutation of xs
    mid := xs[1:4]
    println("midlen=" + str(len(mid)) + " mid0=" + str(mid[0]))   # 3, 20
    push(xs, 60)
    xs[1] = 999
    println("after_mut mid0=" + str(mid[0]) + " mid_len=" + str(len(mid)))  # still 20, 3

    # slice of a slice (a view of a view), still zero-copy as an argument
    println("subsub=" + str(sum(xs[1:5][1:3])))   # [999,30,40,50] -> [30,40] = 70

    # heap-element slice ([string]) and struct-element slice ([P])
    words := ["a", "bb", "ccc", "dddd"]
    println("fw=" + first(words[2:]))             # "ccc"
    ps := [P(1, 2), P(3, 4), P(5, 6)]
    println("sumx_tail=" + str(sumx(ps[1:])))     # 3+5 = 8

    # index a view directly (transient, used immediately)
    println("direct=" + str(xs[2:5][0]))          # xs[2] = 30
