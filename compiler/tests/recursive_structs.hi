struct Node:
    val: int
    kids: [Node]

fn leaf(v: int) -> Node:
    return Node(v, []Node)

fn sum(n: Node) -> int:
    total := n.val
    for i in range(len(n.kids)):
        total = total + sum(n.kids[i])
    return total

fn depth(n: Node) -> int:
    d := 0
    for i in range(len(n.kids)):
        cd := depth(n.kids[i])
        if cd > d:
            d = cd
    return d + 1

fn main():
    # build bottom-up: assemble a subtree in a local, then push it whole
    branch := Node(3, []Node)
    push(branch.kids, leaf(4))
    push(branch.kids, leaf(5))
    root := Node(1, []Node)
    push(root.kids, leaf(2))
    push(root.kids, branch)             # pushes a deep copy of branch
    print("sum=" + str(sum(root)) + "\n")       # 15
    print("depth=" + str(depth(root)) + "\n")   # 3
    print("kids=" + str(len(root.kids)) + " gkids=" + str(len(root.kids[1].kids)) + "\n")
    snap := root                        # deep copy
    push(root.kids, leaf(9))
    print("snap_kids=" + str(len(snap.kids)) + " root_kids=" + str(len(root.kids)) + "\n")
