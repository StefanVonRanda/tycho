# `mut` parameters: explicit borrow-for-mutation. The callee writes back
# into the caller's variable — copy-in copy-out, equivalent to `x = f(x)`.
# The `&` at the call site marks where mutation happens. Value semantics is
# preserved: the same variable can't be passed to two mut params at once.
# Restricted to non-heap types (int, bool, pure-value structs).

struct Stats:
    sum: int
    count: int

fn incr(n: mut int):
    n = n + 1

fn swap(a: mut int, b: mut int):
    t := a
    a = b
    b = t

fn record(s: mut Stats, value: int):
    s.sum = s.sum + value
    s.count = s.count + 1

fn main():
    x := 41
    incr(&x)
    println("incr: " + str(x))                  # 42

    a := 1
    b := 2
    swap(&a, &b)                                      # &a and &b are distinct
    println("swap: " + str(a) + " " + str(b))   # 2 1

    st := Stats(0, 0)
    for i in range(1, 5):
        record(&st, i)                               # mutate the caller's struct
    println("sum=" + str(st.sum) + " count=" + str(st.count))  # sum=10 count=4
