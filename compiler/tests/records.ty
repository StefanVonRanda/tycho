# Heap-bearing struct fields: string and [string] fields, value semantics,
# deep copy on assign/return. Each struct owns its bytes; copies are
# independent at every nesting level.

struct Person:
    name: string
    age: int

struct Team:
    lead: Person
    members: [string]

fn promote(p: Person) -> Person:    # returns a heap struct; promoted into
    q := p                          # the caller's arena (deep-copied)
    q.age = p.age + 1
    return q

fn main():
    ada := Person("Ada", 36)
    println(ada.name + " is " + str(ada.age))

    # value semantics: the copy is independent (deep)
    older := promote(ada)
    println("after promote: ada=" + str(ada.age) + " older=" + str(older.age))

    # nested struct + a [string] field
    t := Team(ada, ["Grace", "Alan"])
    println("lead: " + t.lead.name + ", members: " + str(len(t.members)))
    println("first member: " + t.members[0])

    # replacing a nested struct field, inside a block, with a fresh value
    if ada.age > 0:
        t.lead = Person("Grace Hopper", 79)
    println("new lead: " + t.lead.name)
