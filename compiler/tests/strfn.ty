# Stage 2B: string parameters and string return types, plus unary minus.
fn greet(name: string) -> string:
    return "hello " + name + "\n"

fn classify(n: int) -> string:
    if n < 0:
        return "negative"
    else:
        return "non-negative"

fn main():
    print(greet("world"))
    println("the number -3 is " + classify(-3))
    println("the number 7 is " + classify(7))
