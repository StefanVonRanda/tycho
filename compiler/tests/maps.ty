# Regression test for [string: int] maps: literals, the map_set/map_get
# accumulator, value semantics (independent copies), pure vs in-place delete,
# keys() iteration, mut mutation reaching the caller, and tombstone rehashing
# under a delete-heavy workload. Deterministic (no stdin), so the differential
# harness asserts native and sanitizer builds agree byte-for-byte.

fn yn(b: bool) -> string:
    if b:
        return "T"
    return "F"

fn sumvals(m: [string: int]) -> int:
    ks := keys(m)
    total := 0
    for i in range(len(ks)):
        total = total + map_get(m, ks[i], 0)
    return total

fn bump(m: mut [string: int], k: string):
    m[k] = map_get(m, k, 0) + 1

fn drop(m: mut [string: int], k: string):
    delete m[k]

fn main():
    counts := []string: int
    words := ["a", "b", "a", "c", "a", "b"]
    for i in range(len(words)):
        counts[words[i]] = map_get(counts, words[i], 0) + 1
    println("a=" + str(map_get(counts, "a", 0)) + " b=" + str(map_get(counts, "b", 0)) + " c=" + str(map_get(counts, "c", 0)))
    println("distinct=" + str(len(counts)) + " total=" + str(sumvals(counts)))

    snap := counts
    counts["a"] = 100
    println("snap_a=" + str(map_get(snap, "a", 0)) + " counts_a=" + str(map_get(counts, "a", 0)))

    less := counts                     # value-semantics copy: deleting from it leaves counts intact
    delete less["a"]
    println("less_has_a=" + yn("a" in less) + " counts_has_a=" + yn("a" in counts))
    println("less_len=" + str(len(less)))

    delete counts["b"]
    println("after_del_b_len=" + str(len(counts)) + " has_b=" + yn("b" in counts))

    m := []string: int
    bump(&m, "x")
    bump(&m, "x")
    bump(&m, "y")
    println("mut x=" + str(map_get(m, "x", 0)) + " len=" + str(len(m)))
    drop(&m, "x")
    println("after_drop x_has=" + yn("x" in m) + " len=" + str(len(m)))

    t := []string: int
    for i in range(50):
        t["k" + str(i)] = i
    for i in range(50):
        delete t["k" + str(i)]
    println("emptied len=" + str(len(t)))
    for i in range(30):
        t["k" + str(i)] = i * 2
    println("refilled len=" + str(len(t)) + " k7=" + str(map_get(t, "k7", -1)) + " k49=" + str(map_get(t, "k49", -1)))

    e := []string: int
    println("empty_keys_len=" + str(len(keys(e))))
