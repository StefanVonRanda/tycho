# hierc0 — a compiler for a SUBSET of Hier, written in Hier. Stage 1 of the
# self-hosting bootstrap (docs/bootstrap.md). Source -> C, stdin -> stdout.
#
# Subset: one or more `fn name(p: int, ...) -> int:` / `fn main():`, whose
# indented bodies have `x := EXPR`, `x = EXPR`, `print(SEXPR)`, `return EXPR`,
# and `if`/`elif`/`else`. EXPR = integer arithmetic (`+ - *`, parens, vars, int
# literals, calls `f(args)`) and comparisons (`== < >`). SEXPR (string, only in
# print position) = string literals and `str(EXPR)` joined by `+`. Validated
# DIFFERENTIALLY against the C compiler by `make bootstrap`.

# ---------------------------------------------------------------- lexer ----

enum Tok:
    TInt
    TFloat
    TStr
    TIdent
    TPlus
    TMinus
    TStar
    TSlash
    TLParen
    TRParen
    TLBracket
    TRBracket
    TComma
    TColon
    TDot
    TArrow
    TWalrus
    TEq
    TEqEq
    TLt
    TGt
    TLe
    TGe
    TNe
    TAmp
    TNewline
    TIndent
    TDedent
    TEof

struct Token:
    kind: Tok
    text: string

fn is_digit(c: int) -> bool:
    return c >= 48 and c <= 57

fn is_alpha(c: int) -> bool:
    return (c >= 97 and c <= 122) or (c >= 65 and c <= 90) or c == 95

fn is_alnum(c: int) -> bool:
    return is_alpha(c) or is_digit(c)

fn scan_token(src: string, i: int, toks: inout [Token]) -> int:
    n := len(src)
    c := src[i]
    if c == 32 or c == 9:
        return i + 1
    elif c == 35:
        for i < n and src[i] != 10:
            i = i + 1
        return i
    elif c == 34:                                # string literal "..."
        start := i + 1
        i = i + 1
        for i < n and src[i] != 34:
            if src[i] == 92:                     # backslash escapes the next char
                i = i + 1
            i = i + 1
        if i >= n:
            die("lex: unterminated string")
        push(toks, Token(TStr, substr(src, start, i)))
        return i + 1                             # consume closing quote
    elif is_digit(c):
        start := i
        for i < n and is_digit(src[i]):
            i = i + 1
        if i < n and src[i] == 46 and i + 1 < n and is_digit(src[i + 1]):   # D.D float
            i = i + 1
            for i < n and is_digit(src[i]):
                i = i + 1
            push(toks, Token(TFloat, substr(src, start, i)))
            return i
        push(toks, Token(TInt, substr(src, start, i)))
        return i
    elif is_alpha(c):
        start := i
        for i < n and is_alnum(src[i]):
            i = i + 1
        push(toks, Token(TIdent, substr(src, start, i)))
        return i
    elif c == 43:
        push(toks, Token(TPlus, "+"))
        return i + 1
    elif c == 45:
        if i + 1 < n and src[i + 1] == 62:
            push(toks, Token(TArrow, "->"))
            return i + 2
        push(toks, Token(TMinus, "-"))
        return i + 1
    elif c == 42:
        push(toks, Token(TStar, "*"))
        return i + 1
    elif c == 47:
        push(toks, Token(TSlash, "/"))
        return i + 1
    elif c == 40:
        push(toks, Token(TLParen, "("))
        return i + 1
    elif c == 41:
        push(toks, Token(TRParen, ")"))
        return i + 1
    elif c == 91:
        push(toks, Token(TLBracket, "["))
        return i + 1
    elif c == 93:
        push(toks, Token(TRBracket, "]"))
        return i + 1
    elif c == 44:
        push(toks, Token(TComma, ","))
        return i + 1
    elif c == 46:
        push(toks, Token(TDot, "."))
        return i + 1
    elif c == 58:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TWalrus, ":="))
            return i + 2
        push(toks, Token(TColon, ":"))
        return i + 1
    elif c == 61:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TEqEq, "=="))
            return i + 2
        push(toks, Token(TEq, "="))
        return i + 1
    elif c == 60:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TLe, "<="))
            return i + 2
        push(toks, Token(TLt, "<"))
        return i + 1
    elif c == 62:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TGe, ">="))
            return i + 2
        push(toks, Token(TGt, ">"))
        return i + 1
    elif c == 33:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TNe, "!="))
            return i + 2
        die("lex: '!' must be part of '!='")
        return i + 1
    elif c == 38:
        push(toks, Token(TAmp, "&"))
        return i + 1
    else:
        die("lex: unexpected character")
        return i + 1

fn lex(src: string) -> [Token]:
    toks := []Token
    stack := []int
    push(stack, 0)
    sp := 1
    n := len(src)
    i := 0
    at_bol := true
    for i < n:
        if at_bol:
            ind := 0
            for i < n and src[i] == 32:
                ind = ind + 1
                i = i + 1
            if i >= n:
                at_bol = false
            elif src[i] == 10:
                push(toks, Token(TNewline, ""))
                i = i + 1
            elif src[i] == 35:
                for i < n and src[i] != 10:
                    i = i + 1
            elif ind > stack[sp - 1]:
                if sp < len(stack):
                    stack[sp] = ind
                else:
                    push(stack, ind)
                sp = sp + 1
                push(toks, Token(TIndent, ""))
                at_bol = false
            else:
                for sp > 1 and stack[sp - 1] > ind:
                    sp = sp - 1
                    push(toks, Token(TDedent, ""))
                if stack[sp - 1] != ind:
                    die("lex: inconsistent indentation")
                at_bol = false
        else:
            if src[i] == 10:
                push(toks, Token(TNewline, ""))
                i = i + 1
                at_bol = true
            else:
                i = scan_token(src, i, &toks)
    push(toks, Token(TNewline, ""))
    for sp > 1:
        sp = sp - 1
        push(toks, Token(TDedent, ""))
    push(toks, Token(TEof, ""))
    return toks

# ------------------------------------------------------------------ AST ----

enum Expr:
    EInt(string)
    EFloat(string)            # float literal, emitted verbatim (round-trips as a double)
    EStr(string)              # string literal (raw content, escapes preserved)
    EVar(string)
    EBin(string, Expr, Expr)
    ECall(string, [Expr])    # function call OR struct construction `Point(1,2)`
    EField(Expr, string)     # field access `base.field` (nests: `r.lo.x`)
    EIndex(Expr, Expr)       # array index `base[idx]`
    EArrLit([Expr])          # array literal `[1, 2, 3]` (int elements)
    EArrEmpty(string)        # empty typed array `[]int`
    EMapEmpty(string, string) # empty typed map `[]string: int` (key, value types)
    EMapLit([Expr], [Expr])  # non-empty map literal `[k0: v0, k1: v1]` (keys, vals)
    ETuple([Expr])           # tuple literal `(a, b, ...)` / `return a, b`
    ESlice(Expr, Expr, Expr) # `base[lo:hi]` sub-array (owning copy)
    EAddr(Expr)              # `&place` at a call site (pass to an inout param)

enum Stmt:
    SDecl(string, Expr)
    SAssign(string, Expr)
    SFieldAssign(Expr, Expr) # `lvalue = rhs`, lvalue an EField path
    SPrint(Expr)             # the Expr is a string expression
    SReturn(Expr)
    SReturnVoid              # bare `return` (no value)
    SIf(Expr, [Stmt], [Stmt])
    SWhile(Expr, [Stmt])     # condition-form `for COND:` (Hier's while loop)
    SForRange(string, Expr, Expr, Expr, [Stmt])   # `for i in range(start, stop, step):`
    SExpr(Expr)              # bare expression statement, e.g. a call `f(x)`
    STypedDecl(string, string, Expr)   # `name : Type = expr` (annotation fixes the type)
    SOrReturn(string, Expr)  # `name := result_expr or_return` (unwrap Ok or propagate Err)
    SDestructure([string], Expr)       # `a, b := tuple_expr`
    SMultiAssign([string], Expr)       # `a, b = tuple_expr` (assign existing vars)
    SMatch(Expr, [string], [[string]], [[Stmt]])  # subj, arm variants, arm binds, arm bodies

struct Param:
    name: string
    ty: string                # "int" | "str"

struct Func:
    name: string
    params: [string]
    ptypes: [string]          # parallel to params: "int" | "str"
    ret: string               # "int" | "str" | "void"
    body: [Stmt]

struct Sig:                   # collected up front, for typing calls
    name: string
    ret: string

struct Field:
    name: string
    ty: string                # "int" | "str" | a struct name

struct StructDef:
    name: string
    fields: [Field]

struct Variant:
    name: string
    ptypes: [string]          # payload types: "int"/"str"/struct/enum names

struct EnumDef:
    name: string
    variants: [Variant]

# Read-only typing/codegen context, threaded by value: function return types,
# struct layouts, and enum definitions. (The mutable per-block var env stays as
# the separate names/types arrays.) This is the `Ctx` docs/bootstrap.md wanted.
struct Ctx:
    sigs: [Sig]
    structs: [StructDef]
    enums: [EnumDef]
    ntnames: [string]         # newtype names, parallel to ntunder
    ntunder: [string]         # each newtype's underlying type
    vparams: [string]         # current func's NON-inout param names (map accum guard)
    saccums: [string]         # current func's string-append accumulator locals (in-place hi_append)
    rettype: string           # current func's Hier return type (for the return-slot _scope free)
    owner: string             # arena that fresh allocations go into ("0"=NULL=malloc; "&_t"/"_parent"/"&_scope")
    depth: int                # current block nesting depth (0 = function body _scope; d = block _b<d>)
    block_base: int           # env length at current block entry; a var at index >= this is block-local

struct Program:
    structs: [StructDef]
    enums: [EnumDef]
    funcs: [Func]
    ntnames: [string]
    ntunder: [string]

# --------------------------------------------------------------- parser ----

fn expect(toks: [Token], pos: inout int, k: Tok):
    if toks[pos].kind != k:
        die("parse: unexpected token")
    pos = pos + 1

fn expect_ident(toks: [Token], pos: inout int, name: string):
    if toks[pos].kind != TIdent or toks[pos].text != name:
        die("parse: expected a keyword")
    pos = pos + 1

# Open an indented block: a newline, then any number of blank/comment-only
# lines (each a stray NEWLINE), then the INDENT.
fn open_block(toks: [Token], pos: inout int):
    expect(toks, &pos, TNewline)
    for toks[pos].kind == TNewline:
        pos = pos + 1
    expect(toks, &pos, TIndent)

fn parse_atom(toks: [Token], pos: inout int) -> Expr:
    t := toks[pos]
    if t.kind == TStr:
        pos = pos + 1
        return EStr(t.text)
    elif t.kind == TMinus:                       # unary minus: -E  ==>  (0 - E)
        pos = pos + 1
        return EBin("-", EInt("0"), parse_atom(toks, &pos))
    elif t.kind == TAmp:                         # &place : pass to an inout param
        pos = pos + 1
        return EAddr(parse_postfix(toks, &pos))
    elif t.kind == TInt:
        pos = pos + 1
        return EInt(t.text)
    elif t.kind == TFloat:
        pos = pos + 1
        return EFloat(t.text)
    elif t.kind == TIdent:
        name := t.text
        pos = pos + 1
        if name == "soa":                        # soa []Struct : empty SOA literal
            expect(toks, &pos, TLBracket)
            expect(toks, &pos, TRBracket)
            st := parse_type(toks, &pos)
            return EArrEmpty("soa[" + st + "]")
        if name == "true":
            return EInt("1")
        if name == "false":
            return EInt("0")
        if toks[pos].kind == TLParen:
            pos = pos + 1
            args := []Expr
            if toks[pos].kind != TRParen:
                push(args, parse_expr(toks, &pos))
                for toks[pos].kind == TComma:
                    pos = pos + 1
                    push(args, parse_expr(toks, &pos))
            expect(toks, &pos, TRParen)
            return ECall(name, args)
        return EVar(name)
    elif t.kind == TLParen:
        pos = pos + 1
        e := parse_expr(toks, &pos)
        if toks[pos].kind == TComma:             # tuple literal (a, b, ...)
            elems := []Expr
            push(elems, e)
            for toks[pos].kind == TComma:
                pos = pos + 1
                push(elems, parse_expr(toks, &pos))
            expect(toks, &pos, TRParen)
            return ETuple(elems)
        expect(toks, &pos, TRParen)
        return e
    elif t.kind == TLBracket:
        pos = pos + 1
        if toks[pos].kind == TRBracket:          # []T : empty array  /  []K: V : empty map
            pos = pos + 1
            kty := parse_type(toks, &pos)
            if toks[pos].kind == TColon:
                pos = pos + 1
                vty := parse_type(toks, &pos)
                return EMapEmpty(kty, vty)
            return EArrEmpty(kty)
        first := parse_expr(toks, &pos)
        if toks[pos].kind == TColon:             # [k0: v0, k1: v1] : map literal
            keys := []Expr
            vals := []Expr
            pos = pos + 1
            push(keys, first)
            push(vals, parse_expr(toks, &pos))
            for toks[pos].kind == TComma:
                pos = pos + 1
                push(keys, parse_expr(toks, &pos))
                expect(toks, &pos, TColon)
                push(vals, parse_expr(toks, &pos))
            expect(toks, &pos, TRBracket)
            return EMapLit(keys, vals)
        elems := []Expr                          # [e0, e1, ...] : array literal
        push(elems, first)
        for toks[pos].kind == TComma:
            pos = pos + 1
            push(elems, parse_expr(toks, &pos))
        expect(toks, &pos, TRBracket)
        return EArrLit(elems)
    else:
        die("parse: expected an atom")
        return EInt("0")

fn parse_postfix(toks: [Token], pos: inout int) -> Expr:
    e := parse_atom(toks, &pos)
    for toks[pos].kind == TDot or toks[pos].kind == TLBracket:
        if toks[pos].kind == TDot:               # field access: a.b  /  tuple index: a.0
            pos = pos + 1
            if toks[pos].kind != TIdent and toks[pos].kind != TInt:
                die("parse: expected a field name or index after '.'")
            e = EField(e, toks[pos].text)
            pos = pos + 1
        else:                                    # index a[i]  or  slice a[lo:hi]
            pos = pos + 1
            lenargs := []Expr
            push(lenargs, e)
            if toks[pos].kind == TColon:         # a[:hi] / a[:]
                pos = pos + 1
                hi := ECall("len", lenargs)
                if toks[pos].kind != TRBracket:
                    hi = parse_expr(toks, &pos)
                expect(toks, &pos, TRBracket)
                e = ESlice(e, EInt("0"), hi)
            else:
                idx := parse_expr(toks, &pos)
                if toks[pos].kind == TColon:     # a[lo:hi] / a[lo:]
                    pos = pos + 1
                    hi := ECall("len", lenargs)
                    if toks[pos].kind != TRBracket:
                        hi = parse_expr(toks, &pos)
                    expect(toks, &pos, TRBracket)
                    e = ESlice(e, idx, hi)
                else:
                    expect(toks, &pos, TRBracket)
                    e = EIndex(e, idx)
    return e

fn parse_mul(toks: [Token], pos: inout int) -> Expr:
    l := parse_postfix(toks, &pos)
    for toks[pos].kind == TStar or toks[pos].kind == TSlash:
        op := toks[pos].text
        pos = pos + 1
        r := parse_postfix(toks, &pos)
        l = EBin(op, l, r)
    return l

fn parse_add(toks: [Token], pos: inout int) -> Expr:
    l := parse_mul(toks, &pos)
    for toks[pos].kind == TPlus or toks[pos].kind == TMinus:
        op := toks[pos].text
        pos = pos + 1
        r := parse_mul(toks, &pos)
        l = EBin(op, l, r)
    return l

fn parse_cmp(toks: [Token], pos: inout int) -> Expr:
    l := parse_add(toks, &pos)
    k := toks[pos].kind
    if k == TEqEq or k == TLt or k == TGt or k == TLe or k == TGe or k == TNe:
        op := toks[pos].text
        pos = pos + 1
        r := parse_add(toks, &pos)
        return EBin(op, l, r)
    return l

fn parse_not(toks: [Token], pos: inout int) -> Expr:
    if toks[pos].kind == TIdent and toks[pos].text == "not":
        pos = pos + 1
        return EBin("==", parse_not(toks, &pos), EInt("0"))   # logical not: (X == 0)
    return parse_cmp(toks, &pos)

fn parse_and(toks: [Token], pos: inout int) -> Expr:
    l := parse_not(toks, &pos)
    for toks[pos].kind == TIdent and toks[pos].text == "and":
        pos = pos + 1
        r := parse_not(toks, &pos)
        l = EBin("&&", l, r)
    return l

fn parse_expr(toks: [Token], pos: inout int) -> Expr:
    l := parse_and(toks, &pos)
    for toks[pos].kind == TIdent and toks[pos].text == "or":
        pos = pos + 1
        r := parse_and(toks, &pos)
        l = EBin("||", l, r)
    return l

fn parse_block(toks: [Token], pos: inout int) -> [Stmt]:
    stmts := []Stmt
    open_block(toks, &pos)
    for toks[pos].kind != TDedent:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        else:
            push(stmts, parse_stmt(toks, &pos))
            if toks[pos].kind == TNewline:
                pos = pos + 1
    pos = pos + 1
    return stmts

fn parse_else(toks: [Token], pos: inout int) -> [Stmt]:
    t := toks[pos]
    if t.kind == TIdent and t.text == "elif":
        pos = pos + 1
        cond := parse_expr(toks, &pos)
        expect(toks, &pos, TColon)
        then_body := parse_block(toks, &pos)
        rest := parse_else(toks, &pos)
        inner := []Stmt
        push(inner, SIf(cond, then_body, rest))
        return inner
    elif t.kind == TIdent and t.text == "else":
        pos = pos + 1
        expect(toks, &pos, TColon)
        return parse_block(toks, &pos)
    else:
        return []Stmt

fn parse_stmt(toks: [Token], pos: inout int) -> Stmt:
    t := toks[pos]
    if t.kind == TIdent and t.text == "print":
        pos = pos + 1
        expect(toks, &pos, TLParen)
        e := parse_expr(toks, &pos)
        expect(toks, &pos, TRParen)
        return SPrint(e)
    elif t.kind == TIdent and t.text == "return":
        pos = pos + 1
        if toks[pos].kind == TNewline:           # bare `return` (void)
            return SReturnVoid
        re := parse_expr(toks, &pos)
        if toks[pos].kind == TComma:             # `return a, b` builds a tuple
            elems := []Expr
            push(elems, re)
            for toks[pos].kind == TComma:
                pos = pos + 1
                push(elems, parse_expr(toks, &pos))
            return SReturn(ETuple(elems))
        return SReturn(re)
    elif t.kind == TIdent and t.text == "if":
        pos = pos + 1
        cond := parse_expr(toks, &pos)
        expect(toks, &pos, TColon)
        then_body := parse_block(toks, &pos)
        else_body := parse_else(toks, &pos)
        return SIf(cond, then_body, else_body)
    elif t.kind == TIdent and t.text == "for":
        pos = pos + 1
        if toks[pos].kind == TIdent and toks[pos + 1].kind == TIdent and toks[pos + 1].text == "in":
            varname := toks[pos].text       # counting form: for i in range(...)
            pos = pos + 1
            expect_ident(toks, &pos, "in")
            expect_ident(toks, &pos, "range")
            expect(toks, &pos, TLParen)
            a1 := parse_expr(toks, &pos)
            start := EInt("0")              # range(n): 0..n
            stop := a1
            step := EInt("1")
            if toks[pos].kind == TComma:    # range(a, b[, c])
                pos = pos + 1
                start = a1
                stop = parse_expr(toks, &pos)
                if toks[pos].kind == TComma:
                    pos = pos + 1
                    step = parse_expr(toks, &pos)
            expect(toks, &pos, TRParen)
            expect(toks, &pos, TColon)
            body := parse_block(toks, &pos)
            return SForRange(varname, start, stop, step, body)
        cond := parse_expr(toks, &pos)      # condition form: for COND:
        expect(toks, &pos, TColon)
        body := parse_block(toks, &pos)
        return SWhile(cond, body)
    elif t.kind == TIdent and t.text == "match":
        return parse_match(toks, &pos)
    elif t.kind == TIdent:
        name := t.text
        pos = pos + 1
        if toks[pos].kind == TComma:             # destructure: a, b := tuple_expr
            names := []string
            push(names, name)
            for toks[pos].kind == TComma:
                pos = pos + 1
                if toks[pos].kind != TIdent:
                    die("parse: expected a name in destructure")
                push(names, toks[pos].text)
                pos = pos + 1
            if toks[pos].kind == TWalrus:        # `:=` declares new vars
                pos = pos + 1
                return SDestructure(names, parse_expr(toks, &pos))
            expect(toks, &pos, TEq)              # `=` assigns existing vars
            return SMultiAssign(names, parse_expr(toks, &pos))
        if toks[pos].kind == TWalrus:
            pos = pos + 1
            rhs := parse_expr(toks, &pos)
            if toks[pos].kind == TIdent and toks[pos].text == "or_return":
                pos = pos + 1
                return SOrReturn(name, rhs)
            return SDecl(name, rhs)
        elif toks[pos].kind == TColon:           # `name : Type = expr` typed decl
            pos = pos + 1
            ty := parse_type(toks, &pos)
            expect(toks, &pos, TEq)
            return STypedDecl(name, ty, parse_expr(toks, &pos))
        elif toks[pos].kind == TEq:
            pos = pos + 1
            return SAssign(name, parse_expr(toks, &pos))
        elif toks[pos].kind == TDot or toks[pos].kind == TLBracket:
            lv := EVar(name)                     # place assignment: a.b[i].c = rhs
            for toks[pos].kind == TDot or toks[pos].kind == TLBracket:
                if toks[pos].kind == TDot:
                    pos = pos + 1
                    if toks[pos].kind != TIdent and toks[pos].kind != TInt:
                        die("parse: expected a field name or tuple index after '.'")
                    lv = EField(lv, toks[pos].text)   # TInt -> tuple element place (t.0 = v)
                    pos = pos + 1
                else:
                    pos = pos + 1
                    idx := parse_expr(toks, &pos)
                    expect(toks, &pos, TRBracket)
                    lv = EIndex(lv, idx)
            expect(toks, &pos, TEq)
            return SFieldAssign(lv, parse_expr(toks, &pos))
        elif toks[pos].kind == TLParen:          # bare call statement: f(args)
            pos = pos + 1
            args := []Expr
            if toks[pos].kind != TRParen:
                push(args, parse_expr(toks, &pos))
                for toks[pos].kind == TComma:
                    pos = pos + 1
                    push(args, parse_expr(toks, &pos))
            expect(toks, &pos, TRParen)
            return SExpr(ECall(name, args))
        else:
            die("parse: expected ':=', '=', or '('")
            return SReturn(EInt("0"))
    else:
        die("parse: expected a statement")
        return SReturn(EInt("0"))

fn parse_type(toks: [Token], pos: inout int) -> string:
    if toks[pos].kind == TLParen:                # tuple type (T, U, ...)
        pos = pos + 1
        parts := []string
        push(parts, parse_type(toks, &pos))
        for toks[pos].kind == TComma:
            pos = pos + 1
            push(parts, parse_type(toks, &pos))
        expect(toks, &pos, TRParen)
        out := "("
        i := 0
        for i < len(parts):
            if i > 0:
                out = out + ","
            out = out + parts[i]
            i = i + 1
        return out + ")"
    if toks[pos].kind == TLBracket:              # [T] array  or  [K: V] map
        pos = pos + 1
        inner := parse_type(toks, &pos)
        if toks[pos].kind == TColon:
            pos = pos + 1
            v := parse_type(toks, &pos)
            expect(toks, &pos, TRBracket)
            return "{" + inner + ":" + v + "}"
        expect(toks, &pos, TRBracket)
        return "[" + inner + "]"
    if toks[pos].kind == TIdent and toks[pos].text == "soa":   # soa [Struct]
        pos = pos + 1
        expect(toks, &pos, TLBracket)
        st := parse_type(toks, &pos)
        expect(toks, &pos, TRBracket)
        return "soa[" + st + "]"
    if toks[pos].kind != TIdent:
        die("parse: expected a type")
    name := toks[pos].text
    pos = pos + 1
    if name == "int":
        return "int"
    elif name == "bool":
        return "int"                             # bool is represented as long 0/1
    elif name == "float":
        return "float"
    elif name == "string":
        return "str"
    elif name == "Option":
        expect(toks, &pos, TLParen)
        t := parse_type(toks, &pos)
        expect(toks, &pos, TRParen)
        return "Option(" + t + ")"
    elif name == "Result":
        expect(toks, &pos, TLParen)
        t := parse_type(toks, &pos)
        expect(toks, &pos, TComma)
        e := parse_type(toks, &pos)
        expect(toks, &pos, TRParen)
        return "Result(" + t + "," + e + ")"
    else:
        return name                              # a struct or enum type name

fn parse_param(toks: [Token], pos: inout int) -> Param:
    if toks[pos].kind != TIdent:
        die("parse: expected a parameter name")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TColon)
    if toks[pos].kind == TIdent and toks[pos].text == "inout":
        pos = pos + 1
        return Param(name, "&" + parse_type(toks, &pos))   # inout marker
    return Param(name, parse_type(toks, &pos))

fn parse_func(toks: [Token], pos: inout int) -> Func:
    expect_ident(toks, &pos, "fn")
    if toks[pos].kind != TIdent:
        die("parse: expected a function name")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TLParen)
    params := []string
    ptypes := []string
    if toks[pos].kind != TRParen:
        p := parse_param(toks, &pos)
        push(params, p.name)
        push(ptypes, p.ty)
        for toks[pos].kind == TComma:
            pos = pos + 1
            p2 := parse_param(toks, &pos)
            push(params, p2.name)
            push(ptypes, p2.ty)
    expect(toks, &pos, TRParen)
    ret := "void"
    if toks[pos].kind == TArrow:
        pos = pos + 1
        ret = parse_type(toks, &pos)
    expect(toks, &pos, TColon)
    body := parse_block(toks, &pos)
    return Func(name, params, ptypes, ret, body)

fn parse_struct(toks: [Token], pos: inout int) -> StructDef:
    expect_ident(toks, &pos, "struct")
    if toks[pos].kind != TIdent:
        die("parse: expected a struct name")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TColon)
    open_block(toks, &pos)
    fields := []Field
    for toks[pos].kind != TDedent:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        else:
            if toks[pos].kind != TIdent:
                die("parse: expected a field name")
            fname := toks[pos].text
            pos = pos + 1
            expect(toks, &pos, TColon)
            fty := parse_type(toks, &pos)
            push(fields, Field(fname, fty))
            if toks[pos].kind == TNewline:
                pos = pos + 1
    pos = pos + 1                                # consume TDedent
    return StructDef(name, fields)

fn parse_match(toks: [Token], pos: inout int) -> Stmt:
    expect_ident(toks, &pos, "match")
    subj := parse_expr(toks, &pos)
    expect(toks, &pos, TColon)
    open_block(toks, &pos)
    variants := []string
    allbinds := [][string]
    bodies := [][Stmt]
    for toks[pos].kind != TDedent:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        else:
            if toks[pos].kind != TIdent:
                die("parse: expected a variant name in match arm")
            push(variants, toks[pos].text)
            pos = pos + 1
            binds := []string
            if toks[pos].kind == TLParen:        # payload list is optional (e.g. `None:`)
                pos = pos + 1
                if toks[pos].kind != TRParen:
                    if toks[pos].kind != TIdent:
                        die("parse: expected a binding name")
                    push(binds, toks[pos].text)
                    pos = pos + 1
                    for toks[pos].kind == TComma:
                        pos = pos + 1
                        if toks[pos].kind != TIdent:
                            die("parse: expected a binding name")
                        push(binds, toks[pos].text)
                        pos = pos + 1
                expect(toks, &pos, TRParen)
            expect(toks, &pos, TColon)
            push(allbinds, binds)
            push(bodies, parse_block(toks, &pos))
    pos = pos + 1                                # consume TDedent
    return SMatch(subj, variants, allbinds, bodies)

fn parse_enum(toks: [Token], pos: inout int) -> EnumDef:
    expect_ident(toks, &pos, "enum")
    if toks[pos].kind != TIdent:
        die("parse: expected an enum name")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TColon)
    open_block(toks, &pos)
    variants := []Variant
    for toks[pos].kind != TDedent:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        else:
            if toks[pos].kind != TIdent:
                die("parse: expected a variant name")
            vname := toks[pos].text
            pos = pos + 1
            ptypes := []string
            if toks[pos].kind == TLParen:
                pos = pos + 1
                if toks[pos].kind != TRParen:
                    push(ptypes, parse_type(toks, &pos))
                    for toks[pos].kind == TComma:
                        pos = pos + 1
                        push(ptypes, parse_type(toks, &pos))
                expect(toks, &pos, TRParen)
            push(variants, Variant(vname, ptypes))
            if toks[pos].kind == TNewline:
                pos = pos + 1
    pos = pos + 1                                # consume TDedent
    return EnumDef(name, variants)

fn parse_newtype(toks: [Token], pos: inout int) -> Param:   # `type Name = Underlying`
    expect_ident(toks, &pos, "type")
    if toks[pos].kind != TIdent:
        die("parse: expected a newtype name")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TEq)
    return Param(name, parse_type(toks, &pos))

fn parse_program(toks: [Token], pos: inout int) -> Program:
    structs := []StructDef
    enums := []EnumDef
    funcs := []Func
    ntnames := []string
    ntunder := []string
    for toks[pos].kind != TEof:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        elif toks[pos].kind == TIdent and toks[pos].text == "struct":
            push(structs, parse_struct(toks, &pos))
        elif toks[pos].kind == TIdent and toks[pos].text == "enum":
            push(enums, parse_enum(toks, &pos))
        elif toks[pos].kind == TIdent and toks[pos].text == "type":
            nt := parse_newtype(toks, &pos)
            push(ntnames, nt.name)
            push(ntunder, nt.ty)
        else:
            push(funcs, parse_func(toks, &pos))
    return Program(structs, enums, funcs, ntnames, ntunder)

# -------------------------------------------------------------- codegen ----
# Type-directed: each expression's C form follows its inferred type. A type is
# "int" (-> long), "str" (-> char*), or a struct name (-> that typedef). The
# mutable per-block var env is the names/types arrays; function return types
# and struct layouts come from the read-only `ctx`.

fn is_enum(ctx: Ctx, name: string) -> bool:
    i := 0
    for i < len(ctx.enums):
        if ctx.enums[i].name == name:
            return true
        i = i + 1
    return false

fn is_variant(ctx: Ctx, name: string) -> bool:
    i := 0
    for i < len(ctx.enums):
        j := 0
        for j < len(ctx.enums[i].variants):
            if ctx.enums[i].variants[j].name == name:
                return true
            j = j + 1
        i = i + 1
    return false

fn variant_enum(ctx: Ctx, vname: string) -> string:
    i := 0
    for i < len(ctx.enums):
        j := 0
        for j < len(ctx.enums[i].variants):
            if ctx.enums[i].variants[j].name == vname:
                return ctx.enums[i].name
            j = j + 1
        i = i + 1
    die("type: unknown variant")
    return "int"

fn variant_tag(ctx: Ctx, vname: string) -> int:
    i := 0
    for i < len(ctx.enums):
        j := 0
        for j < len(ctx.enums[i].variants):
            if ctx.enums[i].variants[j].name == vname:
                return j
            j = j + 1
        i = i + 1
    die("type: unknown variant")
    return 0

fn variant_ptypes(ctx: Ctx, vname: string) -> [string]:
    i := 0
    for i < len(ctx.enums):
        j := 0
        for j < len(ctx.enums[i].variants):
            if ctx.enums[i].variants[j].name == vname:
                return ctx.enums[i].variants[j].ptypes
            j = j + 1
        i = i + 1
    die("type: unknown variant")
    return []string

# An inout parameter's type is marked with a leading '&'. The base type drives
# all type logic; the marker only affects C codegen (pointer + deref).
fn is_inout(ty: string) -> bool:
    return len(ty) > 0 and ty[0] == 38

fn base_ty(ty: string) -> string:
    if is_inout(ty):
        return substr(ty, 1, len(ty))
    return ty

fn is_array(ty: string) -> bool:
    return len(ty) > 0 and ty[0] == 91           # "[T]"

fn elem_ty(ty: string) -> string:               # "[T]" -> "T"
    return substr(ty, 1, len(ty) - 1)

# SOA arrays: `soa [Struct]` is encoded "soa[Struct]" (one growable buffer per
# struct field + a shared len/cap, instead of an array of records).
fn is_soa(ty: string) -> bool:
    return len(ty) > 4 and substr(ty, 0, 4) == "soa["
fn soa_struct(ty: string) -> string:            # "soa[Struct]" -> "Struct"
    return substr(ty, 4, len(ty) - 1)

fn is_map(ty: string) -> bool:
    return len(ty) > 0 and ty[0] == 123          # "{str:V}"  (V = int or float)

fn map_val(ty: string) -> string:               # "{str:V}" -> "V"
    inner := substr(ty, 1, len(ty) - 1)
    i := 0
    for i < len(inner):
        if inner[i] == 58:                       # first ':' (key is always str)
            return substr(inner, i + 1, len(inner))
        i = i + 1
    return "int"

fn mstruct(ty: string) -> string:                # map C struct name
    return "Map_str_" + map_val(ty)

fn mfam(ty: string) -> string:                   # map runtime function prefix
    return "map_str_" + map_val(ty)

fn is_cmp(op: string) -> bool:
    return op == "==" or op == "!=" or op == "<" or op == ">" or op == "<=" or op == ">="

# Option(T)/Result(T,E) types are stored as their normalized source string.
fn has_prefix(s: string, p: string) -> bool:
    if len(s) < len(p):
        return false
    return substr(s, 0, len(p)) == p

fn is_option(ty: string) -> bool:
    return has_prefix(ty, "Option(")

fn is_result(ty: string) -> bool:
    return has_prefix(ty, "Result(")

fn option_inner(ty: string) -> string:            # "Option(T)" -> "T"
    return substr(ty, 7, len(ty) - 1)

# index of the top-level comma in a Result inner "T,E" (depth-aware over ()[])
fn top_comma(s: string) -> int:
    depth := 0
    i := 0
    for i < len(s):
        c := s[i]
        if c == 40 or c == 91:
            depth = depth + 1
        elif c == 41 or c == 93:
            depth = depth - 1
        elif c == 44 and depth == 0:
            return i
        i = i + 1
    return -1

fn result_ok(ty: string) -> string:               # "Result(T,E)" -> "T"
    inner := substr(ty, 7, len(ty) - 1)
    return substr(inner, 0, top_comma(inner))

fn result_err(ty: string) -> string:               # "Result(T,E)" -> "E"
    inner := substr(ty, 7, len(ty) - 1)
    return substr(inner, top_comma(inner) + 1, len(inner))

fn is_tuple(ty: string) -> bool:
    return len(ty) > 0 and ty[0] == 40           # "(T,U,...)"

fn tuple_parts(ty: string) -> [string]:          # depth-aware split of the inner types
    inner := substr(ty, 1, len(ty) - 1)
    parts := []string
    depth := 0
    start := 0
    i := 0
    for i < len(inner):
        c := inner[i]
        if c == 40 or c == 91 or c == 123:
            depth = depth + 1
        elif c == 41 or c == 93 or c == 125:
            depth = depth - 1
        elif c == 44 and depth == 0:
            push(parts, substr(inner, start, i))
            start = i + 1
        i = i + 1
    push(parts, substr(inner, start, len(inner)))
    return parts

fn tup_suffix(ty: string) -> string:             # parts mangled, joined by "_"
    parts := tuple_parts(ty)
    out := ""
    i := 0
    for i < len(parts):
        if i > 0:
            out = out + "_"
        out = out + mangle(parts[i])
        i = i + 1
    return out

# A valid C identifier suffix for an element type, so composite element types
# (nested arrays, Option/Result/tuple elements) get legal `Arr_<mangle>` names.
fn mangle(ty: string) -> string:
    if is_array(ty):
        return "arr_" + mangle(elem_ty(ty))
    if is_option(ty):
        return "opt_" + mangle(option_inner(ty))
    if is_result(ty):
        return "res_" + mangle(result_ok(ty)) + "_" + mangle(result_err(ty))
    if is_tuple(ty):
        return "tup_" + tup_suffix(ty)
    if is_map(ty):
        return "map_str_" + map_val(ty)
    if is_soa(ty):
        return "soa_" + soa_struct(ty)
    return ty                                    # int/str/float/struct/enum/newtype: already valid

# Newtypes (`type X = U`) are zero-cost: distinct only for type checking (which
# the C compiler already did), so codegen resolves them to the underlying type.
fn is_newtype(ctx: Ctx, name: string) -> bool:
    i := 0
    for i < len(ctx.ntnames):
        if ctx.ntnames[i] == name:
            return true
        i = i + 1
    return false

fn resolve_nt(ctx: Ctx, ty: string) -> string:
    i := 0
    for i < len(ctx.ntnames):
        if ctx.ntnames[i] == ty:
            return resolve_nt(ctx, ctx.ntunder[i])
        i = i + 1
    return ty

fn cty(ctx: Ctx, ty: string) -> string:
    if is_newtype(ctx, ty):
        return cty(ctx, resolve_nt(ctx, ty))
    if is_inout(ty):                              # inout T -> pointer to T's C type
        inner := cty(ctx, base_ty(ty))           # ends with a space
        return substr(inner, 0, len(inner) - 1) + "* "
    if ty == "int":
        return "long "
    if ty == "float":
        return "double "
    if ty == "str":
        return "char* "
    if is_array(ty):                              # [T] -> the monomorphized Arr_T
        return "Arr_" + mangle(elem_ty(ty)) + " "
    if is_map(ty):                                # {str:V} -> Map_str_V
        return mstruct(ty) + " "
    if is_option(ty):
        return "HOption "
    if is_result(ty):
        return "HResult "
    if is_tuple(ty):
        return "Tup_" + tup_suffix(ty) + " "
    if is_soa(ty):                                # soa [Struct] -> Soa_Struct
        return "Soa_" + soa_struct(ty) + " "
    if is_enum(ctx, ty):                          # enum value -> pointer to node
        return ty + "* "
    return ty + " "                              # struct type: its own typedef

fn var_type(names: [string], types: [string], name: string) -> string:
    i := len(names) - 1                          # newest-first (shadowing)
    for i >= 0:
        if names[i] == name:
            return types[i]
        i = i - 1
    die("type: unknown variable")
    return "int"

fn is_struct(ctx: Ctx, name: string) -> bool:
    i := 0
    for i < len(ctx.structs):
        if ctx.structs[i].name == name:
            return true
        i = i + 1
    return false

fn field_type(ctx: Ctx, sname: string, fld: string) -> string:
    i := 0
    for i < len(ctx.structs):
        if ctx.structs[i].name == sname:
            j := 0
            for j < len(ctx.structs[i].fields):
                if ctx.structs[i].fields[j].name == fld:
                    return ctx.structs[i].fields[j].ty
                j = j + 1
            die("type: no such field")
        i = i + 1
    die("type: field access on a non-struct")
    return "int"

# A struct is "heap-bearing" if any field owns heap memory (a string, an array,
# or a nested heap-bearing struct) and so needs a deep copy on value binding.
# Enum fields are immutable pointers — shared sharing is observationally safe.
fn struct_is_heap(ctx: Ctx, sname: string) -> bool:
    i := 0
    for i < len(ctx.structs):
        if ctx.structs[i].name == sname:
            j := 0
            for j < len(ctx.structs[i].fields):
                ft := ctx.structs[i].fields[j].ty
                if ft == "str":
                    return true
                if is_array(ft):
                    return true
                if is_soa(ft):                   # a soa field owns heap buffers
                    return true
                if is_struct(ctx, ft) and struct_is_heap(ctx, ft):
                    return true
                j = j + 1
            return false
        i = i + 1
    return false

fn sig_ret(ctx: Ctx, name: string) -> string:
    if name == "str":
        return "str"
    if name == "substr":
        return "str"
    if name == "chr":
        return "str"
    if name == "input":
        return "str"
    if name == "split":
        return "[str]"
    if name == "keys":
        return "[str]"
    if name == "map_get":
        return "int"
    if name == "map_has":
        return "int"
    if name == "find":
        return "int"
    if name == "to_float":
        return "float"
    if name == "to_int":
        return "int"
    if name == "to_str":                          # unwrap a string newtype
        return "str"
    if name == "to_bool":                         # unwrap a bool newtype (bool is int)
        return "int"
    if name == "read_all":
        return "str"
    if name == "die":
        return "int"
    if name == "len":
        return "int"
    if name == "input":
        return "str"
    if is_newtype(ctx, name):                     # X(v) constructor -> the newtype
        return name
    if is_variant(ctx, name):                     # enum construction yields its enum
        return variant_enum(ctx, name)
    if is_struct(ctx, name):                      # construction yields the struct
        return name
    i := 0
    for i < len(ctx.sigs):
        if ctx.sigs[i].name == name:
            return ctx.sigs[i].ret
        i = i + 1
    die("type: unknown function")
    return "int"

fn type_of(e: Expr, names: [string], types: [string], ctx: Ctx) -> string:
    match e:
        EInt(t):
            return "int"
        EFloat(f):
            return "float"
        EStr(s):
            return "str"
        EVar(name):
            if name == "None":
                return "Option()"
            if is_variant(ctx, name):            # bare no-payload variant (e.g. Green)
                return variant_enum(ctx, name)
            vt := base_ty(var_type(names, types, name))
            return resolve_nt(ctx, vt)
        EField(base, fld):
            bt := type_of(base, names, types, ctx)
            if is_tuple(bt):                      # tuple index t.0 -> the i-th part type
                return tuple_parts(bt)[fld[0] - 48]
            return resolve_nt(ctx, field_type(ctx, bt, fld))
        EIndex(base, idx):
            bt := type_of(base, names, types, ctx)
            if bt == "str":
                return "int"                      # s[i] is the byte value (ord)
            if is_soa(bt):
                return soa_struct(bt)             # soa element -> the struct
            return substr(bt, 1, len(bt) - 1)     # else array element type
        EArrLit(elems):
            return "[" + type_of(elems[0], names, types, ctx) + "]"
        EArrEmpty(ety):
            if is_soa(ety):                       # `soa []Struct` carries the full soa type
                return ety
            return "[" + ety + "]"
        EMapEmpty(kty, vty):
            return "{" + kty + ":" + vty + "}"
        EMapLit(keys, vals):
            return "{str:" + type_of(vals[0], names, types, ctx) + "}"
        ETuple(elems):
            out := "("
            j := 0
            for j < len(elems):
                if j > 0:
                    out = out + ","
                out = out + type_of(elems[j], names, types, ctx)
                j = j + 1
            return out + ")"
        ESlice(base, lo, hi):
            return type_of(base, names, types, ctx)   # same array type
        EAddr(inner):
            return type_of(inner, names, types, ctx)
        EBin(op, l, r):
            lt := type_of(l, names, types, ctx)
            rt := type_of(r, names, types, ctx)
            if op == "+" and (lt == "str" or rt == "str"):
                return "str"
            if op == "+" or op == "-" or op == "*" or op == "/":
                if lt == "float" or rt == "float":
                    return "float"
                return "int"
            return "int"                          # comparisons, &&, || -> int (bool)
        ECall(name, args):
            if name == "map_set" or name == "map_del":   # return the first arg's map type
                return type_of(args[0], names, types, ctx)
            if name == "map_get":                 # returns the map's value type
                return map_val(type_of(args[0], names, types, ctx))
            if name == "Some":
                return "Option(" + type_of(args[0], names, types, ctx) + ")"
            if name == "Ok":
                return "Result(" + type_of(args[0], names, types, ctx) + ",)"
            if name == "Err":
                return "Result(," + type_of(args[0], names, types, ctx) + ")"
            return resolve_nt(ctx, sig_ret(ctx, name))

fn gen_args(args: [Expr], names: [string], types: [string], ctx: Ctx) -> string:
    out := ""
    i := 0
    for i < len(args):
        if i > 0:
            out = out + ", "
        out = out + gen_expr(args[i], names, types, ctx)
        i = i + 1
    return out

# Like gen_args, but for CONSTRUCTION (struct/enum/array literal): the argument
# value is STORED in the aggregate and outlives the expression, so a heap place
# argument must be deep-copied for value semantics — else the stored field
# aliases the source's buffer, and mutating the source later corrupts the stored
# value (`a := [..]; t := Box(a, ..); a[0] = 9` must leave t untouched). gen_rhs
# copies only is_place heap args; fresh values / scalars / strings pass through.
# Mirrors the tuple path (gen_rhs per element) and the C compiler's per-field
# copy_into. (Found by tests/value_semantics.hi probe 3.)
fn gen_store_args(args: [Expr], names: [string], types: [string], ctx: Ctx) -> string:
    # Values STORED into a container (array-literal / struct / enum / tuple
    # fields) must be malloc'd (owner "0"), not built in the ambient owner: a
    # construction inside a `return` expr has owner=_parent, and the constructed
    # container would then hold _parent-arena string pointers that dangle once the
    # caller's scope frees. Forcing "0" keeps stored strings immortal. (Outside a
    # return, owner is already "0", so this is a no-op there.)
    sctx := with_owner(ctx, "0")
    out := ""
    i := 0
    for i < len(args):
        if i > 0:
            out = out + ", "
        out = out + gen_rhs(args[i], names, types, sctx)
        i = i + 1
    return out

# index of field `fld` in struct `sname` (the soa buffer is f<index>).
fn soa_field_index(ctx: Ctx, sname: string, fld: string) -> int:
    si := 0
    for si < len(ctx.structs):
        if ctx.structs[si].name == sname:
            j := 0
            for j < len(ctx.structs[si].fields):
                if ctx.structs[si].fields[j].name == fld:
                    return j
                j = j + 1
        si = si + 1
    return 0

# If `base` is `soa[i]`, the C for `base.fld` is the field buffer slot
# `(soa).fN[i]` -- a real lvalue, so it serves BOTH read and write. Else "".
# (Hier has no wildcard match, so every Expr arm is listed.)
fn soa_field_access(ctx: Ctx, base: Expr, fld: string, names: [string], types: [string]) -> string:
    match base:
        EIndex(sb, ix):
            sbt := type_of(sb, names, types, ctx)
            if is_soa(sbt):
                fi := soa_field_index(ctx, soa_struct(sbt), fld)
                return "(" + gen_expr(sb, names, types, ctx) + ").f" + str(fi) + "[" + gen_expr(ix, names, types, ctx) + "]"
            return ""
        EInt(t):
            return ""
        EFloat(f):
            return ""
        EStr(s):
            return ""
        EVar(n):
            return ""
        EBin(o, l, r):
            return ""
        ECall(nm, a):
            return ""
        EField(b, f):
            return ""
        EArrLit(es):
            return ""
        EArrEmpty(t):
            return ""
        EMapEmpty(k, v):
            return ""
        EMapLit(ks, vs):
            return ""
        ETuple(es):
            return ""
        ESlice(b, lo, hi):
            return ""
        EAddr(x):
            return ""

# gather a whole struct value from the soa's field buffers at index `ix`.
# (param is `basec` not `sc` — hierc0 emits user names un-prefixed and `sc` is
# the runtime string-concat function, so a `sc` local would shadow it.)
fn gen_soa_gather(ctx: Ctx, ty: string, basec: string, ix: string) -> string:
    sn := soa_struct(ty)
    si := 0
    for si < len(ctx.structs):
        if ctx.structs[si].name == sn:
            flds := ctx.structs[si].fields
            out := "(" + sn + "){"
            i := 0
            for i < len(flds):
                if i > 0:
                    out = out + ","
                out = out + " (" + basec + ").f" + str(i) + "[" + ix + "]"
                i = i + 1
            return out + " }"
        si = si + 1
    die("codegen: soa gather of unknown struct")
    return ""

# soa sub-range [lo:hi]: offset every field buffer by lo (len hi-lo, cap 0).
fn gen_soa_slice(ctx: Ctx, ty: string, basec: string, loc: string, hic: string) -> string:
    sn := soa_struct(ty)
    si := 0
    for si < len(ctx.structs):
        if ctx.structs[si].name == sn:
            flds := ctx.structs[si].fields
            out := "(Soa_" + sn + "){"
            i := 0
            for i < len(flds):
                out = out + " (" + basec + ").f" + str(i) + " + (" + loc + "),"
                i = i + 1
            return out + " (" + hic + ") - (" + loc + "), 0 }"
        si = si + 1
    die("codegen: soa slice of unknown struct")
    return ""

# Return a copy of ctx with a different allocation owner. Sub-expressions of an
# expression built with this ctx allocate into `o` (an arena lvalue string like
# "&_t" / "_parent", or "0" for malloc).
fn with_owner(ctx: Ctx, o: string) -> Ctx:
    return Ctx(ctx.sigs, ctx.structs, ctx.enums, ctx.ntnames, ctx.ntunder, ctx.vparams, ctx.saccums, ctx.rettype, o, ctx.depth, ctx.block_base)

# Enter a nested block: a fresh child arena `_b<depth+1>` becomes the allocation
# owner for the block's transients/local decls. `base` is the env length at entry
# (vars declared from here on are block-local). Sibling blocks reuse the same
# name in separate C scopes; nested blocks get distinct names by depth.
fn enter_block(ctx: Ctx, base: int) -> Ctx:
    d := ctx.depth + 1
    return Ctx(ctx.sigs, ctx.structs, ctx.enums, ctx.ntnames, ctx.ntunder, ctx.vparams, ctx.saccums, ctx.rettype, "&_b" + str(d), d, base)

# C lvalue of the current block's arena.
fn cur_arena(ctx: Ctx) -> string:
    if ctx.depth == 0:
        return "&_scope"
    return "&_b" + str(ctx.depth)

# Free sequence a `return` must run: every enclosing block arena innermost-first,
# then the proc's own _scope. (The returned value lives in _parent, which
# outlives all of these.)
fn return_frees(ctx: Ctx) -> string:
    out := ""
    k := ctx.depth
    for k > 0:
        out = out + "arena_free(&_b" + str(k) + "); "
        k = k - 1
    return out + "arena_free(&_scope);"

fn gen_expr(e: Expr, names: [string], types: [string], ctx: Ctx) -> string:
    match e:
        EInt(t):
            return t
        EFloat(f):
            return f
        EStr(s):
            return "\"" + s + "\""
        EVar(name):
            if name == "None":
                return "hnone()"
            if is_variant(ctx, name):            # bare no-payload variant -> constructor call
                return "mk_" + name + "()"
            if is_inout(var_type(names, types, name)):   # inout param -> deref the pointer
                return "(*" + name + ")"
            return name
        EField(base, fld):
            sf := soa_field_access(ctx, base, fld, names, types)   # soa[i].f -> (soa).fN[i]
            if sf != "":
                return sf
            if is_tuple(type_of(base, names, types, ctx)):   # tuple index t.0 -> t.f0
                return gen_expr(base, names, types, ctx) + ".f" + fld
            return gen_expr(base, names, types, ctx) + "." + fld
        EIndex(base, idx):
            bt := type_of(base, names, types, ctx)
            if bt == "str":                                 # s[i] -> the byte as an int
                return "((long)(unsigned char)" + gen_expr(base, names, types, ctx) + "[" + gen_expr(idx, names, types, ctx) + "])"
            if is_soa(bt):                                  # soa[i] -> gather a struct value
                return gen_soa_gather(ctx, bt, gen_expr(base, names, types, ctx), gen_expr(idx, names, types, ctx))
            return gen_expr(base, names, types, ctx) + ".data[" + gen_expr(idx, names, types, ctx) + "]"
        EArrLit(elems):
            et := type_of(elems[0], names, types, ctx)
            return "Arr_" + mangle(et) + "_from(" + ctx.owner + ", (" + cty(ctx, et) + "[]){" + gen_store_args(elems, names, types, ctx) + "}, " + str(len(elems)) + ")"
        EArrEmpty(ety):
            if is_soa(ety):                       # empty soa: zeroed descriptor
                return "(" + cty(ctx, ety) + "){0}"
            return "Arr_" + mangle(ety) + "_new()"
        EMapEmpty(kty, vty):
            return "map_str_" + vty + "_new()"
        EMapLit(keys, vals):                      # chain of _set onto a fresh map
            f := mfam(type_of(e, names, types, ctx))
            out := f + "_new()"
            j := 0
            for j < len(keys):
                out = f + "_set(" + ctx.owner + ", " + out + ", " + gen_expr(keys[j], names, types, ctx) + ", " + gen_rhs(vals[j], names, types, with_owner(ctx, "0")) + ")"
                j = j + 1
            return out
        ETuple(elems):                            # a tuple owns its fields: deep-copy place elements
            out := "(Tup_" + tup_suffix(type_of(e, names, types, ctx)) + "){"
            j := 0
            for j < len(elems):
                if j > 0:
                    out = out + ", "
                out = out + gen_rhs(elems[j], names, types, with_owner(ctx, "0"))   # tuple owns malloc'd fields (see gen_store_args)
                j = j + 1
            return out + "}"
        ESlice(base, lo, hi):
            bt := type_of(base, names, types, ctx)
            if bt == "str":                       # s[a:b] -> a fresh substring
                return "substr(" + ctx.owner + ", " + gen_expr(base, names, types, ctx) + ", " + gen_expr(lo, names, types, ctx) + ", " + gen_expr(hi, names, types, ctx) + ")"
            if is_soa(bt):
                return gen_soa_slice(ctx, bt, gen_expr(base, names, types, ctx), gen_expr(lo, names, types, ctx), gen_expr(hi, names, types, ctx))
            return "Arr_" + mangle(elem_ty(bt)) + "_slice(" + ctx.owner + ", " + gen_expr(base, names, types, ctx) + ", " + gen_expr(lo, names, types, ctx) + ", " + gen_expr(hi, names, types, ctx) + ")"
        EAddr(inner):                             # &(*p) == p, so passing an inout param onward works
            return "&" + gen_expr(inner, names, types, ctx)
        EBin(op, l, r):
            lt := type_of(l, names, types, ctx)
            if op == "+" and type_of(e, names, types, ctx) == "str":
                return "sc(" + ctx.owner + ", " + gen_expr(l, names, types, ctx) + ", " + gen_expr(r, names, types, ctx) + ")"
            if is_cmp(op) and lt == "str":        # lexicographic string compare (== / != / < ...)
                return "(strcmp(" + gen_expr(l, names, types, ctx) + ", " + gen_expr(r, names, types, ctx) + ") " + op + " 0)"
            # == / != on a structural type (enum/struct/tuple/array/Option/Result):
            # use the generated structural eq; negate for !=. (Enums are boxed
            # pointers, so a raw `!=` would compare addresses, not values.)
            if (op == "==" or op == "!=") and (is_enum(ctx, lt) or is_struct(ctx, lt) or is_tuple(lt) or is_array(lt) or is_option(lt) or is_result(lt) or is_soa(lt) or is_map(lt)):
                eqx := eq_field(ctx, lt, gen_expr(l, names, types, ctx), gen_expr(r, names, types, ctx))
                if op == "!=":
                    return "(!(" + eqx + "))"
                return eqx
            return "(" + gen_expr(l, names, types, ctx) + " " + op + " " + gen_expr(r, names, types, ctx) + ")"
        ECall(name, args):
            if name == "push":                    # push(arr, v): mutate in place
                at := type_of(args[0], names, types, ctx)
                if is_soa(at):                    # soa push: grow each field buffer + scatter
                    return "Soa_" + soa_struct(at) + "_push(&" + gen_expr(args[0], names, types, ctx) + ", " + gen_rhs(args[1], names, types, with_owner(ctx, "0")) + ")"
                et := elem_ty(at)
                return "Arr_" + mangle(et) + "_push(" + owner_arena_of(args[0], names, types, ctx) + ", &" + gen_expr(args[0], names, types, ctx) + ", " + gen_rhs(args[1], names, types, with_owner(ctx, "0")) + ")"
            if name == "len":
                if type_of(args[0], names, types, ctx) == "str":
                    return "strlen(" + gen_expr(args[0], names, types, ctx) + ")"
                return gen_expr(args[0], names, types, ctx) + ".len"
            if name == "str":
                if type_of(args[0], names, types, ctx) == "float":
                    return "f2s(" + ctx.owner + ", " + gen_expr(args[0], names, types, ctx) + ")"
                return "i2s(" + ctx.owner + ", " + gen_expr(args[0], names, types, ctx) + ")"
            if name == "to_float":
                return "((double)(" + gen_expr(args[0], names, types, ctx) + "))"
            if name == "to_int":
                return "((long)(" + gen_expr(args[0], names, types, ctx) + "))"
            if name == "to_str" or name == "to_bool":   # zero-cost newtype unwrap
                return gen_expr(args[0], names, types, ctx)
            if name == "substr":
                return "substr(" + ctx.owner + ", " + gen_expr(args[0], names, types, ctx) + ", " + gen_expr(args[1], names, types, ctx) + ", " + gen_expr(args[2], names, types, ctx) + ")"
            if name == "find":
                return "hi_find(" + gen_expr(args[0], names, types, ctx) + ", " + gen_expr(args[1], names, types, ctx) + ")"
            if name == "split":
                return "hi_split(" + ctx.owner + ", " + gen_expr(args[0], names, types, ctx) + ", " + gen_expr(args[1], names, types, ctx) + ")"
            if name == "map_set":
                return mfam(type_of(args[0], names, types, ctx)) + "_set(" + ctx.owner + ", " + gen_expr(args[0], names, types, ctx) + ", " + gen_expr(args[1], names, types, ctx) + ", " + gen_rhs(args[2], names, types, with_owner(ctx, "0")) + ")"
            if name == "map_get":
                return mfam(type_of(args[0], names, types, ctx)) + "_get(" + gen_expr(args[0], names, types, ctx) + ", " + gen_expr(args[1], names, types, ctx) + ", " + gen_expr(args[2], names, types, ctx) + ")"
            if name == "keys":
                return mfam(type_of(args[0], names, types, ctx)) + "_keys(" + ctx.owner + ", " + gen_expr(args[0], names, types, ctx) + ")"
            if name == "map_del":
                return mfam(type_of(args[0], names, types, ctx)) + "_del(" + ctx.owner + ", " + gen_expr(args[0], names, types, ctx) + ", " + gen_expr(args[1], names, types, ctx) + ")"
            if name == "map_has":
                return mfam(type_of(args[0], names, types, ctx)) + "_has(" + gen_expr(args[0], names, types, ctx) + ", " + gen_expr(args[1], names, types, ctx) + ")"
            if name == "chr":
                return "hi_chr(" + ctx.owner + ", " + gen_expr(args[0], names, types, ctx) + ")"
            if name == "die":
                return "hi_die(" + gen_expr(args[0], names, types, ctx) + ")"
            if name == "read_all":
                return "hi_read_all()"
            if name == "input":
                return "hi_input()"
            if name == "Some":                    # box the payload (deep-copy a place: it is stored)
                ct := cty(ctx, type_of(args[0], names, types, ctx))
                return "hsome(hbox(" + ctx.owner + ", sizeof(" + ct + "), (" + ct + "[]){" + gen_rhs(args[0], names, types, with_owner(ctx, "0")) + "}))"
            if name == "Ok":
                ct := cty(ctx, type_of(args[0], names, types, ctx))
                return "hok(hbox(" + ctx.owner + ", sizeof(" + ct + "), (" + ct + "[]){" + gen_rhs(args[0], names, types, with_owner(ctx, "0")) + "}))"
            if name == "Err":
                ce := cty(ctx, type_of(args[0], names, types, ctx))
                return "herr(hbox(" + ctx.owner + ", sizeof(" + ce + "), (" + ce + "[]){" + gen_rhs(args[0], names, types, with_owner(ctx, "0")) + "}))"
            if is_newtype(ctx, name):             # X(v) is zero-cost: identity
                return gen_expr(args[0], names, types, ctx)
            if is_variant(ctx, name):             # enum construction -> mk_Variant(...)
                return "mk_" + name + "(" + gen_store_args(args, names, types, ctx) + ")"
            if is_struct(ctx, name):              # struct construction -> compound literal
                return "(" + name + "){" + gen_store_args(args, names, types, ctx) + "}"
            if len(args) == 0:                    # user call: thread the current scope as the callee's _parent
                return name + "(" + ctx.owner + ")"
            return name + "(" + ctx.owner + ", " + gen_args(args, names, types, ctx) + ")"

# Root variable of a place expression (`s.items[i]` -> `s`), or "" if not a
# place rooted in a variable. Used to find which arena a container lives in.
fn root_var(e: Expr) -> string:
    match e:
        EVar(n):
            return n
        EField(b, f):
            return root_var(b)
        EIndex(b, i):
            return root_var(b)
        EAddr(x):
            return root_var(x)
        EInt(t):
            return ""
        EFloat(f):
            return ""
        EStr(s):
            return ""
        EBin(o, l, r):
            return ""
        ECall(n, a):
            return ""
        EArrLit(es):
            return ""
        EArrEmpty(t):
            return ""
        EMapEmpty(k, v):
            return ""
        EMapLit(ks, vs):
            return ""
        ETuple(es):
            return ""
        ESlice(b, lo, hi):
            return ""

# The arena a container place lives in: an inout-param container is the caller's
# (its buffer must grow in _parent so it survives the call); a local lives in
# this function's _scope. (One scope per function until MM-5 adds per-block.)
# Most recent declaration index of `name` in the env (-1 if absent). Searches
# from the end so a shadowing inner decl wins.
fn var_index(names: [string], name: string) -> int:
    i := len(names) - 1
    for i >= 0:
        if names[i] == name:
            return i
        i = i - 1
    return -1

# The arena a container place lives in (so a push/grow lands where the container
# itself lives). inout-param container: malloc ("0") — its true home is further
# up the inout chain than _parent, which hierc0 doesn't thread (the C compiler's
# _ina_ param); malloc is immortal so it never dangles. A var declared in the
# current block (index >= block_base): the block arena, freed at block exit / per
# loop iteration. An outer-scope local: the function _scope (outlives all blocks).
fn owner_arena_of(e: Expr, names: [string], types: [string], ctx: Ctx) -> string:
    rv := root_var(e)
    if rv == "":
        return "&_scope"
    if is_inout(var_type(names, types, rv)):
        return "0"
    if var_index(names, rv) >= ctx.block_base:
        return cur_arena(ctx)
    return "&_scope"

# Is `e` an existing storage location (vs a fresh value)? Assigning FROM a
# place needs a value-semantic deep copy so the two bindings stay independent.
fn is_place(e: Expr) -> bool:
    match e:
        EVar(n):
            return true
        EField(b, f):
            return true
        EIndex(b, i):
            return true
        EInt(t):
            return false
        EFloat(f):
            return false
        EStr(s):
            return false
        EBin(o, l, r):
            return false
        ECall(n, a):
            return false
        EArrLit(es):
            return false
        EArrEmpty(t):
            return false
        EMapEmpty(k, v):
            return false
        EMapLit(ks, vs):
            return false
        ETuple(es):
            return false
        ESlice(b, lo, hi):
            return true                          # a slice aliases its source; binding it copies
        EAddr(inner):
            return false

fn is_evar(e: Expr, name: string) -> bool:
    match e:
        EVar(n):
            return n == name
        EInt(t):
            return false
        EFloat(f):
            return false
        EStr(s):
            return false
        EBin(o, l, r):
            return false
        ECall(nm, a):
            return false
        EField(b, f):
            return false
        EIndex(b, i):
            return false
        EArrLit(es):
            return false
        EArrEmpty(t):
            return false
        EMapEmpty(k, v):
            return false
        EMapLit(ks, vs):
            return false
        ETuple(es):
            return false
        ESlice(b, lo, hi):
            return false
        EAddr(x):
            return false

# Deep-copy a C expression `code` of Hier type `ty` (value semantics for a bind
# whose value may be mutated). Copies the mutable heap containers; scalars,
# strings (immutable), and enum/option/result (immutable) are share-safe.
fn cp_typed(ctx: Ctx, ty: string, code: string) -> string:
    rt := resolve_nt(ctx, ty)
    if is_array(rt):
        return "Arr_" + mangle(elem_ty(rt)) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_map(rt):
        return mfam(rt) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_tuple(rt):
        return "Tup_" + tup_suffix(rt) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_struct(ctx, rt) and struct_is_heap(ctx, rt):
        return rt + "_copy(" + ctx.owner + ", " + code + ")"
    return code

# RHS of a whole-value binding: deep-copy an array read from a place so the new
# binding is independent (Hier value semantics). Fresh arrays (literals, call
# results) already own their buffer; scalars/strings need no copy.
fn gen_rhs(e: Expr, names: [string], types: [string], ctx: Ctx) -> string:
    code := gen_expr(e, names, types, ctx)
    ty := type_of(e, names, types, ctx)
    if is_array(ty) and is_place(e):
        return "Arr_" + mangle(elem_ty(ty)) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_struct(ctx, ty) and struct_is_heap(ctx, ty) and is_place(e):
        return ty + "_copy(" + ctx.owner + ", " + code + ")"
    if is_map(ty) and is_place(e):               # value-semantic map copy (e.g. snap := counts)
        return mfam(ty) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_tuple(ty) and is_place(e):             # value-semantic tuple copy (b := a)
        return "Tup_" + tup_suffix(ty) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_soa(ty) and is_place(e):               # value-semantic soa copy (bind/pass/return)
        return "Soa_" + soa_struct(ty) + "_copy(" + code + ")"
    if ty == "str" and is_place(e):              # copy a string bound from a place, so an
        return "scopy(" + ctx.owner + ", " + code + ")" # in-place-appended accumulator's snapshot stays independent
    return code

# names/types are passed BY VALUE so a block's decls never escape to sibling
# or outer scopes (matching C/Hier block scoping).
fn gen_block(stmts: [Stmt], names: [string], types: [string], ctx: Ctx) -> string:
    out := ""
    ns := names                                  # local mutable copies; decls
    ts := types                                  # added here stay block-local
    i := 0
    for i < len(stmts):
        out = out + gen_stmt(stmts[i], &ns, &ts, ctx)
        i = i + 1
    return out

fn gen_stmt(s: Stmt, names: inout [string], types: inout [string], ctx: Ctx) -> string:
    match s:
        SDecl(name, e):
            ty := type_of(e, names, types, ctx)
            if has_str(ctx.saccums, name):        # string accumulator: heap buffer + len/cap sidecars
                code := "    char* " + name + " = scopy(0, " + gen_expr(e, names, types, ctx) + ");\n    long _len_" + name + " = strlen(" + name + ");\n    long _cap_" + name + " = _len_" + name + " + 1;\n"
                push(names, name)
                push(types, ty)
                return code
            code := "    " + cty(ctx, ty) + name + " = " + gen_rhs(e, names, types, ctx) + ";\n"
            push(names, name)                     # in scope for later stmts
            push(types, ty)
            return code
        SAssign(name, e):
            lhs := gen_expr(EVar(name), names, types, ctx)
            if has_str(ctx.saccums, name):        # string accumulator
                pieces := sacc_pieces(e, name)
                if len(pieces) > 0:               # s = s + p1 + ... -> in-place append each piece
                    aout := ""
                    k := 0
                    for k < len(pieces):
                        aout = aout + "    hi_append(&" + name + ", &_len_" + name + ", &_cap_" + name + ", " + gen_expr(pieces[k], names, types, ctx) + ");\n"
                        k = k + 1
                    return aout
                # plain reassign of an accumulator: heap-ify + resync the sidecars
                return "    " + name + " = scopy(0, " + gen_expr(e, names, types, ctx) + ");\n    _len_" + name + " = strlen(" + name + ");\n    _cap_" + name + " = _len_" + name + " + 1;\n"
            deflt := "    " + lhs + " = " + gen_rhs(e, names, types, with_owner(ctx, owner_arena_of(EVar(name), names, types, ctx))) + ";\n"   # build in the var's home arena (block-local -> block; outer -> &_scope)
            match e:                              # accumulator rewrite: x = map_set(x,k,v) -> in-place put
                # A by-value map PARAM must NOT take the in-place put: it shares
                # the caller's table, so mutating it in place is a value-semantics
                # violation. ctx.vparams holds this func's non-inout params; for
                # those we fall through to `deflt` (pure map_set = deep-copy+put),
                # matching the C compiler (src/hierc.c:3556 drops non-inout params
                # from accums). Locals and inout map params still grow in place.
                ECall(fname, args):
                    if fname == "map_set" and is_evar(args[0], name) and not has_str(ctx.vparams, name):
                        return "    " + mfam(type_of(EVar(name), names, types, ctx)) + "_put(" + owner_arena_of(EVar(name), names, types, ctx) + ", &" + lhs + ", " + gen_expr(args[1], names, types, ctx) + ", " + gen_expr(args[2], names, types, ctx) + ");\n"
                    return deflt
                EInt(t):
                    return deflt
                EFloat(f):
                    return deflt
                EStr(s):
                    return deflt
                EVar(n):
                    return deflt
                EBin(o, l, r):
                    return deflt
                EField(b, f):
                    return deflt
                EIndex(b, i):
                    return deflt
                EArrLit(es):
                    return deflt
                EArrEmpty(t):
                    return deflt
                EMapEmpty(k, v):
                    return deflt
                EMapLit(ks, vs):
                    return deflt
                ETuple(es):
                    return deflt
                ESlice(b, lo, hi):
                    return deflt
                EAddr(x):
                    return deflt
        SFieldAssign(lv, rhs):
            # storing into a (malloc) struct field / array element: the value must
            # be malloc'd (owner "0"), not left in _scope which frees at return.
            return "    " + gen_expr(lv, names, types, ctx) + " = " + gen_rhs(rhs, names, types, with_owner(ctx, "0")) + ";\n"
        SPrint(e):
            if type_of(e, names, types, ctx) != "str":
                die("codegen: print expects a string")
            # transient arena: the print arg's string temporaries are consumed by
            # fputs and never escape, so build them in _t and free it right after.
            return "    { Arena _t = arena_new(0); fputs(" + gen_expr(e, names, types, with_owner(ctx, "&_t")) + ", stdout); arena_free(&_t); }\n"
        SReturn(e):
            # deep-copy a returned heap PLACE (a field/element/variable): the
            # return value outlives the callee, so it must not alias the source's
            # buffer (`return b.items` then the caller mutates the result must not
            # reach b). gen_rhs copies is_place array/struct/map/tuple; fresh
            # values / scalars / strings pass through. (tests/value_semantics.hi
            # probe 9; the C compiler does this via return-promotion.)
            # return-slot: evaluate into _ret, free this scope, then return _ret.
            # (S1: the value is still malloc'd, so the free reclaims nothing; later
            # sub-steps build the return value in _parent so this stays sound.)
            # build the return value in _parent (the caller's arena, which outlives
            # _scope), then free _scope. Any string the value reaches is either built
            # in _parent here or, if stored into a constructed container, forced to
            # malloc by the store sites (gen_store_args/ETuple/map_set/hbox) — so the
            # returned value never points into the freed _scope.
            # free every enclosing block arena (return_frees), innermost-first,
            # then _scope; the value is in _parent which outlives them all.
            return "    { " + cty(ctx, ctx.rettype) + "_ret = " + gen_rhs(e, names, types, with_owner(ctx, "_parent")) + "; " + return_frees(ctx) + " return _ret; }\n"
        SReturnVoid:
            return "    " + return_frees(ctx) + " return;\n"
        SExpr(e):
            return "    " + gen_expr(e, names, types, ctx) + ";\n"
        STypedDecl(name, ty, e):                  # annotation fixes the var's type
            if has_str(ctx.saccums, name):        # string accumulator (annotated): same heap buffer + sidecars
                code := "    char* " + name + " = scopy(0, " + gen_expr(e, names, types, ctx) + ");\n    long _len_" + name + " = strlen(" + name + ");\n    long _cap_" + name + " = _len_" + name + " + 1;\n"
                push(names, name)
                push(types, ty)
                return code
            code := "    " + cty(ctx, ty) + name + " = " + gen_rhs(e, names, types, ctx) + ";\n"
            push(names, name)
            push(types, ty)
            return code
        SDestructure(dnames, e):                  # a, b := tuple_expr
            tt := type_of(e, names, types, ctx)
            parts := tuple_parts(tt)
            tmp := "_d_" + dnames[0]
            code := "    Tup_" + tup_suffix(tt) + " " + tmp + " = " + gen_expr(e, names, types, ctx) + ";\n"
            j := 0
            for j < len(dnames):
                code = code + "    " + cty(ctx, parts[j]) + dnames[j] + " = " + tmp + ".f" + str(j) + ";\n"
                push(names, dnames[j])
                push(types, parts[j])
                j = j + 1
            return code
        SMultiAssign(mnames, e):                  # a, b = tuple_expr (existing vars)
            tt := type_of(e, names, types, ctx)
            tmp := "_ma_" + mnames[0]
            code := "    Tup_" + tup_suffix(tt) + " " + tmp + " = " + gen_expr(e, names, types, ctx) + ";\n"
            j := 0
            for j < len(mnames):
                code = code + "    " + mnames[j] + " = " + tmp + ".f" + str(j) + ";\n"
                j = j + 1
            return code
        SOrReturn(name, e):                       # unwrap Ok/Some, or propagate Err/None upward
            rty := type_of(e, names, types, ctx)
            tmp := "_or_" + name
            if is_option(rty):                    # Option: unwrap Some, else return None
                cto := cty(ctx, option_inner(rty))
                oc := "    HOption " + tmp + " = " + gen_expr(e, names, types, ctx) + ";\n"
                oc = oc + "    if (" + tmp + ".tag == 0) return hnone();\n"
                oc = oc + "    " + cto + name + " = *(" + cto + "*)(" + tmp + ".val);\n"
                push(names, name)
                push(types, option_inner(rty))
                return oc
            ct := cty(ctx, result_ok(rty))
            code := "    HResult " + tmp + " = " + gen_expr(e, names, types, ctx) + ";\n"
            code = code + "    if (" + tmp + ".tag == 0) return " + tmp + ";\n"
            code = code + "    " + ct + name + " = *(" + ct + "*)(" + tmp + ".ok);\n"
            push(names, name)
            push(types, result_ok(rty))
            return code
        SIf(cond, then_body, else_body):
            d1 := str(ctx.depth + 1)              # each branch is its own block arena
            bc := enter_block(ctx, len(names))
            op := "        Arena _b" + d1 + " = arena_child(" + cur_arena(ctx) + ");\n"
            fr := "        arena_free(&_b" + d1 + ");\n"
            out := "    if (" + gen_expr(cond, names, types, ctx) + ") {\n" + op + gen_block(then_body, names, types, bc) + fr + "    }"
            if len(else_body) > 0:
                out = out + " else {\n" + op + gen_block(else_body, names, types, bc) + fr + "    }"
            return out + "\n"
        SWhile(cond, body):
            d1 := str(ctx.depth + 1)              # per-iteration block arena
            bc := enter_block(ctx, len(names))
            return "    while (" + gen_expr(cond, names, types, ctx) + ") {\n        Arena _b" + d1 + " = arena_child(" + cur_arena(ctx) + ");\n" + gen_block(body, names, types, bc) + "        arena_free(&_b" + d1 + ");\n    }\n"
        SForRange(name, start, stop, step, body):
            header := "    for (long " + name + " = " + gen_expr(start, names, types, ctx) + "; " + name + " < " + gen_expr(stop, names, types, ctx) + "; " + name + " += " + gen_expr(step, names, types, ctx) + ") {\n"
            bn := names                           # loop var is scoped to body
            bt := types
            push(bn, name)
            push(bt, "int")
            d1 := str(ctx.depth + 1)              # per-iteration block arena
            bc := enter_block(ctx, len(bn))
            return header + "        Arena _b" + d1 + " = arena_child(" + cur_arena(ctx) + ");\n" + gen_block(body, bn, bt, bc) + "        arena_free(&_b" + d1 + ");\n    }\n"
        SMatch(subj, variants, allbinds, bodies):  # tag-dispatch over an enum value
            sty := type_of(subj, names, types, ctx)
            scu := gen_expr(subj, names, types, ctx)   # subj is a simple place / pure call
            if is_option(sty) or is_result(sty):
                return gen_match_optres(ctx, sty, scu, variants, allbinds, bodies, names, types)
            out := ""
            i := 0
            for i < len(variants):
                vname := variants[i]
                binds := allbinds[i]
                pts := variant_ptypes(ctx, vname)
                kw := " else if ("
                if i == 0:
                    kw = "    if ("
                out = out + kw + scu + "->tag == " + str(variant_tag(ctx, vname)) + ") {\n"
                bn := names                       # arm bindings are scoped to the arm
                bt := types
                j := 0
                for j < len(binds):
                    out = out + "    " + cty(ctx, pts[j]) + binds[j] + " = " + cp_typed(ctx, pts[j], scu + "->" + vname + "_" + str(j)) + ";\n"
                    push(bn, binds[j])
                    push(bt, pts[j])
                    j = j + 1
                out = out + gen_block(bodies[i], bn, bt, ctx) + "    }"
                i = i + 1
            return out + "\n"

fn ret_cty(ctx: Ctx, ret: string) -> string:
    if ret == "void":
        return "void "
    return cty(ctx, ret)

fn gen_params(f: Func, ctx: Ctx) -> string:
    out := "Arena* _parent"                       # every fn threads the caller's arena
    i := 0
    for i < len(f.params):
        out = out + ", " + cty(ctx, f.ptypes[i]) + f.params[i]
        i = i + 1
    return out

fn seed_env(f: Func, names: inout [string], types: inout [string]):
    i := 0
    for i < len(f.params):
        push(names, f.params[i])
        push(types, f.ptypes[i])
        i = i + 1

fn gen_proto(f: Func, ctx: Ctx) -> string:
    return ret_cty(ctx, f.ret) + f.name + "(" + gen_params(f, ctx) + ");\n"

# Leftmost-flatten an all-'+' EBin chain into its operands, left to right.
# A non-'+' binop or any leaf is one whole piece. So `a + b + c` -> [a, b, c]
# but `(a - b) + c` -> [(a-b), c].
fn plus_flatten(e: Expr, out: inout [Expr]):
    match e:
        EBin(op, l, r):
            if op == "+":
                plus_flatten(l, &out)
                push(out, r)
            else:
                push(out, e)
        EInt(t):
            push(out, e)
        EFloat(f):
            push(out, e)
        EStr(s):
            push(out, e)
        EVar(n):
            push(out, e)
        ECall(nm, args):
            push(out, e)
        EField(b, fl):
            push(out, e)
        EIndex(b, ix):
            push(out, e)
        EArrLit(es):
            push(out, e)
        EArrEmpty(t):
            push(out, e)
        EMapEmpty(k, v):
            push(out, e)
        EMapLit(ks, vs):
            push(out, e)
        ETuple(es):
            push(out, e)
        ESlice(b, lo, hi):
            push(out, e)
        EAddr(x):
            push(out, e)

# If `e` is `name + p1 + p2 + ...` (an all-'+' chain whose leftmost leaf is the
# variable `name`), return the appended pieces [p1, p2, ...]; else []. Used both
# to DETECT a string self-append accumulator and to emit its in-place appends.
fn sacc_pieces(e: Expr, name: string) -> [Expr]:
    ps := []Expr
    plus_flatten(e, &ps)
    if len(ps) < 2:
        return []Expr
    if not is_evar(ps[0], name):
        return []Expr
    return ps[1:]

# Collect string locals that are self-append accumulators (`s = s + ...`). These
# get a growing heap buffer + len/cap sidecars and in-place hi_append instead of
# the O(n^2) sc()-rebuild. Threads the var env (like collect_stmt) so the type
# guard `var_type == "str"` is accurate; a non-str `c = c + 1` is never flagged.
# Match arms bind payloads as "" (unknown) — at worst an arm-local accumulator is
# missed (stays the safe pure-concat path); a false positive is impossible.
fn sacc_block(acc: inout [string], stmts: [Stmt], names: [string], types: [string], ctx: Ctx):
    ns := names
    ts := types
    i := 0
    for i < len(stmts):
        sacc_stmt(&acc, stmts[i], &ns, &ts, ctx)
        i = i + 1

fn sacc_stmt(acc: inout [string], s: Stmt, names: inout [string], types: inout [string], ctx: Ctx):
    match s:
        SDecl(n, e):
            dty := type_of(e, names, types, ctx)   # compute BEFORE pushing n (keep names/types in sync)
            push(names, n)
            push(types, dty)
        SAssign(n, e):
            if var_type(names, types, n) == "str":
                if len(sacc_pieces(e, n)) > 0:
                    push(acc, n)
        SFieldAssign(lv, rhs):
            i := 0
        SPrint(e):
            i := 0
        SReturn(e):
            i := 0
        SReturnVoid:
            i := 0
        SExpr(e):
            i := 0
        STypedDecl(n, t, e):
            push(names, n)
            push(types, t)
        SOrReturn(n, e):
            ety := type_of(e, names, types, ctx)
            ty := ""
            if is_option(ety):
                ty = option_inner(ety)
            else:
                ty = result_ok(ety)
            push(names, n)
            push(types, ty)
        SDestructure(dn, e):
            parts := tuple_parts(type_of(e, names, types, ctx))
            i := 0
            for i < len(dn):
                push(names, dn[i])
                push(types, parts[i])
                i = i + 1
        SMultiAssign(mn, e):
            i := 0
        SIf(c, tb, eb):
            sacc_block(&acc, tb, names, types, ctx)
            sacc_block(&acc, eb, names, types, ctx)
        SWhile(c, body):
            sacc_block(&acc, body, names, types, ctx)
        SForRange(n, a, b, st, body):
            bn := names
            bt := types
            push(bn, n)
            push(bt, "int")
            sacc_block(&acc, body, bn, bt, ctx)
        SMatch(subj, variants, allbinds, bodies):
            sty := type_of(subj, names, types, ctx)
            j := 0
            for j < len(bodies):
                bn := names                       # bind arm payloads with PROPER types so
                bt := types                       # type_of resolves in the arm (mirror collect_stmt)
                binds := allbinds[j]
                if is_option(sty):
                    if len(binds) > 0:
                        push(bn, binds[0])
                        push(bt, option_inner(sty))
                elif is_result(sty):
                    if len(binds) > 0:
                        push(bn, binds[0])
                        if variants[j] == "Ok":
                            push(bt, result_ok(sty))
                        else:
                            push(bt, result_err(sty))
                else:
                    pts := variant_ptypes(ctx, variants[j])
                    k := 0
                    for k < len(binds):
                        push(bn, binds[k])
                        push(bt, pts[k])
                        k = k + 1
                sacc_block(&acc, bodies[j], bn, bt, ctx)
                j = j + 1

fn gen_func(f: Func, ctx: Ctx) -> string:
    names := []string
    types := []string
    seed_env(f, &names, &types)
    # Record this func's NON-inout param names so the map accumulator pass skips
    # the in-place put on a by-value map param (it would mutate the caller's
    # shared table). Mirrors the C compiler dropping non-inout params from accums
    # (src/hierc.c:3556). Inout map params are left in (in-place is the wanted
    # mutation). The pure-set fallback rehashes the same way the C compiler does,
    # so key order stays identical (no wordcount divergence).
    vparams := []string
    pi := 0
    for pi < len(f.params):
        if not is_inout(f.ptypes[pi]):
            push(vparams, f.params[pi])
        pi = pi + 1
    # String self-append accumulators (locals only — a param has no SDecl, so no
    # sidecars; like the C compiler dropping non-inout params from accums).
    raw := []string
    sn := names
    st := types
    sacc_block(&raw, f.body, sn, st, ctx)
    saccums := []string
    si := 0
    for si < len(raw):
        isp := false
        pj := 0
        for pj < len(f.params):
            if f.params[pj] == raw[si]:
                isp = true
            pj = pj + 1
        if not isp:
            push(saccums, raw[si])
        si = si + 1
    fctx := Ctx(ctx.sigs, ctx.structs, ctx.enums, ctx.ntnames, ctx.ntunder, vparams, saccums, f.ret, "&_scope", 0, len(f.params))
    if f.name == "main":
        # root arena + a child scope; the scope parents every top-level call.
        return "int main(void) {\n    Arena _root = arena_new(0);\n    Arena _scope = arena_child(&_root);\n" + gen_block(f.body, names, types, fctx) + "    arena_free(&_scope);\n    arena_free(&_root);\n    return 0;\n}\n"
    # open a child scope from the caller's arena; void funcs free it on fall-through
    # (every `return` frees it via the return-slot in gen_stmt).
    tail := ""
    if f.ret == "void":
        tail = "    arena_free(&_scope);\n"
    return ret_cty(fctx, f.ret) + f.name + "(" + gen_params(f, fctx) + ") {\n    Arena _scope = _parent ? arena_child(_parent) : arena_new(0);\n" + gen_block(f.body, names, types, fctx) + tail + "}\n"

fn gen_struct(sd: StructDef, ctx: Ctx) -> string:
    out := "struct " + sd.name + " {\n"          # named tag; forward-declared elsewhere
    i := 0
    for i < len(sd.fields):
        out = out + "    " + cty(ctx, sd.fields[i].ty) + sd.fields[i].name + ";\n"
        i = i + 1
    return out + "};\n"

# Match over a boxed Option/Result value. Some/Ok -> tag 1, None/Err -> tag 0.
# A bound payload is read back from the box: `T x = *(T*)(scrut.val)` (Some),
# `.ok`/`.err` for Result. `sc` is re-evaluated per use; scrutinees are places
# or pure calls in practice (no temp/counter needed).
fn gen_match_optres(ctx: Ctx, sty: string, scu: string, variants: [string], allbinds: [[string]], bodies: [[Stmt]], names: [string], types: [string]) -> string:
    out := ""
    i := 0
    for i < len(variants):
        vname := variants[i]
        binds := allbinds[i]
        tag := 0
        if vname == "Some" or vname == "Ok":
            tag = 1
        kw := " else if ("
        if i == 0:
            kw = "    if ("
        out = out + kw + scu +".tag == " + str(tag) + ") {\n"
        bn := names
        bt := types
        if len(binds) > 0:
            bty := option_inner(sty)
            fld := "val"
            if is_result(sty):
                if vname == "Ok":
                    bty = result_ok(sty)
                    fld = "ok"
                else:
                    bty = result_err(sty)
                    fld = "err"
            ct := cty(ctx, bty)
            out = out + "    " + ct + binds[0] + " = " + cp_typed(ctx, bty, "*(" + ct + "*)(" + scu + "." + fld + ")") + ";\n"
            push(bn, binds[0])
            push(bt, bty)
        out = out + gen_block(bodies[i], bn, bt, ctx) + "    }"
        i = i + 1
    return out + "\n"

# Deep copy for a heap-bearing struct: shallow-copy scalars, then dup each
# heap field (string -> fresh bytes, array -> Arr_T_copy, nested heap struct ->
# its own _copy). Source-order emission gives nested copiers before their users.
fn gen_struct_copy(ctx: Ctx, sd: StructDef) -> string:
    nm := sd.name
    out := "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " s) {\n    " + nm + " r = s;\n"
    i := 0
    for i < len(sd.fields):
        f := sd.fields[i]
        if f.ty == "str":
            out = out + "    r." + f.name + " = sc(ar, s." + f.name + ", \"\");\n"
        elif is_array(f.ty):
            out = out + "    r." + f.name + " = Arr_" + mangle(elem_ty(f.ty)) + "_copy(ar, s." + f.name + ");\n"
        elif is_soa(f.ty):
            out = out + "    r." + f.name + " = Soa_" + soa_struct(f.ty) + "_copy(s." + f.name + ");\n"
        elif is_struct(ctx, f.ty) and struct_is_heap(ctx, f.ty):
            out = out + "    r." + f.name + " = " + f.ty + "_copy(ar, s." + f.name + ");\n"
        i = i + 1
    return out + "    return r;\n}\n"

# Structural equality for a struct: AND of per-field equality (recurses through
# nested structs, arrays, enums, and Option/Result fields via eq_field).
fn gen_struct_eq(ctx: Ctx, sd: StructDef) -> string:
    nm := sd.name
    out := "static int " + nm + "_eq(" + nm + " a, " + nm + " b) { return "
    if len(sd.fields) == 0:
        out = out + "1"
    else:
        j := 0
        for j < len(sd.fields):
            if j > 0:
                out = out + " && "
            f := sd.fields[j]
            out = out + eq_field(ctx, f.ty, "a." + f.name, "b." + f.name)
            j = j + 1
    return out + "; }\n"

# A tuple is an anonymous struct with positional fields f0, f1, ...
fn gen_tuple_struct(ctx: Ctx, ty: string) -> string:
    parts := tuple_parts(ty)
    out := "typedef struct { "
    i := 0
    for i < len(parts):
        out = out + cty(ctx, parts[i]) + "f" + str(i) + "; "
        i = i + 1
    return out + "} Tup_" + tup_suffix(ty) + ";\n"

fn gen_tuple_copy(ctx: Ctx, ty: string) -> string:
    nm := "Tup_" + tup_suffix(ty)
    parts := tuple_parts(ty)
    out := "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " s) {\n    " + nm + " r = s;\n"
    i := 0
    for i < len(parts):
        p := parts[i]
        if p == "str":
            out = out + "    r.f" + str(i) + " = sc(ar, s.f" + str(i) + ", \"\");\n"
        elif is_array(p):
            out = out + "    r.f" + str(i) + " = Arr_" + mangle(elem_ty(p)) + "_copy(ar, s.f" + str(i) + ");\n"
        elif is_struct(ctx, p) and struct_is_heap(ctx, p):
            out = out + "    r.f" + str(i) + " = " + p + "_copy(ar, s.f" + str(i) + ");\n"
        i = i + 1
    return out + "    return r;\n}\n"

fn gen_tuple_eq(ctx: Ctx, ty: string) -> string:
    nm := "Tup_" + tup_suffix(ty)
    parts := tuple_parts(ty)
    out := "static int " + nm + "_eq(" + nm + " a, " + nm + " b) { return "
    i := 0
    for i < len(parts):
        if i > 0:
            out = out + " && "
        out = out + eq_field(ctx, parts[i], "a.f" + str(i), "b.f" + str(i))
        i = i + 1
    return out + "; }\n"

fn eq_field(ctx: Ctx, ty: string, a: string, b: string) -> string:
    if ty == "str":
        return "strcmp(" + a + ", " + b + ") == 0"
    if is_array(ty):
        return "Arr_" + mangle(elem_ty(ty)) + "_eq(" + a + ", " + b + ")"
    if is_enum(ctx, ty):
        return ty + "_eq(" + a + ", " + b + ")"
    if is_struct(ctx, ty):
        return ty + "_eq(" + a + ", " + b + ")"
    if is_tuple(ty):
        return "Tup_" + tup_suffix(ty) + "_eq(" + a + ", " + b + ")"
    if is_map(ty):
        return "map_str_" + map_val(ty) + "_eq(" + a + ", " + b + ")"
    if is_soa(ty):
        return "Soa_" + soa_struct(ty) + "_eq(" + a + ", " + b + ")"
    if is_option(ty):                            # tags equal, and (if Some) payloads equal
        ct := cty(ctx, option_inner(ty))
        pa := "*(" + ct + "*)(" + a + ".val)"
        pb := "*(" + ct + "*)(" + b + ".val)"
        return "(" + a + ".tag == " + b + ".tag && (" + a + ".tag == 0 || " + eq_field(ctx, option_inner(ty), pa, pb) + "))"
    if is_result(ty):
        ct := cty(ctx, result_ok(ty))
        ce := cty(ctx, result_err(ty))
        oa := "*(" + ct + "*)(" + a + ".ok)"
        ob := "*(" + ct + "*)(" + b + ".ok)"
        ea := "*(" + ce + "*)(" + a + ".err)"
        eb := "*(" + ce + "*)(" + b + ".err)"
        okeq := eq_field(ctx, result_ok(ty), oa, ob)
        ereq := eq_field(ctx, result_err(ty), ea, eb)
        return "(" + a + ".tag == " + b + ".tag && (" + a + ".tag == 1 ? " + okeq + " : " + ereq + "))"
    return "(" + a + " == " + b + ")"            # int/bool/float by value

fn gen_enum_decl(ed: EnumDef, ctx: Ctx) -> string:
    out := "struct " + ed.name + " {\n    int tag;\n"
    i := 0
    for i < len(ed.variants):
        v := ed.variants[i]
        j := 0
        for j < len(v.ptypes):
            out = out + "    " + cty(ctx, v.ptypes[j]) + v.name + "_" + str(j) + ";\n"
            j = j + 1
        i = i + 1
    return out + "};\n"

fn gen_enum_ctors(ed: EnumDef, ctx: Ctx) -> string:
    out := ""
    i := 0
    for i < len(ed.variants):
        v := ed.variants[i]
        params := "void"
        if len(v.ptypes) > 0:
            params = ""
            j := 0
            for j < len(v.ptypes):
                if j > 0:
                    params = params + ", "
                params = params + cty(ctx, v.ptypes[j]) + "f" + str(j)
                j = j + 1
        out = out + "static " + ed.name + "* mk_" + v.name + "(" + params + ") {\n"
        out = out + "    " + ed.name + "* n = malloc(sizeof(" + ed.name + "));\n"
        out = out + "    n->tag = " + str(i) + ";\n"
        j := 0
        for j < len(v.ptypes):
            out = out + "    n->" + v.name + "_" + str(j) + " = f" + str(j) + ";\n"
            j = j + 1
        out = out + "    return n;\n}\n"
        i = i + 1
    return out

fn gen_enum_eq(ed: EnumDef, ctx: Ctx) -> string:
    out := "static int " + ed.name + "_eq(" + ed.name + "* a, " + ed.name + "* b) {\n"
    out = out + "    if (a->tag != b->tag) return 0;\n"
    i := 0
    for i < len(ed.variants):
        v := ed.variants[i]
        out = out + "    if (a->tag == " + str(i) + ") return "
        if len(v.ptypes) == 0:
            out = out + "1"
        else:
            j := 0
            for j < len(v.ptypes):
                if j > 0:
                    out = out + " && "
                fld := v.name + "_" + str(j)
                out = out + eq_field(ctx, v.ptypes[j], "a->" + fld, "b->" + fld)
                j = j + 1
        out = out + ";\n"
        i = i + 1
    return out + "    return 0;\n}\n"

fn preamble() -> string:
    out := "#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n"
    # Block-list arena: arena_child carves a fresh block list from the parent's
    # block size; arena_free returns every block. Allocations are 8-byte aligned.
    # (S1 of the memory-model port: threading scaffolding. Allocators still malloc
    # until later sub-steps redirect them, so arena_alloc is defined but unused.)
    out = out + "typedef struct ABlk { struct ABlk* next; size_t used, cap; char* mem; } ABlk;\n"
    out = out + "typedef struct { ABlk* head; size_t blocksz; } Arena;\n"
    out = out + "static Arena arena_new(size_t bs) { Arena a; a.head = 0; a.blocksz = bs ? bs : 65536; return a; }\n"
    out = out + "static Arena arena_child(Arena* p) { return arena_new(p->blocksz); }\n"
    out = out + "static void* arena_alloc(Arena* a, size_t n) { n = (n + 7) & ~(size_t)7; if (!a->head || a->head->used + n > a->head->cap) { size_t cap = a->blocksz; if (cap < n) cap = n; ABlk* b = malloc(sizeof(ABlk)); b->mem = malloc(cap); b->cap = cap; b->used = 0; b->next = a->head; a->head = b; } void* p = a->head->mem + a->head->used; a->head->used += n; return p; }\n"
    out = out + "static void arena_free(Arena* a) { ABlk* b = a->head; while (b) { ABlk* nx = b->next; free(b->mem); free(b); b = nx; } a->head = 0; }\n"
    # String allocators take an arena; a NULL arena means malloc (the safe
    # fallback for not-yet-migrated contexts). owner-threading (ctx.owner) flips
    # provably-safe contexts (e.g. print args) to a real arena. hi_append is NOT
    # arena-based: accumulator buffers are realloc-grown, so they must be malloc.
    out = out + "static void* amem(Arena* a, size_t n) { return a ? arena_alloc(a, n) : malloc(n); }\n"
    out = out + "static char* sc(Arena* ar, const char* a, const char* b) { size_t la = strlen(a), lb = strlen(b); char* r = amem(ar, la + lb + 1); memcpy(r, a, la); memcpy(r + la, b, lb + 1); return r; }\n"
    out = out + "static char* i2s(Arena* ar, long n) { char* r = amem(ar, 24); snprintf(r, 24, \"%ld\", n); return r; }\n"
    out = out + "static char* scopy(Arena* ar, const char* s) { size_t n = strlen(s) + 1; char* r = amem(ar, n); memcpy(r, s, n); return r; }\n"
    out = out + "static void hi_append(char** s, long* len, long* cap, const char* e) { long le = (long)strlen(e); if (*len + le + 1 > *cap) { long nc = *cap > 0 ? *cap : 16; while (nc < *len + le + 1) nc *= 2; *s = (char*)realloc(*s, (size_t)nc); *cap = nc; } memcpy(*s + *len, e, (size_t)le + 1); *len += le; }\n"
    out = out + "static char* f2s(Arena* ar, double x) { char t[64]; int m = snprintf(t, sizeof t, \"%.15g\", x); int fl = 0; for (int i = 0; i < m; i++) { char c = t[i]; if (c == '.' || c == 'e' || c == 'E' || c == 'n' || c == 'N' || c == 'i' || c == 'I') { fl = 1; break; } } if (!fl) { t[m++] = '.'; t[m++] = '0'; t[m] = 0; } char* r = amem(ar, m + 1); memcpy(r, t, m + 1); return r; }\n"
    out = out + "static char* substr(Arena* ar, const char* s, long a, long b) { long n = b - a; char* r = amem(ar, n + 1); memcpy(r, s + a, n); r[n] = 0; return r; }\n"
    out = out + "static long hi_find(const char* s, const char* sub) { const char* p = strstr(s, sub); return p ? (long)(p - s) : -1; }\n"
    out = out + "static char* hi_input(void) { size_t cap = 128, len = 0; char* b = malloc(cap); int c; fflush(stdout); while ((c = getchar()) != EOF && c != '\\n') { if (len + 1 >= cap) { cap *= 2; b = realloc(b, cap); } b[len++] = (char)c; } b[len] = 0; return b; }\n"
    out = out + "static char* hi_chr(Arena* ar, long n) { char* r = amem(ar, 2); r[0] = (char)(n & 0xff); r[1] = 0; return r; }\n"
    out = out + "static void hi_die(const char* m) { fputs(m, stderr); fputc('\\n', stderr); exit(1); }\n"
    out = out + "static char* hi_read_all(void) { size_t cap = 4096, len = 0; char* b = malloc(cap); int c; while ((c = getchar()) != EOF) { if (len + 1 >= cap) { cap *= 2; b = realloc(b, cap); } b[len++] = (char)c; } b[len] = 0; return b; }\n"
    out = out + "typedef struct { int tag; void* val; } HOption;\n"
    out = out + "typedef struct { int tag; void* ok; void* err; } HResult;\n"
    out = out + "static void* hbox(Arena* ar, unsigned long n, void* src) { void* p = amem(ar, n); memcpy(p, src, n); return p; }\n"
    out = out + "static HOption hsome(void* v) { HOption o; o.tag = 1; o.val = v; return o; }\n"
    out = out + "static HOption hnone(void) { HOption o; o.tag = 0; o.val = 0; return o; }\n"
    out = out + "static HResult hok(void* v) { HResult r; r.tag = 1; r.ok = v; r.err = 0; return r; }\n"
    out = out + "static HResult herr(void* v) { HResult r; r.tag = 0; r.ok = 0; r.err = v; return r; }\n"
    return out

# One monomorphized value-array family per element type T: Arr_T holds a
# CTY* buffer; copy is a deep copy (value semantics). The struct definition is
# split from the functions so the element struct's full body can be emitted in
# between (the functions need sizeof(T) / by-value assignment, but the Arr_T
# struct itself only needs T as a pointer — this is what lets [P] and recursive
# structs like `struct Node { kids: [Node] }` compile).
fn gen_arr_type(ctx: Ctx, et: string) -> string:
    nm := "Arr_" + mangle(et)                    # typedef + an _eq forward decl, so
    out := "typedef struct { " + cty(ctx, et) + "* data; long len; long cap; } " + nm + ";\n"
    return out + "static int " + nm + "_eq(" + nm + " a, " + nm + " b);\n"   # cross-refs resolve any order

fn gen_arr_fns(ctx: Ctx, et: string) -> string:
    nm := "Arr_" + mangle(et)
    ct := cty(ctx, et)                           # element C type, trailing space
    out := "static " + nm + " " + nm + "_new(void) { " + nm + " a; a.data = 0; a.len = 0; a.cap = 0; return a; }\n"
    # buffer lives in arena `ar` (NULL=malloc). push ARENA-GROWS (no realloc on
    # arena memory): allocate a doubled buffer and copy; the old one is dead and
    # reclaimed at arena_free. Elements are malloc'd by the store-copy at every
    # store site, so copy/slice stay SHALLOW (element pointers) and remain valid.
    out = out + "static " + nm + " " + nm + "_from(Arena* ar, " + ct + "* s, long n) { " + nm + " a; a.len = n; a.cap = n > 0 ? n : 0; a.data = n ? amem(ar, sizeof(" + ct + ") * n) : 0; if (n) memcpy(a.data, s, sizeof(" + ct + ") * n); return a; }\n"
    out = out + "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " a) { return " + nm + "_from(ar, a.data, a.len); }\n"
    out = out + "static void " + nm + "_push(Arena* ar, " + nm + "* a, " + ct + "v) { if (a->len == a->cap) { long nc = a->cap ? a->cap * 2 : 4; " + ct + "* nd = amem(ar, sizeof(" + ct + ") * nc); if (a->len) memcpy(nd, a->data, sizeof(" + ct + ") * a->len); a->data = nd; a->cap = nc; } a->data[a->len++] = v; }\n"
    out = out + "static " + nm + " " + nm + "_slice(Arena* ar, " + nm + " a, long lo, long hi) { return " + nm + "_from(ar, a.data + lo, hi - lo); }\n"
    # _eq for every element type (eq_field handles scalar/str/enum/struct/array/
    # option/result); the gen_arr_type forward decl lets composite eq cross-ref.
    out = out + "static int " + nm + "_eq(" + nm + " a, " + nm + " b) { if (a.len != b.len) return 0; for (long i = 0; i < a.len; i++) if (!(" + eq_field(ctx, et, "a.data[i]", "b.data[i]") + ")) return 0; return 1; }\n"
    return out

# SOA typedef + helper forward decls — emitted BEFORE struct bodies so a struct
# may embed a soa by value, and before struct copy/eq so they can call the soa
# helpers. (Bodies are gen_soa, emitted after struct bodies for sizeof.)
fn gen_soa_decl(ctx: Ctx, ty: string) -> string:
    sn := soa_struct(ty)
    nm := "Soa_" + sn
    si := 0
    for si < len(ctx.structs):
        if ctx.structs[si].name == sn:
            flds := ctx.structs[si].fields
            out := "typedef struct {"
            i := 0
            for i < len(flds):
                out = out + " " + cty(ctx, flds[i].ty) + "* f" + str(i) + ";"
                i = i + 1
            out = out + " long len; long cap; } " + nm + ";\n"
            out = out + "static void " + nm + "_push(" + nm + "* s, " + sn + " v);\n"
            out = out + "static " + nm + " " + nm + "_copy(" + nm + " s);\n"
            out = out + "static int " + nm + "_eq(" + nm + " a, " + nm + " b);\n"
            return out
        si = si + 1
    return ""

# SOA family for `soa [Struct]`: one growable buffer per struct field (f0, f1,
# ...) + a shared len/cap, instead of an array of records. Naive (realloc/leak)
# like the Arr families. push grows each buffer and scatters the struct's fields.
fn gen_soa(ctx: Ctx, ty: string) -> string:
    sn := soa_struct(ty)
    nm := "Soa_" + sn
    si := 0
    for si < len(ctx.structs):
        if ctx.structs[si].name == sn:
            flds := ctx.structs[si].fields       # typedef + decls emitted by gen_soa_decl (early)
            out := "static void " + nm + "_push(" + nm + "* s, " + sn + " v) {\n"
            out = out + "    if (s->len == s->cap) { s->cap = s->cap ? s->cap * 2 : 4;\n"
            i := 0
            for i < len(flds):
                ct := cty(ctx, flds[i].ty)
                out = out + "        s->f" + str(i) + " = realloc(s->f" + str(i) + ", sizeof(" + ct + ") * s->cap);\n"
                i = i + 1
            out = out + "    }\n"
            i = 0
            for i < len(flds):
                out = out + "    s->f" + str(i) + "[s->len] = v." + flds[i].name + ";\n"
                i = i + 1
            out = out + "    s->len = s->len + 1;\n}\n"
            # copy: deep-copy each field buffer (value semantics on bind/pass/return)
            out = out + "static " + nm + " " + nm + "_copy(" + nm + " s) {\n"
            out = out + "    " + nm + " r; r.len = s.len; r.cap = s.len;\n"
            i = 0
            for i < len(flds):
                ct := cty(ctx, flds[i].ty)
                out = out + "    r.f" + str(i) + " = s.len ? malloc(sizeof(" + ct + ") * s.len) : 0;\n"
                out = out + "    for (long j = 0; j < s.len; j = j + 1) r.f" + str(i) + "[j] = s.f" + str(i) + "[j];\n"
                i = i + 1
            out = out + "    return r;\n}\n"
            # structural eq: same length + every field equal elementwise
            out = out + "static int " + nm + "_eq(" + nm + " a, " + nm + " b) {\n"
            out = out + "    if (a.len != b.len) return 0;\n"
            out = out + "    for (long j = 0; j < a.len; j = j + 1) {\n"
            i = 0
            for i < len(flds):
                out = out + "        if (!(" + eq_field(ctx, flds[i].ty, "a.f" + str(i) + "[j]", "b.f" + str(i) + "[j]") + ")) return 0;\n"
                i = i + 1
            out = out + "    }\n    return 1;\n}\n"
            return out
        si = si + 1
    die("codegen: soa of unknown struct")
    return ""

# Runtime that depends on Arr_str (so it is emitted after the array families,
# not in the preamble): split a string on a separator into a [string].
fn gen_strlib() -> string:
    # buffer in `ar` (the result's owner); substrings malloc'd (0) so the array
    # can be shallow-copied/returned without dangling element pointers.
    out := "static Arr_str hi_split(Arena* ar, const char* s, const char* sep) {\n"
    out = out + "    Arr_str r = Arr_str_new();\n"
    out = out + "    long n = strlen(s), sl = strlen(sep);\n"
    out = out + "    if (sl == 0) { Arr_str_push(ar, &r, substr(0, s, 0, n)); return r; }\n"
    out = out + "    long start = 0, i = 0;\n"
    out = out + "    while (i + sl <= n) {\n"
    out = out + "        if (strncmp(s + i, sep, sl) == 0) { Arr_str_push(ar, &r, substr(0, s, start, i)); i += sl; start = i; }\n"
    out = out + "        else i = i + 1;\n"
    out = out + "    }\n"
    out = out + "    Arr_str_push(ar, &r, substr(0, s, start, n));\n"
    out = out + "    return r;\n}\n"
    return out

# String-keyed int map (the one map type the examples use). A faithful mirror
# of the C runtime's open-addressing table (runtime/hier_rt.c): FNV-1a hash,
# power-of-2 capacity (min 8), linear probing, rehash past 1/2 load, deep-copy
# value semantics, keys() in bucket order. No tombstones (the subset has no
# map delete). Mirroring it byte-for-byte is what makes keys()-order match.
# Depends on Arr_str.
fn gen_mhash() -> string:                        # shared FNV-1a hash (value-independent)
    return "static unsigned long mhash(const char* s) { unsigned long h = 1469598103934665603UL; for (; *s; s++) { h ^= (unsigned char)*s; h *= 1099511628211UL; } return h; }\n"

fn gen_map_type(v: string) -> string:
    cv := "long"
    if v == "float":
        cv = "double"
    return "typedef struct { char** keys; " + cv + "* vals; long len; long cap; } Map_str_" + v + ";\n"

# Map family monomorphized over the value type v (int/float). The C value type
# cv is long/double; key hashing/probing is value-independent (shared mhash).
fn gen_map_fns(v: string) -> string:
    cv := "long"
    if v == "float":
        cv = "double"
    M := "Map_str_" + v
    f := "map_str_" + v
    s := "ms_" + v
    out := "static " + M + " " + s + "_cap(Arena* ar, long cap) { " + M + " m; long c = 8; while (c < cap) c *= 2; if (cap == 0) c = 0; m.cap = c; m.len = 0; if (c == 0) { m.keys = 0; m.vals = 0; return m; } m.keys = amem(ar, sizeof(char*) * c); m.vals = amem(ar, sizeof(" + cv + ") * c); for (long i = 0; i < c; i++) m.keys[i] = 0; return m; }\n"
    out = out + "static " + M + " " + f + "_new(void) { return " + s + "_cap(0, 0); }\n"
    out = out + "static long " + s + "_slot(" + M + " m, const char* k) { unsigned long mask = (unsigned long)m.cap - 1; long i = (long)(mhash(k) & mask); while (m.keys[i] != 0) { if (strcmp(m.keys[i], k) == 0) return i; i = (long)((i + 1) & mask); } return i; }\n"
    out = out + "static void " + f + "_put(Arena* ar, " + M + "* m, char* k, " + cv + " val) { if (m->cap == 0 || (m->len + 1) * 2 > m->cap) { long nc = m->cap ? m->cap * 2 : 8; " + M + " n = " + s + "_cap(ar, nc); for (long i = 0; i < m->cap; i++) if (m->keys[i] != 0) { long t = " + s + "_slot(n, m->keys[i]); n.keys[t] = m->keys[i]; n.vals[t] = m->vals[i]; n.len++; } *m = n; } long t = " + s + "_slot(*m, k); if (m->keys[t] == 0) { m->keys[t] = sc(0, k, \"\"); m->len++; } m->vals[t] = val; }\n"
    out = out + "static " + M + " " + f + "_copy(Arena* ar, " + M + " m) { " + M + " r = " + s + "_cap(ar, m.len ? m.len * 2 : 0); for (long i = 0; i < m.cap; i++) if (m.keys[i] != 0) " + f + "_put(ar, &r, m.keys[i], m.vals[i]); return r; }\n"
    out = out + "static " + M + " " + f + "_set(Arena* ar, " + M + " m, char* k, " + cv + " val) { " + M + " r = " + f + "_copy(ar, m); " + f + "_put(ar, &r, k, val); return r; }\n"
    out = out + "static " + cv + " " + f + "_get(" + M + " m, char* k, " + cv + " def) { if (m.cap == 0) return def; long t = " + s + "_slot(m, k); return m.keys[t] ? m.vals[t] : def; }\n"
    out = out + "static int " + f + "_has(" + M + " m, char* k) { if (m.cap == 0) return 0; long t = " + s + "_slot(m, k); return m.keys[t] != 0; }\n"
    out = out + "static " + M + " " + f + "_del(Arena* ar, " + M + " m, char* k) { " + M + " r = " + f + "_new(); for (long i = 0; i < m.cap; i++) if (m.keys[i] != 0 && strcmp(m.keys[i], k) != 0) " + f + "_put(ar, &r, m.keys[i], m.vals[i]); return r; }\n"
    out = out + "static Arr_str " + f + "_keys(Arena* ar, " + M + " m) { Arr_str r = Arr_str_new(); for (long i = 0; i < m.cap; i++) if (m.keys[i] != 0) Arr_str_push(ar, &r, m.keys[i]); return r; }\n"
    # structural equality: same length, and every live key in a present in b with
    # an equal value (same len + a's keys ⊆ b with equal values ⟹ equal).
    out = out + "static int " + f + "_eq(" + M + " a, " + M + " b) { if (a.len != b.len) return 0; for (long i = 0; i < a.cap; i++) if (a.keys[i] != 0) { long t = " + s + "_slot(b, a.keys[i]); if (b.keys[t] == 0 || b.vals[t] != a.vals[i]) return 0; } return 1; }\n"
    return out

fn has_str(xs: [string], s: string) -> bool:
    i := 0
    for i < len(xs):
        if xs[i] == s:
            return true
        i = i + 1
    return false

# Record the array element types a type needs, recursively (so [[int]] also
# pulls in [int], and Option/Result element types are descended into).
fn note_arr_types(acc: inout [string], ty: string):
    b := base_ty(ty)
    if is_array(b):
        et := elem_ty(b)
        if not has_str(acc, et):
            push(acc, et)
        note_arr_types(&acc, et)
    elif is_option(b):
        note_arr_types(&acc, option_inner(b))
    elif is_result(b):
        note_arr_types(&acc, result_ok(b))
        note_arr_types(&acc, result_err(b))
    elif is_soa(b):                              # collect the soa family (Soa_<Struct>)
        if not has_str(acc, b):
            push(acc, b)
    elif is_tuple(b):
        if not has_str(acc, b):
            push(acc, b)
        parts := tuple_parts(b)
        i := 0
        for i < len(parts):
            note_arr_types(&acc, parts[i])
            i = i + 1
    elif is_map(b):
        if not has_str(acc, b):
            push(acc, b)
        note_arr_types(&acc, map_val(b))

# Walk an expression collecting composite array element types from literals
# (array literals / empty arrays that no annotation would reveal).
# The body walkers thread the var env (names/types), mirroring gen, so that
# type_of resolves variables inside tuple/array literals (e.g. t := (a, b)).
fn collect_expr(acc: inout [string], e: Expr, names: [string], types: [string], ctx: Ctx):
    match e:
        EArrLit(elems):
            note_arr_types(&acc, type_of(e, names, types, ctx))
            j := 0
            for j < len(elems):
                collect_expr(&acc, elems[j], names, types, ctx)
                j = j + 1
        EArrEmpty(ety):
            note_arr_types(&acc, "[" + ety + "]")
        EMapEmpty(k, v):
            note_arr_types(&acc, "{" + k + ":" + v + "}")
        EMapLit(keys, vals):
            note_arr_types(&acc, type_of(e, names, types, ctx))
            j := 0
            for j < len(vals):
                collect_expr(&acc, keys[j], names, types, ctx)
                collect_expr(&acc, vals[j], names, types, ctx)
                j = j + 1
        ETuple(elems):
            note_arr_types(&acc, type_of(e, names, types, ctx))
            j := 0
            for j < len(elems):
                collect_expr(&acc, elems[j], names, types, ctx)
                j = j + 1
        EBin(op, l, r):
            collect_expr(&acc, l, names, types, ctx)
            collect_expr(&acc, r, names, types, ctx)
        ECall(nm, args):
            j := 0
            for j < len(args):
                collect_expr(&acc, args[j], names, types, ctx)
                j = j + 1
        EField(b, f):
            collect_expr(&acc, b, names, types, ctx)
        EIndex(b, idx):
            collect_expr(&acc, b, names, types, ctx)
            collect_expr(&acc, idx, names, types, ctx)
        ESlice(b, lo, hi):
            collect_expr(&acc, b, names, types, ctx)
            collect_expr(&acc, lo, names, types, ctx)
            collect_expr(&acc, hi, names, types, ctx)
        EAddr(inner):
            collect_expr(&acc, inner, names, types, ctx)
        EInt(t):
            j := 0
        EFloat(f):
            j := 0
        EStr(s):
            j := 0
        EVar(n):
            j := 0

fn collect_block(acc: inout [string], stmts: [Stmt], names: [string], types: [string], ctx: Ctx):
    ns := names
    ts := types
    i := 0
    for i < len(stmts):
        collect_stmt(&acc, stmts[i], &ns, &ts, ctx)
        i = i + 1

fn collect_stmt(acc: inout [string], s: Stmt, names: inout [string], types: inout [string], ctx: Ctx):
    match s:
        SDecl(n, e):
            collect_expr(&acc, e, names, types, ctx)
            ty := type_of(e, names, types, ctx)
            push(names, n)
            push(types, ty)
        SAssign(n, e):
            collect_expr(&acc, e, names, types, ctx)
        SFieldAssign(lv, rhs):
            collect_expr(&acc, lv, names, types, ctx)
            collect_expr(&acc, rhs, names, types, ctx)
        SPrint(e):
            collect_expr(&acc, e, names, types, ctx)
        SReturn(e):
            collect_expr(&acc, e, names, types, ctx)
        SReturnVoid:
            j := 0
        SExpr(e):
            collect_expr(&acc, e, names, types, ctx)
        STypedDecl(n, t, e):
            note_arr_types(&acc, t)
            collect_expr(&acc, e, names, types, ctx)
            push(names, n)
            push(types, t)
        SOrReturn(n, e):
            collect_expr(&acc, e, names, types, ctx)
            ety := type_of(e, names, types, ctx)
            ty := ""
            if is_option(ety):                    # Option or_return binds the inner type
                ty = option_inner(ety)
            else:
                ty = result_ok(ety)               # (result_ok on a non-Result substrs out of range)
            push(names, n)
            push(types, ty)
        SDestructure(dnames, e):
            collect_expr(&acc, e, names, types, ctx)
            parts := tuple_parts(type_of(e, names, types, ctx))
            j := 0
            for j < len(dnames):
                push(names, dnames[j])
                push(types, parts[j])
                j = j + 1
        SMultiAssign(mnames, e):                  # vars already exist; just collect the RHS
            collect_expr(&acc, e, names, types, ctx)
        SIf(c, tb, eb):
            collect_expr(&acc, c, names, types, ctx)
            collect_block(&acc, tb, names, types, ctx)
            collect_block(&acc, eb, names, types, ctx)
        SWhile(c, body):
            collect_expr(&acc, c, names, types, ctx)
            collect_block(&acc, body, names, types, ctx)
        SForRange(n, a, b, st, body):
            collect_expr(&acc, a, names, types, ctx)
            collect_expr(&acc, b, names, types, ctx)
            collect_expr(&acc, st, names, types, ctx)
            bn := names
            bt := types
            push(bn, n)
            push(bt, "int")
            collect_block(&acc, body, bn, bt, ctx)
        SMatch(subj, variants, allbinds, bodies):
            collect_expr(&acc, subj, names, types, ctx)
            sty := type_of(subj, names, types, ctx)
            j := 0
            for j < len(bodies):
                bn := names                       # bind arm payloads so type_of resolves them
                bt := types                       # in the arm body (mirrors gen_stmt's match)
                binds := allbinds[j]
                if is_option(sty):
                    if len(binds) > 0:
                        push(bn, binds[0])
                        push(bt, option_inner(sty))
                elif is_result(sty):
                    if len(binds) > 0:
                        push(bn, binds[0])
                        if variants[j] == "Ok":
                            push(bt, result_ok(sty))
                        else:
                            push(bt, result_err(sty))
                else:
                    pts := variant_ptypes(ctx, variants[j])
                    k := 0
                    for k < len(binds):
                        push(bn, binds[k])
                        push(bt, pts[k])
                        k = k + 1
                collect_block(&acc, bodies[j], bn, bt, ctx)
                j = j + 1

# Element types needing an Arr_T family: int/str (cover every literal seen in
# practice) plus every array element type that appears in an annotation.
fn collect_elem_types(prog: Program, ctx: Ctx) -> [string]:
    acc := []string
    push(acc, "int")
    push(acc, "str")
    push(acc, "float")
    i := 0                                       # seed every struct/enum name so a
    for i < len(prog.structs):                   # literal-only [Struct]/[Enum] (no annotation
        push(acc, prog.structs[i].name)          # to scan) still gets its Arr_T family
        i = i + 1
    i = 0
    for i < len(prog.enums):
        push(acc, prog.enums[i].name)
        i = i + 1
    i = 0
    for i < len(prog.funcs):
        f := prog.funcs[i]
        j := 0
        for j < len(f.ptypes):
            note_arr_types(&acc, f.ptypes[j])
            j = j + 1
        note_arr_types(&acc, f.ret)
        en := []string                           # seed the body walk with the params
        et := []string
        k := 0
        for k < len(f.params):
            push(en, f.params[k])
            push(et, f.ptypes[k])
            k = k + 1
        collect_block(&acc, f.body, en, et, ctx)   # composite types from literals
        i = i + 1
    i = 0
    for i < len(prog.structs):
        j := 0
        for j < len(prog.structs[i].fields):
            note_arr_types(&acc, prog.structs[i].fields[j].ty)
            j = j + 1
        i = i + 1
    i = 0
    for i < len(prog.enums):
        j := 0
        for j < len(prog.enums[i].variants):
            k := 0
            for k < len(prog.enums[i].variants[j].ptypes):
                note_arr_types(&acc, prog.enums[i].variants[j].ptypes[k])
                k = k + 1
            j = j + 1
        i = i + 1
    return acc

fn main():
    src := read_all()
    toks := lex(src)
    pos := 0
    prog := parse_program(toks, &pos)
    funcs := prog.funcs
    sigs := []Sig
    i := 0
    for i < len(funcs):
        push(sigs, Sig(funcs[i].name, funcs[i].ret))
        i = i + 1
    ctx := Ctx(sigs, prog.structs, prog.enums, prog.ntnames, prog.ntunder, []string, []string, "", "0", 0, 0)
    ets := collect_elem_types(prog, ctx)
    out := preamble()
    # Emission order is carefully staged so every C type is complete before use,
    # supporting arrays-of-structs, recursive structs, and mutual struct/enum refs:
    i = 0                                        # 1a. forward-declare struct tags
    for i < len(prog.structs):
        out = out + "typedef struct " + prog.structs[i].name + " " + prog.structs[i].name + ";\n"
        i = i + 1
    i = 0                                        # 1b. forward-declare enum tags
    for i < len(prog.enums):
        out = out + "typedef struct " + prog.enums[i].name + " " + prog.enums[i].name + ";\n"
        i = i + 1
    i = 0                                        # 2. array STRUCT bodies (element types
    for i < len(ets):                            #    only appear as pointers here, so fwd decls suffice)
        if not is_tuple(ets[i]) and not is_map(ets[i]) and not is_soa(ets[i]):
            out = out + gen_arr_type(ctx, ets[i])
        i = i + 1
    i = 0                                        # 2c. soa typedefs + helper fwd decls (before struct
    for i < len(ets):                            #     bodies, so a struct may embed a soa by value)
        if is_soa(ets[i]):
            out = out + gen_soa_decl(ctx, ets[i])
        i = i + 1
    i = 0                                        # map struct(s), one per value type used
    for i < len(ets):
        if is_map(ets[i]):
            out = out + gen_map_type(map_val(ets[i]))
        i = i + 1
    i = 0                                        # 2b. tuple struct bodies (may embed Arr_T, now complete)
    for i < len(ets):
        if is_tuple(ets[i]):
            out = out + gen_tuple_struct(ctx, ets[i])
        i = i + 1
    i = 0                                        # 3. enum + struct eq prototypes (mutual recursion)
    for i < len(prog.enums):
        out = out + "static int " + prog.enums[i].name + "_eq(" + prog.enums[i].name + "* a, " + prog.enums[i].name + "* b);\n"
        i = i + 1
    i = 0
    for i < len(prog.structs):
        out = out + "static int " + prog.structs[i].name + "_eq(" + prog.structs[i].name + " a, " + prog.structs[i].name + " b);\n"
        i = i + 1
    i = 0                                        # 4. user struct bodies (source order; array fields
    for i < len(prog.structs):                   #    use the now-complete Arr_T struct)
        out = out + gen_struct(prog.structs[i], ctx)
        i = i + 1
    i = 0                                        # 5. enum struct bodies (payloads may be value structs)
    for i < len(prog.enums):
        out = out + gen_enum_decl(prog.enums[i], ctx)
        i = i + 1
    i = 0                                        # 6. array FUNCTIONS (need element bodies
    for i < len(ets):                            #    complete for sizeof / by-value moves)
        if not is_tuple(ets[i]) and not is_map(ets[i]) and not is_soa(ets[i]):
            out = out + gen_arr_fns(ctx, ets[i])
        i = i + 1
    i = 0                                        # 6b. soa families (after struct bodies: push takes S_X by value)
    for i < len(ets):
        if is_soa(ets[i]):
            out = out + gen_soa(ctx, ets[i])
        i = i + 1
    i = 0                                        # shared hash + per-value-type map families
    has_map := false
    for i < len(ets):
        if is_map(ets[i]):
            has_map = true
        i = i + 1
    if has_map:
        out = out + gen_mhash()
    i = 0
    for i < len(ets):
        if is_map(ets[i]):
            out = out + gen_map_fns(map_val(ets[i]))
        i = i + 1
    out = out + gen_strlib()
    i = 0                                        # 6b. tuple copy + equality (may call array fns above)
    for i < len(ets):
        if is_tuple(ets[i]):
            out = out + gen_tuple_copy(ctx, ets[i])
            out = out + gen_tuple_eq(ctx, ets[i])
        i = i + 1
    i = 0                                        # 7. enum constructors + equality
    for i < len(prog.enums):
        out = out + gen_enum_ctors(prog.enums[i], ctx)
        i = i + 1
    i = 0
    for i < len(prog.enums):
        out = out + gen_enum_eq(prog.enums[i], ctx)
        i = i + 1
    i = 0                                        # 8. struct equality + deep-copy fns
    for i < len(prog.structs):
        out = out + gen_struct_eq(ctx, prog.structs[i])
        if struct_is_heap(ctx, prog.structs[i].name):
            out = out + gen_struct_copy(ctx, prog.structs[i])
        i = i + 1
    i = 0                                        # 9. prototypes
    for i < len(funcs):
        if funcs[i].name != "main":
            out = out + gen_proto(funcs[i], ctx)
        i = i + 1
    i = 0
    for i < len(funcs):
        out = out + gen_func(funcs[i], ctx)
        i = i + 1
    print(out)
