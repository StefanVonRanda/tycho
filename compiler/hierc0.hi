# hierc0 — a compiler for a SUBSET of Hier, written in Hier. Stage 1 of the
# self-hosting bootstrap (docs/bootstrap.md). Emits C to stdout. With no
# argument it reads source on stdin; `hierc0 path/to/main.hi` compiles that file
# directly, and if the file declares a `package` it walks the whole package
# (imports included) from disk via the read_file/list_dir/args builtins — a
# standalone driver, no `hierc --bundle` needed.
#
# Subset: one or more `fn name(p: int, ...) -> int:` / `fn main():`, whose
# indented bodies have `x := EXPR`, `x = EXPR`, `print(SEXPR)`, `return EXPR`,
# and `if`/`elif`/`else`. EXPR = integer arithmetic (`+ - *`, parens, vars, int
# literals, calls `f(args)`) and comparisons (`== < >`). SEXPR (string, only in
# print position) = string literals and `str(EXPR)` joined by `+`. Validated
# DIFFERENTIALLY against the C compiler by `make bootstrap`.

# ---------------------------------------------------------------- lexer ----

enum Tok:
    TInt
    TFloat
    TStr
    TFStr                                        # f"..." interpolated string literal
    TChar
    TIdent
    TPlus
    TMinus
    TStar
    TSlash
    TLParen
    TRParen
    TLBracket
    TRBracket
    TComma
    TColon
    TDot
    TArrow
    TWalrus
    TEq
    TEqEq
    TLt
    TGt
    TLe
    TGe
    TNe
    TAmp
    TPercent
    TPipe
    TCaret
    TTilde
    TShl
    TShr
    TNewline
    TIndent
    TDedent
    TEof

struct Token:
    kind: Tok
    text: string
    line: int                 # 1-based source line, for parse diagnostics
    col: int                  # 0-based source column, for the diagnostic caret

fn is_digit(c: int) -> bool:
    return c >= 48 and c <= 57

fn is_alpha(c: int) -> bool:
    return (c >= 97 and c <= 122) or (c >= 65 and c <= 90) or c == 95

fn is_alnum(c: int) -> bool:
    return is_alpha(c) or is_digit(c)

# Lexer diagnostic: print `msg` then the offending source line + a caret under
# byte offset `at`, then exit. die() is terminal, so this never returns. (Mirrors
# hierc's snippet+caret for lex errors; src + offset are local to the lexer, so no
# globals/threading are needed. Parse errors report "line N" via Token.line;
# resolve/codegen errors stay message-only — hierc0's AST carries no position.)
fn lex_err(src: string, at: int, msg: string):
    n := len(src)
    p := at
    if p > n:
        p = n
    ls := 0                                   # start offset of the line containing `p`
    ln := 1                                   # 1-based line number
    j := 0
    for j < p:
        if src[j] == 10:
            ln = ln + 1
            ls = j + 1
        j = j + 1
    le := ls                                  # end offset (the newline or EOF)
    for le < n and src[le] != 10:
        le = le + 1
    gutter := "  " + str(ln) + " | "
    npad := len(gutter) + (p - ls)            # spaces before the caret
    pad := ""
    k := 0
    for k < npad:
        pad = pad + " "
        k = k + 1
    die(msg + "\n" + gutter + substr(src, ls, le) + "\n" + pad + "^")

# encode a token's (line, col) into one int for the AST position field; die_at
# decodes it back. 1-based line, 0-based col; assumes no line >= 100000 chars.
fn tloc(t: Token) -> int:
    return t.line * 100000 + t.col

fn scan_token(src: string, n: int, i: int, toks: inout [Token], line: int, linestart: int) -> int:
    c := src[i]
    tok0 := i                                    # token start, for the error caret (i advances as we scan)
    col := tok0 - linestart                       # 0-based column of the token start (for the diagnostic caret)
    if c == 32 or c == 9:
        return i + 1
    elif c == 35:
        for i < n and src[i] != 10:
            i = i + 1
        return i
    elif c == 34:                                # string literal "..."
        start := i + 1
        i = i + 1
        for i < n and src[i] != 34:
            if src[i] == 92:                     # backslash escapes the next char
                i = i + 1
            i = i + 1
        if i >= n:
            lex_err(src, tok0, "lex: unterminated string")
        push(toks, Token(TStr, substr(src, start, i), line, col))
        return i + 1                             # consume closing quote
    elif c == 102 and i + 1 < n and src[i + 1] == 34:   # f"..." interpolated string (102='f', 34='"')
        start := i + 2
        i = i + 2
        depth := 0                               # brace depth inside a `{...}` hole (0 in the literal part)
        for i < n and (src[i] != 34 or depth > 0):
            ch := src[i]
            if ch == 92:                         # backslash escapes the next char
                i = i + 2
            elif depth == 0 and ch == 123 and i + 1 < n and src[i + 1] == 123:   # {{ literal brace
                i = i + 2
            elif depth == 0 and ch == 125 and i + 1 < n and src[i + 1] == 125:   # }} literal brace
                i = i + 2
            elif ch == 123:                      # { opens / nests a hole
                depth = depth + 1
                i = i + 1
            elif depth > 0 and ch == 125:        # } closes a hole level
                depth = depth - 1
                i = i + 1
            elif depth > 0 and ch == 34:         # nested string literal inside a hole: skip it whole
                i = i + 1
                for i < n and src[i] != 34:
                    if src[i] == 92:
                        i = i + 1
                    i = i + 1
                if i >= n:
                    lex_err(src, tok0, "lex: unterminated string in f-string hole")
                i = i + 1                         # consume closing quote
            else:
                i = i + 1
        if i >= n:
            lex_err(src, tok0, "lex: unterminated f-string")
        push(toks, Token(TFStr, substr(src, start, i), line, col))
        return i + 1
    elif c == 39:                                # char literal '...' -> one byte
        i = i + 1
        if i >= n:
            lex_err(src, tok0, "lex: unterminated char literal")
        b := 0
        if src[i] == 92:                         # backslash escape
            i = i + 1
            if i >= n:
                lex_err(src, tok0, "lex: unterminated char literal")
            e := src[i]
            if e == 110:                         # \n
                b = 10
            elif e == 116:                       # \t
                b = 9
            elif e == 114:                       # \r
                b = 13
            elif e == 48:                        # \0
                b = 0
            elif e == 92:                        # backslash
                b = 92
            elif e == 39:                        # quote
                b = 39
            else:
                lex_err(src, tok0, "lex: bad char escape (use \\n \\t \\r \\0 \\\\ \\')")
            i = i + 1
        else:
            b = src[i]
            i = i + 1
        if i >= n or src[i] != 39:
            lex_err(src, tok0, "lex: char literal must be exactly one character")
        push(toks, Token(TChar, str(b), line, col))
        return i + 1                             # consume closing quote
    elif is_digit(c):
        start := i
        for i < n and is_digit(src[i]):
            i = i + 1
        if i < n and src[i] == 46 and i + 1 < n and is_digit(src[i + 1]):   # D.D float
            i = i + 1
            for i < n and is_digit(src[i]):
                i = i + 1
            push(toks, Token(TFloat, substr(src, start, i), line, col))
            return i
        push(toks, Token(TInt, substr(src, start, i), line, col))
        return i
    elif is_alpha(c):
        start := i
        for i < n and is_alnum(src[i]):
            i = i + 1
        push(toks, Token(TIdent, substr(src, start, i), line, col))
        return i
    elif c == 43:
        push(toks, Token(TPlus, "+", line, col))
        return i + 1
    elif c == 45:
        if i + 1 < n and src[i + 1] == 62:
            push(toks, Token(TArrow, "->", line, col))
            return i + 2
        push(toks, Token(TMinus, "-", line, col))
        return i + 1
    elif c == 42:
        push(toks, Token(TStar, "*", line, col))
        return i + 1
    elif c == 47:
        push(toks, Token(TSlash, "/", line, col))
        return i + 1
    elif c == 40:
        push(toks, Token(TLParen, "(", line, col))
        return i + 1
    elif c == 41:
        push(toks, Token(TRParen, ")", line, col))
        return i + 1
    elif c == 91:
        push(toks, Token(TLBracket, "[", line, col))
        return i + 1
    elif c == 93:
        push(toks, Token(TRBracket, "]", line, col))
        return i + 1
    elif c == 44:
        push(toks, Token(TComma, ",", line, col))
        return i + 1
    elif c == 46:
        push(toks, Token(TDot, ".", line, col))
        return i + 1
    elif c == 58:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TWalrus, ":=", line, col))
            return i + 2
        push(toks, Token(TColon, ":", line, col))
        return i + 1
    elif c == 61:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TEqEq, "==", line, col))
            return i + 2
        push(toks, Token(TEq, "=", line, col))
        return i + 1
    elif c == 60:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TLe, "<=", line, col))
            return i + 2
        if i + 1 < n and src[i + 1] == 60:
            push(toks, Token(TShl, "<<", line, col))
            return i + 2
        push(toks, Token(TLt, "<", line, col))
        return i + 1
    elif c == 62:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TGe, ">=", line, col))
            return i + 2
        if i + 1 < n and src[i + 1] == 62:
            push(toks, Token(TShr, ">>", line, col))
            return i + 2
        push(toks, Token(TGt, ">", line, col))
        return i + 1
    elif c == 33:
        if i + 1 < n and src[i + 1] == 61:
            push(toks, Token(TNe, "!=", line, col))
            return i + 2
        lex_err(src, tok0, "lex: '!' must be part of '!='")
        return i + 1
    elif c == 38:
        push(toks, Token(TAmp, "&", line, col))
        return i + 1
    elif c == 37:
        push(toks, Token(TPercent, "%", line, col))
        return i + 1
    elif c == 124:
        push(toks, Token(TPipe, "|", line, col))
        return i + 1
    elif c == 94:
        push(toks, Token(TCaret, "^", line, col))
        return i + 1
    elif c == 126:
        push(toks, Token(TTilde, "~", line, col))
        return i + 1
    else:
        lex_err(src, tok0, "lex: unexpected character")
        return i + 1

fn lex(src: string) -> [Token]:
    toks := []Token
    stack := []int
    push(stack, 0)
    sp := 1
    n := len(src)
    i := 0
    line := 1
    linestart := 0                                # byte offset of the current line's start (for token columns)
    at_bol := true
    for i < n:
        if at_bol:
            ind := 0
            for i < n and src[i] == 32:
                ind = ind + 1
                i = i + 1
            if i >= n:
                at_bol = false
            elif src[i] == 10:
                push(toks, Token(TNewline, "", line, 0))
                i = i + 1
                line = line + 1
                linestart = i
            elif src[i] == 35:
                for i < n and src[i] != 10:
                    i = i + 1
            elif ind > stack[sp - 1]:
                if sp < len(stack):
                    stack[sp] = ind
                else:
                    push(stack, ind)
                sp = sp + 1
                push(toks, Token(TIndent, "", line, 0))
                at_bol = false
            else:
                for sp > 1 and stack[sp - 1] > ind:
                    sp = sp - 1
                    push(toks, Token(TDedent, "", line, 0))
                if stack[sp - 1] != ind:
                    lex_err(src, i, "lex: inconsistent indentation")
                at_bol = false
        else:
            if src[i] == 10:
                push(toks, Token(TNewline, "", line, 0))
                i = i + 1
                line = line + 1
                linestart = i
                at_bol = true
            else:
                i = scan_token(src, n, i, &toks, line, linestart)
    push(toks, Token(TNewline, "", line, 0))
    for sp > 1:
        sp = sp - 1
        push(toks, Token(TDedent, "", line, 0))
    push(toks, Token(TEof, "", line, 0))
    return toks

# ------------------------------------------------------------------ AST ----

enum Expr:
    EInt(string, int)
    EBool(string, int)             # bool literal `true`/`false`, carried as "1"/"0" (distinct from int so str() prints true/false)
    EChar(string, int)             # char literal `'x'`, carried as the byte value in decimal text
    EFloat(string, int)            # float literal, emitted verbatim (round-trips as a double)
    EStr(string, int)              # string literal (raw content, escapes preserved)
    EVar(string, int)
    EBin(string, Expr, Expr, int)
    ECall(string, [Expr], int)    # function call OR struct construction `Point(1,2)`
    EField(Expr, string, int)     # field access `base.field` (nests: `r.lo.x`)
    EIndex(Expr, Expr, int)       # array index `base[idx]`
    EArrLit([Expr], int)          # array literal `[1, 2, 3]` (int elements)
    EArrEmpty(string, int)        # empty typed array `[]int`
    EMapEmpty(string, string, int) # empty typed map `[]string: int` (key, value types)
    EMapLit([Expr], [Expr], int)  # non-empty map literal `[k0: v0, k1: v1]` (keys, vals)
    ETuple([Expr], int)           # tuple literal `(a, b, ...)` / `return a, b`
    ESlice(Expr, Expr, Expr, int) # `base[lo:hi]` sub-array (owning copy)
    EAddr(Expr, int)              # `&place` at a call site (pass to an inout param)
    ELambda(int, [string], [string], string, Expr, [string], [string], int)   # `fn(p)->r: e` closure literal: id, params, ptypes, ret, body-expr, capnames, captypes (last two filled by the lift pass)
    ECallV(Expr, [Expr], int)     # call-on-expression: `<expr>(args)` — an indirect call on a fn VALUE (array elem, struct field, call result)
    ESpawn(int, string, [Expr], int)   # `spawn f(args)` (CC-1): spawn-site id (assigned by the lift pass), callee, args

enum Stmt:
    SDecl(string, Expr, int)
    SAssign(string, Expr, int)
    SFieldAssign(Expr, Expr, int) # `lvalue = rhs`, lvalue an EField path
    SPrint(Expr, int)             # the Expr is a string expression
    SReturn(Expr, int)
    SReturnVoid              # bare `return` (no value)
    SIf(Expr, [Stmt], [Stmt], int)
    SWhile(Expr, [Stmt], int)     # condition-form `for COND:` (Hier's while loop)
    SForRange(string, Expr, Expr, Expr, [Stmt], int)   # `for i in range(start, stop, step):`
    SExpr(Expr, int)              # bare expression statement, e.g. a call `f(x)`
    STypedDecl(string, string, Expr, int)   # `name : Type = expr` (annotation fixes the type)
    SOrReturn(string, Expr, int)  # `name := result_expr or_return` (unwrap Ok or propagate Err)
    SDestructure([string], Expr, int)       # `a, b := tuple_expr`
    SMultiAssign([string], Expr, int)       # `a, b = tuple_expr` (assign existing vars)
    SMatch(Expr, [string], [[string]], [[Stmt]], int)  # subj, arm variants, arm binds, arm bodies
    SBreak                   # break out of the nearest enclosing loop
    SContinue                # skip to the next iteration of the nearest loop
    SSelect(string, [string], [Expr], [string], [[Stmt]], int)   # `select` (CC-5): uid, arm kinds ("recv"/"default"/"closed"),
                             # per-arm channel exprs (dummy for non-recv), per-arm bind names ("" for non-recv), arm bodies
    SParFor(string, Expr, Expr, [Stmt], int, int)   # `parallel for` (CC-3): loopvar, start, stop, body, par-id
                             # (parse: body=original, par-id=-1; the lift pass moves the body into a
                             # lifted __par<N> chunk proc and stores caps/accs in the pars side table)

struct Param:
    name: string
    ty: string                # "int" | "str"

struct Func:
    name: string
    params: [string]
    ptypes: [string]          # parallel to params: "int" | "str"
    ret: string               # "int" | "str" | "void"
    body: [Stmt]
    is_extern: int            # FFI: 1 -> `extern fn`, calls a C symbol directly (no arena, name unmangled, no body)
    lib: string               # FFI: link library from `extern "Lib" fn`; "" for bare extern

struct Sig:                   # collected up front, for typing calls
    name: string
    ret: string
    ptypes: [string]          # parameter types, so a bare fn name can be typed as a value
    is_extern: int            # FFI: 1 -> call the C symbol `name` directly (no arena); str ret arena-copied

struct LamInfo:               # one per lambda, produced by the lift pass; drives env-struct + thunk emission
    id: int
    ftype: string             # the VALUE's fn type fn(lamparams->ret) — for the Fn_<suffix>
    capnames: [string]
    captypes: [string]        # env field types (Hier types)
    lamptypes: [string]       # the lambda's OWN param types — the thunk's call signature
    ret: string

struct SpawnInfo:             # one per spawn SITE (incl. each parallel-for chunk), from the lift
    fname: string             # pass; drives the HSpawnA_<i> args-struct + hier_spawn_<i> thread
    argtypes: [string]        # trampoline emission in the driver (mirrors hierc's g_spawn)
    retty: string

struct ParInfo:               # one per `parallel for` site (CC-3), from the lift pass
    sid: int                  # its chunk proc's spawn-site id (HSpawnA_<sid>/hier_spawn_<sid>)
    capnames: [string]        # captured outer vars (deep-copied per chunk at the site)
    captypes: [string]
    accnames: [string]        # reduction accumulators (outer int/float locals)
    accops: [string]          # "+" | "*" (the fold op, applied at the in-order join)
    retty: string             # the chunk proc's partial type (acc type, or a tuple of them)

struct Field:
    name: string
    ty: string                # "int" | "str" | a struct name

struct StructDef:
    name: string
    fields: [Field]

struct Variant:
    name: string
    ptypes: [string]          # payload types: "int"/"str"/struct/enum names

struct EnumDef:
    name: string
    variants: [Variant]

# Read-only typing/codegen context, threaded by value: function return types,
# struct layouts, and enum definitions. (The mutable per-block var env stays as
# the separate names/types arrays.) This is the `Ctx` docs/bootstrap.md wanted.
struct Decls:                 # immutable after parse — threaded read-only as `dc`,
    sigs: [Sig]               # NEVER reconstructed, so its (large) arrays are never
    structs: [StructDef]      # deep-copied per scope change. The old Ctx kept these
    enums: [EnumDef]          # fields, so with_owner/enter_block deep-copied all of
    ntnames: [string]         # sigs/structs/enums on every owner/depth change (~37%
    ntunder: [string]         # of self-compile). hierc threads `arena` the same way.
    sigmap: [string: int]     # function name -> index in `sigs`, built once: O(1) sig_ret
    pars: [ParInfo]           # parallel-for sites from the lift pass (CC-3), indexed by SParFor's par-id
                              # (safe to map here precisely because Decls is never rebuilt)
    src_lines: [string]       # the source split into lines (bundle-relative), for die_at snippet + caret
    vmap: [string: int]       # variant name -> enum index, built once (sibling of sigmap): O(1) is_variant/variant_enum, was a nested linear scan over all enums x variants (~7% of self-compile)

struct Ctx:                   # mutable per-scope / per-function state only
    vparams: [string]         # current func's NON-inout param names (map accum guard)
    saccums: [string]         # current func's string-append accumulator locals (in-place hi_append)
    rettype: string           # current func's Hier return type (for the return-slot _scope free)
    owner: string             # arena that fresh allocations go into ("0"=NULL=malloc; "&_t"/"_parent"/"&_scope")
    depth: int                # current block nesting depth (0 = function body _scope; d = block _b<d>)
    bbases: [int]             # env length at entry to each nested block (one per depth 1..depth); a var's
                              # declaration depth = deepest k with bbases[k-1] <= its env index (see var_block_depth)
    movables: [string]        # locals read exactly once in the body and not inside a loop — move-on-last-use
                              # candidates: a `b := a` over one of these hands off a's buffer (no deep copy)
    loopdepth: int            # block depth of the innermost enclosing loop's body arena (0 = not in a loop);
                              # break/continue free _b<depth> .. _b<loopdepth> before the C jump
    fusearr: [string]         # push-loop fusion: array names whose cursor is live (cached data/len/cap)
    fusesuf: [string]         # parallel: the C cursor suffix (e.g. "3_0") -> _fd3_0/_fl3_0/_fc3_0
    fusety: [string]          # parallel: scalar element type ("int" | "float") for the grow hook
    line: int               # current statement source line, for resolve/codegen diagnostics

struct Program:
    structs: [StructDef]
    enums: [EnumDef]
    funcs: [Func]
    ntnames: [string]
    ntunder: [string]

# --------------------------------------------------------------- parser ----

fn expect(toks: [Token], pos: inout int, k: Tok):
    if toks[pos].kind != k:
        die("parse: line " + str(toks[pos].line) + ": unexpected token")
    pos = pos + 1

fn expect_ident(toks: [Token], pos: inout int, name: string):
    if toks[pos].kind != TIdent or toks[pos].text != name:
        die("parse: line " + str(toks[pos].line) + ": expected a keyword")
    pos = pos + 1

# Open an indented block: a newline, then any number of blank/comment-only
# lines (each a stray NEWLINE), then the INDENT.
fn open_block(toks: [Token], pos: inout int):
    expect(toks, &pos, TNewline)
    for toks[pos].kind == TNewline:
        pos = pos + 1
    expect(toks, &pos, TIndent)

# String interpolation: an f-string's text "a{e}b" desugars to ("a" + str(e) + "b").
# `{{`/`}}` are literal braces; each `{e}` is lexed+parsed as a sub-expression and
# wrapped in str() (identity on a string, i2s/f2s on int/float). No new AST node.
fn desugar_interp(s: string) -> Expr:
    _el := 0
    pieces := []Expr
    n := len(s)
    buf := ""
    i := 0
    for i < n:
        c := s[i]
        if c == 123 and i + 1 < n and s[i + 1] == 123:        # {{ -> literal {
            buf = buf + chr(123)
            i = i + 2
        elif c == 125 and i + 1 < n and s[i + 1] == 125:      # }} -> literal }
            buf = buf + chr(125)
            i = i + 2
        elif c == 125:
            die("interp: unmatched } in an f-string (use }} for a literal brace)")
        elif c == 123:                                        # {expr}
            if len(buf) > 0:
                push(pieces, EStr(buf, _el))
                buf = ""
            i = i + 1
            estart := i
            depth := 1                                         # balance nested braces; skip nested strings
            for i < n and depth > 0:
                ch := s[i]
                if ch == 34:                                   # string literal in the hole: '}' inside it is not a hole end
                    i = i + 1
                    for i < n and s[i] != 34:
                        if s[i] == 92:
                            i = i + 1
                        i = i + 1
                    if i >= n:
                        die("interp: unterminated string in an f-string hole")
                    i = i + 1
                elif ch == 123:
                    depth = depth + 1
                    i = i + 1
                elif ch == 125:
                    depth = depth - 1
                    if depth > 0:
                        i = i + 1
                else:
                    i = i + 1
            if depth > 0:
                die("interp: unterminated { in an f-string")
            esub := substr(s, estart, i)
            i = i + 1                                          # consume }
            if len(esub) == 0:
                die("interp: empty {} in an f-string")
            etoks := lex(esub)
            ep := 0
            ex := parse_expr(etoks, &ep)
            args := []Expr
            push(args, ex)
            push(pieces, ECall("str", args, _el))
        else:
            buf = buf + chr(c)
            i = i + 1
    if len(buf) > 0:
        push(pieces, EStr(buf, _el))
    if len(pieces) == 0:
        return EStr("", _el)
    acc := pieces[0]
    j := 1
    for j < len(pieces):
        acc = EBin("+", acc, pieces[j], _el)
        j = j + 1
    return acc

fn parse_atom(toks: [Token], pos: inout int) -> Expr:
    _el := tloc(toks[pos])
    t := toks[pos]
    if t.kind == TStr:
        pos = pos + 1
        return EStr(t.text, _el)
    elif t.kind == TFStr:                        # f"a{e}b" -> ("a" + str(e) + "b")
        pos = pos + 1
        return desugar_interp(t.text)
    elif t.kind == TMinus:                       # unary minus: -E  ==>  (0 - E)
        pos = pos + 1
        return EBin("-", EInt("0", _el), parse_atom(toks, &pos), _el)
    elif t.kind == TTilde:                       # unary bitwise NOT: ~E ==> ((0 - E) - 1)
        pos = pos + 1
        return EBin("-", EBin("-", EInt("0", _el), parse_atom(toks, &pos), _el), EInt("1", _el), _el)
    elif t.kind == TAmp:                         # &place : pass to an inout param
        pos = pos + 1
        return EAddr(parse_postfix(toks, &pos), _el)
    elif t.kind == TInt:
        pos = pos + 1
        return EInt(t.text, _el)
    elif t.kind == TChar:
        pos = pos + 1
        return EChar(t.text, _el)
    elif t.kind == TFloat:
        pos = pos + 1
        return EFloat(t.text, _el)
    elif t.kind == TIdent:
        name := t.text
        pos = pos + 1
        if name == "fn" and toks[pos].kind == TLParen:   # lambda literal `fn(p: T, ...) [-> R]: expr`
            return parse_lambda(toks, &pos)
        if name == "soa":                        # soa []Struct : empty SOA literal
            expect(toks, &pos, TLBracket)
            expect(toks, &pos, TRBracket)
            st := parse_type(toks, &pos)
            return EArrEmpty("soa[" + st + "]", _el)
        if name == "spawn":                      # spawn f(args): run the call on a new thread (CC-1)
            sp := parse_postfix(toks, &pos)
            match sp:
                ECall(sn, sa, _el):
                    return ESpawn(0, sn, sa, _el)     # site id assigned by the lift pass
                EInt(t, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EBool(t, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EChar(t, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EFloat(t, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EStr(t, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EVar(t, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EBin(o, l, r, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EField(b, f, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EIndex(b, ix, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EArrLit(es, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EArrEmpty(t, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EMapEmpty(k, mv, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EMapLit(ks, vs, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                ETuple(es, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                ESlice(b, lo, hi, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                EAddr(x, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                ELambda(lid, ps, pts, ret, bx, cn, ct, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                ECallV(c, a, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
                ESpawn(sid, sn2, sa2, _el):
                    die("parse: spawn requires a direct call: spawn f(args)")
            return EInt("0", _el)
        if name == "channel" and toks[pos].kind == TLParen:   # channel(T, cap) (CC-4); the type rides the name
            pos = pos + 1
            chty := parse_type(toks, &pos)
            expect(toks, &pos, TComma)
            chargs := []Expr
            push(chargs, parse_expr(toks, &pos))
            expect(toks, &pos, TRParen)
            return ECall("channel:" + chty, chargs, _el)
        if name == "true":
            return EBool("1", _el)
        if name == "false":
            return EBool("0", _el)
        if name == "null":                       # FFI opaque ptr literal -> a 0-arg builtin call
            return ECall("null", []Expr, _el)
        if toks[pos].kind == TDot and toks[pos + 1].kind == TIdent and toks[pos + 2].kind == TLParen:
            qn := name + "." + toks[pos + 1].text     # qualified call pkg.name(args); resolved by the mangler
            pos = pos + 3
            qargs := []Expr
            if toks[pos].kind != TRParen:
                push(qargs, parse_expr(toks, &pos))
                for toks[pos].kind == TComma:
                    pos = pos + 1
                    push(qargs, parse_expr(toks, &pos))
            expect(toks, &pos, TRParen)
            return ECall(qn, qargs, _el)
        if toks[pos].kind == TLParen:
            pos = pos + 1
            args := []Expr
            if toks[pos].kind != TRParen:
                push(args, parse_expr(toks, &pos))
                for toks[pos].kind == TComma:
                    pos = pos + 1
                    push(args, parse_expr(toks, &pos))
            expect(toks, &pos, TRParen)
            return ECall(name, args, _el)
        return EVar(name, _el)
    elif t.kind == TLParen:
        pos = pos + 1
        e := parse_expr(toks, &pos)
        if toks[pos].kind == TComma:             # tuple literal (a, b, ...)
            elems := []Expr
            push(elems, e)
            for toks[pos].kind == TComma:
                pos = pos + 1
                push(elems, parse_expr(toks, &pos))
            expect(toks, &pos, TRParen)
            return ETuple(elems, _el)
        expect(toks, &pos, TRParen)
        return e
    elif t.kind == TLBracket:
        pos = pos + 1
        if toks[pos].kind == TRBracket:          # []T : empty array  /  []K: V : empty map  /  bare []
            pos = pos + 1
            # B-0 (docs/inference.md): `[]` not followed by a type-starter token
            # is a bare empty literal, grounded from the destination type by the
            # pre-lift checking pass (ground_pre) at every supplying position.
            if toks[pos].kind != TIdent and toks[pos].kind != TLBracket and toks[pos].kind != TLParen:
                return EArrEmpty("", _el)
            kty := parse_type(toks, &pos)
            if toks[pos].kind == TColon:
                pos = pos + 1
                vty := parse_type(toks, &pos)
                return EMapEmpty(kty, vty, _el)
            return EArrEmpty(kty, _el)
        first := parse_expr(toks, &pos)
        if toks[pos].kind == TColon:             # [k0: v0, k1: v1] : map literal
            keys := []Expr
            vals := []Expr
            pos = pos + 1
            push(keys, first)
            push(vals, parse_expr(toks, &pos))
            for toks[pos].kind == TComma:
                pos = pos + 1
                push(keys, parse_expr(toks, &pos))
                expect(toks, &pos, TColon)
                push(vals, parse_expr(toks, &pos))
            expect(toks, &pos, TRBracket)
            return EMapLit(keys, vals, _el)
        elems := []Expr                          # [e0, e1, ...] : array literal
        push(elems, first)
        for toks[pos].kind == TComma:
            pos = pos + 1
            push(elems, parse_expr(toks, &pos))
        expect(toks, &pos, TRBracket)
        return EArrLit(elems, _el)
    else:
        die("parse: line " + str(toks[pos].line) + ": expected an atom")
        return EInt("0", _el)

fn parse_postfix(toks: [Token], pos: inout int) -> Expr:
    _el := tloc(toks[pos])
    e := parse_atom(toks, &pos)
    for toks[pos].kind == TDot or toks[pos].kind == TLBracket or toks[pos].kind == TLParen:
        if toks[pos].kind == TLParen:            # call-on-expression: <expr>(args) -- indirect call on a fn value
            pos = pos + 1
            cargs := []Expr
            if toks[pos].kind != TRParen:
                push(cargs, parse_expr(toks, &pos))
                for toks[pos].kind == TComma:
                    pos = pos + 1
                    push(cargs, parse_expr(toks, &pos))
            expect(toks, &pos, TRParen)
            e = ECallV(e, cargs, _el)
        elif toks[pos].kind == TDot:             # field access: a.b  /  tuple index: a.0
            pos = pos + 1
            if toks[pos].kind != TIdent and toks[pos].kind != TInt:
                die("parse: line " + str(toks[pos].line) + ": expected a field name or index after '.'")
            e = EField(e, toks[pos].text, _el)
            pos = pos + 1
        else:                                    # index a[i]  or  slice a[lo:hi]
            pos = pos + 1
            lenargs := []Expr
            push(lenargs, e)
            if toks[pos].kind == TColon:         # a[:hi] / a[:]
                pos = pos + 1
                hi := ECall("len", lenargs, _el)
                if toks[pos].kind != TRBracket:
                    hi = parse_expr(toks, &pos)
                expect(toks, &pos, TRBracket)
                e = ESlice(e, EInt("0", _el), hi, _el)
            else:
                idx := parse_expr(toks, &pos)
                if toks[pos].kind == TColon:     # a[lo:hi] / a[lo:]
                    pos = pos + 1
                    hi := ECall("len", lenargs, _el)
                    if toks[pos].kind != TRBracket:
                        hi = parse_expr(toks, &pos)
                    expect(toks, &pos, TRBracket)
                    e = ESlice(e, idx, hi, _el)
                else:
                    expect(toks, &pos, TRBracket)
                    e = EIndex(e, idx, _el)
    return e

fn parse_mul(toks: [Token], pos: inout int) -> Expr:
    _el := tloc(toks[pos])
    l := parse_postfix(toks, &pos)
    for toks[pos].kind == TStar or toks[pos].kind == TSlash or toks[pos].kind == TPercent or toks[pos].kind == TShl or toks[pos].kind == TShr or toks[pos].kind == TAmp:
        op := toks[pos].text
        pos = pos + 1
        r := parse_postfix(toks, &pos)
        l = EBin(op, l, r, _el)
    return l

fn parse_add(toks: [Token], pos: inout int) -> Expr:
    _el := tloc(toks[pos])
    l := parse_mul(toks, &pos)
    for toks[pos].kind == TPlus or toks[pos].kind == TMinus or toks[pos].kind == TPipe or toks[pos].kind == TCaret:
        op := toks[pos].text
        pos = pos + 1
        r := parse_mul(toks, &pos)
        l = EBin(op, l, r, _el)
    return l

fn parse_cmp(toks: [Token], pos: inout int) -> Expr:
    _el := tloc(toks[pos])
    l := parse_add(toks, &pos)
    k := toks[pos].kind
    if k == TEqEq or k == TLt or k == TGt or k == TLe or k == TGe or k == TNe:
        op := toks[pos].text
        pos = pos + 1
        r := parse_add(toks, &pos)
        return EBin(op, l, r, _el)
    return l

fn parse_not(toks: [Token], pos: inout int) -> Expr:
    _el := tloc(toks[pos])
    if toks[pos].kind == TIdent and toks[pos].text == "not":
        pos = pos + 1
        return EBin("==", parse_not(toks, &pos), EInt("0", _el), _el)   # logical not: (X == 0)
    return parse_cmp(toks, &pos)

fn parse_and(toks: [Token], pos: inout int) -> Expr:
    _el := tloc(toks[pos])
    l := parse_not(toks, &pos)
    for toks[pos].kind == TIdent and toks[pos].text == "and":
        pos = pos + 1
        r := parse_not(toks, &pos)
        l = EBin("&&", l, r, _el)
    return l

fn parse_expr(toks: [Token], pos: inout int) -> Expr:
    _el := tloc(toks[pos])
    l := parse_and(toks, &pos)
    for toks[pos].kind == TIdent and toks[pos].text == "or":
        pos = pos + 1
        r := parse_and(toks, &pos)
        l = EBin("||", l, r, _el)
    return l

# `for x in COLL:` desugars to a collection-temp decl plus a range loop over its
# indices, pushed as TWO statements (Hier has no globals for a prelude queue, so
# the block builder calls this directly). COLL is bound to a temp so it is
# evaluated exactly once; the element read `x := _fc[_fi]` reuses array/string
# indexing. The temp id is the `for` token position -- unique per occurrence.
fn parse_foreach(toks: [Token], pos: inout int, out: inout [Stmt]):
    _el := tloc(toks[pos])
    _sl := tloc(toks[pos])
    uid := str(pos)
    pos = pos + 1                            # 'for'
    varname := toks[pos].text
    pos = pos + 1
    expect_ident(toks, &pos, "in")
    coll := parse_expr(toks, &pos)
    expect(toks, &pos, TColon)
    body := parse_block(toks, &pos)
    cn := "_fc" + uid
    iv := "_fi" + uid
    largs := []Expr
    push(largs, EVar(cn, _el))                    # len(_fc)
    fbody := []Stmt
    push(fbody, SDecl(varname, EIndex(EVar(cn, _el), EVar(iv, _el), _el), _sl))   # x := _fc[_fi]
    k := 0
    for k < len(body):
        push(fbody, body[k])
        k = k + 1
    push(out, SDecl(cn, coll, _sl))                                # _fc := COLL  (the prelude)
    push(out, SForRange(iv, EInt("0", _el), ECall("len", largs, _el), EInt("1", _el), fbody, _sl))

fn parse_block(toks: [Token], pos: inout int) -> [Stmt]:
    stmts := []Stmt
    open_block(toks, &pos)
    for toks[pos].kind != TDedent:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        else:
            # foreach `for x in <non-range>:` -> handled here so it can push the
            # collection-temp decl ahead of the loop; everything else is one stmt.
            isfe := false
            if toks[pos].kind == TIdent and toks[pos].text == "for" and pos + 4 < len(toks):
                if toks[pos + 1].kind == TIdent and toks[pos + 2].kind == TIdent and toks[pos + 2].text == "in":
                    if not (toks[pos + 3].kind == TIdent and toks[pos + 3].text == "range" and toks[pos + 4].kind == TLParen):
                        isfe = true
            if isfe:
                parse_foreach(toks, &pos, &stmts)
            else:
                firstkw := ""                        # the stmt's leading keyword (compound stmts self-terminate via their block)
                if toks[pos].kind == TIdent:
                    firstkw = toks[pos].text
                pend := []Stmt                       # preludes (e.g. hoisted index temps)
                st := parse_stmt(toks, &pos, &pend)
                pj := 0
                for pj < len(pend):
                    push(stmts, pend[pj])
                    pj = pj + 1
                push(stmts, st)
                # fail-closed: a SIMPLE statement must end at a newline; without this
                # two statements on one line (`print(x)  continue`) were silently
                # accepted. Compound stmts (if/for/while/match/select/parallel-for)
                # end at their block's dedent, so the next token is the following
                # stmt -- exempt them (keyed on the leading keyword).
                cmpd := firstkw == "if" or firstkw == "for" or firstkw == "while" or firstkw == "match" or firstkw == "select" or firstkw == "parallel"
                if not cmpd and toks[pos].kind != TNewline and toks[pos].kind != TDedent:
                    die("parse: line " + str(toks[pos].line) + ": expected newline")
            if toks[pos].kind == TNewline:
                pos = pos + 1
    pos = pos + 1
    return stmts

fn parse_else(toks: [Token], pos: inout int) -> [Stmt]:
    _sl := tloc(toks[pos])
    t := toks[pos]
    if t.kind == TIdent and t.text == "elif":
        pos = pos + 1
        cond := parse_expr(toks, &pos)
        expect(toks, &pos, TColon)
        then_body := parse_block(toks, &pos)
        rest := parse_else(toks, &pos)
        inner := []Stmt
        push(inner, SIf(cond, then_body, rest, _sl))
        return inner
    elif t.kind == TIdent and t.text == "else":
        pos = pos + 1
        expect(toks, &pos, TColon)
        return parse_block(toks, &pos)
    else:
        return []Stmt

# the binary-operator token kinds that have a compound-assignment form `x OP= e`
# (detected as the operator token followed by `=`, so no dedicated token needed).
fn is_caop_kind(k: Tok) -> bool:
    return k == TPlus or k == TMinus or k == TStar or k == TSlash or k == TPercent or k == TAmp or k == TPipe or k == TCaret or k == TShl or k == TShr

fn parse_stmt(toks: [Token], pos: inout int, pending: inout [Stmt]) -> Stmt:
    _el := tloc(toks[pos])
    _sl := tloc(toks[pos])
    t := toks[pos]
    if t.kind == TIdent and t.text == "print":
        pos = pos + 1
        expect(toks, &pos, TLParen)
        e := parse_expr(toks, &pos)
        expect(toks, &pos, TRParen)
        return SPrint(e, _sl)
    elif t.kind == TIdent and t.text == "println":   # desugar: print(x + "\n")
        pos = pos + 1
        expect(toks, &pos, TLParen)
        e := parse_expr(toks, &pos)
        expect(toks, &pos, TRParen)
        return SPrint(EBin("+", e, EStr("\\n", _el), _el), _sl)
    elif t.kind == TIdent and t.text == "return":
        pos = pos + 1
        if toks[pos].kind == TNewline:           # bare `return` (void)
            return SReturnVoid
        re := parse_expr(toks, &pos)
        if toks[pos].kind == TComma:             # `return a, b` builds a tuple
            elems := []Expr
            push(elems, re)
            for toks[pos].kind == TComma:
                pos = pos + 1
                push(elems, parse_expr(toks, &pos))
            return SReturn(ETuple(elems, _el), _sl)
        return SReturn(re, _sl)
    elif t.kind == TIdent and t.text == "if":
        pos = pos + 1
        cond := parse_expr(toks, &pos)
        expect(toks, &pos, TColon)
        then_body := parse_block(toks, &pos)
        else_body := parse_else(toks, &pos)
        return SIf(cond, then_body, else_body, _sl)
    elif t.kind == TIdent and t.text == "select":   # select over channels (CC-5)
        suid := str(pos)
        pos = pos + 1
        expect(toks, &pos, TColon)
        expect(toks, &pos, TNewline)
        expect(toks, &pos, TIndent)
        svars := []string
        schans := []Expr
        sbinds := []string
        sbodies := [][Stmt]
        for toks[pos].kind != TDedent:
            if toks[pos].kind == TNewline:
                pos = pos + 1
            else:
                if toks[pos].kind != TIdent:
                    die("parse: line " + str(toks[pos].line) + ": a select arm is `recv(ch, x):`, `default:`, or `closed:`")
                av := toks[pos].text
                pos = pos + 1
                ach := EInt("0", _el)
                abind := ""
                if av == "recv":
                    expect(toks, &pos, TLParen)
                    ach = parse_expr(toks, &pos)
                    expect(toks, &pos, TComma)
                    abind = toks[pos].text
                    pos = pos + 1
                    expect(toks, &pos, TRParen)
                elif av != "default" and av != "closed":
                    die("parse: line " + str(toks[pos].line) + ": a select arm is `recv(ch, x):`, `default:`, or `closed:`")
                expect(toks, &pos, TColon)
                push(svars, av)
                push(schans, ach)
                push(sbinds, abind)
                push(sbodies, parse_block(toks, &pos))
        pos = pos + 1
        return SSelect(suid, svars, schans, sbinds, sbodies, _sl)
    elif t.kind == TIdent and t.text == "parallel":   # parallel for ... (CC-3)
        pos = pos + 1
        if not (toks[pos].kind == TIdent and toks[pos].text == "for"):
            die("parse: line " + str(toks[pos].line) + ": expected 'for' after 'parallel'")
        pos = pos + 1
        if toks[pos].kind == TIdent and toks[pos + 1].kind == TIdent and toks[pos + 1].text == "in":
            pvar := toks[pos].text
            pos = pos + 1
            expect_ident(toks, &pos, "in")
            if toks[pos].kind == TIdent and toks[pos].text == "range" and toks[pos + 1].kind == TLParen:
                pos = pos + 1
                expect(toks, &pos, TLParen)
                pa1 := parse_expr(toks, &pos)
                pstart := EInt("0", _el)
                pstop := pa1
                if toks[pos].kind == TComma:
                    pos = pos + 1
                    pstart = pa1
                    pstop = parse_expr(toks, &pos)
                    if toks[pos].kind == TComma:
                        die("parse: line " + str(toks[pos].line) + ": parallel for does not support a range step")
                expect(toks, &pos, TRParen)
                expect(toks, &pos, TColon)
                pbody := parse_block(toks, &pos)
                return SParFor(pvar, pstart, pstop, pbody, 0 - 1, _sl)
            # foreach form: `parallel for x in COLL:` -> prelude `_fc := COLL`
            # (via `pending`) + a parallel range loop, mirroring parse_foreach
            pcoll := parse_expr(toks, &pos)
            expect(toks, &pos, TColon)
            pubody := parse_block(toks, &pos)
            puid := str(pos)
            pcn := "_fc" + puid
            piv := "_fi" + puid
            plargs := []Expr
            push(plargs, EVar(pcn, _el))
            pfbody := []Stmt
            push(pfbody, SDecl(pvar, EIndex(EVar(pcn, _el), EVar(piv, _el), _el), _sl))
            pk := 0
            for pk < len(pubody):
                push(pfbody, pubody[pk])
                pk = pk + 1
            push(pending, SDecl(pcn, pcoll, _sl))
            return SParFor(piv, EInt("0", _el), ECall("len", plargs, _el), pfbody, 0 - 1, _sl)
        die("parse: line " + str(t.line) + ": parallel supports 'for x in range(...)' and 'for x in collection' loops")
        return SBreak
    elif t.kind == TIdent and t.text == "for":
        pos = pos + 1
        if toks[pos].kind == TIdent and toks[pos + 1].kind == TIdent and toks[pos + 1].text == "in":
            varname := toks[pos].text       # counting form: for i in range(...)
            pos = pos + 1
            expect_ident(toks, &pos, "in")
            expect_ident(toks, &pos, "range")
            expect(toks, &pos, TLParen)
            a1 := parse_expr(toks, &pos)
            start := EInt("0", _el)              # range(n): 0..n
            stop := a1
            step := EInt("1", _el)
            if toks[pos].kind == TComma:    # range(a, b[, c])
                pos = pos + 1
                start = a1
                stop = parse_expr(toks, &pos)
                if toks[pos].kind == TComma:
                    pos = pos + 1
                    step = parse_expr(toks, &pos)
            expect(toks, &pos, TRParen)
            expect(toks, &pos, TColon)
            body := parse_block(toks, &pos)
            return SForRange(varname, start, stop, step, body, _sl)
        cond := parse_expr(toks, &pos)      # condition form: for COND:
        expect(toks, &pos, TColon)
        body := parse_block(toks, &pos)
        return SWhile(cond, body, _sl)
    elif t.kind == TIdent and t.text == "match":
        return parse_match(toks, &pos)
    elif t.kind == TIdent and t.text == "break":
        pos = pos + 1
        return SBreak
    elif t.kind == TIdent and t.text == "continue":
        pos = pos + 1
        return SContinue
    elif t.kind == TIdent:
        name := t.text
        pos = pos + 1
        if toks[pos].kind == TComma:             # destructure: a, b := tuple_expr
            names := []string
            push(names, name)
            for toks[pos].kind == TComma:
                pos = pos + 1
                if toks[pos].kind != TIdent:
                    die("parse: line " + str(toks[pos].line) + ": expected a name in destructure")
                push(names, toks[pos].text)
                pos = pos + 1
            if toks[pos].kind == TWalrus:        # `:=` declares new vars
                pos = pos + 1
                return SDestructure(names, parse_expr(toks, &pos), _sl)
            expect(toks, &pos, TEq)              # `=` assigns existing vars
            return SMultiAssign(names, parse_expr(toks, &pos), _sl)
        if toks[pos].kind == TWalrus:
            pos = pos + 1
            rhs := parse_expr(toks, &pos)
            if toks[pos].kind == TIdent and toks[pos].text == "or_return":
                pos = pos + 1
                return SOrReturn(name, rhs, _sl)
            return SDecl(name, rhs, _sl)
        elif toks[pos].kind == TColon:           # `name : Type = expr` typed decl
            pos = pos + 1
            ty := parse_type(toks, &pos)
            expect(toks, &pos, TEq)
            return STypedDecl(name, ty, parse_expr(toks, &pos), _sl)
        elif toks[pos].kind == TEq:
            pos = pos + 1
            return SAssign(name, parse_expr(toks, &pos), _sl)
        elif is_caop_kind(toks[pos].kind) and toks[pos + 1].kind == TEq:   # x OP= rhs -> x = x OP rhs
            op := toks[pos].text
            pos = pos + 1
            expect(toks, &pos, TEq)
            return SAssign(name, EBin(op, EVar(name, _el), parse_expr(toks, &pos), _el), _sl)
        elif toks[pos].kind == TDot or toks[pos].kind == TLBracket:
            # collect the place steps first (a.b[i].c ...) so that, for a compound
            # assignment, a call-bearing index can be hoisted to a temp -- the place
            # is evaluated twice (read + store), and a side-effecting index must run
            # once. Plain assignment and pure indices are unchanged.
            pkinds := []int                      # 0 = field, 1 = index
            pflds := []string
            pidxs := []Expr
            for toks[pos].kind == TDot or toks[pos].kind == TLBracket:
                if toks[pos].kind == TDot:
                    pos = pos + 1
                    if toks[pos].kind != TIdent and toks[pos].kind != TInt:
                        die("parse: line " + str(toks[pos].line) + ": expected a field name or tuple index after '.'")
                    push(pkinds, 0)
                    push(pflds, toks[pos].text)   # TInt -> tuple element place (t.0 = v)
                    push(pidxs, EInt("0", _el))        # placeholder; unused for a field step
                    pos = pos + 1
                    if toks[pos].kind == TLParen:   # method-call STATEMENT (ch.send(v), t.wait(), x.foo(a)):
                        mb := EVar(name, _el)            # rebuild the receiver from the steps before the method name
                        mj := 0
                        for mj < len(pkinds) - 1:
                            if pkinds[mj] == 0:
                                mb = EField(mb, pflds[mj], _el)
                            else:
                                mb = EIndex(mb, pidxs[mj], _el)
                            mj = mj + 1
                        pos = pos + 1
                        margs := []Expr
                        if toks[pos].kind != TRParen:
                            push(margs, parse_expr(toks, &pos))
                            for toks[pos].kind == TComma:
                                pos = pos + 1
                                push(margs, parse_expr(toks, &pos))
                        expect(toks, &pos, TRParen)
                        return SExpr(ECallV(EField(mb, pflds[len(pflds) - 1], _el), margs, _el), _sl)
                else:
                    pos = pos + 1
                    push(pkinds, 1)
                    push(pflds, "")
                    push(pidxs, parse_expr(toks, &pos))
                    expect(toks, &pos, TRBracket)
            iscomp := is_caop_kind(toks[pos].kind) and toks[pos + 1].kind == TEq
            lv := EVar(name, _el)
            ci := 0
            j := 0
            for j < len(pkinds):
                if pkinds[j] == 0:
                    lv = EField(lv, pflds[j], _el)
                else:
                    ix := pidxs[j]
                    if iscomp and expr_has_call(ix):   # bind a side-effecting index once
                        tn := "_cx" + str(pos) + "_" + str(ci)
                        ci = ci + 1
                        push(pending, SDecl(tn, ix, _sl))
                        ix = EVar(tn, _el)
                    lv = EIndex(lv, ix, _el)
                j = j + 1
            if iscomp:                           # lv OP= rhs -> lv = lv OP rhs
                op := toks[pos].text
                pos = pos + 1
                expect(toks, &pos, TEq)
                return SFieldAssign(lv, EBin(op, lv, parse_expr(toks, &pos), _el), _sl)
            expect(toks, &pos, TEq)
            return SFieldAssign(lv, parse_expr(toks, &pos), _sl)
        elif toks[pos].kind == TLParen:          # bare call statement: f(args)
            pos = pos + 1
            args := []Expr
            if toks[pos].kind != TRParen:
                push(args, parse_expr(toks, &pos))
                for toks[pos].kind == TComma:
                    pos = pos + 1
                    push(args, parse_expr(toks, &pos))
            expect(toks, &pos, TRParen)
            return SExpr(ECall(name, args, _el), _sl)
        else:
            die("parse: line " + str(toks[pos].line) + ": expected ':=', '=', or '('")
            return SReturn(EInt("0", _el), _sl)
    else:
        die("parse: line " + str(toks[pos].line) + ": expected a statement")
        return SReturn(EInt("0", _el), _sl)

fn parse_type(toks: [Token], pos: inout int) -> string:
    if toks[pos].kind == TLParen:                # tuple type (T, U, ...)
        pos = pos + 1
        parts := []string
        push(parts, parse_type(toks, &pos))
        for toks[pos].kind == TComma:
            pos = pos + 1
            push(parts, parse_type(toks, &pos))
        expect(toks, &pos, TRParen)
        out := "("
        i := 0
        for i < len(parts):
            if i > 0:
                out = out + ","
            out = out + parts[i]
            i = i + 1
        return out + ")"
    if toks[pos].kind == TLBracket:              # [T] array  or  [K: V] map
        pos = pos + 1
        inner := parse_type(toks, &pos)
        if toks[pos].kind == TColon:
            pos = pos + 1
            v := parse_type(toks, &pos)
            expect(toks, &pos, TRBracket)
            return "{" + inner + ":" + v + "}"
        expect(toks, &pos, TRBracket)
        return "[" + inner + "]"
    if toks[pos].kind == TIdent and toks[pos].text == "soa":   # soa [Struct]
        pos = pos + 1
        expect(toks, &pos, TLBracket)
        st := parse_type(toks, &pos)
        expect(toks, &pos, TRBracket)
        return "soa[" + st + "]"
    if toks[pos].kind == TIdent and toks[pos].text == "fn":    # function type fn(P...) [-> R]
        pos = pos + 1
        expect(toks, &pos, TLParen)
        params := []string
        if toks[pos].kind != TRParen:
            push(params, parse_type(toks, &pos))
            for toks[pos].kind == TComma:
                pos = pos + 1
                push(params, parse_type(toks, &pos))
        expect(toks, &pos, TRParen)
        ret := "void"
        if toks[pos].kind == TArrow:
            pos = pos + 1
            ret = parse_type(toks, &pos)
        out := "fn("
        i := 0
        for i < len(params):
            if i > 0:
                out = out + ","
            out = out + params[i]
            i = i + 1
        return out + "->" + ret + ")"
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected a type")
    name := toks[pos].text
    pos = pos + 1
    if toks[pos].kind == TDot and toks[pos + 1].kind == TIdent:   # qualified type pkg.Type
        name = name + "." + toks[pos + 1].text
        pos = pos + 2
    if name == "int":
        return "int"
    elif name == "bool":
        return "bool"                            # distinct type; same C repr as int (long 0/1)
    elif name == "float":
        return "float"
    elif name == "string":
        return "str"
    elif name == "ptr":                          # FFI opaque handle -> void*
        return "ptr"
    elif name == "Channel":                      # Channel(T): a worker param's queue type (CC-4)
        expect(toks, &pos, TLParen)
        cht := parse_type(toks, &pos)
        expect(toks, &pos, TRParen)
        return "Channel(" + cht + ")"
    elif name == "Option":
        expect(toks, &pos, TLParen)
        t := parse_type(toks, &pos)
        expect(toks, &pos, TRParen)
        return "Option(" + t + ")"
    elif name == "Result":
        expect(toks, &pos, TLParen)
        t := parse_type(toks, &pos)
        expect(toks, &pos, TComma)
        e := parse_type(toks, &pos)
        expect(toks, &pos, TRParen)
        return "Result(" + t + "," + e + ")"
    else:
        return name                              # a struct or enum type name

fn parse_param(toks: [Token], pos: inout int) -> Param:
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected a parameter name")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TColon)
    if toks[pos].kind == TIdent and toks[pos].text == "inout":
        pos = pos + 1
        return Param(name, "&" + parse_type(toks, &pos))   # inout marker
    return Param(name, parse_type(toks, &pos))

fn parse_func(toks: [Token], pos: inout int) -> Func:
    expect_ident(toks, &pos, "fn")
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected a function name")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TLParen)
    params := []string
    ptypes := []string
    if toks[pos].kind != TRParen:
        p := parse_param(toks, &pos)
        push(params, p.name)
        push(ptypes, p.ty)
        for toks[pos].kind == TComma:
            pos = pos + 1
            p2 := parse_param(toks, &pos)
            push(params, p2.name)
            push(ptypes, p2.ty)
    expect(toks, &pos, TRParen)
    ret := "void"
    if toks[pos].kind == TArrow:
        pos = pos + 1
        ret = parse_type(toks, &pos)
    expect(toks, &pos, TColon)
    body := parse_block(toks, &pos)
    return Func(name, params, ptypes, ret, body, 0, "")

# FFI Stage 1: only scalars + string cross the C boundary (composites have
# hier-internal C reps, not a stable ABI). Reject everything else (fail closed).
fn ffi_scalar(ty: string) -> bool:
    return ty == "int" or ty == "char" or ty == "float" or ty == "bool" or ty == "str" or ty == "ptr"

# extern [ "Lib" ] fn name(p: T, ...) [-> T]   (bodyless; calls a C symbol).
# Name is NOT mangled — a C symbol is global.
fn parse_extern_func(toks: [Token], pos: inout int) -> Func:
    expect_ident(toks, &pos, "extern")
    lib := ""
    if toks[pos].kind == TStr:                 # optional link-library name
        lib = toks[pos].text
        pos = pos + 1
    expect_ident(toks, &pos, "fn")
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected a C function name after 'extern fn'")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TLParen)
    params := []string
    ptypes := []string
    if toks[pos].kind != TRParen:
        p := parse_param(toks, &pos)
        if not ffi_scalar(p.ty):
            die("parse: line " + str(toks[pos].line) + ": extern fn '" + name + "': parameters must be int/char/float/bool/string")
        push(params, p.name)
        push(ptypes, p.ty)
        for toks[pos].kind == TComma:
            pos = pos + 1
            p2 := parse_param(toks, &pos)
            if not ffi_scalar(p2.ty):
                die("parse: line " + str(toks[pos].line) + ": extern fn '" + name + "': parameters must be int/char/float/bool/string")
            push(params, p2.name)
            push(ptypes, p2.ty)
    expect(toks, &pos, TRParen)
    ret := "void"
    if toks[pos].kind == TArrow:
        pos = pos + 1
        ret = parse_type(toks, &pos)
        if not ffi_scalar(ret):
            die("parse: line " + str(toks[pos].line) + ": extern fn '" + name + "': return type must be int/char/float/bool/string or omitted")
    return Func(name, params, ptypes, ret, []Stmt, 1, lib)

# A lambda literal `fn(p: T, ...) [-> R]: expr` — single-expression body (implicit
# return). The leading `fn` and the opening `(` have already been consumed-checked
# by the caller (parse_atom). id is a placeholder (0); the lift pass assigns it.
fn parse_lambda(toks: [Token], pos: inout int) -> Expr:
    _el := tloc(toks[pos])
    expect(toks, &pos, TLParen)
    params := []string
    ptypes := []string
    if toks[pos].kind != TRParen:
        # B-2: the `: T` is elidable -- "" is filled from the expected fn type
        # by ground_pre before the lift (or dies with a local error there)
        push(params, toks[pos].text)
        pos = pos + 1
        lt0 := ""
        if toks[pos].kind == TColon:
            pos = pos + 1
            lt0 = parse_type(toks, &pos)
        push(ptypes, lt0)
        for toks[pos].kind == TComma:
            pos = pos + 1
            push(params, toks[pos].text)
            pos = pos + 1
            lt1 := ""
            if toks[pos].kind == TColon:
                pos = pos + 1
                lt1 = parse_type(toks, &pos)
            push(ptypes, lt1)
    expect(toks, &pos, TRParen)
    ret := "void"
    if toks[pos].kind == TArrow:
        pos = pos + 1
        ret = parse_type(toks, &pos)
    expect(toks, &pos, TColon)
    bexpr := parse_expr(toks, &pos)
    return ELambda(0, params, ptypes, ret, bexpr, []string, []string, _el)   # body is the single expr; lift wraps it in a Func

fn parse_struct(toks: [Token], pos: inout int) -> StructDef:
    expect_ident(toks, &pos, "struct")
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected a struct name")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TColon)
    open_block(toks, &pos)
    fields := []Field
    for toks[pos].kind != TDedent:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        else:
            if toks[pos].kind != TIdent:
                die("parse: line " + str(toks[pos].line) + ": expected a field name")
            fname := toks[pos].text
            pos = pos + 1
            expect(toks, &pos, TColon)
            fty := parse_type(toks, &pos)
            push(fields, Field(fname, fty))
            if toks[pos].kind == TNewline:
                pos = pos + 1
    pos = pos + 1                                # consume TDedent
    return StructDef(name, fields)

fn parse_match(toks: [Token], pos: inout int) -> Stmt:
    _sl := tloc(toks[pos])
    expect_ident(toks, &pos, "match")
    subj := parse_expr(toks, &pos)
    expect(toks, &pos, TColon)
    open_block(toks, &pos)
    variants := []string
    allbinds := [][string]
    bodies := [][Stmt]
    for toks[pos].kind != TDedent:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        else:
            if toks[pos].kind != TIdent:
                die("parse: line " + str(toks[pos].line) + ": expected a variant name in match arm")
            avar := toks[pos].text
            pos = pos + 1
            if toks[pos].kind == TDot and toks[pos + 1].kind == TIdent:   # qualified arm pkg.Variant
                avar = avar + "." + toks[pos + 1].text
                pos = pos + 2
            push(variants, avar)
            binds := []string
            if toks[pos].kind == TLParen:        # payload list is optional (e.g. `None:`)
                pos = pos + 1
                if toks[pos].kind != TRParen:
                    if toks[pos].kind != TIdent:
                        die("parse: line " + str(toks[pos].line) + ": expected a binding name")
                    push(binds, toks[pos].text)
                    pos = pos + 1
                    for toks[pos].kind == TComma:
                        pos = pos + 1
                        if toks[pos].kind != TIdent:
                            die("parse: line " + str(toks[pos].line) + ": expected a binding name")
                        push(binds, toks[pos].text)
                        pos = pos + 1
                expect(toks, &pos, TRParen)
            expect(toks, &pos, TColon)
            push(allbinds, binds)
            push(bodies, parse_block(toks, &pos))
    pos = pos + 1                                # consume TDedent
    return SMatch(subj, variants, allbinds, bodies, _sl)

fn parse_enum(toks: [Token], pos: inout int) -> EnumDef:
    expect_ident(toks, &pos, "enum")
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected an enum name")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TColon)
    open_block(toks, &pos)
    variants := []Variant
    for toks[pos].kind != TDedent:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        else:
            if toks[pos].kind != TIdent:
                die("parse: line " + str(toks[pos].line) + ": expected a variant name")
            vname := toks[pos].text
            pos = pos + 1
            ptypes := []string
            if toks[pos].kind == TLParen:
                pos = pos + 1
                if toks[pos].kind != TRParen:
                    push(ptypes, parse_type(toks, &pos))
                    for toks[pos].kind == TComma:
                        pos = pos + 1
                        push(ptypes, parse_type(toks, &pos))
                expect(toks, &pos, TRParen)
            push(variants, Variant(vname, ptypes))
            if toks[pos].kind == TNewline:
                pos = pos + 1
    pos = pos + 1                                # consume TDedent
    return EnumDef(name, variants)

fn parse_newtype(toks: [Token], pos: inout int) -> Param:   # `type Name = Underlying`
    expect_ident(toks, &pos, "type")
    if toks[pos].kind != TIdent:
        die("parse: line " + str(toks[pos].line) + ": expected a newtype name")
    name := toks[pos].text
    pos = pos + 1
    expect(toks, &pos, TEq)
    return Param(name, parse_type(toks, &pos))

# ---- package mangling (Stage D) ------------------------------------------
# The stdin stream may concatenate several packages, each headed by `package X`
# (produced by `hierc --bundle`, dependencies first). Every top-level name in an
# imported package is mangled `<pkg>__name` so distinct packages never collide
# in the one flat namespace; the `main` package and a plain single-file program
# keep the empty prefix, so their output is unchanged. Mangling runs ONLY when a
# `package` decl was seen, so a normal single-file compile (incl. hierc0.hi
# itself) is byte-identical. Qualified references arrive from the parser as
# dotted `pkg.name` strings; they become `<realpkg>__name` (`realpkg` resolves an
# import alias to the package's true name).
#
# Mctx is the read-only resolution table built once per program in pass 1 of
# parse_program: `prefix` is the current def's package prefix; `aliasn`/`aliasp`
# map an import alias to its package name; `pkgs` is every usable qualifier
# (package names + aliases); `variants` is every mangled variant name (so a bare
# `Red`/`pkg.Red` payload-less variant value resolves).
struct Mctx:
    prefix: string
    aliasn: [string]
    aliasp: [string]
    pkgs: [string]
    variants: [string]
    locals: [string]          # enclosing fn's param names: a call to one is an INDIRECT call (fn value), not a package fn -> don't prefix
    externs: [string]         # FFI extern fn names: global C symbols, never package-mangled (like builtins)

fn is_builtin_call(name: string) -> bool:
    return name == "str" or name == "substr" or name == "chr" or name == "input" or name == "split" or name == "keys" or name == "map_get" or name == "map_has" or name == "map_set" or name == "map_del" or name == "find" or name == "sqrt" or name == "pow" or name == "floor" or name == "fabs" or name == "to_float" or name == "to_int" or name == "to_str" or name == "to_bool" or name == "read_all" or name == "read_file" or name == "write_file" or name == "list_dir" or name == "args" or name == "getenv" or name == "is_null" or name == "null" or name == "die" or name == "eprint" or name == "len" or name == "push" or name == "pop" or name == "reserve" or name == "Some" or name == "Ok" or name == "Err" or name == "None"

fn resolve_pkg(m: Mctx, qual: string) -> string:       # import alias -> real package name (else identity)
    i := 0
    for i < len(m.aliasn):
        if m.aliasn[i] == qual:
            return m.aliasp[i]
        i = i + 1
    return qual

fn mangle_dotted(m: Mctx, s: string) -> string:        # "g.add" -> "<realpkg(g)>__add"
    idx := find(s, ".")
    return resolve_pkg(m, substr(s, 0, idx)) + "__" + substr(s, idx + 1, len(s))

fn is_pkg_ref(m: Mctx, name: string) -> bool:          # is `name` a package name or import alias?
    i := 0
    for i < len(m.pkgs):
        if m.pkgs[i] == name:
            return true
        i = i + 1
    return false

fn is_known_variant(m: Mctx, mn: string) -> bool:      # is `mn` (already mangled) a declared variant?
    i := 0
    for i < len(m.variants):
        if m.variants[i] == mn:
            return true
        i = i + 1
    return false

fn mangle_ref(m: Mctx, name: string) -> string:
    if find(name, ".") >= 0:
        return mangle_dotted(m, name)
    if is_builtin_call(name):
        return name
    if has_str(m.externs, name):                 # FFI: a global C symbol — never package-mangle a call to it
        return name
    if has_str(m.locals, name):                  # an enclosing param (a fn value): `f(v)` is an indirect call, NOT a package fn
        return name
    return m.prefix + name

# Mangle a comma-separated type list (tuple / Result element types), splitting on
# TOP-LEVEL commas only so nested `[..]`/`(..)`/`{..}` are left intact.
fn mangle_type_list(m: Mctx, s: string) -> string:
    out := ""
    part := ""
    depth := 0
    i := 0
    for i < len(s):
        ch := substr(s, i, i + 1)
        if ch == "(" or ch == "[" or ch == "{":
            depth = depth + 1
            part = part + ch
        elif ch == ")" or ch == "]" or ch == "}":
            depth = depth - 1
            part = part + ch
        elif ch == "," and depth == 0:
            if len(out) > 0:
                out = out + ","
            out = out + mangle_type(m, part)
            part = ""
        else:
            part = part + ch
        i = i + 1
    if len(out) > 0:
        out = out + ","
    return out + mangle_type(m, part)

fn mangle_type(m: Mctx, ty: string) -> string:
    if has_prefix(ty, "&"):
        return "&" + mangle_type(m, substr(ty, 1, len(ty)))
    if has_prefix(ty, "soa["):
        return "soa[" + mangle_type(m, substr(ty, 4, len(ty) - 1)) + "]"
    if has_prefix(ty, "["):
        return "[" + mangle_type(m, substr(ty, 1, len(ty) - 1)) + "]"
    if has_prefix(ty, "Option("):
        return "Option(" + mangle_type(m, substr(ty, 7, len(ty) - 1)) + ")"
    if has_prefix(ty, "Result("):
        return "Result(" + mangle_type_list(m, substr(ty, 7, len(ty) - 1)) + ")"
    if has_prefix(ty, "{"):
        return ty                  # map [str: int/float]: value is primitive, never a package type
    if has_prefix(ty, "("):
        return "(" + mangle_type_list(m, substr(ty, 1, len(ty) - 1)) + ")"
    if has_prefix(ty, "fn("):                  # fn(P...->R): mangle the param + ret types, keep the fn(...) shape (else it falls through to m.prefix+ty -> a broken type, breaking indirect-call typing in packages)
        inner := func_inner(ty)
        ar := func_arrow(inner)
        mp := ""
        if ar > 0:
            mp = mangle_type_list(m, substr(inner, 0, ar))
        return "fn(" + mp + "->" + mangle_type(m, substr(inner, ar + 2, len(inner))) + ")"
    if ty == "int" or ty == "float" or ty == "str" or ty == "void" or ty == "bool" or ty == "char":
        return ty                  # builtin scalar types are never package-qualified
    if find(ty, ".") >= 0:
        return mangle_dotted(m, ty)
    return m.prefix + ty

fn mangle_types(m: Mctx, tys: [string]) -> [string]:
    out := []string
    i := 0
    for i < len(tys):
        push(out, mangle_type(m, tys[i]))
        i = i + 1
    return out

fn mangle_args(m: Mctx, es: [Expr]) -> [Expr]:
    out := []Expr
    i := 0
    for i < len(es):
        push(out, mangle_expr(m, es[i]))
        i = i + 1
    return out

fn mangle_expr(m: Mctx, e: Expr) -> Expr:
    match e:
        EInt(s, _el):
            return EInt(s, _el)
        EBool(s, _el):
            return EBool(s, _el)
        EChar(s, _el):
            return EChar(s, _el)
        EFloat(s, _el):
            return EFloat(s, _el)
        EStr(s, _el):
            return EStr(s, _el)
        EVar(s, _el):
            if is_known_variant(m, m.prefix + s):   # a bare payload-less variant value in this package
                return EVar(m.prefix + s, _el)
            if has_str(m.locals, s) or s == "None":  # a local var / None: never package-qualified
                return EVar(s, _el)
            return EVar(m.prefix + s, _el)                # a bare same-package fn name used as a VALUE (e.g. `g := base`)
        EBin(op, l, r, _el):
            return EBin(op, mangle_expr(m, l), mangle_expr(m, r), _el)
        ECall(nm, a, _el):
            di := find(nm, ".")
            if di >= 0 and has_str(m.locals, substr(nm, 0, di)):   # `h.cb(args)` where h is a LOCAL var (not a package): call through a fn-typed struct field
                return ECallV(EField(EVar(substr(nm, 0, di), _el), substr(nm, di + 1, len(nm)), _el), mangle_args(m, a), _el)
            return ECall(mangle_ref(m, nm), mangle_args(m, a), _el)
        EField(b, f, _el):
            bn := evar_name(b)
            # `pkg.Variant` (no parens) parses as a field access; if `pkg` is an
            # imported package and `pkg.Variant` names a real variant, it is a
            # qualified payload-less variant VALUE, not a struct field read.
            if bn != "" and is_pkg_ref(m, bn) and is_known_variant(m, resolve_pkg(m, bn) + "__" + f):
                return EVar(resolve_pkg(m, bn) + "__" + f, _el)
            return EField(mangle_expr(m, b), f, _el)
        EIndex(b, ix, _el):
            return EIndex(mangle_expr(m, b), mangle_expr(m, ix), _el)
        EArrLit(es, _el):
            return EArrLit(mangle_args(m, es), _el)
        EArrEmpty(ty, _el):
            return EArrEmpty(mangle_type(m, ty), _el)
        EMapEmpty(k, v, _el):
            return EMapEmpty(k, v, _el)
        EMapLit(ks, vs, _el):
            return EMapLit(mangle_args(m, ks), mangle_args(m, vs), _el)
        ETuple(es, _el):
            return ETuple(mangle_args(m, es), _el)
        ESlice(b, lo, hi, _el):
            return ESlice(mangle_expr(m, b), mangle_expr(m, lo), mangle_expr(m, hi), _el)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return ELambda(id, ps, mangle_types(m, pts), mangle_type(m, ret), mangle_expr(m, body), cn, ct, _el)
        ECallV(callee, cargs, _el):
            return ECallV(mangle_expr(m, callee), mangle_args(m, cargs), _el)
        EAddr(x, _el):
            return EAddr(mangle_expr(m, x), _el)
        ESpawn(id, nm, a, _el):
            return ESpawn(id, mangle_ref(m, nm), mangle_args(m, a), _el)

fn mctx_add(m: Mctx, name: string) -> Mctx:       # extend the local-name set (a new binding shadows a package name)
    nl := []string
    i := 0
    for i < len(m.locals):
        push(nl, m.locals[i])
        i = i + 1
    push(nl, name)
    return Mctx(m.prefix, m.aliasn, m.aliasp, m.pkgs, m.variants, nl, m.externs)

fn mctx_bind(m: Mctx, s: Stmt) -> Mctx:           # the block-level binding(s) a statement introduces (visible to later siblings)
    match s:
        SDecl(n, e, _sl):
            return mctx_add(m, n)
        STypedDecl(n, ty, e, _sl):
            return mctx_add(m, n)
        SOrReturn(n, e, _sl):
            return mctx_add(m, n)
        SDestructure(ns, e, _sl):
            mm := m
            i := 0
            for i < len(ns):
                mm = mctx_add(mm, ns[i])
                i = i + 1
            return mm
        SMultiAssign(ns, e, _sl):
            return m
        SAssign(n, e, _sl):
            return m
        SFieldAssign(lv, r, _sl):
            return m
        SPrint(e, _sl):
            return m
        SReturn(e, _sl):
            return m
        SReturnVoid:
            return m
        SBreak:
            return m
        SContinue:
            return m
        SIf(c, t, el, _sl):
            return m
        SWhile(c, b, _sl):
            return m
        SForRange(v, a, b, st, body, _sl):
            return m
        SExpr(e, _sl):
            return m
        SMatch(subj, vars, binds, bodies, _sl):
            return m
        SParFor(v, a, b, body, pid, _sl):
            return m
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            return m

fn mangle_block(m: Mctx, ss: [Stmt]) -> [Stmt]:
    out := []Stmt
    mm := m                                       # thread locals: a decl is in scope for the statements after it
    i := 0
    for i < len(ss):
        push(out, mangle_stmt(mm, ss[i]))
        mm = mctx_bind(mm, ss[i])
        i = i + 1
    return out

fn mangle_arm(m: Mctx, v: string) -> string:
    if find(v, ".") >= 0:
        return mangle_dotted(m, v)
    if v == "Some" or v == "None" or v == "Ok" or v == "Err":
        return v
    return m.prefix + v

fn mangle_variants(m: Mctx, vs: [string]) -> [string]:
    out := []string
    i := 0
    for i < len(vs):
        push(out, mangle_arm(m, vs[i]))
        i = i + 1
    return out

fn mangle_bodies(m: Mctx, bs: [[Stmt]]) -> [[Stmt]]:
    out := [][Stmt]
    i := 0
    for i < len(bs):
        push(out, mangle_block(m, bs[i]))
        i = i + 1
    return out

fn mangle_stmt(m: Mctx, s: Stmt) -> Stmt:
    match s:
        SDecl(n, e, _sl):
            return SDecl(n, mangle_expr(m, e), _sl)
        SAssign(n, e, _sl):
            return SAssign(n, mangle_expr(m, e), _sl)
        SFieldAssign(lv, r, _sl):
            return SFieldAssign(mangle_expr(m, lv), mangle_expr(m, r), _sl)
        SPrint(e, _sl):
            return SPrint(mangle_expr(m, e), _sl)
        SReturn(e, _sl):
            return SReturn(mangle_expr(m, e), _sl)
        SReturnVoid:
            return SReturnVoid
        SBreak:
            return SBreak
        SContinue:
            return SContinue
        SIf(c, t, el, _sl):
            return SIf(mangle_expr(m, c), mangle_block(m, t), mangle_block(m, el), _sl)
        SWhile(c, b, _sl):
            return SWhile(mangle_expr(m, c), mangle_block(m, b), _sl)
        SForRange(v, a, b, st, body, _sl):
            return SForRange(v, mangle_expr(m, a), mangle_expr(m, b), mangle_expr(m, st), mangle_block(mctx_add(m, v), body), _sl)
        SExpr(e, _sl):
            return SExpr(mangle_expr(m, e), _sl)
        STypedDecl(n, ty, e, _sl):
            return STypedDecl(n, mangle_type(m, ty), mangle_expr(m, e), _sl)
        SOrReturn(n, e, _sl):
            return SOrReturn(n, mangle_expr(m, e), _sl)
        SDestructure(ns, e, _sl):
            return SDestructure(ns, mangle_expr(m, e), _sl)
        SMultiAssign(ns, e, _sl):
            return SMultiAssign(ns, mangle_expr(m, e), _sl)
        SMatch(subj, vars, binds, bodies, _sl):
            nb := [][Stmt]                            # each arm's payload binds are locals in that arm's body
            k := 0
            for k < len(bodies):
                mm := m
                bi := 0
                for bi < len(binds[k]):
                    mm = mctx_add(mm, binds[k][bi])
                    bi = bi + 1
                push(nb, mangle_block(mm, bodies[k]))
                k = k + 1
            return SMatch(mangle_expr(m, subj), mangle_variants(m, vars), binds, nb, _sl)
        SParFor(v, a, b, body, pid, _sl):
            return SParFor(v, mangle_expr(m, a), mangle_expr(m, b), mangle_block(mctx_add(m, v), body), pid, _sl)
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            nch := mangle_args(m, schans)
            nb := [][Stmt]
            sk := 0
            for sk < len(sbodies):
                mm := m
                if svars[sk] == "recv":
                    mm = mctx_add(mm, sbinds[sk])
                push(nb, mangle_block(mm, sbodies[sk]))
                sk = sk + 1
            return SSelect(uid, svars, nch, sbinds, nb, _sl)

fn mangle_func(m: Mctx, f: Func) -> Func:
    mb := Mctx(m.prefix, m.aliasn, m.aliasp, m.pkgs, m.variants, f.params, m.externs)   # body sees the params as locals (indirect calls stay unprefixed)
    nm := m.prefix + f.name
    if f.is_extern == 1:                      # FFI: a C symbol is global — never package-mangle it
        nm = f.name
    return Func(nm, f.params, mangle_types(m, f.ptypes), mangle_type(m, f.ret), mangle_block(mb, f.body), f.is_extern, f.lib)

fn mangle_struct(m: Mctx, sd: StructDef) -> StructDef:
    fs := []Field
    i := 0
    for i < len(sd.fields):
        push(fs, Field(sd.fields[i].name, mangle_type(m, sd.fields[i].ty)))
        i = i + 1
    return StructDef(m.prefix + sd.name, fs)

fn mangle_enum(m: Mctx, ed: EnumDef) -> EnumDef:
    vs := []Variant
    i := 0
    for i < len(ed.variants):
        push(vs, Variant(m.prefix + ed.variants[i].name, mangle_types(m, ed.variants[i].ptypes)))
        i = i + 1
    return EnumDef(m.prefix + ed.name, vs)

fn path_last(path: string) -> string:                  # "math/geom" -> "geom"
    out := path
    j := 0
    for j < len(path):
        if substr(path, j, j + 1) == "/":
            out = substr(path, j + 1, len(path))
        j = j + 1
    return out

fn parse_program(toks: [Token], pos: inout int) -> Program:
    # Pass 1: parse every def, recording its package prefix, and collect the
    # package / alias / variant tables. Two passes are needed because a qualified
    # or bare reference may name a package, alias, or variant declared later in
    # the stream (mangling can't run until all of them are known).
    rstructs := []StructDef
    spfx := []string
    renums := []EnumDef
    epfx := []string
    rfuncs := []Func
    fpfx := []string
    rntn := []string
    rntu := []string
    npfx := []string
    pkgs := []string
    aliasn := []string
    aliasp := []string
    variants := []string
    externs := []string                          # FFI extern fn names (global C symbols, never mangled)
    curpfx := ""
    sawpkg := false
    for toks[pos].kind != TEof:
        if toks[pos].kind == TNewline:
            pos = pos + 1
        elif toks[pos].kind == TIdent and toks[pos].text == "package":
            pos = pos + 1
            pname := toks[pos].text
            pos = pos + 1
            sawpkg = true
            if pname == "main":
                curpfx = ""
            else:
                curpfx = pname + "__"
                push(pkgs, pname)
            for toks[pos].kind != TNewline and toks[pos].kind != TEof:
                pos = pos + 1
        elif toks[pos].kind == TIdent and toks[pos].text == "import":
            pos = pos + 1
            alias := ""
            if toks[pos].kind == TIdent:           # `import alias "path"`
                alias = toks[pos].text
                pos = pos + 1
            if toks[pos].kind == TStr:
                pkn := path_last(toks[pos].text)
                pos = pos + 1
                if alias != "":
                    push(aliasn, alias)
                    push(aliasp, pkn)
                    push(pkgs, alias)
                push(pkgs, pkn)
            for toks[pos].kind != TNewline and toks[pos].kind != TEof:
                pos = pos + 1
        elif toks[pos].kind == TIdent and toks[pos].text == "struct":
            push(rstructs, parse_struct(toks, &pos))
            push(spfx, curpfx)
        elif toks[pos].kind == TIdent and toks[pos].text == "enum":
            ed := parse_enum(toks, &pos)
            push(renums, ed)
            push(epfx, curpfx)
            vi := 0
            for vi < len(ed.variants):             # remember every variant's mangled name
                push(variants, curpfx + ed.variants[vi].name)
                vi = vi + 1
        elif toks[pos].kind == TIdent and toks[pos].text == "type":
            nt := parse_newtype(toks, &pos)
            push(rntn, nt.name)
            push(rntu, nt.ty)
            push(npfx, curpfx)
        elif toks[pos].kind == TIdent and toks[pos].text == "extern":   # FFI: extern fn (bodyless C decl)
            ef := parse_extern_func(toks, &pos)
            push(rfuncs, ef)
            push(fpfx, curpfx)
            push(externs, ef.name)                                      # global C symbol — bare calls to it stay unmangled
        else:
            push(rfuncs, parse_func(toks, &pos))
            push(fpfx, curpfx)
    # Pass 2: mangle, but only if the stream actually declared packages — so a
    # plain single-file program is returned untouched (byte-identical).
    structs := []StructDef
    enums := []EnumDef
    funcs := []Func
    ntnames := []string
    ntunder := []string
    si := 0
    for si < len(rstructs):
        if sawpkg:
            push(structs, mangle_struct(Mctx(spfx[si], aliasn, aliasp, pkgs, variants, []string, externs), rstructs[si]))
        else:
            push(structs, rstructs[si])
        si = si + 1
    ei := 0
    for ei < len(renums):
        if sawpkg:
            push(enums, mangle_enum(Mctx(epfx[ei], aliasn, aliasp, pkgs, variants, []string, externs), renums[ei]))
        else:
            push(enums, renums[ei])
        ei = ei + 1
    fi := 0
    for fi < len(rfuncs):
        if sawpkg:
            push(funcs, mangle_func(Mctx(fpfx[fi], aliasn, aliasp, pkgs, variants, []string, externs), rfuncs[fi]))
        else:
            push(funcs, rfuncs[fi])
        fi = fi + 1
    ni := 0
    for ni < len(rntn):
        if sawpkg:
            push(ntnames, npfx[ni] + rntn[ni])
            push(ntunder, mangle_type(Mctx(npfx[ni], aliasn, aliasp, pkgs, variants, []string, externs), rntu[ni]))
        else:
            push(ntnames, rntn[ni])
            push(ntunder, rntu[ni])
        ni = ni + 1
    return Program(structs, enums, funcs, ntnames, ntunder)

# -------------------------------------------------------------- codegen ----
# Type-directed: each expression's C form follows its inferred type. A type is
# "int" (-> long), "str" (-> char*), or a struct name (-> that typedef). The
# mutable per-block var env is the names/types arrays; function return types
# and struct layouts come from the read-only `ctx`.

fn is_enum(dc: Decls, ctx: Ctx, name: string) -> bool:
    i := 0
    for i < len(dc.enums):
        if dc.enums[i].name == name:
            return true
        i = i + 1
    return false

# Build the variant-name -> enum-index map once (called at Decls construction).
# Variant names are globally unique (check_dups rejects duplicates), so a flat
# map is exact -- last-write equals the old scan's first-match.
fn build_vmap(enums: [EnumDef]) -> [string: int]:
    m : [string: int] = []
    i := 0
    for i < len(enums):
        j := 0
        for j < len(enums[i].variants):
            m = map_set(m, enums[i].variants[j].name, i)
            j = j + 1
        i = i + 1
    return m

fn is_variant(dc: Decls, ctx: Ctx, name: string) -> bool:
    return map_get(dc.vmap, name, -1) >= 0

fn variant_enum(dc: Decls, ctx: Ctx, vname: string) -> string:
    i := map_get(dc.vmap, vname, -1)
    if i < 0:
        die("type: unknown variant")
    return dc.enums[i].name

fn variant_tag(dc: Decls, ctx: Ctx, vname: string) -> int:
    i := 0
    for i < len(dc.enums):
        j := 0
        for j < len(dc.enums[i].variants):
            if dc.enums[i].variants[j].name == vname:
                return j
            j = j + 1
        i = i + 1
    die("type: unknown variant")
    return 0

fn variant_ptypes(dc: Decls, ctx: Ctx, vname: string) -> [string]:
    i := 0
    for i < len(dc.enums):
        j := 0
        for j < len(dc.enums[i].variants):
            if dc.enums[i].variants[j].name == vname:
                return dc.enums[i].variants[j].ptypes
            j = j + 1
        i = i + 1
    die("type: unknown variant")
    return []string

# An inout parameter's type is marked with a leading '&'. The base type drives
# all type logic; the marker only affects C codegen (pointer + deref).
fn is_inout(ty: string) -> bool:
    return len(ty) > 0 and ty[0] == 38

fn base_ty(ty: string) -> string:
    if is_inout(ty):
        return substr(ty, 1, len(ty))
    return ty

fn is_array(ty: string) -> bool:
    return len(ty) > 0 and ty[0] == 91           # "[T]"

fn elem_ty(ty: string) -> string:               # "[T]" -> "T"
    return substr(ty, 1, len(ty) - 1)

# SOA arrays: `soa [Struct]` is encoded "soa[Struct]" (one growable buffer per
# struct field + a shared len/cap, instead of an array of records).
fn is_soa(ty: string) -> bool:
    return len(ty) > 4 and substr(ty, 0, 4) == "soa["
fn soa_struct(ty: string) -> string:            # "soa[Struct]" -> "Struct"
    return substr(ty, 4, len(ty) - 1)

fn is_map(ty: string) -> bool:
    return len(ty) > 0 and ty[0] == 123          # "{str:V}"  (V = int or float)

fn map_val(ty: string) -> string:               # "{K:V}" -> "V"
    inner := substr(ty, 1, len(ty) - 1)
    i := 0
    for i < len(inner):
        if inner[i] == 58:                       # first ':'
            return substr(inner, i + 1, len(inner))
        i = i + 1
    return "int"

fn map_key(ty: string) -> string:               # "{K:V}" -> "K"
    inner := substr(ty, 1, len(ty) - 1)
    i := 0
    for i < len(inner):
        if inner[i] == 58:                       # first ':'
            return substr(inner, 0, i)
        i = i + 1
    return "str"

fn mstruct(ty: string) -> string:                # map C struct name
    return "Map_" + map_key(ty) + "_" + mangle(map_val(ty))

fn mfam(ty: string) -> string:                   # map runtime function prefix
    return "map_" + map_key(ty) + "_" + mangle(map_val(ty))

fn mtag(k: string) -> string:                    # slotptr family tag: 1-char for the base keys,
    if k == "int" or k == "str":                 # the full (distinct) name for a newtype key
        return substr(k, 0, 1)                   # (1-char tags would collide across newtypes)
    return k

fn is_cmp(op: string) -> bool:
    return op == "==" or op == "!=" or op == "<" or op == ">" or op == "<=" or op == ">="

# Option(T)/Result(T,E) types are stored as their normalized source string.
fn has_prefix(s: string, p: string) -> bool:
    if len(s) < len(p):
        return false
    return substr(s, 0, len(p)) == p

fn is_task(ty: string) -> bool:                   # Task(T): the handle from `spawn f(args)` (CC-1)
    return has_prefix(ty, "Task(")
fn task_inner(ty: string) -> string:              # "Task(T)" -> "T"
    return substr(ty, 5, len(ty) - 1)
fn is_chan(ty: string) -> bool:                   # Channel(T): the bounded queue handle (CC-4)
    return has_prefix(ty, "Channel(")
fn chan_inner(ty: string) -> string:              # "Channel(T)" -> "T"
    return substr(ty, 8, len(ty) - 1)
fn is_conc_method(nm: string) -> bool:            # the task/channel "methods" outside the Sig table
    return nm == "wait" or nm == "send" or nm == "recv" or nm == "close"

fn is_option(ty: string) -> bool:
    return has_prefix(ty, "Option(")

fn is_result(ty: string) -> bool:
    return has_prefix(ty, "Result(")

fn option_inner(ty: string) -> string:            # "Option(T)" -> "T"
    return substr(ty, 7, len(ty) - 1)

# index of the top-level comma in a Result inner "T,E" (depth-aware over ()[])
fn top_comma(s: string) -> int:
    depth := 0
    i := 0
    for i < len(s):
        c := s[i]
        if c == 40 or c == 91:
            depth = depth + 1
        elif c == 41 or c == 93:
            depth = depth - 1
        elif c == 44 and depth == 0:
            return i
        i = i + 1
    return -1

fn result_ok(ty: string) -> string:               # "Result(T,E)" -> "T"
    inner := substr(ty, 7, len(ty) - 1)
    return substr(inner, 0, top_comma(inner))

fn result_err(ty: string) -> string:               # "Result(T,E)" -> "E"
    inner := substr(ty, 7, len(ty) - 1)
    return substr(inner, top_comma(inner) + 1, len(inner))

fn is_tuple(ty: string) -> bool:
    return len(ty) > 0 and ty[0] == 40           # "(T,U,...)"

fn tuple_parts(ty: string) -> [string]:          # depth-aware split of the inner types
    inner := substr(ty, 1, len(ty) - 1)
    parts := []string
    depth := 0
    start := 0
    i := 0
    for i < len(inner):
        c := inner[i]
        if c == 40 or c == 91 or c == 123:
            depth = depth + 1
        elif c == 41 or c == 93 or c == 125:
            depth = depth - 1
        elif c == 44 and depth == 0:
            push(parts, substr(inner, start, i))
            start = i + 1
        i = i + 1
    push(parts, substr(inner, start, len(inner)))
    return parts

fn tup_suffix(ty: string) -> string:             # parts mangled, joined by "_"
    parts := tuple_parts(ty)
    out := ""
    i := 0
    for i < len(parts):
        if i > 0:
            out = out + "_"
        out = out + mangle(parts[i])
        i = i + 1
    return out

# First-class function values: a `fn(P...) -> R` type is the string
# "fn(p1,p2->ret)" (ret always present, "void" if none). A value is a C function
# pointer to a top-level function (no capture). Encoded/parsed depth-aware so a
# function-type param can itself be a function/tuple/array type.
fn is_func(ty: string) -> bool:
    return len(ty) >= 3 and ty[0] == 102 and ty[1] == 110 and ty[2] == 40   # "fn("

fn func_inner(ty: string) -> string:             # the body between `fn(` and the final `)`
    return substr(ty, 3, len(ty) - 1)

fn func_arrow(inner: string) -> int:             # offset of the top-level "->" (params|ret split)
    depth := 0
    i := 0
    for i < len(inner):
        c := inner[i]
        if c == 40 or c == 91 or c == 123:
            depth = depth + 1
        elif c == 41 or c == 93 or c == 125:
            depth = depth - 1
        elif depth == 0 and c == 45 and i + 1 < len(inner) and inner[i + 1] == 62:
            return i
        i = i + 1
    return -1

fn func_params(ty: string) -> [string]:
    inner := func_inner(ty)
    pstr := substr(inner, 0, func_arrow(inner))
    parts := []string
    if len(pstr) == 0:
        return parts
    depth := 0
    start := 0
    i := 0
    for i < len(pstr):
        c := pstr[i]
        if c == 40 or c == 91 or c == 123:
            depth = depth + 1
        elif c == 41 or c == 93 or c == 125:
            depth = depth - 1
        elif c == 44 and depth == 0:
            push(parts, substr(pstr, start, i))
            start = i + 1
        i = i + 1
    push(parts, substr(pstr, start, len(pstr)))
    return parts

fn func_ret(ty: string) -> string:
    inner := func_inner(ty)
    return substr(inner, func_arrow(inner) + 2, len(inner))

fn func_suffix(ty: string) -> string:            # a C identifier for the signature
    out := "fn"
    ps := func_params(ty)
    i := 0
    for i < len(ps):
        out = out + "_" + mangle(ps[i])
        i = i + 1
    return out + "_ret_" + mangle(func_ret(ty))

# A valid C identifier suffix for an element type, so composite element types
# (nested arrays, Option/Result/tuple elements) get legal `Arr_<mangle>` names.
fn mangle(ty: string) -> string:
    if is_array(ty):
        return "arr_" + mangle(elem_ty(ty))
    if is_option(ty):
        return "opt_" + mangle(option_inner(ty))
    if is_result(ty):
        return "res_" + mangle(result_ok(ty)) + "_" + mangle(result_err(ty))
    if is_tuple(ty):
        return "tup_" + tup_suffix(ty)
    if is_map(ty):
        return "map_" + map_key(ty) + "_" + map_val(ty)
    if is_soa(ty):
        return "soa_" + soa_struct(ty)
    if is_func(ty):
        return func_suffix(ty)                   # fn(int->int) -> fn_int_ret_int
    return ty                                    # int/str/float/struct/enum/newtype: already valid

# Newtypes (`type X = U`) are zero-cost: distinct only for type checking (which
# the C compiler already did), so codegen resolves them to the underlying type.
fn is_newtype(dc: Decls, ctx: Ctx, name: string) -> bool:
    i := 0
    for i < len(dc.ntnames):
        if dc.ntnames[i] == name:
            return true
        i = i + 1
    return false

fn resolve_nt(dc: Decls, ctx: Ctx, ty: string) -> string:
    i := 0
    for i < len(dc.ntnames):
        if dc.ntnames[i] == ty:
            return resolve_nt(dc, ctx, dc.ntunder[i])
        i = i + 1
    return ty

# Every variant nullary: usable as a map key (the tag IS the value; the cells
# are immortal per-variant singletons). A payload enum is rejected by hierc.
fn enum_fieldless(dc: Decls, ctx: Ctx, ty: string) -> bool:
    i := 0
    for i < len(dc.enums):
        if dc.enums[i].name == ty:
            j := 0
            for j < len(dc.enums[i].variants):
                if len(dc.enums[i].variants[j].ptypes) > 0:
                    return false
                j = j + 1
            return true
        i = i + 1
    return false

fn krt(dc: Decls, ctx: Ctx, mt: string, ke: string) -> string:   # a map key as the runtime
    if enum_fieldless(dc, ctx, map_key(mt)):     # stores it: an enum key passes its TAG
        return "((" + ke + ")->tag)"
    return ke

fn cty(dc: Decls, ctx: Ctx, ty: string) -> string:
    if is_newtype(dc, ctx, ty):
        return cty(dc, ctx, resolve_nt(dc, ctx, ty))
    if is_inout(ty):                              # inout T -> pointer to T's C type
        inner := cty(dc, ctx, base_ty(ty))           # ends with a space
        return substr(inner, 0, len(inner) - 1) + "* "
    if ty == "int":
        return "long "
    if ty == "bool":                             # bool carried as a long 0/1
        return "long "
    if ty == "char":                             # one byte carried as a long
        return "long "
    if ty == "float":
        return "double "
    if ty == "str":
        return "char* "
    if ty == "ptr":                              # FFI opaque handle
        return "void* "
    if is_task(ty):                              # opaque runtime task handle (spawn/wait, CC-1)
        return "HTask* "
    if is_chan(ty):                              # shared bounded-queue handle (channels, CC-4)
        return "HChan* "
    if is_array(ty):                              # [T] -> the monomorphized Arr_T
        return "Arr_" + mangle(elem_ty(ty)) + " "
    if is_map(ty):                                # {str:V} -> Map_str_V
        return mstruct(ty) + " "
    if is_option(ty):
        return "HOption "
    if is_result(ty):
        return "HResult "
    if is_tuple(ty):
        return "Tup_" + tup_suffix(ty) + " "
    if is_soa(ty):                                # soa [Struct] -> Soa_Struct
        return "Soa_" + soa_struct(ty) + " "
    if is_func(ty):                               # fn(P...) -> R : a function-pointer typedef
        return "Fn_" + func_suffix(ty) + " "
    if is_enum(dc, ctx, ty):                          # enum value -> pointer to node
        return uet(ty) + "* "
    if ty == "void":
        return "void "
    if is_struct(dc, ctx, ty):                        # struct type: its own typedef
        return ust(ty) + " "
    die_at(dc, ctx.line, "type: unknown type '" + ty + "'")   # fail-closed: an unknown bare name would emit a dangling S_<name>
    return ust(ty) + " "

fn var_type(names: [string], types: [string], name: string) -> string:
    i := len(names) - 1                          # newest-first (shadowing)
    for i >= 0:
        if names[i] == name:
            return types[i]
        i = i - 1
    die("type: unknown variable '" + name + "'")
    return "int"

fn is_struct(dc: Decls, ctx: Ctx, name: string) -> bool:
    i := 0
    for i < len(dc.structs):
        if dc.structs[i].name == name:
            return true
        i = i + 1
    return false

fn field_type(dc: Decls, ctx: Ctx, sname: string, fld: string) -> string:
    i := 0
    for i < len(dc.structs):
        if dc.structs[i].name == sname:
            j := 0
            for j < len(dc.structs[i].fields):
                if dc.structs[i].fields[j].name == fld:
                    return dc.structs[i].fields[j].ty
                j = j + 1
            die_at(dc, ctx.line, "type: no such field '" + fld + "' on struct '" + sname + "'")
        i = i + 1
    die_at(dc, ctx.line, "type: '" + sname + "' is not a struct (field ." + fld + ")")
    return "int"

# A struct is "heap-bearing" if any field owns heap memory (a string, an array,
# or a nested heap-bearing struct) and so needs a deep copy on value binding.
# Enum fields are immutable pointers — shared sharing is observationally safe.
fn struct_is_heap(dc: Decls, ctx: Ctx, sname: string) -> bool:
    i := 0
    for i < len(dc.structs):
        if dc.structs[i].name == sname:
            j := 0
            for j < len(dc.structs[i].fields):
                ft := dc.structs[i].fields[j].ty
                if ft == "str":
                    return true
                if is_array(ft):
                    return true
                if is_soa(ft):                   # a soa field owns heap buffers
                    return true
                if is_map(ft):                   # a map field owns its table (keys now arena-allocated)
                    return true
                if is_struct(dc, ctx, ft) and struct_is_heap(dc, ctx, ft):
                    return true
                j = j + 1
            return false
        i = i + 1
    return false

fn sig_ret(dc: Decls, ctx: Ctx, name: string) -> string:
    if name == "str":
        return "str"
    if name == "substr":
        return "str"
    if name == "chr":
        return "str"
    if name == "input":
        return "str"
    if name == "split":
        return "[str]"
    if name == "keys":
        return "[str]"
    if name == "map_get":
        return "int"
    if name == "map_has":
        return "bool"
    if name == "find":
        return "int"
    if name == "sqrt" or name == "pow" or name == "floor" or name == "fabs":
        return "float"
    if name == "to_float":
        return "float"
    if name == "to_int":
        return "int"
    if name == "to_str":                          # unwrap a string newtype
        return "str"
    if name == "to_bool":                         # unwrap a bool newtype
        return "bool"
    if name == "read_all":
        return "str"
    if name == "read_file":
        return "str"
    if name == "write_file":                      # (path, contents) -> bool
        return "bool"
    if name == "list_dir":
        return "[str]"
    if name == "args":
        return "[str]"
    if name == "getenv":                          # env var value, or "" if unset
        return "str"
    if name == "null":                            # FFI opaque ptr literal
        return "ptr"
    if name == "is_null":                         # FFI: opaque-handle NULL test
        return "bool"
    if name == "die":
        return "int"
    if name == "eprint":
        return "int"
    if name == "len":
        return "int"
    if name == "input":
        return "str"
    if is_newtype(dc, ctx, name):                     # X(v) constructor -> the newtype
        return name
    if is_variant(dc, ctx, name):                     # enum construction yields its enum
        return variant_enum(dc, ctx, name)
    if is_struct(dc, ctx, name):                      # construction yields the struct
        return name
    si := map_get(dc.sigmap, name, -1)                # O(1) user-function lookup (was a linear scan)
    if si >= 0:
        return dc.sigs[si].ret
    die_at(dc, ctx.line, "type: unknown function '" + name + "'")
    return "int"

# The function-value type "fn(p1,p2->ret)" for a top-level function name, or ""
# if `name` is not a user function (so a bare name can be typed as a value).
fn sig_ptypes(dc: Decls, name: string) -> [string]:   # the named fn's param types (spawn-site copy-in, CC-1)
    si := map_get(dc.sigmap, name, -1)
    if si < 0:
        die("type: unknown function '" + name + "' in spawn")
    return dc.sigs[si].ptypes

fn sig_functype(dc: Decls, name: string) -> string:
    si := map_get(dc.sigmap, name, -1)
    if si < 0:
        return ""
    s := dc.sigs[si]
    out := "fn("
    i := 0
    for i < len(s.ptypes):
        if i > 0:
            out = out + ","
        out = out + s.ptypes[i]
        i = i + 1
    return out + "->" + s.ret + ")"

# UFCS methods: x.foo(args) / expr.foo(args) lowers (via the mangler / postfix
# parse) to a call-on-expression with an EField callee. At codegen, if the field
# name isn't a fn-typed struct field but IS a free fn whose first parameter has
# the receiver's type, it's a method call -> foo(recv, args). Static dispatch;
# mirrors hierc. (Bare field name resolves against package main; a same-package
# method would need its prefix threaded — deferred, like hierc's scope.)
fn efield_fname(e: Expr) -> string:               # field name if e is EField, else ""
    match e:
        EField(b, f, _el):
            return f
        EInt(s, _el):
            return ""
        EBool(s, _el):
            return ""
        EChar(s, _el):
            return ""
        EFloat(s, _el):
            return ""
        EStr(s, _el):
            return ""
        EVar(s, _el):
            return ""
        EBin(o, l, r, _el):
            return ""
        ECall(nm, a, _el):
            return ""
        EIndex(b, ix, _el):
            return ""
        EArrLit(es, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        EMapLit(ks, vs, _el):
            return ""
        ETuple(es, _el):
            return ""
        ESlice(b, lo, hi, _el):
            return ""
        EAddr(x, _el):
            return ""
        ELambda(id, ps, pts, r, bx, cn, ct, _el):
            return ""
        ECallV(c, a, _el):
            return ""
        ESpawn(id, nm, a, _el):
            return ""

fn efield_base(e: Expr) -> Expr:                  # base of an EField (caller guards via efield_fname)
    match e:
        EField(b, f, _el):
            return b
        EInt(s, _el):
            return e
        EBool(s, _el):
            return e
        EChar(s, _el):
            return e
        EFloat(s, _el):
            return e
        EStr(s, _el):
            return e
        EVar(s, _el):
            return e
        EBin(o, l, r, _el):
            return e
        ECall(nm, a, _el):
            return e
        EIndex(b, ix, _el):
            return e
        EArrLit(es, _el):
            return e
        EArrEmpty(t, _el):
            return e
        EMapEmpty(k, v, _el):
            return e
        EMapLit(ks, vs, _el):
            return e
        ETuple(es, _el):
            return e
        ESlice(b, lo, hi, _el):
            return e
        EAddr(x, _el):
            return e
        ELambda(id, ps, pts, r, bx, cn, ct, _el):
            return e
        ECallV(c, a, _el):
            return e
        ESpawn(id, nm, a, _el):
            return e

fn struct_fn_field(dc: Decls, sname: string, fname: string) -> bool:   # sname has a fn-typed field fname?
    i := 0
    for i < len(dc.structs):
        if dc.structs[i].name == sname:
            j := 0
            for j < len(dc.structs[i].fields):
                if dc.structs[i].fields[j].name == fname and is_func(dc.structs[i].fields[j].ty):
                    return true
                j = j + 1
            return false
        i = i + 1
    return false

# Method name (matches un()) if `callee` is a UFCS method call, else "".
fn ufcs_name(dc: Decls, ctx: Ctx, names: [string], types: [string], callee: Expr) -> string:
    fname := efield_fname(callee)
    if fname == "":
        return ""
    if is_builtin_call(fname):
        return ""
    bt := type_of(efield_base(callee), names, types, dc, ctx)
    if struct_fn_field(dc, bt, fname):            # a real fn-typed field wins (call-through-field)
        return ""
    si := map_get(dc.sigmap, fname, -1)
    if si >= 0 and len(dc.sigs[si].ptypes) >= 1 and dc.sigs[si].ptypes[0] == bt:
        return fname
    us := find(bt, "__")                          # method in the receiver type's package: geom__Circle -> geom__area
    if us >= 0:
        qn := substr(bt, 0, us + 2) + fname
        sj := map_get(dc.sigmap, qn, -1)
        if sj >= 0 and len(dc.sigs[sj].ptypes) >= 1 and dc.sigs[sj].ptypes[0] == bt:
            return qn
    return ""

fn type_of(e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    match e:
        EInt(t, _el):
            return "int"
        EBool(t, _el):
            return "bool"
        EChar(t, _el):
            return "char"
        EFloat(f, _el):
            return "float"
        EStr(s, _el):
            return "str"
        EVar(name, _el):
            if name == "None":
                return "Option()"
            if is_variant(dc, ctx, name):            # bare no-payload variant (e.g. Green)
                return variant_enum(dc, ctx, name)
            if not has_str(names, name):             # not a local: a bare top-level fn name as a value
                ft := sig_functype(dc, name)
                if ft != "":
                    return ft
                die_at(dc, _el, "type: unknown variable '" + name + "'")
            vt := base_ty(var_type(names, types, name))
            return resolve_nt(dc, ctx, vt)
        EField(base, fld, _el):
            bt := type_of(base, names, types, dc, ctx)
            if is_tuple(bt):                      # tuple index t.0 -> the i-th part type
                # parse the FULL index and range-check it (fail closed): the old
                # fld[0]-48 read one digit, silently accepting t.10 as part 1
                # (hierc: "tuple index %ld out of range", src/hierc.c:2259)
                parts := tuple_parts(bt)
                tidx := 0
                tk := 0
                for tk < len(fld):
                    if fld[tk] < 48 or fld[tk] > 57:
                        die("type: tuple index ." + fld + " is not a number")
                    tidx = tidx * 10 + (fld[tk] - 48)
                    tk = tk + 1
                if tidx >= len(parts):
                    die("type: tuple index ." + fld + " out of range (the tuple has " + str(len(parts)) + " elements)")
                return parts[tidx]
            return resolve_nt(dc, ctx, field_type(dc, with_line(ctx, _el), bt, fld))
        EIndex(base, idx, _el):
            bt := type_of(base, names, types, dc, ctx)
            if bt == "str":
                return "int"                      # s[i] is the byte value (ord)
            if is_soa(bt):
                return soa_struct(bt)             # soa element -> the struct
            if is_map(bt):                        # m[k] place -> the value type (#2)
                return map_val(bt)
            return substr(bt, 1, len(bt) - 1)     # else array element type
        EArrLit(elems, _el):
            return "[" + type_of(elems[0], names, types, dc, ctx) + "]"
        EArrEmpty(ety, _el):
            if ety == "":                         # bare []: ground_pre had no destination type for it
                die("type: cannot type a bare [] here -- no expected type (write []T, or use it where the element type is known)")
            if is_soa(ety):                       # `soa []Struct` carries the full soa type
                return ety
            return "[" + ety + "]"
        EMapEmpty(kty, vty, _el):
            return "{" + kty + ":" + vty + "}"
        EMapLit(keys, vals, _el):
            return "{" + type_of(keys[0], names, types, dc, ctx) + ":" + type_of(vals[0], names, types, dc, ctx) + "}"
        ETuple(elems, _el):
            out := "("
            j := 0
            for j < len(elems):
                if j > 0:
                    out = out + ","
                out = out + type_of(elems[j], names, types, dc, ctx)
                j = j + 1
            return out + ")"
        ESlice(base, lo, hi, _el):
            return type_of(base, names, types, dc, ctx)   # same array type
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return mk_functype(pts, ret)
        ECallV(callee, cargs, _el):
            cfn := efield_fname(callee)           # t.wait() / ch.send(v) ...: a task/chan "method" (CC)
            if is_conc_method(cfn):
                cbt := type_of(efield_base(callee), names, types, dc, ctx)
                if is_task(cbt) and cfn == "wait":
                    return task_inner(cbt)
                if is_chan(cbt):
                    if cfn == "recv":
                        return "Option(" + chan_inner(cbt) + ")"
                    return "void"                 # send / close
            mn := ufcs_name(dc, ctx, names, types, callee)
            if mn != "":                          # UFCS method: its return type
                return resolve_nt(dc, ctx, sig_ret(dc, ctx, mn))
            return resolve_nt(dc, ctx, func_ret(type_of(callee, names, types, dc, ctx)))
        ESpawn(id, nm, sargs, _el):
            return "Task(" + resolve_nt(dc, ctx, sig_ret(dc, ctx, nm)) + ")"
        EAddr(inner, _el):
            return type_of(inner, names, types, dc, ctx)
        EBin(op, l, r, _el):
            lt := type_of(l, names, types, dc, ctx)
            rt := type_of(r, names, types, dc, ctx)
            if op == "+" and (lt == "str" or rt == "str"):
                return "str"                      # str + char appends one byte
            if (op == "+" or op == "-") and (lt == "char" or rt == "char"):
                return "char"                     # char +/- int (or char) stays a byte
            if op == "+" or op == "-" or op == "*" or op == "/":
                if lt == "float" or rt == "float":
                    return "float"
                return "int"
            if is_cmp(op) or op == "&&" or op == "||":
                return "bool"                     # comparisons / and / or -> bool
            return "int"                          # %, <<, >>, &, |, ^ -> int
        ECall(name, args, _el):
            di := find(name, ".")
            if di >= 0 and has_str(names, substr(name, 0, di)):   # `h.cb(args)` where h is a LOCAL: a fn-field call
                return type_of(ECallV(EField(EVar(substr(name, 0, di), _el), substr(name, di + 1, len(name)), _el), args, _el), names, types, dc, ctx)
            if has_str(names, name):              # indirect call through a function-typed variable
                vt := base_ty(var_type(names, types, name))
                if is_func(vt):
                    return resolve_nt(dc, ctx, func_ret(vt))
            if name == "map_set" or name == "map_del":   # return the first arg's map type
                return type_of(args[0], names, types, dc, ctx)
            if name == "map_get":                 # returns the map's value type
                return map_val(type_of(args[0], names, types, dc, ctx))
            if name == "pop":                      # pop(arr) -> the array's element type
                pt := type_of(args[0], names, types, dc, ctx)
                if is_soa(pt):                     # pop(soa) yields the struct value
                    return soa_struct(pt)
                return elem_ty(pt)
            if name == "keys":                     # returns [K] (the map's key array)
                return "[" + map_key(type_of(args[0], names, types, dc, ctx)) + "]"
            if has_prefix(name, "channel:"):      # channel(T, cap) creation (the type rides the name)
                return "Channel(" + substr(name, 8, len(name)) + ")"
            if name == "wait":                    # wait(t) -> T (CC-1)
                return task_inner(type_of(args[0], names, types, dc, ctx))
            if name == "recv":                    # recv(ch) -> Option(T); None = closed+drained (CC-4)
                return "Option(" + chan_inner(type_of(args[0], names, types, dc, ctx)) + ")"
            if name == "send" or name == "close":
                return "void"
            if name == "to_under":                # generic newtype unwrap -> the underlying type. resolve_nt is
                # NOT redundant: type_of resolves a newtype at a VAR read, but an
                # array-element read (to_under(ks[i]) over ks: [Nt]) returns the
                # bare elem type "Nt" (fuzz-found: len() then gen'd the array path)
                return resolve_nt(dc, ctx, type_of(args[0], names, types, dc, ctx))
            if name == "Some":
                return "Option(" + type_of(args[0], names, types, dc, ctx) + ")"
            if name == "Ok":
                return "Result(" + type_of(args[0], names, types, dc, ctx) + ",)"
            if name == "Err":
                return "Result(," + type_of(args[0], names, types, dc, ctx) + ")"
            return resolve_nt(dc, ctx, sig_ret(dc, with_line(ctx, _el), name))

fn gen_args(args: [Expr], names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    out := ""
    i := 0
    for i < len(args):
        if i > 0:
            out = out + ", "
        out = out + gen_expr(args[i], names, types, dc, ctx)
        i = i + 1
    return out

# If `arg` is an inout container argument (`&place` where place is an array/map/
# soa), the extra hidden arena to pass after it: the place's home arena in the
# CALLER (a local -> its scope/block arena; a chained inout -> the caller's own
# _ina_, threading the true home up the chain). "" otherwise. Mirrors
# inout_container_param exactly so call arity matches the callee signature.
fn arg_ina(arg: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    match arg:
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return ""
        ECallV(callee, cargs, _el):
            return ""
        EAddr(inner, _el):
            b := base_ty(type_of(inner, names, types, dc, ctx))
            if resolve_nt(dc, ctx, b) == "str" or is_array(b) or is_map(b) or is_soa(b) or (is_struct(dc, ctx, b) and struct_is_heap(dc, ctx, b)):   # mirrors inout_container_param
                return ", " + owner_arena_of(inner, names, types, dc, ctx)
            return ""
        EVar(n, _el):
            return ""
        EInt(t, _el):
            return ""
        EBool(t, _el):
            return ""
        EChar(t, _el):
            return ""
        EFloat(f, _el):
            return ""
        EStr(s, _el):
            return ""
        EBin(o, l, r, _el):
            return ""
        ECall(nm, a, _el):
            return ""
        EField(b, f, _el):
            return ""
        EIndex(b, i, _el):
            return ""
        EArrLit(es, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        EMapLit(ks, vs, _el):
            return ""
        ETuple(es, _el):
            return ""
        ESlice(b, lo, hi, _el):
            return ""
        ESpawn(id, nm, a, _el):
            return ""

# Like gen_args, but after each inout-container arg, interleave its home arena
# (the hidden _ina_ param) — kept positionally in sync with gen_params.
fn gen_call_args(args: [Expr], names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    out := ""
    i := 0
    for i < len(args):
        if i > 0:
            out = out + ", "
        out = out + gen_expr(args[i], names, types, dc, ctx) + arg_ina(args[i], names, types, dc, ctx)
        i = i + 1
    return out

# Like gen_args, but for CONSTRUCTION (struct/enum/array literal): the argument
# value is STORED in the aggregate and outlives the expression, so a heap place
# argument must be deep-copied for value semantics — else the stored field
# aliases the source's buffer, and mutating the source later corrupts the stored
# value (`a := [..]; t := Box(a, ..); a[0] = 9` must leave t untouched). gen_rhs
# copies only is_place heap args; fresh values / scalars / strings pass through.
# Mirrors the tuple path (gen_rhs per element) and the C compiler's per-field
# copy_into. (Found by tests/value_semantics.hi probe 3.)
fn gen_store_args(args: [Expr], names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    # Values STORED into a container (array-literal / struct / enum / tuple
    # fields) must be malloc'd (owner "0"), not built in the ambient owner: a
    # construction inside a `return` expr has owner=_parent, and the constructed
    # container would then hold _parent-arena string pointers that dangle once the
    # caller's scope frees. Forcing "0" keeps stored strings immortal. (Outside a
    # return, owner is already "0", so this is a no-op there.)
    return gen_store_args_owner(args, names, types, dc, ctx, "0")

# Like gen_store_args but with an explicit owner arena for the stored values.
# Array literals of a deep-copied element type pass ctx.owner (the array's home
# arena) so element temporaries are freed at scope instead of leaking; struct/
# enum/tuple construction keeps owner "0" (immortal) via gen_store_args.
fn gen_store_args_owner(args: [Expr], names: [string], types: [string], dc: Decls, ctx: Ctx, owner: string) -> string:
    sctx := with_owner(dc, ctx, owner)
    out := ""
    i := 0
    for i < len(args):
        if i > 0:
            out = out + ", "
        out = out + gen_rhs(args[i], names, types, dc, sctx)
        i = i + 1
    return out

# index of field `fld` in struct `sname` (the soa buffer is f<index>).
fn soa_field_index(dc: Decls, ctx: Ctx, sname: string, fld: string) -> int:
    si := 0
    for si < len(dc.structs):
        if dc.structs[si].name == sname:
            j := 0
            for j < len(dc.structs[si].fields):
                if dc.structs[si].fields[j].name == fld:
                    return j
                j = j + 1
        si = si + 1
    return 0

# If `base` is `soa[i]`, the C for `base.fld` is the field buffer slot
# `(soa).fN[i]` -- a real lvalue, so it serves BOTH read and write. Else "".
# (Hier has no wildcard match, so every Expr arm is listed.)
fn soa_field_access(dc: Decls, ctx: Ctx, base: Expr, fld: string, names: [string], types: [string]) -> string:
    match base:
        EIndex(sb, ix, _el):
            sbt := type_of(sb, names, types, dc, ctx)
            if is_soa(sbt):
                fi := soa_field_index(dc, ctx, soa_struct(sbt), fld)
                return "(" + gen_expr(sb, names, types, dc, ctx) + ").f" + str(fi) + "[" + gen_expr(ix, names, types, dc, ctx) + "]"
            return ""
        EInt(t, _el):
            return ""
        EBool(t, _el):
            return ""
        EChar(t, _el):
            return ""
        EFloat(f, _el):
            return ""
        EStr(s, _el):
            return ""
        EVar(n, _el):
            return ""
        EBin(o, l, r, _el):
            return ""
        ECall(nm, a, _el):
            return ""
        EField(b, f, _el):
            return ""
        EArrLit(es, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        EMapLit(ks, vs, _el):
            return ""
        ETuple(es, _el):
            return ""
        ESlice(b, lo, hi, _el):
            return ""
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return ""
        ECallV(callee, cargs, _el):
            return ""
        EAddr(x, _el):
            return ""
        ESpawn(id, nm, a, _el):
            return ""

# gather a whole struct value from the soa's field buffers at index `ix`.
# (param is `basec` not `sc` — hierc0 emits user names un-prefixed and `sc` is
# the runtime string-concat function, so a `sc` local would shadow it.)
fn gen_soa_gather(dc: Decls, ctx: Ctx, ty: string, basec: string, ix: string) -> string:
    sn := soa_struct(ty)
    si := 0
    for si < len(dc.structs):
        if dc.structs[si].name == sn:
            flds := dc.structs[si].fields
            out := "(" + ust(sn) + "){"
            i := 0
            for i < len(flds):
                if i > 0:
                    out = out + ","
                out = out + " (" + basec + ").f" + str(i) + "[" + ix + "]"
                i = i + 1
            return out + " }"
        si = si + 1
    die("codegen: soa gather of unknown struct")
    return ""

# soa sub-range [lo:hi]: offset every field buffer by lo (len hi-lo, cap 0).
fn gen_soa_slice(dc: Decls, ctx: Ctx, ty: string, basec: string, loc: string, hic: string) -> string:
    sn := soa_struct(ty)
    si := 0
    for si < len(dc.structs):
        if dc.structs[si].name == sn:
            flds := dc.structs[si].fields
            out := "(Soa_" + sn + "){"
            i := 0
            for i < len(flds):
                out = out + " (" + basec + ").f" + str(i) + " + (" + loc + "),"
                i = i + 1
            return out + " (" + hic + ") - (" + loc + "), 0 }"
        si = si + 1
    die("codegen: soa slice of unknown struct")
    return ""

# Return a copy of ctx with a different allocation owner. Sub-expressions of an
# expression built with this ctx allocate into `o` (an arena lvalue string like
# "&_t" / "_parent", or "0" for malloc).
fn with_owner(dc: Decls, ctx: Ctx, o: string) -> Ctx:
    return Ctx(ctx.vparams, ctx.saccums, ctx.rettype, o, ctx.depth, ctx.bbases, ctx.movables, ctx.loopdepth, ctx.fusearr, ctx.fusesuf, ctx.fusety, ctx.line)

# set the current statement source line (for resolve/codegen diagnostics)
fn with_line(ctx: Ctx, n: int) -> Ctx:
    return Ctx(ctx.vparams, ctx.saccums, ctx.rettype, ctx.owner, ctx.depth, ctx.bbases, ctx.movables, ctx.loopdepth, ctx.fusearr, ctx.fusesuf, ctx.fusety, n)

# a statement's source line (0 for the no-payload variants -- callers fall back to ctx.line)
fn stmt_line(s: Stmt) -> int:
    match s:
        SDecl(a, b, ln):
            return ln
        SAssign(a, b, ln):
            return ln
        SFieldAssign(a, b, ln):
            return ln
        SPrint(a, ln):
            return ln
        SReturn(a, ln):
            return ln
        SReturnVoid:
            return 0
        SIf(a, b, c, ln):
            return ln
        SWhile(a, b, ln):
            return ln
        SForRange(a, b, c, d, e, ln):
            return ln
        SExpr(a, ln):
            return ln
        STypedDecl(a, b, c, ln):
            return ln
        SOrReturn(a, b, ln):
            return ln
        SDestructure(a, b, ln):
            return ln
        SMultiAssign(a, b, ln):
            return ln
        SMatch(a, b, c, d, ln):
            return ln
        SBreak:
            return 0
        SContinue:
            return 0
        SSelect(a, b, c, d, e, ln):
            return ln
        SParFor(a, b, c, d, e, ln):
            return ln

# abort with "line N: msg" + the source line and a caret under its first
# non-blank char (resolve/codegen diagnostics). line 0 / out of range = no snippet.
fn die_at(dc: Decls, code: int, msg: string):
    nl := chr(10)
    lineno := code / 100000                        # decode tloc: 1-based line, 0-based col
    col := code % 100000
    if lineno > 0 and lineno <= len(dc.src_lines):
        txt := dc.src_lines[lineno - 1]
        pad := ""                                  # spaces to push the caret under the token's column
        c := 0
        for c < col:
            pad = pad + " "
            c = c + 1
        die("line " + str(lineno) + ": " + msg + nl + "    " + txt + nl + "    " + pad + "^")
    if lineno > 0:
        die("line " + str(lineno) + ": " + msg)
    die(msg)

# warn_at: non-fatal diagnostic. Mirrors die_at (same tloc decode + snippet/caret)
# but writes stderr via eprint and does NOT exit. Used by the loop-progress check.
fn warn_at(dc: Decls, code: int, msg: string):
    nl := chr(10)
    lineno := code / 100000                        # decode tloc: 1-based line, 0-based col
    col := code % 100000
    if lineno > 0 and lineno <= len(dc.src_lines):
        txt := dc.src_lines[lineno - 1]
        pad := ""
        c := 0
        for c < col:
            pad = pad + " "
            c = c + 1
        eprint("line " + str(lineno) + ": warning: " + msg + nl + "    " + txt + nl + "    " + pad + "^" + nl)
        return
    if lineno > 0:
        eprint("line " + str(lineno) + ": warning: " + msg + nl)
        return
    eprint("warning: " + msg + nl)

# Loop-progress check (1:1 port of src/hierc.c wl_*): a `for COND:` whose condition
# variables are never changed in the body (and which can't break/return/die) may
# spin forever. Sound under value semantics: a var changes only by assign-to-it,
# place-mutation (v[i]=/v.f=), push/pop(v,..), or &v passed to an inout param.
fn wl_root(e: Expr) -> string:                     # base identifier of a place: v / v[i] / v.f
    match e:
        EIndex(b, ix, p):
            return wl_root(b)
        EField(b, fld, p):
            return wl_root(b)
        EVar(n, p):
            return n
        EInt(t, p):
            return ""
        EBool(t, p):
            return ""
        EChar(t, p):
            return ""
        EFloat(t, p):
            return ""
        EStr(t, p):
            return ""
        EBin(op, l, r, p):
            return ""
        ECall(nm, args, p):
            return ""
        EArrLit(es, p):
            return ""
        EArrEmpty(t, p):
            return ""
        EMapEmpty(kt, vt, p):
            return ""
        EMapLit(ks, vls, p):
            return ""
        ETuple(es, p):
            return ""
        ESlice(b, lo, hi, p):
            return ""
        EAddr(x, p):
            return ""
        ELambda(lid, ps, pts, ret, lb, cn, ct, p):
            return ""
        ECallV(callee, cargs, p):
            return ""
        ESpawn(sid, snm, sargs, p):
            return ""

fn wl_cond_vars(e: Expr, vs: inout [string], hc: inout bool):   # collect cond idents; flag a call/spawn
    match e:
        ECall(nm, args, p):
            hc = true
        ECallV(callee, cargs, p):
            hc = true
        ESpawn(sid, snm, sargs, p):
            hc = true
        EVar(n, p):
            push(vs, n)
        EBin(op, l, r, p):
            wl_cond_vars(l, &vs, &hc)
            wl_cond_vars(r, &vs, &hc)
        EField(b, fld, p):
            wl_cond_vars(b, &vs, &hc)
        EIndex(b, ix, p):
            wl_cond_vars(b, &vs, &hc)
            wl_cond_vars(ix, &vs, &hc)
        ESlice(b, lo, hi, p):
            wl_cond_vars(b, &vs, &hc)
            wl_cond_vars(lo, &vs, &hc)
            wl_cond_vars(hi, &vs, &hc)
        EAddr(x, p):
            wl_cond_vars(x, &vs, &hc)
        ETuple(es, p):
            k := 0
            for k < len(es):
                wl_cond_vars(es[k], &vs, &hc)
                k = k + 1
        EArrLit(es, p):
            k := 0
            for k < len(es):
                wl_cond_vars(es[k], &vs, &hc)
                k = k + 1
        EMapLit(ks, vls, p):
            k := 0
            for k < len(ks):
                wl_cond_vars(ks[k], &vs, &hc)
                k = k + 1
            j := 0
            for j < len(vls):
                wl_cond_vars(vls[j], &vs, &hc)
                j = j + 1
        EInt(t, p):
            hc = hc
        EBool(t, p):
            hc = hc
        EChar(t, p):
            hc = hc
        EFloat(t, p):
            hc = hc
        EStr(t, p):
            hc = hc
        EArrEmpty(t, p):
            hc = hc
        EMapEmpty(kt, vt, p):
            hc = hc
        ELambda(lid, ps, pts, ret, lb, cn, ct, p):
            hc = hc

fn wl_scan_expr(e: Expr, mut: inout [string], ex: inout bool):   # &v / push/pop(v) / die hiding in an expr
    match e:
        EAddr(x, p):
            r := wl_root(x)
            if r != "":
                push(mut, r)
            wl_scan_expr(x, &mut, &ex)
        ECall(nm, args, p):
            if nm == "die":
                ex = true
            if (nm == "push" or nm == "pop") and len(args) >= 1:
                r := wl_root(args[0])
                if r != "":
                    push(mut, r)
            k := 0
            for k < len(args):
                wl_scan_expr(args[k], &mut, &ex)
                k = k + 1
        ECallV(callee, cargs, p):
            wl_scan_expr(callee, &mut, &ex)
            k := 0
            for k < len(cargs):
                wl_scan_expr(cargs[k], &mut, &ex)
                k = k + 1
        ESpawn(sid, snm, sargs, p):
            k := 0
            for k < len(sargs):
                wl_scan_expr(sargs[k], &mut, &ex)
                k = k + 1
        EBin(op, l, r, p):
            wl_scan_expr(l, &mut, &ex)
            wl_scan_expr(r, &mut, &ex)
        EField(b, fld, p):
            wl_scan_expr(b, &mut, &ex)
        EIndex(b, ix, p):
            wl_scan_expr(b, &mut, &ex)
            wl_scan_expr(ix, &mut, &ex)
        ESlice(b, lo, hi, p):
            wl_scan_expr(b, &mut, &ex)
            wl_scan_expr(lo, &mut, &ex)
            wl_scan_expr(hi, &mut, &ex)
        ETuple(es, p):
            k := 0
            for k < len(es):
                wl_scan_expr(es[k], &mut, &ex)
                k = k + 1
        EArrLit(es, p):
            k := 0
            for k < len(es):
                wl_scan_expr(es[k], &mut, &ex)
                k = k + 1
        EMapLit(ks, vls, p):
            k := 0
            for k < len(ks):
                wl_scan_expr(ks[k], &mut, &ex)
                k = k + 1
            j := 0
            for j < len(vls):
                wl_scan_expr(vls[j], &mut, &ex)
                j = j + 1
        ELambda(lid, ps, pts, ret, lb, cn, ct, p):
            wl_scan_expr(lb, &mut, &ex)
        EVar(n, p):
            ex = ex
        EInt(t, p):
            ex = ex
        EBool(t, p):
            ex = ex
        EChar(t, p):
            ex = ex
        EFloat(t, p):
            ex = ex
        EStr(t, p):
            ex = ex
        EArrEmpty(t, p):
            ex = ex
        EMapEmpty(kt, vt, p):
            ex = ex

fn wl_scan_body(stmts: [Stmt], mut: inout [string], ex: inout bool):
    i := 0
    for i < len(stmts):
        match stmts[i]:
            SDecl(n, e, p):
                push(mut, n)
                wl_scan_expr(e, &mut, &ex)
            SAssign(n, e, p):
                push(mut, n)
                wl_scan_expr(e, &mut, &ex)
            STypedDecl(n, t, e, p):
                push(mut, n)
                wl_scan_expr(e, &mut, &ex)
            SOrReturn(n, e, p):
                push(mut, n)
                wl_scan_expr(e, &mut, &ex)
            SForRange(n, a, b, st, body, p):
                push(mut, n)
                wl_scan_expr(a, &mut, &ex)
                wl_scan_expr(b, &mut, &ex)
                wl_scan_expr(st, &mut, &ex)
                wl_scan_body(body, &mut, &ex)
            SMultiAssign(ns, e, p):
                k := 0
                for k < len(ns):
                    push(mut, ns[k])
                    k = k + 1
                wl_scan_expr(e, &mut, &ex)
            SDestructure(ns, e, p):
                k := 0
                for k < len(ns):
                    push(mut, ns[k])
                    k = k + 1
                wl_scan_expr(e, &mut, &ex)
            SFieldAssign(lv, r, p):
                rt := wl_root(lv)
                if rt != "":
                    push(mut, rt)
                wl_scan_expr(lv, &mut, &ex)
                wl_scan_expr(r, &mut, &ex)
            SReturn(e, p):
                ex = true
            SReturnVoid:
                ex = true
            SBreak:
                ex = true
            SContinue:
                i = i
            SIf(cnd, b, els, p):
                wl_scan_expr(cnd, &mut, &ex)
                wl_scan_body(b, &mut, &ex)
                wl_scan_body(els, &mut, &ex)
            SWhile(cnd, b, p):
                wl_scan_expr(cnd, &mut, &ex)
                wl_scan_body(b, &mut, &ex)
            SMatch(subj, vsn, bs, bodies, p):
                wl_scan_expr(subj, &mut, &ex)
                k := 0
                for k < len(bodies):
                    wl_scan_body(bodies[k], &mut, &ex)
                    k = k + 1
            SExpr(e, p):
                wl_scan_expr(e, &mut, &ex)
            SPrint(e, p):
                wl_scan_expr(e, &mut, &ex)
            SParFor(v, a, b, body, pid, p):
                push(mut, v)
                wl_scan_expr(a, &mut, &ex)
                wl_scan_expr(b, &mut, &ex)
                wl_scan_body(body, &mut, &ex)
            SSelect(uid, svars, schans, sbinds, sbodies, p):
                k := 0
                for k < len(schans):
                    wl_scan_expr(schans[k], &mut, &ex)
                    k = k + 1
                j := 0
                for j < len(sbodies):
                    wl_scan_body(sbodies[j], &mut, &ex)
                    j = j + 1
        i = i + 1

fn wl_check(cond: Expr, body: [Stmt], pos: int, dc: Decls):   # `body` is the loop body of a `for COND:`
    cv := []string
    hc := false
    wl_cond_vars(cond, &cv, &hc)
    if len(cv) == 0 or hc:                          # constant cond (`for true:`) or a call in it: skip
        return
    mut := []string
    ex := false
    wl_scan_body(body, &mut, &ex)
    if ex:                                          # a break/return/die can end the loop
        return
    i := 0
    for i < len(cv):
        if count_str_occ(mut, cv[i]) > 0:           # a condition variable is changed -> progresses
            return
        i = i + 1
    warn_at(dc, pos, "loop condition never changes; this `for` may run forever (forgot to advance a variable? consider `for x in range(...)`)")

# "pure" builtins: no side effect, so discarding the result in statement position
# is a no-op (map_set/map_del return a NEW map — a common footgun). Mirrors
# is_pure_builtin in src/hierc.c.
fn is_pure_bi(n: string) -> bool:
    return n == "str" or n == "substr" or n == "chr" or n == "split" or n == "keys" or n == "find" or n == "map_get" or n == "map_has" or n == "map_set" or n == "map_del" or n == "sqrt" or n == "pow" or n == "floor" or n == "fabs" or n == "to_float" or n == "to_int" or n == "to_str" or n == "to_bool" or n == "is_null" or n == "len"

fn pure_call_name(e: Expr) -> string:              # the pure-builtin name if e is such a call, else ""
    match e:
        ECall(name, args, p):
            if is_pure_bi(name):
                return name
            return ""
        EInt(t, p):
            return ""
        EBool(t, p):
            return ""
        EChar(t, p):
            return ""
        EFloat(t, p):
            return ""
        EStr(t, p):
            return ""
        EVar(n, p):
            return ""
        EBin(op, l, r, p):
            return ""
        EField(b, fld, p):
            return ""
        EIndex(b, ix, p):
            return ""
        EArrLit(es, p):
            return ""
        EArrEmpty(t, p):
            return ""
        EMapEmpty(kt, vt, p):
            return ""
        EMapLit(ks, vls, p):
            return ""
        ETuple(es, p):
            return ""
        ESlice(b, lo, hi, p):
            return ""
        EAddr(x, p):
            return ""
        ELambda(lid, ps, pts, ret, lb, cn, ct, p):
            return ""
        ECallV(callee, cargs, p):
            return ""
        ESpawn(sid, snm, sargs, p):
            return ""

# Enter a nested block: a fresh child arena `_b<depth+1>` becomes the allocation
# owner for the block's transients/local decls. `base` is the env length at entry
# (vars declared from here on are block-local). Sibling blocks reuse the same
# name in separate C scopes; nested blocks get distinct names by depth.
fn enter_block(dc: Decls, ctx: Ctx, base: int) -> Ctx:
    d := ctx.depth + 1
    nb := ctx.bbases                              # push this block's entry index (depth d -> nb[d-1])
    push(nb, base)
    return Ctx(ctx.vparams, ctx.saccums, ctx.rettype, "&_b" + str(d), d, nb, ctx.movables, ctx.loopdepth, ctx.fusearr, ctx.fusesuf, ctx.fusety, ctx.line)

# C lvalue of the current block's arena.
fn cur_arena(dc: Decls, ctx: Ctx) -> string:
    if ctx.depth == 0:
        return "&_scope"
    return "&_b" + str(ctx.depth)

# Free sequence a `return` must run: every enclosing block arena innermost-first,
# then the proc's own _scope. (The returned value lives in _parent, which
# outlives all of these.)
fn return_frees(dc: Decls, ctx: Ctx) -> string:
    out := ""
    k := ctx.depth
    for k > 0:
        out = out + "arena_free(&_b" + str(k) + "); "
        k = k - 1
    return out + "arena_free(&_scope);"

# break/continue free every block arena from the current depth down to AND
# INCLUDING the innermost loop's body arena (_b<loopdepth>). hierc0 arena_child's
# the loop body at the top of each iteration and arena_free's it at the bottom,
# so a C break/continue that jumps over that free would leak it (plus any
# enclosing if-block arenas). Unlike return_frees this stops at the loop, not _scope.
fn loop_frees(dc: Decls, ctx: Ctx) -> string:
    out := ""
    k := ctx.depth
    for k >= ctx.loopdepth:
        out = out + "arena_free(&_b" + str(k) + "); "
        k = k - 1
    return out

# Mark a block ctx as a loop body: its own depth becomes the boundary that an
# enclosed break/continue frees down to (nested if-blocks inherit it via enter_block).
fn in_loop(ctx: Ctx) -> Ctx:
    return Ctx(ctx.vparams, ctx.saccums, ctx.rettype, ctx.owner, ctx.depth, ctx.bbases, ctx.movables, ctx.depth, ctx.fusearr, ctx.fusesuf, ctx.fusety, ctx.line)

# Emitted C name for a USER variable / parameter / function identifier. Prefixed so a
# user name can never collide with hierc0's emitted runtime helpers (sc/hs/amem/i2s/
# mk_*/Arr_*/...) or a C keyword (int/long/struct/default/...). Mirrors the C compiler's
# h_ scheme. Generated temps (_scope/_ret/_fc.../_ina_...) are emitted raw, never via un.
# `main` is the C entry point and is carved out upstream (gen_func early-returns it,
# the proto loop skips it, and nothing calls it), so it never reaches un.
fn un(n: string) -> string:
    return "h_" + n

# Emitted C name for a user STRUCT FIELD (member). f_ prefix so a field named a C
# keyword (default/case/...) is legal. Mirrors the C compiler. Positional tuple/soa
# fields (.f0/.f1) and enum variant union members are NOT routed through this (the
# latter matches the C compiler, which also leaves them raw).
fn uf(n: string) -> string:
    return "f_" + n

# Emitted C type names for user STRUCT (S_) and ENUM (E_) types — so a user type named
# a C keyword (default/...) or a generated family (Arr_int/HOption/...) can't collide.
# Mirrors the C compiler. The struct/enum NAME also labels generated families
# (Arr_<name>/Soa_<name>/<name>_copy) — those labels stay raw (they're distinct from the
# S_/E_ TYPE name, so no collision), only the C type and the type's own copy/eq/typedef
# identifiers are prefixed. tcopy/teq dispatch a copy/eq call site to the right prefix.
fn ust(n: string) -> string:
    return "S_" + n
fn uet(n: string) -> string:
    return "E_" + n
fn tcopy(dc: Decls, ctx: Ctx, ty: string) -> string:
    if is_enum(dc, ctx, ty):
        return uet(ty) + "_copy"
    return ust(ty) + "_copy"
fn teq(dc: Decls, ctx: Ctx, ty: string) -> string:
    if is_enum(dc, ctx, ty):
        return uet(ty) + "_eq"
    return ust(ty) + "_eq"

fn gen_expr(e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    match e:
        EInt(t, _el):
            return t
        EBool(t, _el):
            return t
        EChar(t, _el):
            return t
        EFloat(f, _el):
            return f
        EStr(s, _el):                                    # length-headered, interned once per occurrence (cached static)
            return "({ static char* _l = 0; if (!_l) _l = hi_intern(\"" + s + "\"); _l; })"
        EVar(name, _el):
            if name == "None":
                return "hnone()"
            if is_variant(dc, ctx, name):            # bare no-payload variant -> constructor call
                return "mk_" + name + "(" + ctx.owner + ")"
            if not has_str(names, name):             # not a local: a bare fn name -> the fat value {0, thunk}
                ft := sig_functype(dc, name)
                if ft != "":
                    return "(Fn_" + func_suffix(ft) + "){0, " + un(name) + "__clo, 0}"   # plain ref: no env to re-home
                return un(name)
            if is_inout(var_type(names, types, name)):   # inout param -> deref the pointer
                return "(*" + un(name) + ")"
            return un(name)
        EField(base, fld, _el):
            sf := soa_field_access(dc, ctx, base, fld, names, types)   # soa[i].f -> (soa).fN[i]
            if sf != "":
                return sf
            if is_tuple(type_of(base, names, types, dc, ctx)):   # tuple index t.0 -> t.f0
                return gen_expr(base, names, types, dc, ctx) + ".f" + fld
            return gen_expr(base, names, types, dc, ctx) + "." + uf(fld)
        EIndex(base, idx, _el):
            bt := type_of(base, names, types, dc, ctx)
            if bt == "str":                                 # s[i] -> the byte as an int, bounds-checked via the length header
                return "hi_sidx(" + gen_expr(base, names, types, dc, ctx) + ", " + gen_expr(idx, names, types, dc, ctx) + ")"
            if is_soa(bt):                                  # soa[i] -> gather a struct value
                return gen_soa_gather(dc, ctx, bt, gen_expr(base, names, types, dc, ctx), gen_expr(idx, names, types, dc, ctx))
            if is_map(bt):                                  # m[k] rvalue READ -> a PURE map_get (never inserts)
                vt := map_val(bt)
                z := map_read_zero(vt)                       # scalar value: literal zero (0 / 0.0 / "" / false)
                if z == "":                                  # composite value: the empty/zeroed (V){0} -- the SAME
                    z = "(" + cty(dc, ctx, vt) + "){0}"      # value slotptr inserts (empty array / zeroed struct)
                # Write targets / push / reserve route through gen_place -> the slot
                # lvalue instead, so reaching gen_expr here is always a read.
                return mfam(bt) + "_get(" + gen_expr(base, names, types, dc, ctx) + ", " + krt(dc, ctx, bt, gen_expr(idx, names, types, dc, ctx)) + ", " + z + ")"
            return gen_expr(base, names, types, dc, ctx) + ".data[" + gen_expr(idx, names, types, dc, ctx) + "]"
        EArrLit(elems, _el):
            et := type_of(elems[0], names, types, dc, ctx)
            eo := "0"                              # deep-copied element temporaries
            if elem_deepcopy(dc, ctx, et):             # live in the array's arena (no leak);
                eo = ctx.owner                     # _from re-copies them into `ar` anyway
            return "Arr_" + mangle(et) + "_from(" + ctx.owner + ", (" + cty(dc, ctx, et) + "[]){" + gen_store_args_owner(elems, names, types, dc, ctx, eo) + "}, " + str(len(elems)) + ")"
        EArrEmpty(ety, _el):
            if is_soa(ety):                       # empty soa: zeroed descriptor
                return "(" + cty(dc, ctx, ety) + "){0}"
            return "Arr_" + mangle(ety) + "_new()"
        EMapEmpty(kty, vty, _el):                      # value type must be mangled to match the family ([int] -> arr_int)
            return "map_" + kty + "_" + mangle(vty) + "_new()"
        EMapLit(keys, vals, _el):                      # chain of _set onto a fresh map
            mt := type_of(e, names, types, dc, ctx)
            f := mfam(mt)
            out := f + "_new()"
            j := 0
            for j < len(keys):
                # value in ctx.owner, not owner 0: _set's put deep-copies it into the map's
                # arena anyway, so an owner-0 (malloc) source leaks (same as the map_set fix).
                # String literals are interned (owner-independent) so existing cases are unchanged.
                out = f + "_set(" + ctx.owner + ", " + out + ", " + krt(dc, ctx, mt, gen_expr(keys[j], names, types, dc, ctx)) + ", " + gen_rhs(vals[j], names, types, dc, ctx) + ")"
                j = j + 1
            return out
        ETuple(elems, _el):                            # a tuple owns its fields: deep-copy place elements
            out := "(Tup_" + tup_suffix(type_of(e, names, types, dc, ctx)) + "){"
            j := 0
            for j < len(elems):
                if j > 0:
                    out = out + ", "
                out = out + gen_rhs(elems[j], names, types, dc, ctx)   # fields inherit the ambient arena (Tup_*_copy re-homes them on any cross-arena move; enum/box/field-store set owner 0 first to keep stored tuples immortal)
                j = j + 1
            return out + "}"
        ESlice(base, lo, hi, _el):
            bt := type_of(base, names, types, dc, ctx)
            if bt == "str":                       # s[a:b] -> a fresh substring
                return "substr(" + ctx.owner + ", " + gen_expr(base, names, types, dc, ctx) + ", " + gen_expr(lo, names, types, dc, ctx) + ", " + gen_expr(hi, names, types, dc, ctx) + ")"
            if is_soa(bt):
                return gen_soa_slice(dc, ctx, bt, gen_expr(base, names, types, dc, ctx), gen_expr(lo, names, types, dc, ctx), gen_expr(hi, names, types, dc, ctx))
            return "Arr_" + mangle(elem_ty(bt)) + "_slice(" + ctx.owner + ", " + gen_expr(base, names, types, dc, ctx) + ", " + gen_expr(lo, names, types, dc, ctx) + ", " + gen_expr(hi, names, types, dc, ctx) + ")"
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            suffix := func_suffix(mk_functype(pts, ret))
            if len(cn) == 0:
                return "(Fn_" + suffix + "){0, " + un("__lam" + str(id)) + "__clo, 0}"
            # captures: build the env as a compound literal and hbox it into the
            # OWNER arena (where this closure value is stored) — so a loop-local
            # closure is reclaimed each iteration with its block, not retained in the
            # function arena. Every escape re-homes the env via Env_<id>_copy.
            env := "(Env_" + str(id) + "[]){"
            j := 0
            for j < len(cn):
                if j > 0:
                    env = env + ", "
                cv := gen_expr(EVar(cn[j], _el), names, types, dc, ctx)
                if elem_deepcopy(dc, ctx, ct[j]):                          # heap capture: own a deep copy in the env arena (value semantics)
                    cv = cp_field(dc, ctx, ct[j], ctx.owner, cv)
                env = env + cv
                j = j + 1
            env = env + "}"
            return "(Fn_" + suffix + "){hbox(" + ctx.owner + ", sizeof(Env_" + str(id) + "), " + env + "), " + un("__lam" + str(id)) + "__clo, Env_" + str(id) + "_copy}"
        ECallV(callee, cargs, _el):
            cfn := efield_fname(callee)           # t.wait() / ch.send(v) / ch.recv() / ch.close() (CC):
            if is_conc_method(cfn):               # rewrite to the free-call form and recurse
                cbt := type_of(efield_base(callee), names, types, dc, ctx)
                if is_task(cbt) or is_chan(cbt):
                    nca := []Expr
                    push(nca, efield_base(callee))
                    cci := 0
                    for cci < len(cargs):
                        push(nca, cargs[cci])
                        cci = cci + 1
                    return gen_expr(ECall(cfn, nca, _el), names, types, dc, ctx)
            mn := ufcs_name(dc, ctx, names, types, callee)
            if mn != "":                          # UFCS method call: foo(recv, args)
                allargs := []Expr
                push(allargs, efield_base(callee))
                ci := 0
                for ci < len(cargs):
                    push(allargs, cargs[ci])
                    ci = ci + 1
                return un(mn) + "(" + ctx.owner + ", " + gen_call_args(allargs, names, types, dc, ctx) + ")"
            ct := cty(dc, ctx, type_of(callee, names, types, dc, ctx))
            code := "({ " + ct + "_f = " + gen_expr(callee, names, types, dc, ctx) + "; _f.call(_f.env, " + ctx.owner
            if len(cargs) > 0:
                code = code + ", " + gen_call_args(cargs, names, types, dc, ctx)
            return code + "); })"
        EAddr(inner, _el):                             # &(*p) == p, so passing an inout param onward works
            return "&" + gen_expr(inner, names, types, dc, ctx)
        EBin(op, l, r, _el):
            lt := type_of(l, names, types, dc, ctx)
            if op == "+" and type_of(e, names, types, dc, ctx) == "str":
                if type_of(r, names, types, dc, ctx) == "char":   # str + char: append one byte
                    return "sc_char(" + ctx.owner + ", " + gen_expr(l, names, types, dc, ctx) + ", " + gen_expr(r, names, types, dc, ctx) + ")"
                return "sc(" + ctx.owner + ", " + gen_expr(l, names, types, dc, ctx) + ", " + gen_expr(r, names, types, dc, ctx) + ")"
            if is_cmp(op) and lt == "str":        # lexicographic string compare (== / != / < ...)
                return "(strcmp(" + gen_expr(l, names, types, dc, ctx) + ", " + gen_expr(r, names, types, dc, ctx) + ") " + op + " 0)"
            # == / != on a structural type (enum/struct/tuple/array/Option/Result):
            # use the generated structural eq; negate for !=. (Enums are boxed
            # pointers, so a raw `!=` would compare addresses, not values.)
            if (op == "==" or op == "!=") and (is_enum(dc, ctx, lt) or is_struct(dc, ctx, lt) or is_tuple(lt) or is_array(lt) or is_option(lt) or is_result(lt) or is_soa(lt) or is_map(lt)):
                eqx := eq_field(dc, ctx, lt, gen_expr(l, names, types, dc, ctx), gen_expr(r, names, types, dc, ctx))
                if op == "!=":
                    return "(!(" + eqx + "))"
                return eqx
            return "(" + gen_expr(l, names, types, dc, ctx) + " " + op + " " + gen_expr(r, names, types, dc, ctx) + ")"
        ECall(name, args, _el):
            cdi := find(name, ".")
            if cdi >= 0 and has_str(names, substr(name, 0, cdi)):   # `h.cb(args)` where h is a LOCAL: a fn-field call
                return gen_expr(ECallV(EField(EVar(substr(name, 0, cdi), _el), substr(name, cdi + 1, len(name)), _el), args, _el), names, types, dc, ctx)
            if name == "push":                    # push(arr, v): mutate in place
                at := type_of(args[0], names, types, dc, ctx)
                if is_soa(at):                    # soa push: grow each field buffer (in the soa's arena) + scatter
                    return "Soa_" + soa_struct(at) + "_push(" + owner_arena_of(args[0], names, types, dc, ctx) + ", &" + gen_place(args[0], names, types, dc, ctx) + ", " + gen_rhs(args[1], names, types, dc, with_owner(dc, ctx, "0")) + ")"
                et := elem_ty(at)
                pv := evar_name(args[0])              # push-loop fusion: register-resident cursor write
                if pv != "" and count_str_occ(ctx.fusearr, pv) > 0:
                    fi := 0
                    for fi < len(ctx.fusearr):
                        if ctx.fusearr[fi] == pv:
                            suf := ctx.fusesuf[fi]
                            ow := owner_arena_of(args[0], names, types, dc, ctx)
                            gname := "Arr_" + mangle(ctx.fusety[fi]) + "_grow"
                            v := gen_expr(args[1], names, types, dc, ctx)
                            if elem_deepcopy(dc, ctx, et):    # heap element (str): deep-copy into the array's arena, like the non-fused push
                                v = gen_rhs(args[1], names, types, dc, with_owner(dc, ctx, ow))
                            return "({ if (_fl" + suf + " == _fc" + suf + ") " + gname + "(" + ow + ", &_fd" + suf + ", &_fc" + suf + ", _fl" + suf + "); _fd" + suf + "[_fl" + suf + "++] = " + v + "; })"
                        fi = fi + 1
                oa := owner_arena_of(args[0], names, types, dc, ctx)   # array's home arena (buffer + deep-copied elements)
                vo := ctx.owner                    # a scalar element needs no arena, but a nested TRANSIENT alloc
                                                   # (e.g. str() consumed by len()) must be freed with the current
                                                   # scope, not malloc'd at owner-0 and leaked (leak fuzzer found it)
                if elem_deepcopy(dc, ctx, et):         # deep-copy elements (str/struct) are STORED in the array's arena
                    vo = oa
                return "Arr_" + mangle(et) + "_push(" + oa + ", &" + gen_place(args[0], names, types, dc, ctx) + ", " + gen_rhs(args[1], names, types, dc, with_owner(dc, ctx, vo)) + ")"
            if name == "pop":                     # pop(arr): remove + return the last element
                pat := type_of(args[0], names, types, dc, ctx)
                if is_soa(pat):
                    return "Soa_" + soa_struct(pat) + "_pop(&" + gen_place(args[0], names, types, dc, ctx) + ")"
                # result is deep-copied into ctx.owner (the array buffer may recycle), so
                # the popped value is independent of the (shrunk) array. Scalars pass through.
                return "Arr_" + mangle(elem_ty(pat)) + "_pop(" + ctx.owner + ", &" + gen_place(args[0], names, types, dc, ctx) + ")"
            if name == "reserve":                 # reserve(arr, n): preallocate exact capacity
                rt := elem_ty(type_of(args[0], names, types, dc, ctx))
                ra := owner_arena_of(args[0], names, types, dc, ctx)
                return "Arr_" + mangle(rt) + "_reserve(" + ra + ", &" + gen_place(args[0], names, types, dc, ctx) + ", " + gen_expr(args[1], names, types, dc, ctx) + ")"
            if name == "len":
                if type_of(args[0], names, types, dc, ctx) == "str":
                    return "((const long*)(" + gen_expr(args[0], names, types, dc, ctx) + "))[-1]"   # O(1): the length header
                return gen_expr(args[0], names, types, dc, ctx) + ".len"
            if name == "str":
                at := type_of(args[0], names, types, dc, ctx)
                if at == "str":                                  # str(string) is identity (interpolation)
                    return gen_expr(args[0], names, types, dc, ctx)
                if at == "float":
                    return "f2s(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
                if at == "bool":
                    return "b2s(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
                return "i2s(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "sqrt" or name == "floor" or name == "fabs":
                return name + "(" + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "pow":
                return "pow(" + gen_expr(args[0], names, types, dc, ctx) + ", " + gen_expr(args[1], names, types, dc, ctx) + ")"
            if name == "to_float":
                return "((double)(" + gen_expr(args[0], names, types, dc, ctx) + "))"
            if name == "to_int":
                return "((long)(" + gen_expr(args[0], names, types, dc, ctx) + "))"
            if name == "to_str" or name == "to_bool" or name == "to_under":   # zero-cost newtype unwrap
                return gen_expr(args[0], names, types, dc, ctx)
            if name == "substr":
                return "substr(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ", " + gen_expr(args[1], names, types, dc, ctx) + ", " + gen_expr(args[2], names, types, dc, ctx) + ")"
            if name == "find":
                return "hi_find(" + gen_expr(args[0], names, types, dc, ctx) + ", " + gen_expr(args[1], names, types, dc, ctx) + ")"
            if name == "split":
                return "hi_split(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ", " + gen_expr(args[1], names, types, dc, ctx) + ")"
            if name == "map_set":
                # value built in the map's arena (ctx.owner), NOT owner 0: _set's put deep-copies
                # it into that same arena anyway, so an owner-0 (malloc) source is pure leak -- it's
                # abandoned after the copy. ctx.owner is freed with the map; an escaping map re-copies
                # its values (map_copy/cp_field) so this can't dangle. (in-place self-mapset already
                # uses &_scope; this matches it for the param / non-self case.)
                return mfam(type_of(args[0], names, types, dc, ctx)) + "_set(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ", " + krt(dc, ctx, type_of(args[0], names, types, dc, ctx), gen_expr(args[1], names, types, dc, ctx)) + ", " + gen_rhs(args[2], names, types, dc, ctx) + ")"
            if name == "map_get":
                mt := type_of(args[0], names, types, dc, ctx)
                g := mfam(mt) + "_get(" + gen_expr(args[0], names, types, dc, ctx) + ", " + krt(dc, ctx, mt, gen_expr(args[1], names, types, dc, ctx)) + ", " + gen_expr(args[2], names, types, dc, ctx) + ")"
                return cp_field(dc, ctx, map_val(mt), ctx.owner, g)   # get returns a borrow into the map (or default) -> deep-copy into the caller's arena (passthrough for scalar values)
            if name == "keys":
                return mfam(type_of(args[0], names, types, dc, ctx)) + "_keys(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "map_del":
                return mfam(type_of(args[0], names, types, dc, ctx)) + "_del(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ", " + krt(dc, ctx, type_of(args[0], names, types, dc, ctx), gen_expr(args[1], names, types, dc, ctx)) + ")"
            if name == "map_has":
                return mfam(type_of(args[0], names, types, dc, ctx)) + "_has(" + gen_expr(args[0], names, types, dc, ctx) + ", " + krt(dc, ctx, type_of(args[0], names, types, dc, ctx), gen_expr(args[1], names, types, dc, ctx)) + ")"
            if name == "chr":
                return "hi_chr(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "die":
                return "hi_die(" + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "eprint":
                return "hi_eprint(" + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "read_all":
                return "hi_read_all(" + ctx.owner + ")"
            if name == "read_file":
                return "hi_read_file(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "write_file":              # (path, contents) -> bool; no arena (no alloc)
                return "hi_write_file(" + gen_expr(args[0], names, types, dc, ctx) + ", " + gen_expr(args[1], names, types, dc, ctx) + ")"
            if name == "list_dir":
                return "hi_list_dir(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "args":
                return "hi_args(" + ctx.owner + ")"
            if name == "getenv":                  # env var value, or "" if unset
                return "hi_getenv(" + ctx.owner + ", " + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "null":                    # FFI opaque ptr literal
                return "((void*)0)"
            if name == "is_null":                 # FFI: opaque-handle NULL test
                return "((" + gen_expr(args[0], names, types, dc, ctx) + ") == 0)"
            if name == "input":
                return "hi_input(" + ctx.owner + ")"
            if name == "Some":                    # box the payload in the SAME arena as the box, so a
                ct := cty(dc, ctx, type_of(args[0], names, types, dc, ctx))   # heap payload frees with it instead of
                return "hsome(hbox(" + ctx.owner + ", sizeof(" + ct + "), (" + ct + "[]){" + gen_rhs(args[0], names, types, dc, ctx) + "}))"   # leaking at owner-0 (every copy path deep-copies via box_payload)
            if name == "Ok":
                ct := cty(dc, ctx, type_of(args[0], names, types, dc, ctx))
                return "hok(hbox(" + ctx.owner + ", sizeof(" + ct + "), (" + ct + "[]){" + gen_rhs(args[0], names, types, dc, ctx) + "}))"
            if name == "Err":
                ce := cty(dc, ctx, type_of(args[0], names, types, dc, ctx))
                return "herr(hbox(" + ctx.owner + ", sizeof(" + ce + "), (" + ce + "[]){" + gen_rhs(args[0], names, types, dc, ctx) + "}))"
            if has_prefix(name, "channel:"):      # channel(T, cap): create the shared bounded queue (CC-4)
                return "hier_chan_new(" + gen_expr(args[0], names, types, dc, ctx) + ")"
            if name == "wait" and len(args) == 1 and is_task(type_of(args[0], names, types, dc, ctx)):
                # join; deep-copy the result out of the task's root arena into the
                # destination (ctx.owner); free the arena tree eagerly. A NAMED handle's
                # struct stays alive to its scope-exit hier_task_finish (so a second
                # wait dies on the done flag); an anonymous wait(spawn ...) frees all.
                wt := task_inner(type_of(args[0], names, types, dc, ctx))
                wct := cty(dc, ctx, wt)
                wfree := "arena_free(&_tk->root);"
                if evar_name(args[0]) == "":
                    wfree = "hier_task_free(_tk);"
                return "({ HTask* _tk = " + gen_expr(args[0], names, types, dc, ctx) + "; hier_task_join(_tk); " + wct + "_w = " + cp_field(dc, ctx, wt, ctx.owner, "(*(" + wct + "*)_tk->ret)") + "; " + wfree + " _w; })"
            if name == "send" and len(args) == 2 and is_chan(type_of(args[0], names, types, dc, ctx)):
                # deep-copy the payload into the CLAIMED cell's arena -- exclusive
                # between claim and commit, no lock held (CC-5); every element type
                sty := chan_inner(type_of(args[0], names, types, dc, ctx))
                sct := cty(dc, ctx, sty)
                return "({ HChan* _ch = " + gen_expr(args[0], names, types, dc, ctx) + "; HCell* _c = hier_chan_send_cell(_ch); " + sct + "* _p = (" + sct + "*)amem(&_c->arena, sizeof(" + sct + ")); *_p = " + cp_field(dc, ctx, sty, "(&_c->arena)", gen_expr(args[1], names, types, dc, ctx)) + "; hier_chan_send_commit(_ch, _c, _p); })"
            if name == "recv" and len(args) == 1 and is_chan(type_of(args[0], names, types, dc, ctx)):
                # Option(T): tag 0 (None) = closed and drained; the value deep-copies
                # out of the claimed cell into the destination arena before commit
                rty := chan_inner(type_of(args[0], names, types, dc, ctx))
                rct := cty(dc, ctx, rty)
                return "({ HChan* _ch = " + gen_expr(args[0], names, types, dc, ctx) + "; HOption _co; HCell* _rc = hier_chan_recv_cell(_ch); if (_rc) { " + rct + " _v = " + cp_field(dc, ctx, rty, ctx.owner, "(*(" + rct + "*)_rc->val)") + "; hier_chan_recv_commit(_ch, _rc); _co = hsome(hbox(" + ctx.owner + ", sizeof(" + rct + "), &_v)); } else { _co = hnone(); } _co; })"
            if name == "close" and len(args) == 1 and is_chan(type_of(args[0], names, types, dc, ctx)):
                return "hier_chan_close(" + gen_expr(args[0], names, types, dc, ctx) + ")"
            if is_newtype(dc, ctx, name):             # X(v) is zero-cost: identity
                return gen_expr(args[0], names, types, dc, ctx)
            if is_variant(dc, ctx, name):             # enum construction -> mk_Variant(ar, ...); node
                return "mk_" + name + "(" + ctx.owner + ", " + gen_store_args_owner(args, names, types, dc, ctx, ctx.owner) + ")"   # + payload fields inherit the ambient arena (nested children co-located)
            if is_struct(dc, ctx, name):              # struct construction -> compound literal; fields
                return "(" + ust(name) + "){" + gen_store_args_owner(args, names, types, dc, ctx, ctx.owner) + "}"   # inherit the ambient arena (an array elem -> the array's; a return -> _parent; an enum/box/field-store sets owner 0 first, keeping those immortal)
            if sig_is_extern(dc, name):               # FFI: call the C symbol directly — no arena, no h_ prefix
                xa := ""
                ai := 0
                for ai < len(args):
                    if ai > 0:
                        xa = xa + ", "
                    xa = xa + gen_expr(args[ai], names, types, dc, ctx)   # hier str is already char* -> zero-cost arg
                    ai = ai + 1
                xc := name + "(" + xa + ")"
                if sig_ret(dc, ctx, name) == "str":   # C-owned return -> copy into the arena (NULL -> "")
                    return "scopy(" + ctx.owner + ", ({ const char* _x = " + xc + "; _x ? _x : \"\"; }))"
                return xc
            if has_str(names, name) and is_func(var_type(names, types, name)):   # indirect call through a fn value: g.call(g.env, arena, args)
                cl := un(name) + ".call(" + un(name) + ".env, " + ctx.owner
                if len(args) > 0:
                    cl = cl + ", " + gen_call_args(args, names, types, dc, ctx)
                return cl + ")"
            # fail-closed: builtins, ctors (struct/enum/newtype), extern, and
            # fn-value calls are all handled above, so a name that reaches here
            # but is not a known user function is a call to something undefined.
            # (A value-position call is already caught in type_of; this covers
            # the statement position, whose result -- and thus type_of -- is unused.)
            if map_get(dc.sigmap, name, -1) < 0:
                die_at(dc, ctx.line, "type: unknown function '" + name + "'")
            if len(args) == 0:                    # user call: thread the current scope as the callee's _parent
                return un(name) + "(" + ctx.owner + ")"
            return un(name) + "(" + ctx.owner + ", " + gen_call_args(args, names, types, dc, ctx) + ")"
        ESpawn(id, nm, sargs, _el):
            # CC-1 spawn site: copy every argument into the task's private root
            # arena (after this, spawner and task share zero bytes), then start
            # the thread on the per-site trampoline emitted by the driver.
            sid := str(id)
            spt := sig_ptypes(dc, nm)
            sout := "({ HTask* _tk = hier_task_new(); HSpawnA_" + sid + "* _sa = (HSpawnA_" + sid + "*)amem(&_tk->root, sizeof(HSpawnA_" + sid + ")); _sa->t = _tk;"
            sk := 0
            for sk < len(sargs):
                sout = sout + " _sa->a" + str(sk) + " = " + cp_field(dc, ctx, spt[sk], "(&_tk->root)", gen_expr(sargs[sk], names, types, dc, ctx)) + ";"
                sk = sk + 1
            return sout + " hier_task_start(_tk, hier_spawn_" + sid + ", _sa); _tk; })"

# Root variable of a place expression (`s.items[i]` -> `s`), or "" if not a
# place rooted in a variable. Used to find which arena a container lives in.
fn root_var(e: Expr) -> string:
    match e:
        EVar(n, _el):
            return n
        EField(b, f, _el):
            return root_var(b)
        EIndex(b, i, _el):
            return root_var(b)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return ""
        ECallV(callee, cargs, _el):
            return ""
        EAddr(x, _el):
            return root_var(x)
        EInt(t, _el):
            return ""
        EBool(t, _el):
            return ""
        EChar(t, _el):
            return ""
        EFloat(f, _el):
            return ""
        EStr(s, _el):
            return ""
        EBin(o, l, r, _el):
            return ""
        ECall(n, a, _el):
            return ""
        EArrLit(es, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        EMapLit(ks, vs, _el):
            return ""
        ETuple(es, _el):
            return ""
        ESlice(b, lo, hi, _el):
            return ""
        ESpawn(id, nm, a, _el):
            return ""

# The arena a container place lives in: an inout-param container is the caller's
# (its buffer must grow in _parent so it survives the call); a local lives in
# this function's _scope. (One scope per function until MM-5 adds per-block.)
# Most recent declaration index of `name` in the env (-1 if absent). Searches
# from the end so a shadowing inner decl wins.
fn var_index(names: [string], name: string) -> int:
    i := len(names) - 1
    for i >= 0:
        if names[i] == name:
            return i
        i = i - 1
    return -1

# The arena a container place lives in (so a push/grow lands where the container
# itself lives). inout-param array/map/soa: its home arena, threaded as the hidden
# `_ina_<name>` param (so the grow frees with the caller's container instead of
# malloc-leaking). inout scalar/struct: malloc ("0", immortal — no _ina_). A var
# declared in the current block (index >= block_base): the block arena, freed at
# block exit / per loop iteration. An outer-scope local: the function _scope.
# Does an array of element type `et` deep-copy its elements (vs shallow memcpy)?
# True for heap element types whose copy fn is reachable from Arr_*_from:
#   - str  -> scopy (preamble; always available).
#   - array (nested [[T]]) -> the inner Arr_*_copy, forward-declared by gen_arr_type.
#   - tuple / heap struct -> Tup_*_copy / Struct_copy, forward-declared (step 5b).
#   - option / result -> re-boxed via hbox/hsome/... (preamble; payload shared,
#     immortal, so shallow). map/non-heap-struct elements stay shallow memcpy.
fn elem_deepcopy(dc: Decls, ctx: Ctx, et: string) -> bool:
    if resolve_nt(dc, ctx, et) == "str":
        return true
    if is_func(et):                                          # a closure element carries an env to re-home on escape
        return true
    if is_array(et):
        return true
    if is_tuple(et):
        return true
    if is_option(et) or is_result(et):                       # re-box into the array's arena
        return true
    if is_enum(dc, ctx, et):                                     # deep-copy the node tree into the arena
        return true
    return is_struct(dc, ctx, et) and struct_is_heap(dc, ctx, et)   # only heap structs have a _copy fn

# The 3rd arg to hbox for an option/result payload of Hier type `ty`, whose boxed
# value sits at `*(<ct>*)valptr`. A HEAP payload (str/array/struct/nested option…)
# is deep-copied into `ar` so it frees with the box instead of leaking at owner-0
# (the [Option(str)]/[Result([int],_)] element residual); a scalar payload's bytes
# live inside the box already, so a shallow re-box (the raw pointer) is sound.
# Mirrors hierc's hier_optN_copy (`if (v.has) v.val = hier_str_copy(a, v.val)`).
fn box_payload(dc: Decls, ctx: Ctx, ty: string, ar: string, valptr: string) -> string:
    ct := cty(dc, ctx, ty)
    if elem_deepcopy(dc, ctx, ty):
        return "(" + ct + "[]){" + cp_field(dc, ctx, ty, ar, "(*(" + ct + "*)(" + valptr + "))") + "}"
    return valptr

# The C expression that deep-copies one element of type `et` (from `src`) into
# arena `ar`. Only called for elem_deepcopy types: str copies its bytes; a
# nested array / tuple / heap struct recurses through its own _copy (re-homing
# its buffer and, transitively, every str/array/struct/tuple sub-element). The
# copy fns are forward-declared (gen_arr_type for arrays; the struct/tuple copy
# protos emitted before the array fns) so order never matters.
fn elem_copy_expr(dc: Decls, ctx: Ctx, et: string, ar: string, src: string) -> string:
    if resolve_nt(dc, ctx, et) == "str":
        return "scopy(" + ar + ", " + src + ")"
    if is_func(et):                                  # a fn value: re-home its env into `ar` (plain ref env==0 -> no-op)
        return "({ Fn_" + func_suffix(et) + " _t = (" + src + "); if (_t.env) _t.env = _t.copyenv(" + ar + ", _t.env); _t; })"
    if is_array(et):
        return "Arr_" + mangle(elem_ty(et)) + "_copy(" + ar + ", " + src + ")"
    if is_tuple(et):
        return "Tup_" + tup_suffix(et) + "_copy(" + ar + ", " + src + ")"
    if is_option(et):                                # re-box the payload into `ar`; box_payload
        ict := cty(dc, ctx, option_inner(et))            # deep-copies a HEAP inner (else shallow re-box)
        return "(" + src + ".tag ? hsome(hbox(" + ar + ", sizeof(" + ict + "), " + box_payload(dc, ctx, option_inner(et), ar, src + ".val") + ")) : hnone())"
    if is_result(et):
        oct := cty(dc, ctx, result_ok(et))
        ect := cty(dc, ctx, result_err(et))
        return "(" + src + ".tag == 1 ? hok(hbox(" + ar + ", sizeof(" + oct + "), " + box_payload(dc, ctx, result_ok(et), ar, src + ".ok") + ")) : herr(hbox(" + ar + ", sizeof(" + ect + "), " + box_payload(dc, ctx, result_err(et), ar, src + ".err") + ")))"
    return tcopy(dc, ctx, et) + "(" + ar + ", " + src + ")"   # heap struct OR enum: S_/E_ _copy

# Deep-copy a value of Hier type `ty` from `src` into arena `ar` (the C expr) —
# full type dispatch, used to copy enum payload fields (which may be any type).
# Scalars / non-heap structs pass through; everything heap routes to its _copy.
fn cp_field(dc: Decls, ctx: Ctx, ty: string, ar: string, src: string) -> string:
    rt := resolve_nt(dc, ctx, ty)
    if rt == "str":
        return "scopy(" + ar + ", " + src + ")"
    if is_func(rt):                                  # a fn value: re-home its env into `ar`
        return "({ Fn_" + func_suffix(rt) + " _t = (" + src + "); if (_t.env) _t.env = _t.copyenv(" + ar + ", _t.env); _t; })"
    if is_array(rt):
        return "Arr_" + mangle(elem_ty(rt)) + "_copy(" + ar + ", " + src + ")"
    if is_map(rt):
        return mfam(rt) + "_copy(" + ar + ", " + src + ")"
    if is_tuple(rt):
        return "Tup_" + tup_suffix(rt) + "_copy(" + ar + ", " + src + ")"
    if is_enum(dc, ctx, rt):
        return tcopy(dc, ctx, rt) + "(" + ar + ", " + src + ")"
    if is_struct(dc, ctx, rt) and struct_is_heap(dc, ctx, rt):
        return tcopy(dc, ctx, rt) + "(" + ar + ", " + src + ")"
    if is_option(rt):
        ict := cty(dc, ctx, option_inner(rt))
        return "(" + src + ".tag ? hsome(hbox(" + ar + ", sizeof(" + ict + "), " + box_payload(dc, ctx, option_inner(rt), ar, src + ".val") + ")) : hnone())"
    if is_result(rt):
        oct := cty(dc, ctx, result_ok(rt))
        ect := cty(dc, ctx, result_err(rt))
        return "(" + src + ".tag == 1 ? hok(hbox(" + ar + ", sizeof(" + oct + "), " + box_payload(dc, ctx, result_ok(rt), ar, src + ".ok") + ")) : herr(hbox(" + ar + ", sizeof(" + ect + "), " + box_payload(dc, ctx, result_err(rt), ar, src + ".err") + ")))"
    if is_soa(rt):
        return "Soa_" + soa_struct(rt) + "_copy(" + ar + ", " + src + ")"
    return src                                              # scalar / bool / non-heap struct

# The block-nesting depth at which env index `vi` was declared: the deepest block
# whose entry index is <= vi (bbases is increasing, so the last match wins). 0 =
# function scope. A var declared in an enclosing block routes to THAT block's arena
# (`&_b<d>`, in scope at any deeper point), not coarsely to `&_scope` — so a
# loop-local grown inside a nested loop still frees per outer-loop iteration.
fn var_block_depth(dc: Decls, ctx: Ctx, vi: int) -> int:
    d := 0
    i := 0
    for i < len(ctx.bbases):
        if ctx.bbases[i] <= vi:
            d = i + 1
        i = i + 1
    return d

fn owner_arena_of(e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    rv := root_var(e)
    if rv == "":
        return "&_scope"
    rvt := var_type(names, types, rv)
    if is_inout(rvt):
        if inout_container_param(dc, ctx, rvt):       # its home arena is threaded as a hidden param
            return "_ina_" + rv
        return "0"                                # inout scalar / struct: no _ina_ (malloc, immortal)
    d := var_block_depth(dc, ctx, var_index(names, rv))
    if d == 0:
        return "&_scope"
    return "&_b" + str(d)

# C zero literal for a scalar map VALUE type, for lowering an rvalue read `m[k]`
# to <family>_get(m, k, <zero>) -- a PURE read (zero on a missing key, NO insert).
# "" => the value is not a scalar (composite/newtype): keep the slot-lvalue path
# (a composite m[k] read still needs an explicit map_get at the source, which the
# C compiler enforces; this stays the find-or-insert slot, as before).
fn map_read_zero(vt: string) -> string:
    if vt == "int":
        return "0"
    elif vt == "bool":
        return "0"
    elif vt == "float":
        return "0.0"
    elif vt == "str":
        return "hi_intern(\"\")"
    return ""

# The slot lvalue for a map place `m[k]`: find-or-insert, deref the value slot
# (#2). A real C lvalue, so it serves a write target / `op=` read-half / push.
# `bt` is the map type of `b`.
fn gen_map_slotptr(b: Expr, i: Expr, bt: string, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    sp := "m" + mtag(map_key(bt)) + "_" + mangle(map_val(bt)) + "_slotptr"
    # the base is a PLACE (gen_place), so a nested map-of-map m1[k1][k2] threads
    # slotptr through, never the read-side map_get from gen_expr.
    return "(*" + sp + "(" + owner_arena_of(b, names, types, dc, ctx) + ", &(" + gen_place(b, names, types, dc, ctx) + "), " + krt(dc, ctx, bt, gen_expr(i, names, types, dc, ctx)) + "))"

# C lvalue for a PLACE (assignment target, or the first arg of push/reserve/pop).
# gen_expr lowers ANY `m[k]` read (scalar OR composite) to a pure map_get, so a
# place must instead take the slot lvalue at every map index. This RECURSES the
# field/index spine so chains like `m[k].f = v`, `m[k][j] = v`, and
# `push(m[k], v)` thread slotptr through the map index instead of map_get. The
# leaf (a variable) and non-map indices/fields are already real lvalues.
fn gen_place(lv: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    match lv:
        EIndex(b, i, _el):
            bt := type_of(b, names, types, dc, ctx)
            if is_map(bt):
                return gen_map_slotptr(b, i, bt, names, types, dc, ctx)
            if is_soa(bt):                          # soa element place: handled via field access (soa[i].f); bare soa[i] target is not a thing
                return gen_expr(lv, names, types, dc, ctx)
            return gen_place(b, names, types, dc, ctx) + ".data[" + gen_expr(i, names, types, dc, ctx) + "]"
        EField(b, f, _el):
            sf := soa_field_access(dc, ctx, b, f, names, types)   # soa[i].f -> (soa).fN[i], a real lvalue
            if sf != "":
                return sf
            if is_tuple(type_of(b, names, types, dc, ctx)):
                return gen_place(b, names, types, dc, ctx) + ".f" + f
            return gen_place(b, names, types, dc, ctx) + "." + uf(f)
        EVar(n, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EInt(t, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EBool(t, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EChar(t, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EFloat(f, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EStr(s, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EBin(o, l, r, _el):
            return gen_expr(lv, names, types, dc, ctx)
        ECall(nm, ar, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EArrLit(es, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EArrEmpty(ty, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EMapEmpty(k, v, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EMapLit(ks, vs, _el):
            return gen_expr(lv, names, types, dc, ctx)
        ETuple(es, _el):
            return gen_expr(lv, names, types, dc, ctx)
        ESlice(b, lo, hi, _el):
            return gen_expr(lv, names, types, dc, ctx)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return gen_expr(lv, names, types, dc, ctx)
        ECallV(callee, cargs, _el):
            return gen_expr(lv, names, types, dc, ctx)
        EAddr(inr, _el):
            return gen_expr(lv, names, types, dc, ctx)
        ESpawn(id, nm, a, _el):
            return gen_expr(lv, names, types, dc, ctx)

# Is `e` a map-place `m[k]` (an EIndex whose base is a map)? Such a place's slot
# lives in the MAP's arena, so a value stored there must be built in that arena —
# NOT at owner 0 (the struct-field/array-element default), where a multi-piece
# map literal's chained `_set` copies leak their abandoned intermediate tables.
fn is_map_index(e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> bool:
    match e:
        EIndex(b, i, _el):
            return is_map(type_of(b, names, types, dc, ctx))
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EVar(n, _el):
            return false
        EBin(o, l, r, _el):
            return false
        ECall(nm, ar, _el):
            return false
        EField(b, f, _el):
            return false
        EArrLit(es, _el):
            return false
        EArrEmpty(ty, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        EMapLit(ks, vs, _el):
            return false
        ETuple(es, _el):
            return false
        ESlice(b, lo, hi, _el):
            return false
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return false
        ECallV(callee, cargs, _el):
            return false
        EAddr(inr, _el):
            return false
        ESpawn(id, nm, a, _el):
            return false

# Is `e` an index into a STRING array (a heap-element slot)? Overwriting such a
# slot can recycle the evicted element back to the array's arena (MM-9), so peak
# RSS tracks the live window not the whole stream. Mirrors hierc's hier_arr_str_set.
fn is_str_arr_index(e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> bool:
    match e:
        EIndex(b, i, _el):
            bt := type_of(b, names, types, dc, ctx)
            return is_array(bt) and elem_ty(bt) == "str"
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EVar(n, _el):
            return false
        EBin(o, l, r, _el):
            return false
        ECall(nm, ar, _el):
            return false
        EField(b, f, _el):
            return false
        EArrLit(es, _el):
            return false
        EArrEmpty(ty, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        EMapLit(ks, vs, _el):
            return false
        ETuple(es, _el):
            return false
        ESlice(b, lo, hi, _el):
            return false
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return false
        ECallV(callee, cargs, _el):
            return false
        EAddr(inr, _el):
            return false
        ESpawn(id, nm, a, _el):
            return false

# Is `e` an existing storage location (vs a fresh value)? Assigning FROM a
# place needs a value-semantic deep copy so the two bindings stay independent.
fn is_place(e: Expr) -> bool:
    match e:
        EVar(n, _el):
            return true
        EField(b, f, _el):
            return true
        EIndex(b, i, _el):
            return true
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EBin(o, l, r, _el):
            return false
        ECall(n, a, _el):
            return false
        EArrLit(es, _el):
            return false
        EArrEmpty(t, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        EMapLit(ks, vs, _el):
            return false
        ETuple(es, _el):
            return false
        ESlice(b, lo, hi, _el):
            return true                          # a slice aliases its source; binding it copies
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return false
        ECallV(callee, cargs, _el):
            return false
        EAddr(inner, _el):
            return false
        ESpawn(id, nm, a, _el):
            return false

# A slice expression already MATERIALIZES an owning copy in ctx.owner
# (Arr_*_slice/substr/gen_soa_slice all allocate fresh into ctx.owner), so unlike
# other places it must NOT be deep-copied again on bind -- that double-allocates
# and leaks the intermediate. gen_rhs returns the slice code directly.
fn is_eslice(e: Expr) -> bool:
    match e:
        ESlice(b, lo, hi, _el):
            return true
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EVar(n, _el):
            return false
        EBin(o, l, r, _el):
            return false
        ECall(n, a, _el):
            return false
        EField(b, f, _el):
            return false
        EIndex(b, i, _el):
            return false
        EArrLit(es, _el):
            return false
        EArrEmpty(t, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        EMapLit(ks, vs, _el):
            return false
        ETuple(es, _el):
            return false
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return false
        ECallV(callee, cargs, _el):
            return false
        EAddr(inner, _el):
            return false
        ESpawn(sid, nm, a, _el):
            return false

fn is_evar(e: Expr, name: string) -> bool:
    match e:
        EVar(n, _el):
            return n == name
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EBin(o, l, r, _el):
            return false
        ECall(nm, a, _el):
            return false
        EField(b, f, _el):
            return false
        EIndex(b, i, _el):
            return false
        EArrLit(es, _el):
            return false
        EArrEmpty(t, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        EMapLit(ks, vs, _el):
            return false
        ETuple(es, _el):
            return false
        ESlice(b, lo, hi, _el):
            return false
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return false
        ECallV(callee, cargs, _el):
            return false
        EAddr(x, _el):
            return false
        ESpawn(sid, snm, sa, _el):
            return false

# Deep-copy a C expression `code` of Hier type `ty` (value semantics for a bind
# whose value may be mutated). Copies the mutable heap containers; scalars,
# strings (immutable), and enum/option/result (immutable) are share-safe.
fn cp_typed(dc: Decls, ctx: Ctx, ty: string, code: string) -> string:
    rt := resolve_nt(dc, ctx, ty)
    if is_array(rt):
        return "Arr_" + mangle(elem_ty(rt)) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_map(rt):
        return mfam(rt) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_tuple(rt):
        return "Tup_" + tup_suffix(rt) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_struct(dc, ctx, rt) and struct_is_heap(dc, ctx, rt):
        return tcopy(dc, ctx, rt) + "(" + ctx.owner + ", " + code + ")"
    return code

# --- move-on-last-use (deep-copy elision) --------------------------------
# `b := a` normally deep-copies a heap value so the two are independent. But if
# `a` is a uniquely-owned local read exactly once in the whole function (so this
# read is its last use, on every path), and that read is not inside a loop (so it
# is a single DYNAMIC read), `b` can take over `a`'s buffer — a move, no copy.
# Mirrors the C compiler's can_move_from. Conditions baked into ctx.movables:
# read-exactly-once + not-in-loop; the rest (heap, not a param, same arena as the
# destination) are checked at the move site. Output-invisible when sound, so the
# fixpoint differential catches any over-aggressive move.
fn evar_name(e: Expr) -> string:
    match e:
        EVar(n, _el):
            return n
        EInt(t, _el):
            return ""
        EBool(t, _el):
            return ""
        EChar(t, _el):
            return ""
        EFloat(f, _el):
            return ""
        EStr(s, _el):
            return ""
        EBin(o, l, r, _el):
            return ""
        ECall(nm, a, _el):
            return ""
        EField(b, f, _el):
            return ""
        EIndex(b, i, _el):
            return ""
        EArrLit(es, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        EMapLit(ks, vs, _el):
            return ""
        ETuple(es, _el):
            return ""
        ESlice(b, lo, hi, _el):
            return ""
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return ""
        ECallV(callee, cargs, _el):
            return ""
        EAddr(x, _el):
            return ""
        ESpawn(sid, snm, sa, _el):
            return ""

fn count_str_occ(xs: [string], s: string) -> int:
    c := 0
    i := 0
    for i < len(xs):
        if xs[i] == s:
            c = c + 1
        i = i + 1
    return c

# ---- push-loop fusion (mirror of hierc's src/hierc.c) ---------------------
# A loop whose body uses a local scalar array ONLY as push(arr,...) gets its
# descriptor (data/len/cap) cached in C locals across the loop, so the hot path
# is a register write; a grow hook runs only on overflow; the descriptor is
# written back at loop exit. Sound by construction: fuse only when reads==pushes
# (used solely as push target), the array is a plain non-inout scalar local not
# defined/shadowed in the body, and (while) the condition does not read it.
fn push_target(e: Expr) -> string:        # var name if e is push(EVar, ...), else ""
    match e:
        ECall(nm, a, _el):
            if nm == "push" and len(a) >= 1:
                return evar_name(a[0])
            return ""
        EVar(n, _el):
            return ""
        EInt(t, _el):
            return ""
        EBool(t, _el):
            return ""
        EChar(t, _el):
            return ""
        EFloat(f, _el):
            return ""
        EStr(s, _el):
            return ""
        EBin(o, l, r, _el):
            return ""
        EField(b, f, _el):
            return ""
        EIndex(b, i, _el):
            return ""
        EArrLit(es, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        EMapLit(ks, vs, _el):
            return ""
        ETuple(es, _el):
            return ""
        ESlice(b, lo, hi, _el):
            return ""
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return ""
        ECallV(callee, cargs, _el):
            return ""
        EAddr(x, _el):
            return ""
        ESpawn(sid, snm, sa, _el):
            return ""

fn fuse_pushcount(stmts: [Stmt], name: string) -> int:
    c := 0
    i := 0
    for i < len(stmts):
        match stmts[i]:
            SExpr(e, _sl):
                if push_target(e) == name:
                    c = c + 1
            SIf(cnd, b, els, _sl):
                c = c + fuse_pushcount(b, name) + fuse_pushcount(els, name)
            SWhile(cnd, b, _sl):
                c = c + fuse_pushcount(b, name)
            SForRange(n, a, bb, st, b, _sl):
                c = c + fuse_pushcount(b, name)
            SMatch(subj, vs, bs, bodies, _sl):
                j := 0
                for j < len(bodies):
                    c = c + fuse_pushcount(bodies[j], name)
                    j = j + 1
            SDecl(n, e, _sl):
                i = i
            SAssign(n, e, _sl):
                i = i
            SFieldAssign(lv, r, _sl):
                i = i
            SPrint(e, _sl):
                i = i
            SReturn(e, _sl):
                i = i
            SReturnVoid:
                i = i
            STypedDecl(n, t, e, _sl):
                i = i
            SOrReturn(n, e, _sl):
                i = i
            SDestructure(ns, e, _sl):
                i = i
            SMultiAssign(ns, e, _sl):
                i = i
            SBreak:
                i = i
            SContinue:
                i = i
            SParFor(v, a, b, body, pid, _sl):
                i = i
            SSelect(uid, svars, schans, sbinds, sbodies, _sl):
                i = i
        i = i + 1
    return c

fn fuse_gather(stmts: [Stmt], out: inout [string]):
    i := 0
    for i < len(stmts):
        match stmts[i]:
            SExpr(e, _sl):
                t := push_target(e)
                if t != "" and count_str_occ(out, t) == 0:
                    push(out, t)
            SIf(cnd, b, els, _sl):
                fuse_gather(b, &out)
                fuse_gather(els, &out)
            SWhile(cnd, b, _sl):
                fuse_gather(b, &out)
            SForRange(n, a, bb, st, b, _sl):
                fuse_gather(b, &out)
            SMatch(subj, vs, bs, bodies, _sl):
                j := 0
                for j < len(bodies):
                    fuse_gather(bodies[j], &out)
                    j = j + 1
            SDecl(n, e, _sl):
                i = i
            SAssign(n, e, _sl):
                i = i
            SFieldAssign(lv, r, _sl):
                i = i
            SPrint(e, _sl):
                i = i
            SReturn(e, _sl):
                i = i
            SReturnVoid:
                i = i
            STypedDecl(n, t, e, _sl):
                i = i
            SOrReturn(n, e, _sl):
                i = i
            SDestructure(ns, e, _sl):
                i = i
            SMultiAssign(ns, e, _sl):
                i = i
            SBreak:
                i = i
            SContinue:
                i = i
            SParFor(v, a, b, body, pid, _sl):
                i = i
            SSelect(uid, svars, schans, sbinds, sbodies, _sl):
                i = i
        i = i + 1

fn fuse_defines(stmts: [Stmt], name: string) -> bool:
    i := 0
    for i < len(stmts):
        match stmts[i]:
            SDecl(n, e, _sl):
                if n == name:
                    return true
            SAssign(n, e, _sl):
                if n == name:
                    return true
            STypedDecl(n, t, e, _sl):
                if n == name:
                    return true
            SOrReturn(n, e, _sl):
                if n == name:
                    return true
            SDestructure(ns, e, _sl):
                if count_str_occ(ns, name) > 0:
                    return true
            SMultiAssign(ns, e, _sl):
                if count_str_occ(ns, name) > 0:
                    return true
            SForRange(n, a, bb, st, b, _sl):
                if n == name:
                    return true
                if fuse_defines(b, name):
                    return true
            SIf(cnd, b, els, _sl):
                if fuse_defines(b, name):
                    return true
                if fuse_defines(els, name):
                    return true
            SWhile(cnd, b, _sl):
                if fuse_defines(b, name):
                    return true
            SMatch(subj, vs, bs, bodies, _sl):
                j := 0
                for j < len(bodies):
                    if count_str_occ(bs[j], name) > 0:
                        return true
                    if fuse_defines(bodies[j], name):
                        return true
                    j = j + 1
            SFieldAssign(lv, r, _sl):
                i = i
            SPrint(e, _sl):
                i = i
            SReturn(e, _sl):
                i = i
            SReturnVoid:
                i = i
            SExpr(e, _sl):
                i = i
            SBreak:
                i = i
            SContinue:
                i = i
            SParFor(v, a, b, body, pid, _sl):
                return true   # a parallel for captures arrays by value -- any live fusion cursor would be stale; fail closed
            SSelect(uid, svars, schans, sbinds, sbodies, _sl):
                return true   # select arm bodies run between cursor writes -- fail closed, like parallel for
        i = i + 1
    return false

fn fuse_envtype(names: [string], types: [string], nm: string) -> string:
    i := len(names) - 1
    for i >= 0:
        if names[i] == nm:
            return types[i]
        i = i - 1
    return ""

fn add_fuse(ctx: Ctx, nm: string, suf: string, ety: string) -> Ctx:
    fa := ctx.fusearr
    fs := ctx.fusesuf
    ft := ctx.fusety
    push(fa, nm)
    push(fs, suf)
    push(ft, ety)
    return Ctx(ctx.vparams, ctx.saccums, ctx.rettype, ctx.owner, ctx.depth, ctx.bbases, ctx.movables, ctx.loopdepth, fa, fs, ft, ctx.line)

# Return the fusible scalar arrays of `body` as parallel (name, cursor-suffix,
# elem-type) lists. A candidate qualifies iff: scalar int/float local (the env
# type is exactly "[int]"/"[float]" -- an inout param reads as "inout [...]" and
# is excluded); not already cached by an enclosing loop; not defined/shadowed in
# the body; used solely as a push target (reads == pushes); and, for a while
# loop, not read by the condition (which re-evaluates each iteration).
fn fuse_detect(body: [Stmt], names: [string], types: [string], dc: Decls, ctx: Ctx, guard: Expr, useguard: bool) -> ([string], [string], [string]):
    cand := []string
    fuse_gather(body, &cand)
    reads := []string
    lr := []string
    rd_block(&reads, &lr, body, false)
    greads := []string
    glr := []string
    if useguard:
        rd_expr(&greads, &glr, guard, false)
    fnm := []string
    fsf := []string
    fty := []string
    i := 0
    for i < len(cand):
        nm := cand[i]
        et := fuse_envtype(names, types, nm)
        ok := true
        if not is_array(et):                          # any array element type (scalar/str/struct/tuple/...); inout + soa excluded by is_array
            ok = false
        if count_str_occ(ctx.fusearr, nm) > 0:
            ok = false
        if fuse_defines(body, nm):
            ok = false
        if count_str_occ(reads, nm) != fuse_pushcount(body, nm):
            ok = false
        if useguard and count_str_occ(greads, nm) > 0:
            ok = false
        if ok:
            push(fnm, nm)
            push(fsf, str(ctx.depth) + "_" + str(len(fnm) - 1))
            push(fty, elem_ty(et))
        i = i + 1
    return (fnm, fsf, fty)

# Collect every variable READ (expression occurrence), and separately those read
# inside a loop body/condition. A name read exactly once and never in a loop is a
# move candidate. (Decl/loop-var/assign-target NAMES are writes — not collected.)
fn rd_expr(reads: inout [string], loopreads: inout [string], e: Expr, inloop: bool):
    match e:
        EVar(n, _el):
            push(reads, n)
            if inloop:
                push(loopreads, n)
        EBin(o, l, r, _el):
            rd_expr(&reads, &loopreads, l, inloop)
            rd_expr(&reads, &loopreads, r, inloop)
        ECall(nm, args, _el):
            j := 0
            for j < len(args):
                rd_expr(&reads, &loopreads, args[j], inloop)
                j = j + 1
        EField(b, f, _el):
            rd_expr(&reads, &loopreads, b, inloop)
        EIndex(b, idx, _el):
            rd_expr(&reads, &loopreads, b, inloop)
            rd_expr(&reads, &loopreads, idx, inloop)
        ESlice(b, lo, hi, _el):
            rd_expr(&reads, &loopreads, b, inloop)
            rd_expr(&reads, &loopreads, lo, inloop)
            rd_expr(&reads, &loopreads, hi, inloop)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            j := 0
            for j < len(cn):
                push(reads, cn[j])
                j = j + 1
        ECallV(callee, cargs, _el):
            rd_expr(&reads, &loopreads, callee, inloop)
            j := 0
            for j < len(cargs):
                rd_expr(&reads, &loopreads, cargs[j], inloop)
                j = j + 1
        EAddr(x, _el):
            rd_expr(&reads, &loopreads, x, inloop)
        EArrLit(es, _el):
            j := 0
            for j < len(es):
                rd_expr(&reads, &loopreads, es[j], inloop)
                j = j + 1
        EMapLit(ks, vs, _el):
            j := 0
            for j < len(vs):
                rd_expr(&reads, &loopreads, ks[j], inloop)
                rd_expr(&reads, &loopreads, vs[j], inloop)
                j = j + 1
        ETuple(es, _el):
            j := 0
            for j < len(es):
                rd_expr(&reads, &loopreads, es[j], inloop)
                j = j + 1
        EInt(t, _el):
            j := 0
        EBool(t, _el):
            j := 0
        EChar(t, _el):
            j := 0
        EFloat(f, _el):
            j := 0
        EStr(s, _el):
            j := 0
        EArrEmpty(t, _el):
            j := 0
        EMapEmpty(k, v, _el):
            j := 0
        ESpawn(sid, snm, sa, _el):
            j := 0                                # spawn args read as if in a loop: never move-eligible (the
            for j < len(sa):                      # site always deep-copies into the task root -- keep it that way)
                rd_expr(&reads, &loopreads, sa[j], true)
                j = j + 1

fn rd_block(reads: inout [string], loopreads: inout [string], stmts: [Stmt], inloop: bool):
    i := 0
    for i < len(stmts):
        rd_stmt(&reads, &loopreads, stmts[i], inloop)
        i = i + 1

fn rd_stmt(reads: inout [string], loopreads: inout [string], s: Stmt, inloop: bool):
    match s:
        SDecl(n, e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SAssign(n, e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SFieldAssign(lv, rhs, _sl):
            rd_expr(&reads, &loopreads, lv, inloop)
            rd_expr(&reads, &loopreads, rhs, inloop)
        SPrint(e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SReturn(e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SReturnVoid:
            j := 0
        SBreak:
            j := 0
        SContinue:
            j := 0
        SExpr(e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        STypedDecl(n, t, e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SOrReturn(n, e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SDestructure(dnames, e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SMultiAssign(mnames, e, _sl):
            rd_expr(&reads, &loopreads, e, inloop)
        SIf(c, tb, eb, _sl):
            rd_expr(&reads, &loopreads, c, inloop)
            rd_block(&reads, &loopreads, tb, inloop)
            rd_block(&reads, &loopreads, eb, inloop)
        SWhile(c, body, _sl):
            rd_expr(&reads, &loopreads, c, true)
            rd_block(&reads, &loopreads, body, true)
        SForRange(n, a, b, st, body, _sl):
            rd_expr(&reads, &loopreads, a, inloop)
            rd_expr(&reads, &loopreads, b, inloop)
            rd_expr(&reads, &loopreads, st, inloop)
            rd_block(&reads, &loopreads, body, true)
        SMatch(subj, variants, allbinds, bodies, _sl):
            rd_expr(&reads, &loopreads, subj, inloop)
            j := 0
            for j < len(bodies):
                rd_block(&reads, &loopreads, bodies[j], inloop)
                j = j + 1
        SParFor(v, a, b, body, pid, _sl):
            rd_expr(&reads, &loopreads, a, inloop)
            rd_expr(&reads, &loopreads, b, inloop)
            rd_block(&reads, &loopreads, body, true)   # captured reads run N times across chunks: never move-eligible
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            sk := 0
            for sk < len(svars):
                rd_expr(&reads, &loopreads, schans[sk], true)   # the retry loop re-reads the channel exprs
                rd_block(&reads, &loopreads, sbodies[sk], inloop)
                sk = sk + 1

fn compute_movables(body: [Stmt]) -> [string]:
    reads := []string
    loopreads := []string
    rd_block(&reads, &loopreads, body, false)
    # movable = read exactly once AND never inside a loop. The old form called
    # count_str_occ(reads, n) per element = O(reads^2); a one-pass frequency map
    # + a loopreads set makes it O(reads). (The old `not has_str(mv, n)` guard was
    # redundant: a name read once is pushed at most once.)
    freq := []string: int
    lset := []string: int
    i := 0
    for i < len(loopreads):
        lset = map_set(lset, loopreads[i], 1)
        i = i + 1
    i = 0
    for i < len(reads):
        freq = map_set(freq, reads[i], map_get(freq, reads[i], 0) + 1)
        i = i + 1
    mv := []string
    i = 0
    for i < len(reads):
        n := reads[i]
        if map_get(freq, n, 0) == 1 and map_get(lset, n, 0) == 0:
            push(mv, n)
        i = i + 1
    return mv

# May `gen_rhs(e)` move e's buffer (return it as-is) instead of deep-copying?
# e is a bare local var of heap type, read exactly once and not in a loop
# (ctx.movables), not a param (params borrow the caller's buffer), and its home
# arena equals the destination owner (so the handed-off buffer's lifetime fits).
fn can_move(e: Expr, ty: string, names: [string], types: [string], dc: Decls, ctx: Ctx) -> bool:
    nm := evar_name(e)
    if nm == "":
        return false
    if not has_str(ctx.movables, nm):
        return false
    if var_index(names, nm) < 0:                  # an EVar that is not a local (a bare enum variant
        return false                              # like `Leaf`) — not a movable variable
    rt := resolve_nt(dc, ctx, ty)
    isheap := is_array(rt) or is_map(rt) or is_tuple(rt) or is_enum(dc, ctx, rt) or (is_struct(dc, ctx, rt) and struct_is_heap(dc, ctx, rt))
    if not isheap:
        return false
    if has_str(ctx.vparams, nm) or is_inout(var_type(names, types, nm)):   # never move a param (borrowed)
        return false
    return owner_arena_of(e, names, types, dc, ctx) == ctx.owner

# RHS of a whole-value binding: deep-copy an array read from a place so the new
# binding is independent (Hier value semantics). Fresh arrays (literals, call
# results) already own their buffer; scalars/strings need no copy.
fn gen_rhs(e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    code := gen_expr(e, names, types, dc, ctx)
    ty := type_of(e, names, types, dc, ctx)
    if can_move(e, ty, names, types, dc, ctx):       # move-on-last-use: hand off the buffer, elide the copy
        return code
    if is_eslice(e) and (is_array(ty) or ty == "str"):   # array/str slices already own (Arr_*_slice/substr
        return code                                      # build fresh in ctx.owner) -- no double copy. A SOA slice
                                                         # is a VIEW (cap 0), so it falls through to Soa_*_copy below.
    if is_array(ty) and is_place(e):
        return "Arr_" + mangle(elem_ty(ty)) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_struct(dc, ctx, ty) and struct_is_heap(dc, ctx, ty) and is_place(e):
        return tcopy(dc, ctx, ty) + "(" + ctx.owner + ", " + code + ")"
    if is_map(ty) and is_place(e):               # value-semantic map copy (e.g. snap := counts)
        return mfam(ty) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_tuple(ty) and is_place(e):             # value-semantic tuple copy (b := a)
        return "Tup_" + tup_suffix(ty) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_soa(ty) and is_place(e):               # value-semantic soa copy (bind/pass/return)
        return "Soa_" + soa_struct(ty) + "_copy(" + ctx.owner + ", " + code + ")"
    if is_enum(dc, ctx, ty) and is_place(e) and var_index(names, root_var(e)) >= 0:   # a REAL enum place (var/
        return tcopy(dc, ctx, ty) + "(" + ctx.owner + ", " + code + ")"   # field/elem) escaping -> deep-copy. NOT a bare nullary-variant ctor (`return Leaf`), which is already fresh. Match arms BORROW (cp_typed).
    if (is_option(ty) or is_result(ty)) and is_place(e) and var_index(names, root_var(e)) >= 0:   # a REAL option/result
        return elem_copy_expr(dc, ctx, ty, ctx.owner, code)     # place (var/field/elem, not the bare `None` ctor): re-box into ctx.owner

    if ty == "str" and is_place(e):              # copy a string bound from a place, so an
        return "scopy(" + ctx.owner + ", " + code + ")" # in-place-appended accumulator's snapshot stays independent
    return code

# A scalar (non-heap) result type. When an assignment/decl LHS is scalar, the
# whole RHS value carries no heap, so every heap value built while evaluating it
# is transient (consumed in the statement, never stored) and can be reclaimed.
fn is_scalar_ty(dc: Decls, ctx: Ctx, ty: string) -> bool:
    rt := resolve_nt(dc, ctx, ty)
    return rt == "int" or rt == "float" or rt == "bool"

# Does `e` contain a call anywhere? A call is the only thing that can allocate a
# heap transient, so a call-free scalar RHS (e.g. `i + 1`) needs no transient
# arena — this keeps the hot loop-counter assignments allocation-free.
fn expr_has_call(e: Expr) -> bool:
    match e:
        ECall(n, a, _el):
            return true
        EBin(o, l, r, _el):
            return expr_has_call(l) or expr_has_call(r)
        EField(b, f, _el):
            return expr_has_call(b)
        EIndex(b, i, _el):
            return expr_has_call(b) or expr_has_call(i)
        ESlice(b, lo, hi, _el):
            return expr_has_call(b) or expr_has_call(lo) or expr_has_call(hi)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return false
        ECallV(callee, cargs, _el):
            return true
        EAddr(x, _el):
            return expr_has_call(x)
        EArrLit(es, _el):
            return any_has_call(es)
        EMapLit(ks, vs, _el):
            return any_has_call(ks) or any_has_call(vs)
        ETuple(es, _el):
            return any_has_call(es)
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EVar(n, _el):
            return false
        EArrEmpty(t, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        ESpawn(sid, snm, sa, _el):
            return true                           # a spawn site allocates (task root + arg copies)

fn any_has_call(es: [Expr]) -> bool:
    i := 0
    for i < len(es):
        if expr_has_call(es[i]):
            return true
        i = i + 1
    return false

# Does the expression subtree reference the identifier `name`? Used as the
# alias guard for multi-piece string appends: by value semantics the
# accumulator uniquely owns its buffer, so a piece can only alias it by NAMING
# it. Mirrors expr_has_call's exhaustive structure.
fn expr_refs(e: Expr, name: string) -> bool:
    match e:
        EVar(n, _el):
            return n == name
        EBin(o, l, r, _el):
            return expr_refs(l, name) or expr_refs(r, name)
        ECall(nm, a, _el):
            return any_refs(a, name)
        EField(b, f, _el):
            return expr_refs(b, name)
        EIndex(b, i, _el):
            return expr_refs(b, name) or expr_refs(i, name)
        ESlice(b, lo, hi, _el):
            return expr_refs(b, name) or expr_refs(lo, name) or expr_refs(hi, name)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            j := 0
            for j < len(cn):
                if cn[j] == name:
                    return true
                j = j + 1
            return false
        ECallV(callee, cargs, _el):
            if expr_refs(callee, name):
                return true
            j := 0
            for j < len(cargs):
                if expr_refs(cargs[j], name):
                    return true
                j = j + 1
            return false
        EAddr(x, _el):
            return expr_refs(x, name)
        EArrLit(es, _el):
            return any_refs(es, name)
        EMapLit(ks, vs, _el):
            return any_refs(ks, name) or any_refs(vs, name)
        ETuple(es, _el):
            return any_refs(es, name)
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(f, _el):
            return false
        EStr(s, _el):
            return false
        EArrEmpty(t, _el):
            return false
        EMapEmpty(k, v, _el):
            return false
        ESpawn(sid, snm, sa, _el):
            return any_refs(sa, name)

fn any_refs(es: [Expr], name: string) -> bool:
    i := 0
    for i < len(es):
        if expr_refs(es[i], name):
            return true
        i = i + 1
    return false

# A scalar assignment/decl whose RHS makes a call: evaluate the RHS in a fresh
# per-statement arena `_t` and free it after the scalar result is stored — so a
# heap transient (e.g. the tree in `sum = sum + check(make(d))`) is reclaimed at
# the statement, not retained in the enclosing scope. `assign` is the C lvalue +
# " = " (the decl declares it first); stores inside the RHS still route to their
# own arena (owner_arena_of), so only true transients land in `_t`.
fn scalar_transient(dc: Decls, ctx: Ctx, e: Expr, names: [string], types: [string], assign: string) -> string:
    return "    { Arena _t = arena_new(0); " + assign + gen_rhs(e, names, types, dc, with_owner(dc, ctx, "&_t")) + "; arena_free(&_t); }\n"

# names/types are passed BY VALUE so a block's decls never escape to sibling
# or outer scopes (matching C/Hier block scoping).
fn gen_block(stmts: [Stmt], names: [string], types: [string], dc: Decls, ctx: Ctx) -> string:
    out := ""
    ns := names                                  # local mutable copies; decls
    ts := types                                  # added here stay block-local
    entry := len(ns)                             # CC-2: finalizer sentinels above this die at block end
    i := 0
    for i < len(stmts):
        out = out + gen_stmt(stmts[i], &ns, &ts, dc, ctx)
        i = i + 1
    fin := conc_finals(ns, entry)                # implicit join / channel free at every normal block exit
    if fin != "":                                # (dead C after a trailing return -- the return path already ran them)
        out = out + "    " + fin + "\n"
    return out

# CC-2 implicit join / CC-4 channel free: SDecl pushes a "!<finalizer-call>"
# sentinel into the names env (with a "!" placeholder type, keeping the arrays
# in lockstep); no user identifier can start with '!' so name lookups never
# collide. Every scope exit emits the pending calls LIFO -- gen_block covers
# block/iteration/proc-body ends, the return paths cover early exits (incl.
# or_return), break/continue cover loop escapes via bbases[loopdepth-1].
fn conc_finals(names: [string], from: int) -> string:
    out := ""
    i := len(names) - 1
    for i >= from:
        if len(names[i]) > 0 and names[i][0] == 33:   # '!' sentinel
            out = out + substr(names[i], 1, len(names[i])) + "; "
        i = i - 1
    return out

fn conc_loop_finals(names: [string], ctx: Ctx) -> string:   # finals since the innermost loop body's entry
    if ctx.loopdepth < 1 or len(ctx.bbases) < ctx.loopdepth:
        return ""
    return conc_finals(names, ctx.bbases[ctx.loopdepth - 1])

fn gen_stmt(s: Stmt, names: inout [string], types: inout [string], dc: Decls, ctx: Ctx) -> string:
    _el := 0
    ctx = with_line(ctx, stmt_line(s))            # statement line for any resolve/codegen die() within
    match s:
        SDecl(name, e, _sl):
            di := 0                                   # fail-closed: a same-scope re-`:=` (incl. shadowing a param at the top level, both depth 0) would emit a duplicate C local; nested-block shadowing stays legal (different depth)
            for di < len(names):
                if names[di] == name and var_block_depth(dc, ctx, di) == ctx.depth:
                    die("'" + name + "' is already declared in this scope")
                di = di + 1
            ty := type_of(e, names, types, dc, ctx)
            if has_str(ctx.saccums, name):        # string accumulator: buffer in the var's arena + len/cap sidecars
                push(names, name)
                push(types, ty)
                aar := owner_arena_of(EVar(name, _el), names, types, dc, ctx)   # grow in the var's home arena (freed with it, not leaked)
                code := "    char* " + un(name) + " = scopy(" + aar + ", " + gen_expr(e, names, types, dc, ctx) + ");\n    long _len_" + un(name) + " = strlen(" + un(name) + ");\n    long _cap_" + un(name) + " = _len_" + un(name) + " + 1;\n"
                return code
            if is_scalar_ty(dc, ctx, ty) and expr_has_call(e):   # transient placement (see scalar_transient)
                code := "    " + cty(dc, ctx, ty) + un(name) + ";\n" + scalar_transient(dc, ctx, e, names, types, un(name) + " = ")
                push(names, name)
                push(types, ty)
                if is_task(ty):                   # CC-2: implicit join at this var's scope exit
                    push(names, "!hier_task_finish(" + un(name) + ")")
                    push(types, "!")
                if is_chan(ty) and expr_has_call(e):   # CC-4: a CREATED channel (not an alias) frees at its scope exit
                    push(names, "!hier_chan_free(" + un(name) + ")")
                    push(types, "!")
                return code
            init := " = "
            if expr_refs(e, name):                # value semantics: a self-referential shadow `y := y + 2` reads the NEW binding (its type's zero value), so zero-init before the assignment -- else the C local reads itself uninitialized (UB)
                init = " = {0}; " + un(name) + " = "
            code := "    " + cty(dc, ctx, ty) + un(name) + init + gen_rhs(e, names, types, dc, ctx) + ";\n"
            push(names, name)                     # in scope for later stmts
            push(types, ty)
            if is_task(ty):                       # CC-2 (see the transient path above)
                push(names, "!hier_task_finish(" + un(name) + ")")
                push(types, "!")
            if is_chan(ty) and expr_has_call(e):
                push(names, "!hier_chan_free(" + un(name) + ")")
                push(types, "!")
            return code
        SAssign(name, e, _sl):
            lhs := gen_expr(EVar(name, _el), names, types, dc, ctx)
            if is_scalar_ty(dc, ctx, type_of(EVar(name, _el), names, types, dc, ctx)) and expr_has_call(e):   # transient placement
                return scalar_transient(dc, ctx, e, names, types, lhs + " = ")
            if has_str(ctx.saccums, name):        # string accumulator
                aar := owner_arena_of(EVar(name, _el), names, types, dc, ctx)   # the var's home arena (consistent with its decl)
                pieces := sacc_pieces(e, name)
                # multi-piece in-place is sound only if no piece names the
                # accumulator: the first append grows its buffer, so a later
                # piece reading `name` would see the grown value. A single piece
                # passes straight through (runtime handles s=s+s). Otherwise fall
                # back to the pure-concat scopy path below.
                if len(pieces) > 0 and (len(pieces) == 1 or not any_refs(pieces, name)):   # s = s + p1 + ... -> in-place append each piece
                    aout := ""
                    k := 0
                    for k < len(pieces):
                        if type_of(pieces[k], names, types, dc, ctx) == "char":   # one-byte append, no strlen
                            aout = aout + "    hi_append_char(" + aar + ", &" + un(name) + ", &_len_" + un(name) + ", &_cap_" + un(name) + ", " + gen_expr(pieces[k], names, types, dc, ctx) + ");\n"
                        else:
                            aout = aout + "    hi_append(" + aar + ", &" + un(name) + ", &_len_" + un(name) + ", &_cap_" + un(name) + ", " + gen_expr(pieces[k], names, types, dc, ctx) + ");\n"
                        k = k + 1
                    return aout
                # plain reassign of an accumulator: heap-ify + resync the sidecars
                return "    " + un(name) + " = scopy(" + aar + ", " + gen_expr(e, names, types, dc, ctx) + ");\n    _len_" + un(name) + " = strlen(" + un(name) + ");\n    _cap_" + un(name) + " = _len_" + un(name) + " + 1;\n"
            deflt := "    " + lhs + " = " + gen_rhs(e, names, types, dc, with_owner(dc, ctx, owner_arena_of(EVar(name, _el), names, types, dc, ctx))) + ";\n"   # build in the var's home arena (block-local -> block; outer -> &_scope)
            # liveness-driven recycle (ANY array RHS: call / slice / copybind / literal).
            # a's old buffer is dead and -- value semantics -- uniquely owned, GATED on
            # NOT movable so `name` is never a move source whose buffer is shared via
            # `b := a`. The new value is always a DISTINCT fresh buffer (a place RHS is
            # deep-copied by gen_rhs; a call/literal is fresh), enforced by the runtime
            # `.data != .data` guard. Eval the RHS into a { }-scoped temp FIRST (it may
            # read the old buffer), THEN recycle, THEN assign. is_array excludes maps, so
            # the map_set in-place put below is unaffected.
            rnty := type_of(EVar(name, _el), names, types, dc, ctx)
            rown := owner_arena_of(EVar(name, _el), names, types, dc, ctx)
            if is_array(rnty) and not has_str(ctx.vparams, name) and not is_inout(var_type(names, types, name)) and not has_str(ctx.movables, name) and rown != "0":
                return "    { " + cty(dc, ctx, rnty) + "_r = " + gen_rhs(e, names, types, dc, with_owner(dc, ctx, rown)) + "; if (" + lhs + ".data && " + lhs + ".data != _r.data) arena_recycle(" + rown + ", " + lhs + ".data, (size_t)" + lhs + ".cap * sizeof(*" + lhs + ".data)); " + lhs + " = _r; }\n"
            match e:                              # accumulator rewrite: x = map_set(x,k,v) -> in-place put
                # A by-value map PARAM must NOT take the in-place put: it shares
                # the caller's table, so mutating it in place is a value-semantics
                # violation. ctx.vparams holds this func's non-inout params; for
                # those we fall through to `deflt` (pure map_set = deep-copy+put),
                # matching the C compiler (src/hierc.c:3556 drops non-inout params
                # from accums). Locals and inout map params still grow in place.
                ECall(fname, args, _el):
                    if fname == "map_set" and is_evar(args[0], name) and not has_str(ctx.vparams, name):
                        return "    " + mfam(type_of(EVar(name, _el), names, types, dc, ctx)) + "_put(" + owner_arena_of(EVar(name, _el), names, types, dc, ctx) + ", &" + lhs + ", " + krt(dc, ctx, type_of(EVar(name, _el), names, types, dc, ctx), gen_expr(args[1], names, types, dc, ctx)) + ", " + gen_expr(args[2], names, types, dc, ctx) + ");\n"
                    return deflt
                EInt(t, _el):
                    return deflt
                EBool(t, _el):
                    return deflt
                EChar(t, _el):
                    return deflt
                EFloat(f, _el):
                    return deflt
                EStr(s, _el):
                    return deflt
                EVar(n, _el):
                    return deflt
                EBin(o, l, r, _el):
                    return deflt
                EField(b, f, _el):
                    return deflt
                EIndex(b, i, _el):
                    return deflt
                EArrLit(es, _el):
                    return deflt
                EArrEmpty(t, _el):
                    return deflt
                EMapEmpty(k, v, _el):
                    return deflt
                EMapLit(ks, vs, _el):
                    return deflt
                ETuple(es, _el):
                    return deflt
                ESlice(b, lo, hi, _el):
                    return deflt
                ECallV(callee, cargs, _el):
                    return deflt
                EAddr(x, _el):
                    return deflt
                ELambda(id, ps, pts, ret, body, cn, ct, _el):
                    return deflt
                ESpawn(sid, snm, sa, _el):
                    return deflt
        SFieldAssign(lv, rhs, _sl):
            # storing into a (malloc) struct field / array element: the value must
            # be malloc'd (owner "0"), not left in _scope which frees at return.
            # EXCEPT a map-place m[k]: its slot lives in the map's own arena, so
            # build the value there — owner 0 would leak a multi-piece map literal's
            # chained-_set intermediate tables (the slotptr store doesn't re-home it).
            # MM-9: overwriting a string-array slot. Place the new element in the
            # array's OWN arena (oa) -- not malloc (owner 0), which would leak every
            # evicted record -- and recycle the dead old element so the next store
            # reuses it. Reads deep-copy out (value semantics) so the old buffer is
            # uniquely owned + dead. Build new BEFORE recycling (the rhs may read the
            # slot, e.g. a[k]=a[k]+x); arena_owns gates out literals/cross-arena
            # pointers; _o != slot rules out recycling the freshly-stored buffer.
            if is_str_arr_index(lv, names, types, dc, ctx):
                oa := owner_arena_of(lv, names, types, dc, ctx)
                slot := gen_expr(lv, names, types, dc, ctx)
                nv := gen_rhs(rhs, names, types, dc, with_owner(dc, ctx, oa))
                return "    { char* _o = " + slot + "; " + slot + " = " + nv + "; if (_o && _o != " + slot + " && arena_owns(" + oa + ", _o - 8)) arena_recycle(" + oa + ", _o - 8, (size_t)(((const long*)_o)[-1] + 16) & ~(size_t)7); }\n"
            sfo := "0"
            if is_scalar_ty(dc, ctx, type_of(lv, names, types, dc, ctx)):
                sfo = ctx.owner    # a scalar slot stores a value word; build the RHS (and any nested transient, e.g. str() inside len()) in the current scope so it frees, not malloc'd at owner-0 and leaked
            if is_map_index(lv, names, types, dc, ctx):
                sfo = owner_arena_of(lv, names, types, dc, ctx)
            return "    " + gen_place(lv, names, types, dc, ctx) + " = " + gen_rhs(rhs, names, types, dc, with_owner(dc, ctx, sfo)) + ";\n"
        SPrint(e, _sl):
            if type_of(e, names, types, dc, ctx) != "str":
                die_at(dc, ctx.line, "codegen: print expects a string")
            # transient arena: the print arg's string temporaries are consumed by
            # fputs and never escape, so build them in _t and free it right after.
            return "    { Arena _t = arena_new(0); fputs(" + gen_expr(e, names, types, dc, with_owner(dc, ctx, "&_t")) + ", stdout); arena_free(&_t); }\n"
        SReturn(e, _sl):
            # deep-copy a returned heap PLACE (a field/element/variable): the
            # return value outlives the callee, so it must not alias the source's
            # buffer (`return b.items` then the caller mutates the result must not
            # reach b). gen_rhs copies is_place array/struct/map/tuple; fresh
            # values / scalars / strings pass through. (tests/value_semantics.hi
            # probe 9; the C compiler does this via return-promotion.)
            # return-slot: evaluate into _ret, free this scope, then return _ret.
            # (S1: the value is still malloc'd, so the free reclaims nothing; later
            # sub-steps build the return value in _parent so this stays sound.)
            # build the return value in _parent (the caller's arena, which outlives
            # _scope), then free _scope. Any string the value reaches is either built
            # in _parent here or, if stored into a constructed container, forced to
            # malloc by the store sites (gen_store_args/ETuple/map_set/hbox) — so the
            # returned value never points into the freed _scope.
            # free every enclosing block arena (return_frees), innermost-first,
            # then _scope; the value is in _parent which outlives them all.
            # push-loop fusion: a return leaves before the after-loop flush, so write
            # every live cursor back first (the returned value must see the real length)
            rfl := ""
            fk := 0
            for fk < len(ctx.fusearr):
                rfl = rfl + "    " + un(ctx.fusearr[fk]) + ".data = _fd" + ctx.fusesuf[fk] + "; " + un(ctx.fusearr[fk]) + ".len = _fl" + ctx.fusesuf[fk] + "; " + un(ctx.fusearr[fk]) + ".cap = _fc" + ctx.fusesuf[fk] + ";\n"
                fk = fk + 1
            if is_func(ctx.rettype):              # escaping closure: re-home the captured env into _parent before freeing _scope (its hbox lives in &_scope); plain ref has env==0 -> no-op
                return rfl + "    { " + cty(dc, ctx, ctx.rettype) + "_ret = " + gen_expr(e, names, types, dc, ctx) + "; if (_ret.env) _ret.env = _ret.copyenv(_parent, _ret.env); " + conc_finals(names, 0) + return_frees(dc, ctx) + " return _ret; }\n"
            return rfl + "    { " + cty(dc, ctx, ctx.rettype) + "_ret = " + gen_rhs(e, names, types, dc, with_owner(dc, ctx, "_parent")) + "; " + conc_finals(names, 0) + return_frees(dc, ctx) + " return _ret; }\n"
        SReturnVoid:
            return "    " + conc_finals(names, 0) + return_frees(dc, ctx) + " return;\n"
        SBreak:
            return "    " + conc_loop_finals(names, ctx) + loop_frees(dc, ctx) + "break;\n"
        SContinue:
            return "    " + conc_loop_finals(names, ctx) + loop_frees(dc, ctx) + "continue;\n"
        SExpr(e, _sl):                                 # MM-10: discarded result -> all transients dead at stmt end; free them in a per-stmt _t arena (matches hierc S_EXPR + scalar_transient)
            pn := pure_call_name(e)                     # warn on a discarded pure-builtin result (no-op statement)
            if pn != "":
                warn_at(dc, _sl, "result of " + pn + " is discarded; it has no side effects, so this statement does nothing (map_set/map_del return a new map: use m = map_set(...) or m[k] = v)")
            return "    { Arena _t = arena_new(0); " + gen_expr(e, names, types, dc, with_owner(dc, ctx, "&_t")) + "; arena_free(&_t); }\n"
        STypedDecl(name, ty, e, _sl):                  # annotation fixes the var's type
            if has_str(ctx.saccums, name):        # string accumulator (annotated): same heap buffer + sidecars
                push(names, name)
                push(types, ty)
                aar := owner_arena_of(EVar(name, _el), names, types, dc, ctx)   # grow in the var's home arena (freed with it, not leaked) — mirrors the SDecl saccum path; scopy(0,...) here was a malloc leak
                code := "    char* " + un(name) + " = scopy(" + aar + ", " + gen_expr(e, names, types, dc, ctx) + ");\n    long _len_" + un(name) + " = strlen(" + un(name) + ");\n    long _cap_" + un(name) + " = _len_" + un(name) + " + 1;\n"
                return code
            if is_scalar_ty(dc, ctx, ty) and expr_has_call(e):   # transient placement
                code := "    " + cty(dc, ctx, ty) + un(name) + ";\n" + scalar_transient(dc, ctx, e, names, types, un(name) + " = ")
                push(names, name)
                push(types, ty)
                return code
            code := "    " + cty(dc, ctx, ty) + un(name) + " = " + gen_rhs(e, names, types, dc, ctx) + ";\n"
            push(names, name)
            push(types, ty)
            return code
        SDestructure(dnames, e, _sl):                  # a, b := tuple_expr
            tt := type_of(e, names, types, dc, ctx)
            parts := tuple_parts(tt)
            tmp := "_d_" + dnames[0]
            code := "    Tup_" + tup_suffix(tt) + " " + tmp + " = " + gen_expr(e, names, types, dc, ctx) + ";\n"
            j := 0
            for j < len(dnames):
                code = code + "    " + cty(dc, ctx, parts[j]) + un(dnames[j]) + " = " + tmp + ".f" + str(j) + ";\n"
                push(names, dnames[j])
                push(types, parts[j])
                j = j + 1
            return code
        SMultiAssign(mnames, e, _sl):                  # a, b = tuple_expr (existing vars)
            tt := type_of(e, names, types, dc, ctx)
            tmp := "_ma_" + mnames[0]
            # brace-scope the temp: two multi-assigns with the same first target in
            # one block must not redefine it (hierc names its temp _mt<g_blk++>)
            code := "    { Tup_" + tup_suffix(tt) + " " + tmp + " = " + gen_expr(e, names, types, dc, ctx) + ";\n"
            j := 0
            for j < len(mnames):
                code = code + "    " + un(mnames[j]) + " = " + tmp + ".f" + str(j) + ";\n"
                j = j + 1
            return code + "    }\n"
        SOrReturn(name, e, _sl):                       # unwrap Ok/Some, or propagate Err/None upward
            rty := type_of(e, names, types, dc, ctx)
            tmp := "_or_" + name
            # the early return leaves the function like SReturn does: flush any
            # live push-loop fusion cursors, then free every enclosing block
            # arena + _scope (return_frees) — skipping them leaked every arena
            # on the error path. The Err payload is promoted into _parent BEFORE
            # the frees (it points into a scope we are about to free), exactly
            # like hierc's E_ORRETURN (src/hierc.c:4135).
            orfl := ""
            ofk := 0
            for ofk < len(ctx.fusearr):
                orfl = orfl + "    " + un(ctx.fusearr[ofk]) + ".data = _fd" + ctx.fusesuf[ofk] + "; " + un(ctx.fusearr[ofk]) + ".len = _fl" + ctx.fusesuf[ofk] + "; " + un(ctx.fusearr[ofk]) + ".cap = _fc" + ctx.fusesuf[ofk] + ";\n"
                ofk = ofk + 1
            if is_option(rty):                    # Option: unwrap Some, else return None
                cto := cty(dc, ctx, option_inner(rty))
                oc := "    HOption " + tmp + " = " + gen_expr(e, names, types, dc, ctx) + ";\n"
                oc = oc + "    if (" + tmp + ".tag == 0) {\n" + orfl + "    " + conc_finals(names, 0) + return_frees(dc, ctx) + " return hnone(); }\n"
                oc = oc + "    " + cto + un(name) + " = *(" + cto + "*)(" + tmp + ".val);\n"
                push(names, name)
                push(types, option_inner(rty))
                return oc
            ct := cty(dc, ctx, result_ok(rty))
            ect := cty(dc, ctx, result_err(rty))
            code := "    HResult " + tmp + " = " + gen_expr(e, names, types, dc, ctx) + ";\n"
            code = code + "    if (" + tmp + ".tag == 0) {\n" + orfl + "    HResult _re_" + name + " = herr(hbox(_parent, sizeof(" + ect + "), " + box_payload(dc, ctx, result_err(rty), "_parent", tmp + ".err") + ")); " + conc_finals(names, 0) + return_frees(dc, ctx) + " return _re_" + name + "; }\n"
            code = code + "    " + ct + un(name) + " = *(" + ct + "*)(" + tmp + ".ok);\n"
            push(names, name)
            push(types, result_ok(rty))
            return code
        SIf(cond, then_body, else_body, _sl):
            d1 := str(ctx.depth + 1)              # each branch is its own block arena
            bc := enter_block(dc, ctx, len(names))
            op := "        Arena _b" + d1 + " = arena_child(" + cur_arena(dc, ctx) + ");\n"
            fr := "        arena_free(&_b" + d1 + ");\n"
            out := "    if (" + gen_expr(cond, names, types, dc, ctx) + ") {\n" + op + gen_block(then_body, names, types, dc, bc) + fr + "    }"
            if len(else_body) > 0:
                out = out + " else {\n" + op + gen_block(else_body, names, types, dc, bc) + fr + "    }"
            return out + "\n"
        SWhile(cond, body, _sl):
            wl_check(cond, body, _sl, dc)         # warn on a `for COND:` whose cond never advances
            fnm, fsf, fty := fuse_detect(body, names, types, dc, ctx, cond, true)
            d1 := str(ctx.depth + 1)              # per-iteration block arena
            bc := in_loop(enter_block(dc, ctx, len(names)))
            decls := ""
            flush := ""
            k := 0
            for k < len(fnm):
                ct := cty(dc, ctx, fty[k])
                decls = decls + "        " + ct + "* _fd" + fsf[k] + " = " + un(fnm[k]) + ".data; long _fl" + fsf[k] + " = " + un(fnm[k]) + ".len, _fc" + fsf[k] + " = " + un(fnm[k]) + ".cap;\n"
                flush = flush + "        " + un(fnm[k]) + ".data = _fd" + fsf[k] + "; " + un(fnm[k]) + ".len = _fl" + fsf[k] + "; " + un(fnm[k]) + ".cap = _fc" + fsf[k] + ";\n"
                bc = add_fuse(bc, fnm[k], fsf[k], fty[k])
                k = k + 1
            inner := "    while (" + gen_expr(cond, names, types, dc, ctx) + ") {\n        Arena _b" + d1 + " = arena_child(" + cur_arena(dc, ctx) + ");\n" + gen_block(body, names, types, dc, bc) + "        arena_free(&_b" + d1 + ");\n    }\n"
            if len(fnm) == 0:
                return inner
            return "    {\n" + decls + inner + flush + "    }\n"
        SForRange(name, start, stop, step, body, _sl):
            fnm, fsf, fty := fuse_detect(body, names, types, dc, ctx, start, false)
            bn := names                           # loop var is scoped to body
            bt := types
            push(bn, name)
            push(bt, "int")
            d1 := str(ctx.depth + 1)              # per-iteration block arena
            bc := in_loop(enter_block(dc, ctx, len(bn)))
            decls := ""
            flush := ""
            k := 0
            for k < len(fnm):
                ct := cty(dc, ctx, fty[k])
                decls = decls + "        " + ct + "* _fd" + fsf[k] + " = " + un(fnm[k]) + ".data; long _fl" + fsf[k] + " = " + un(fnm[k]) + ".len, _fc" + fsf[k] + " = " + un(fnm[k]) + ".cap;\n"
                flush = flush + "        " + un(fnm[k]) + ".data = _fd" + fsf[k] + "; " + un(fnm[k]) + ".len = _fl" + fsf[k] + "; " + un(fnm[k]) + ".cap = _fc" + fsf[k] + ";\n"
                bc = add_fuse(bc, fnm[k], fsf[k], fty[k])
                k = k + 1
            # bounds eval once, pre-loop; the condition is sign-aware so a negative
            # step counts down (hierc: _stop/_step temps + step>0 ? < : >)
            sx := "_stop_" + un(name)
            px := "_step_" + un(name)
            header := "    { long " + sx + " = " + gen_expr(stop, names, types, dc, ctx) + ", " + px + " = " + gen_expr(step, names, types, dc, ctx) + ";\n"
            header = header + "    for (long " + un(name) + " = " + gen_expr(start, names, types, dc, ctx) + "; " + px + " > 0 ? " + un(name) + " < " + sx + " : " + un(name) + " > " + sx + "; " + un(name) + " += " + px + ") {\n"
            inner := header + "        Arena _b" + d1 + " = arena_child(" + cur_arena(dc, ctx) + ");\n" + gen_block(body, bn, bt, dc, bc) + "        arena_free(&_b" + d1 + ");\n    } }\n"
            if len(fnm) == 0:
                return inner
            return "    {\n" + decls + inner + flush + "    }\n"
        SMatch(subj, variants, allbinds, bodies, _sl):  # tag-dispatch over an enum value
            sty := type_of(subj, names, types, dc, ctx)
            # evaluate the subject ONCE into a brace-scoped temp: a side-effecting
            # subject (match pop(s):) must not run once per arm test (hierc: _m<id>)
            sv := gen_expr(subj, names, types, dc, ctx)
            scu := "_msub"
            hd := "    { " + cty(dc, ctx, sty) + scu + " = " + sv + ";\n"
            if is_option(sty) or is_result(sty):
                return hd + gen_match_optres(dc, ctx, sty, scu, variants, allbinds, bodies, names, types) + "    }\n"
            out := hd
            i := 0
            for i < len(variants):
                vname := variants[i]
                binds := allbinds[i]
                pts := variant_ptypes(dc, ctx, vname)
                kw := " else if ("
                if i == 0:
                    kw = "    if ("
                out = out + kw + scu + "->tag == " + str(variant_tag(dc, ctx, vname)) + ") {\n"
                bn := names                       # arm bindings are scoped to the arm
                bt := types
                j := 0
                for j < len(binds):
                    out = out + "    " + cty(dc, ctx, pts[j]) + un(binds[j]) + " = " + cp_typed(dc, ctx, pts[j], efield(scu, vname, j)) + ";\n"
                    push(bn, binds[j])
                    push(bt, pts[j])
                    j = j + 1
                out = out + gen_block(bodies[i], bn, bt, dc, ctx) + "    }"
                i = i + 1
            return out + "\n    }\n"
        SParFor(v, a, b, body, pid, _sl):
            # CC-3: K = hier_ncpu() chunk tasks of the lifted __par chunk proc,
            # through the same HSpawnA/hier_spawn trampolines as CC-1 spawn;
            # captures deep-copy into each task root; partials fold at the
            # in-order join. All tasks join inside this statement (structured).
            pf := dc.pars[pid]
            sid := str(pf.sid)
            rct := cty(dc, ctx, pf.retty)
            out := "    { long _plo = " + gen_expr(a, names, types, dc, ctx) + ", _phi = " + gen_expr(b, names, types, dc, ctx) + ";\n"
            out = out + "    if (_phi < _plo) _phi = _plo;\n"
            out = out + "    long _pk = hier_ncpu();\n    if (_pk > _phi - _plo) _pk = _phi - _plo;\n    if (_pk < 1) _pk = 1; if (_pk > 64) _pk = 64;\n"
            out = out + "    HTask* _pts[64];\n"
            out = out + "    for (long _pc = 0; _pc < _pk; _pc++) {\n"
            out = out + "        HTask* _tk = hier_task_new();\n"
            out = out + "        HSpawnA_" + sid + "* _sa = (HSpawnA_" + sid + "*)amem(&_tk->root, sizeof(HSpawnA_" + sid + "));\n"
            out = out + "        _sa->t = _tk;\n        _sa->a0 = _plo + (_phi - _plo) * _pc / _pk;\n        _sa->a1 = _plo + (_phi - _plo) * (_pc + 1) / _pk;\n"
            ck := 0
            for ck < len(pf.capnames):
                out = out + "        _sa->a" + str(ck + 2) + " = " + cp_field(dc, ctx, pf.captypes[ck], "(&_tk->root)", gen_expr(EVar(pf.capnames[ck], _el), names, types, dc, ctx)) + ";\n"
                ck = ck + 1
            out = out + "        hier_task_start(_tk, hier_spawn_" + sid + ", _sa);\n        _pts[_pc] = _tk;\n    }\n"
            out = out + "    for (long _pc = 0; _pc < _pk; _pc++) {\n        hier_task_join(_pts[_pc]);\n        " + rct + "_pp = *(" + rct + "*)_pts[_pc]->ret;\n        hier_task_free(_pts[_pc]);\n"
            ak := 0
            for ak < len(pf.accnames):
                part := "_pp"
                if len(pf.accnames) > 1:
                    part = "_pp.f" + str(ak)
                out = out + "        " + un(pf.accnames[ak]) + " = " + un(pf.accnames[ak]) + " " + pf.accops[ak] + " " + part + ";\n"
                ak = ak + 1
            return out + "    }\n    }\n"
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            # CC-5: try every recv arm; closed when ALL drain; else default or
            # pause+retry. A goto loop (not for(;;)) so a user break/continue in
            # an arm body binds to the USER'S enclosing loop, never to select's.
            sout := "    { "
            sk := 0
            for sk < len(svars):
                if svars[sk] == "recv":
                    sout = sout + "HChan* _sc" + uid + "_" + str(sk) + " = " + gen_expr(schans[sk], names, types, dc, ctx) + "; "
                sk = sk + 1
            sout = sout + "int _ssp" + uid + " = 0, _open" + uid + " = 0;\n"
            sout = sout + "    _sel_retry_" + uid + ": ;\n    _open" + uid + " = 0;\n"
            sk = 0
            for sk < len(svars):
                if svars[sk] == "recv":
                    cit := chan_inner(type_of(schans[sk], names, types, dc, ctx))
                    cct := cty(dc, ctx, cit)
                    sout = sout + "    { HCell* _tc; int _st = hier_chan_try_recv(_sc" + uid + "_" + str(sk) + ", &_tc); if (_st == 1) {\n"
                    sout = sout + "    " + cct + un(sbinds[sk]) + " = " + cp_field(dc, ctx, cit, cur_arena(dc, ctx), "(*(" + cct + "*)_tc->val)") + "; hier_chan_recv_commit(_sc" + uid + "_" + str(sk) + ", _tc);\n"
                    bn := names
                    bt := types
                    push(bn, sbinds[sk])
                    push(bt, cit)
                    sout = sout + gen_block(sbodies[sk], bn, bt, dc, ctx)
                    sout = sout + "    goto _sel_done_" + uid + ";\n    } if (_st == 0) _open" + uid + " = 1; }\n"
                sk = sk + 1
            sout = sout + "    if (!_open" + uid + ") {\n"
            sk = 0
            for sk < len(svars):
                if svars[sk] == "closed":
                    sout = sout + gen_block(sbodies[sk], names, types, dc, ctx)
                sk = sk + 1
            sout = sout + "    goto _sel_done_" + uid + "; }\n"
            hasdef := false
            sk = 0
            for sk < len(svars):
                if svars[sk] == "default":
                    hasdef = true
                    sout = sout + gen_block(sbodies[sk], names, types, dc, ctx)
                    sout = sout + "    goto _sel_done_" + uid + ";\n"
                sk = sk + 1
            if not hasdef:
                sout = sout + "    hier_select_pause(&_ssp" + uid + ");\n    goto _sel_retry_" + uid + ";\n"
            return sout + "    _sel_done_" + uid + ": ;\n    }\n"

fn ret_cty(dc: Decls, ctx: Ctx, ret: string) -> string:
    if ret == "void":
        return "void "
    return cty(dc, ctx, ret)

# An inout array/map/soa param: its container's home arena is the CALLER's, so
# the callee receives it as a hidden `Arena* _ina_<name>` param and grows/allocs
# into it (instead of malloc-leaking). Inout scalars and inout structs do NOT get
# one (a struct's field-container is a smaller separate residual, still malloc).
fn inout_container_param(dc: Decls, ctx: Ctx, ptype: string) -> bool:
    if not is_inout(ptype):
        return false
    b := base_ty(ptype)
    if resolve_nt(dc, ctx, b) == "str":          # inout string: reassignment bytes build in _ina_
        return true
    return is_array(b) or is_map(b) or is_soa(b) or (is_struct(dc, ctx, b) and struct_is_heap(dc, ctx, b))   # a heap struct's field-containers grow in _ina_

fn gen_params(f: Func, dc: Decls, ctx: Ctx) -> string:
    out := "Arena* _parent"                       # every fn threads the caller's arena
    i := 0
    for i < len(f.params):
        out = out + ", " + cty(dc, ctx, f.ptypes[i]) + un(f.params[i])
        if inout_container_param(dc, ctx, f.ptypes[i]):   # + the container's home arena (keyed by SOURCE name, like owner_arena_of)
            out = out + ", Arena* _ina_" + f.params[i]
        i = i + 1
    return out

fn seed_env(f: Func, names: inout [string], types: inout [string]):
    i := 0
    for i < len(f.params):
        push(names, f.params[i])
        push(types, f.ptypes[i])
        i = i + 1

fn gen_proto(f: Func, dc: Decls, ctx: Ctx) -> string:
    return ret_cty(dc, ctx, f.ret) + un(f.name) + "(" + gen_params(f, dc, ctx) + ");\n"

# FFI: is `name` an extern (C) function? Drives the direct-call codegen.
fn sig_is_extern(dc: Decls, name: string) -> bool:
    si := map_get(dc.sigmap, name, -1)
    if si < 0:
        return false
    return dc.sigs[si].is_extern == 1

# FFI: forward-declare the C symbol with its real C ABI — no arena, no h_ prefix.
fn gen_extern_proto(f: Func, dc: Decls, ctx: Ctx) -> string:
    out := "extern " + ret_cty(dc, ctx, f.ret) + f.name + "("
    if len(f.params) == 0:
        out = out + "void"
    i := 0
    for i < len(f.params):
        if i > 0:
            out = out + ", "
        out = out + cty(dc, ctx, f.ptypes[i])
        i = i + 1
    return out + ");\n"

# Leftmost-flatten an all-'+' EBin chain into its operands, left to right.
# A non-'+' binop or any leaf is one whole piece. So `a + b + c` -> [a, b, c]
# but `(a - b) + c` -> [(a-b), c].
fn plus_flatten(e: Expr, out: inout [Expr]):
    match e:
        EBin(op, l, r, _el):
            if op == "+":
                plus_flatten(l, &out)
                push(out, r)
            else:
                push(out, e)
        EInt(t, _el):
            push(out, e)
        EBool(t, _el):
            push(out, e)
        EChar(t, _el):
            push(out, e)
        EFloat(f, _el):
            push(out, e)
        EStr(s, _el):
            push(out, e)
        EVar(n, _el):
            push(out, e)
        ECall(nm, args, _el):
            push(out, e)
        EField(b, fl, _el):
            push(out, e)
        EIndex(b, ix, _el):
            push(out, e)
        EArrLit(es, _el):
            push(out, e)
        EArrEmpty(t, _el):
            push(out, e)
        EMapEmpty(k, v, _el):
            push(out, e)
        EMapLit(ks, vs, _el):
            push(out, e)
        ETuple(es, _el):
            push(out, e)
        ESlice(b, lo, hi, _el):
            push(out, e)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            push(out, e)
        ECallV(callee, cargs, _el):
            push(out, e)
        EAddr(x, _el):
            push(out, e)
        ESpawn(sid, snm, sa, _el):
            push(out, e)

# If `e` is `name + p1 + p2 + ...` (an all-'+' chain whose leftmost leaf is the
# variable `name`), return the appended pieces [p1, p2, ...]; else []. Used both
# to DETECT a string self-append accumulator and to emit its in-place appends.
fn sacc_pieces(e: Expr, name: string) -> [Expr]:
    ps := []Expr
    plus_flatten(e, &ps)
    if len(ps) < 2:
        return []Expr
    if not is_evar(ps[0], name):
        return []Expr
    return ps[1:]

# Collect string locals that are self-append accumulators (`s = s + ...`). These
# get a growing heap buffer + len/cap sidecars and in-place hi_append instead of
# the O(n^2) sc()-rebuild. Threads the var env (like collect_stmt) so the type
# guard `var_type == "str"` is accurate; a non-str `c = c + 1` is never flagged.
# Match arms bind payloads as "" (unknown) — at worst an arm-local accumulator is
# missed (stays the safe pure-concat path); a false positive is impossible.
fn sacc_block(acc: inout [string], stmts: [Stmt], names: [string], types: [string], dc: Decls, ctx: Ctx):
    ns := names
    ts := types
    i := 0
    for i < len(stmts):
        sacc_stmt(&acc, stmts[i], &ns, &ts, dc, ctx)
        i = i + 1

fn sacc_stmt(acc: inout [string], s: Stmt, names: inout [string], types: inout [string], dc: Decls, ctx: Ctx):
    match s:
        SDecl(n, e, _sl):
            dty := type_of(e, names, types, dc, ctx)   # compute BEFORE pushing n (keep names/types in sync)
            push(names, n)
            push(types, dty)
        SAssign(n, e, _sl):
            if var_type(names, types, n) == "str":
                if len(sacc_pieces(e, n)) > 0:
                    push(acc, n)
        SFieldAssign(lv, rhs, _sl):
            i := 0
        SPrint(e, _sl):
            i := 0
        SReturn(e, _sl):
            i := 0
        SReturnVoid:
            i := 0
        SBreak:
            i := 0
        SContinue:
            i := 0
        SExpr(e, _sl):
            i := 0
        STypedDecl(n, t, e, _sl):
            push(names, n)
            push(types, t)
        SOrReturn(n, e, _sl):
            ety := type_of(e, names, types, dc, ctx)
            ty := ""
            if is_option(ety):
                ty = option_inner(ety)
            else:
                ty = result_ok(ety)
            push(names, n)
            push(types, ty)
        SDestructure(dn, e, _sl):
            parts := tuple_parts(type_of(e, names, types, dc, ctx))
            i := 0
            for i < len(dn):
                push(names, dn[i])
                push(types, parts[i])
                i = i + 1
        SMultiAssign(mn, e, _sl):
            i := 0
        SIf(c, tb, eb, _sl):
            sacc_block(&acc, tb, names, types, dc, ctx)
            sacc_block(&acc, eb, names, types, dc, ctx)
        SWhile(c, body, _sl):
            sacc_block(&acc, body, names, types, dc, ctx)
        SForRange(n, a, b, st, body, _sl):
            bn := names
            bt := types
            push(bn, n)
            push(bt, "int")
            sacc_block(&acc, body, bn, bt, dc, ctx)
        SMatch(subj, variants, allbinds, bodies, _sl):
            sty := type_of(subj, names, types, dc, ctx)
            j := 0
            for j < len(bodies):
                bn := names                       # bind arm payloads with PROPER types so
                bt := types                       # type_of resolves in the arm (mirror collect_stmt)
                binds := allbinds[j]
                if is_option(sty):
                    if len(binds) > 0:
                        push(bn, binds[0])
                        push(bt, option_inner(sty))
                elif is_result(sty):
                    if len(binds) > 0:
                        push(bn, binds[0])
                        if variants[j] == "Ok":
                            push(bt, result_ok(sty))
                        else:
                            push(bt, result_err(sty))
                else:
                    pts := variant_ptypes(dc, ctx, variants[j])
                    k := 0
                    for k < len(binds):
                        push(bn, binds[k])
                        push(bt, pts[k])
                        k = k + 1
                sacc_block(&acc, bodies[j], bn, bt, dc, ctx)
                j = j + 1
        SParFor(v, a, b, body, pid, _sl):
            np := 0                               # reductions are int/float only -- never a string accumulator
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            j := 0                                # recurse arm bodies so an OUTER-local string accumulator
            for j < len(sbodies):                 # appended inside a select arm grows in place (matches hierc's
                sacc_block(&acc, sbodies[j], names, types, dc, ctx)   # collect_accums, which walks select arms)
                j = j + 1

fn gen_func(f: Func, dc: Decls, ctx: Ctx) -> string:
    names := []string
    types := []string
    seed_env(f, &names, &types)
    # Record this func's NON-inout param names so the map accumulator pass skips
    # the in-place put on a by-value map param (it would mutate the caller's
    # shared table). Mirrors the C compiler dropping non-inout params from accums
    # (src/hierc.c:3556). Inout map params are left in (in-place is the wanted
    # mutation). The pure-set fallback rehashes the same way the C compiler does,
    # so key order stays identical (no wordcount divergence).
    vparams := []string
    pi := 0
    for pi < len(f.params):
        if not is_inout(f.ptypes[pi]):
            push(vparams, f.params[pi])
        pi = pi + 1
    # String self-append accumulators (locals only — a param has no SDecl, so no
    # sidecars; like the C compiler dropping non-inout params from accums).
    raw := []string
    sn := names
    st := types
    sacc_block(&raw, f.body, sn, st, dc, ctx)
    saccums := []string
    si := 0
    for si < len(raw):
        isp := false
        pj := 0
        for pj < len(f.params):
            if f.params[pj] == raw[si]:
                isp = true
            pj = pj + 1
        if not isp:
            push(saccums, raw[si])
        si = si + 1
    movables := compute_movables(f.body)          # locals read once, not in a loop -> move-on-last-use
    fctx := Ctx(vparams, saccums, f.ret, "&_scope", 0, []int, movables, 0, []string, []string, []string, 0)
    if f.name == "main":
        # root arena + a child scope; the scope parents every top-level call.
        return "int main(int argc, char **argv) {\n    hi_argc = argc; hi_argv = argv;\n    Arena _root = arena_new(0);\n    Arena _scope = arena_child(&_root);\n" + gen_block(f.body, names, types, dc, fctx) + "    arena_free(&_scope);\n    arena_free(&_root);\n    return 0;\n}\n"
    # open a child scope from the caller's arena; void funcs free it on fall-through
    # (every `return` frees it via the return-slot in gen_stmt).
    tail := ""
    if f.ret == "void":
        tail = "    arena_free(&_scope);\n"
    return ret_cty(dc, fctx, f.ret) + un(f.name) + "(" + gen_params(f, dc, fctx) + ") {\n    Arena _scope = _parent ? arena_child(_parent) : arena_new(0);\n" + gen_block(f.body, names, types, dc, fctx) + tail + "}\n"

fn gen_struct(sd: StructDef, dc: Decls, ctx: Ctx) -> string:
    out := "struct " + ust(sd.name) + " {\n"     # named tag; forward-declared elsewhere
    i := 0
    for i < len(sd.fields):
        out = out + "    " + cty(dc, ctx, sd.fields[i].ty) + uf(sd.fields[i].name) + ";\n"
        i = i + 1
    return out + "};\n"

# Match over a boxed Option/Result value. Some/Ok -> tag 1, None/Err -> tag 0.
# A bound payload is read back from the box: `T x = *(T*)(scrut.val)` (Some),
# `.ok`/`.err` for Result. `scu` is the caller's already-evaluated subject temp
# (SMatch evaluates the subject exactly once before dispatching here).
fn gen_match_optres(dc: Decls, ctx: Ctx, sty: string, scu: string, variants: [string], allbinds: [[string]], bodies: [[Stmt]], names: [string], types: [string]) -> string:
    out := ""
    i := 0
    for i < len(variants):
        vname := variants[i]
        binds := allbinds[i]
        tag := 0
        if vname == "Some" or vname == "Ok":
            tag = 1
        kw := " else if ("
        if i == 0:
            kw = "    if ("
        out = out + kw + scu +".tag == " + str(tag) + ") {\n"
        bn := names
        bt := types
        if len(binds) > 0:
            bty := option_inner(sty)
            fld := "val"
            if is_result(sty):
                if vname == "Ok":
                    bty = result_ok(sty)
                    fld = "ok"
                else:
                    bty = result_err(sty)
                    fld = "err"
            ct := cty(dc, ctx, bty)
            out = out + "    " + ct + un(binds[0]) + " = " + cp_typed(dc, ctx, bty, "*(" + ct + "*)(" + scu + "." + fld + ")") + ";\n"
            push(bn, binds[0])
            push(bt, bty)
        out = out + gen_block(bodies[i], bn, bt, dc, ctx) + "    }"
        i = i + 1
    return out + "\n"

# Deep copy for a heap-bearing struct: shallow-copy scalars, then dup each
# heap field (string -> fresh bytes, array -> Arr_T_copy, nested heap struct ->
# its own _copy). Source-order emission gives nested copiers before their users.
fn gen_struct_copy(dc: Decls, ctx: Ctx, sd: StructDef) -> string:
    nm := ust(sd.name)
    out := "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " s) {\n    " + nm + " r = s;\n"
    i := 0
    for i < len(sd.fields):
        f := sd.fields[i]
        if f.ty == "str":
            out = out + "    r." + uf(f.name) + " = sc(ar, s." + uf(f.name) + ", \"\");\n"
        elif is_array(f.ty):
            out = out + "    r." + uf(f.name) + " = Arr_" + mangle(elem_ty(f.ty)) + "_copy(ar, s." + uf(f.name) + ");\n"
        elif is_map(f.ty):
            out = out + "    r." + uf(f.name) + " = " + mfam(f.ty) + "_copy(ar, s." + uf(f.name) + ");\n"
        elif is_soa(f.ty):
            out = out + "    r." + uf(f.name) + " = Soa_" + soa_struct(f.ty) + "_copy(ar, s." + uf(f.name) + ");\n"
        elif is_enum(dc, ctx, f.ty):                  # deep-copy the enum node tree into `ar`
            out = out + "    r." + uf(f.name) + " = " + tcopy(dc, ctx, f.ty) + "(ar, s." + uf(f.name) + ");\n"
        elif is_struct(dc, ctx, f.ty) and struct_is_heap(dc, ctx, f.ty):
            out = out + "    r." + uf(f.name) + " = " + tcopy(dc, ctx, f.ty) + "(ar, s." + uf(f.name) + ");\n"
        i = i + 1
    return out + "    return r;\n}\n"

# Structural equality for a struct: AND of per-field equality (recurses through
# nested structs, arrays, enums, and Option/Result fields via eq_field).
fn gen_struct_eq(dc: Decls, ctx: Ctx, sd: StructDef) -> string:
    nm := ust(sd.name)
    out := "static int " + nm + "_eq(" + nm + " a, " + nm + " b) { return "
    if len(sd.fields) == 0:
        out = out + "1"
    else:
        j := 0
        for j < len(sd.fields):
            if j > 0:
                out = out + " && "
            f := sd.fields[j]
            out = out + eq_field(dc, ctx, f.ty, "a." + uf(f.name), "b." + uf(f.name))
            j = j + 1
    return out + "; }\n"

# A tuple is an anonymous struct with positional fields f0, f1, ...
# `typedef R (*Fn_<suffix>)(Arena*, P...)` for a fn(P...) -> R type. Matches every
# hier function's uniform C ABI (the hidden return arena is always the first param).
fn gen_func_typedef(dc: Decls, ctx: Ctx, ty: string) -> string:
    r := func_ret(ty)
    rc := "void "                                # cty has no "void" case (fns handle it separately)
    if r != "void":
        rc = cty(dc, ctx, r)
    out := "typedef struct { void* env; " + rc + "(*call)(void*, Arena*"   # fat value: env + adapter thunk (closures carry captures in env)
    ps := func_params(ty)
    i := 0
    for i < len(ps):
        out = out + ", " + cty(dc, ctx, ps[i])
        i = i + 1
    return out + "); void* (*copyenv)(Arena*, void*); } Fn_" + func_suffix(ty) + ";\n"   # copyenv re-homes the env on return (0 for a plain ref)

fn fn_value_eligible(f: Func) -> bool:           # usable as a value: no inout params (the fat-ptr call ABI carries none)
    i := 0
    for i < len(f.ptypes):
        if is_inout(f.ptypes[i]):
            return false
        i = i + 1
    return true

# Adapter thunk: a fat-ptr `call` is R(void* env, Arena*, P...); the real C
# function h_<name> is R(Arena*, P...). The thunk ignores env and forwards.
fn gen_fnval_thunk(f: Func, dc: Decls, ctx: Ctx) -> string:
    out := "static " + ret_cty(dc, ctx, f.ret) + un(f.name) + "__clo(void* _e, Arena* _p"
    i := 0
    for i < len(f.ptypes):
        out = out + ", " + cty(dc, ctx, f.ptypes[i]) + "a" + str(i)
        i = i + 1
    out = out + ") { (void)_e; "
    if f.ret != "void":
        out = out + "return "
    out = out + un(f.name) + "(_p"
    i = 0
    for i < len(f.ptypes):
        out = out + ", a" + str(i)
        i = i + 1
    return out + "); }\n"

# Closure thunk for a lifted lambda: unpack the env's captures and forward, with
# the lambda's own args, to h___lam<id>(_p, c0..., a0...). The lifted proc's
# params are [captures...][lambda params...], so this restores that order.
fn gen_lambda_thunk(li: LamInfo, dc: Decls, ctx: Ctx) -> string:
    nm := "__lam" + str(li.id)
    out := "static " + ret_cty(dc, ctx, li.ret) + un(nm) + "__clo(void* _env, Arena* _p"
    j := 0
    for j < len(li.lamptypes):
        out = out + ", " + cty(dc, ctx, li.lamptypes[j]) + "a" + str(j)
        j = j + 1
    out = out + ") { "
    if len(li.capnames) > 0:
        out = out + "Env_" + str(li.id) + "* _e = (Env_" + str(li.id) + "*)_env; "
    else:
        out = out + "(void)_env; "
    if li.ret != "void":
        out = out + "return "
    out = out + un(nm) + "(_p"
    cj := 0
    for cj < len(li.capnames):
        out = out + ", _e->c" + str(cj)
        cj = cj + 1
    j = 0
    for j < len(li.lamptypes):
        out = out + ", a" + str(j)
        j = j + 1
    return out + "); }\n"

fn gen_tuple_struct(dc: Decls, ctx: Ctx, ty: string) -> string:
    parts := tuple_parts(ty)
    out := "typedef struct { "
    i := 0
    for i < len(parts):
        out = out + cty(dc, ctx, parts[i]) + "f" + str(i) + "; "
        i = i + 1
    return out + "} Tup_" + tup_suffix(ty) + ";\n"

fn gen_tuple_copy(dc: Decls, ctx: Ctx, ty: string) -> string:
    nm := "Tup_" + tup_suffix(ty)
    parts := tuple_parts(ty)
    out := "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " s) {\n    " + nm + " r = s;\n"
    i := 0
    for i < len(parts):
        p := parts[i]
        if p == "str":
            out = out + "    r.f" + str(i) + " = sc(ar, s.f" + str(i) + ", \"\");\n"
        elif is_array(p):
            out = out + "    r.f" + str(i) + " = Arr_" + mangle(elem_ty(p)) + "_copy(ar, s.f" + str(i) + ");\n"
        elif is_map(p):
            out = out + "    r.f" + str(i) + " = " + mfam(p) + "_copy(ar, s.f" + str(i) + ");\n"
        elif is_enum(dc, ctx, p):                     # deep-copy the enum node tree into `ar`
            out = out + "    r.f" + str(i) + " = " + tcopy(dc, ctx, p) + "(ar, s.f" + str(i) + ");\n"
        elif is_struct(dc, ctx, p) and struct_is_heap(dc, ctx, p):
            out = out + "    r.f" + str(i) + " = " + tcopy(dc, ctx, p) + "(ar, s.f" + str(i) + ");\n"
        i = i + 1
    return out + "    return r;\n}\n"

fn gen_tuple_eq(dc: Decls, ctx: Ctx, ty: string) -> string:
    nm := "Tup_" + tup_suffix(ty)
    parts := tuple_parts(ty)
    out := "static int " + nm + "_eq(" + nm + " a, " + nm + " b) { return "
    i := 0
    for i < len(parts):
        if i > 0:
            out = out + " && "
        out = out + eq_field(dc, ctx, parts[i], "a.f" + str(i), "b.f" + str(i))
        i = i + 1
    return out + "; }\n"

fn eq_field(dc: Decls, ctx: Ctx, ty: string, a: string, b: string) -> string:
    if ty == "str":
        return "strcmp(" + a + ", " + b + ") == 0"
    if is_array(ty):
        return "Arr_" + mangle(elem_ty(ty)) + "_eq(" + a + ", " + b + ")"
    if is_enum(dc, ctx, ty):
        return teq(dc, ctx, ty) + "(" + a + ", " + b + ")"
    if is_struct(dc, ctx, ty):
        return teq(dc, ctx, ty) + "(" + a + ", " + b + ")"
    if is_tuple(ty):
        return "Tup_" + tup_suffix(ty) + "_eq(" + a + ", " + b + ")"
    if is_map(ty):
        return mfam(ty) + "_eq(" + a + ", " + b + ")"
    if is_soa(ty):
        return "Soa_" + soa_struct(ty) + "_eq(" + a + ", " + b + ")"
    if is_option(ty):                            # tags equal, and (if Some) payloads equal
        ct := cty(dc, ctx, option_inner(ty))
        pa := "*(" + ct + "*)(" + a + ".val)"
        pb := "*(" + ct + "*)(" + b + ".val)"
        return "(" + a + ".tag == " + b + ".tag && (" + a + ".tag == 0 || " + eq_field(dc, ctx, option_inner(ty), pa, pb) + "))"
    if is_result(ty):
        ct := cty(dc, ctx, result_ok(ty))
        ce := cty(dc, ctx, result_err(ty))
        oa := "*(" + ct + "*)(" + a + ".ok)"
        ob := "*(" + ct + "*)(" + b + ".ok)"
        ea := "*(" + ce + "*)(" + a + ".err)"
        eb := "*(" + ce + "*)(" + b + ".err)"
        okeq := eq_field(dc, ctx, result_ok(ty), oa, ob)
        ereq := eq_field(dc, ctx, result_err(ty), ea, eb)
        return "(" + a + ".tag == " + b + ".tag && (" + a + ".tag == 1 ? " + okeq + " : " + ereq + "))"
    if is_func(ty):                              # fn values: identity equality (same thunk + env) — closures aren't structurally comparable
        return "((" + a + ").call == (" + b + ").call && (" + a + ").env == (" + b + ").env)"
    return "(" + a + " == " + b + ")"            # int/bool/float by value

# Recursive deep-copy of an enum node into arena `ar`: fresh node, same tag, and
# each present variant's payload fields copied by type (cp_field recurses through
# nested enums / arrays / structs / strings). The value-semantic mirror of the
# arena-allocating mk_ ctors — so a returned/stored/copied enum owns its subtree
# in the destination arena instead of aliasing a freed scope.
fn gen_enum_copy(ed: EnumDef, dc: Decls, ctx: Ctx) -> string:
    nm := uet(ed.name)
    out := "static " + nm + "* " + nm + "_copy(Arena* ar, " + nm + "* s) {\n"
    i := 0
    for i < len(ed.variants):
        v := ed.variants[i]
        if len(v.ptypes) > 0:                 # allocate a cell sized to THIS variant, not the union max
            out = out + "    if (s->tag == " + str(i) + ") {\n"
            out = out + "        " + nm + "* r = amem(ar, offsetof(" + nm + ", u) + sizeof(((" + nm + "*)0)->u." + v.name + "));\n        r->tag = " + str(i) + ";\n"
            j := 0
            for j < len(v.ptypes):
                out = out + "        " + efield("r", v.name, j) + " = " + cp_field(dc, ctx, v.ptypes[j], "ar", efield("s", v.name, j)) + ";\n"
                j = j + 1
            out = out + "        return r;\n    }\n"
        i = i + 1
    return out + "    return s;\n}\n"           # nullary variant: shared immortal singleton

# C lvalue for variant `vn`'s payload field j of enum node `base` (a pointer).
# The compact layout nests payloads in a union (one struct per payload-bearing
# variant), so a node is only as big as its ACTIVE variant -- not the flat sum of
# every variant's fields. (Tree node 24B; the compiler's Expr/Stmt shrink ~5-8x.)
fn efield(base: string, vn: string, j: int) -> string:
    return base + "->u." + vn + ".f" + str(j)

fn gen_enum_decl(ed: EnumDef, dc: Decls, ctx: Ctx) -> string:
    out := "struct " + uet(ed.name) + " {\n    int tag;\n"
    members := ""
    i := 0
    for i < len(ed.variants):
        v := ed.variants[i]
        if len(v.ptypes) > 0:
            members = members + "        struct {"
            j := 0
            for j < len(v.ptypes):
                members = members + " " + cty(dc, ctx, v.ptypes[j]) + "f" + str(j) + ";"
                j = j + 1
            members = members + " } " + v.name + ";\n"
        i = i + 1
    if members != "":
        out = out + "    union {\n" + members + "    } u;\n"
    return out + "};\n"

fn gen_enum_ctors(ed: EnumDef, dc: Decls, ctx: Ctx) -> string:
    out := ""
    i := 0
    for i < len(ed.variants):
        v := ed.variants[i]
        if len(v.ptypes) == 0:                    # nullary variant: one shared immortal singleton,
            sg := "_sing_" + ed.name + "_" + str(i)   # no per-construction allocation (no payload, and
            out = out + "static " + uet(ed.name) + " " + sg + " = { " + str(i) + " };\n"   # enum values are immutable)
            out = out + "static " + uet(ed.name) + "* mk_" + v.name + "(Arena* ar) { (void)ar; return &" + sg + "; }\n"
        else:
            params := "Arena* ar"                 # the node lives in `ar` (the ambient arena)
            j := 0
            for j < len(v.ptypes):
                params = params + ", " + cty(dc, ctx, v.ptypes[j]) + "f" + str(j)
                j = j + 1
            out = out + "static " + uet(ed.name) + "* mk_" + v.name + "(" + params + ") {\n"
            out = out + "    " + uet(ed.name) + "* n = amem(ar, offsetof(" + uet(ed.name) + ", u) + sizeof(((" + uet(ed.name) + "*)0)->u." + v.name + "));\n"
            out = out + "    n->tag = " + str(i) + ";\n"
            j = 0
            for j < len(v.ptypes):
                out = out + "    " + efield("n", v.name, j) + " = f" + str(j) + ";\n"
                j = j + 1
            out = out + "    return n;\n}\n"
        i = i + 1
    return out

fn gen_enum_eq(ed: EnumDef, dc: Decls, ctx: Ctx) -> string:
    out := "static int " + uet(ed.name) + "_eq(" + uet(ed.name) + "* a, " + uet(ed.name) + "* b) {\n"
    out = out + "    if (a->tag != b->tag) return 0;\n"
    i := 0
    for i < len(ed.variants):
        v := ed.variants[i]
        out = out + "    if (a->tag == " + str(i) + ") return "
        if len(v.ptypes) == 0:
            out = out + "1"
        else:
            j := 0
            for j < len(v.ptypes):
                if j > 0:
                    out = out + " && "
                out = out + eq_field(dc, ctx, v.ptypes[j], efield("a", v.name, j), efield("b", v.name, j))
                j = j + 1
        out = out + ";\n"
        i = i + 1
    return out + "    return 0;\n}\n"

fn preamble() -> string:
    out := "#ifndef _DEFAULT_SOURCE\n#define _DEFAULT_SOURCE\n#endif\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <stddef.h>\n#include <dirent.h>\n#include <pthread.h>\n#include <unistd.h>\n#include <stdatomic.h>\n#include <sched.h>\n#include <time.h>\n"
    # Math builtins (sqrt/pow/floor/fabs): declare ONLY these four with their
    # exact libc prototypes rather than `#include <math.h>`. The full header
    # drops dozens of names into the global namespace (yn, y0, j0, gamma, ...)
    # that collide with bare user-function names hierc0 emits (e.g. maps.hi's
    # `fn yn`). -lm at link still provides the definitions.
    out = out + "double sqrt(double); double pow(double, double); double floor(double); double fabs(double);\n"
    # Block-list arena, 8-byte aligned. A process-global block FREE-LIST (g_pool)
    # makes the per-scope/per-loop-iteration arena_child/free O(1) pointer ops:
    # arena_free hands blocks to the pool (not the OS) and arena_alloc takes from
    # it first, so allocation-heavy/deeply-recursive workloads (the self-compile)
    # stop paying malloc/free per scope. Peak live memory is unchanged (the pool
    # holds at most what a scope just released; reclaimed by the OS at exit).
    out = out + "typedef struct ABlk { struct ABlk* next; size_t used, cap; char* mem; } ABlk;\n"
    # Per-arena object free-list for liveness-driven recycling: when the compiler
    # proves a buffer is dead + uniquely owned (value semantics ⇒ no aliasing), it
    # is handed back via arena_recycle and the next same-size arena_alloc reuses it
    # (best-fit). FBIP-style reuse from STATIC value semantics, no refcount. Sound
    # because arena_alloc only bumps FORWARD, so a recycled region never overlaps a
    # fresh bump; arena_free drops the list (its chunks live in pooled blocks).
    out = out + "typedef struct FreeNode { struct FreeNode* next; size_t size; } FreeNode;\n"
    # Tiny objects recycle through a SEGREGATED free-list (one LIFO per 8-byte size
    # class, bkt[16] = sizes 8..120B): O(1) push/pop, NO cap -- a sliding-window
    # eviction needs the per-class list to grow to the window size, which a single
    # capped best-fit list cannot. Larger chunks keep the capped best-fit `freelist`.
    out = out + "typedef struct { ABlk* head; size_t blocksz; FreeNode* bkt[16]; FreeNode* freelist; int nfree; } Arena;\n"
    # THREAD-LOCAL (CC-0): each thread owns a private pool -- allocation never
    # contends or races. Blocks may be freed on a different thread than they
    # were allocated on (wait() frees the task tree on the waiting thread);
    # that's fine, a block is just malloc'd memory and lands in the releasing
    # thread's pool. A spawned thread flushes its pool before exiting.
    out = out + "static __thread ABlk* g_pool = 0;\n"
    out = out + "static ABlk* blk_get(size_t cap) { if (g_pool && g_pool->cap >= cap) { ABlk* b = g_pool; g_pool = b->next; b->used = 0; b->next = 0; return b; } for (ABlk** link = &g_pool; *link; link = &(*link)->next) if ((*link)->cap >= cap) { ABlk* b = *link; *link = b->next; b->used = 0; b->next = 0; return b; } ABlk* b = malloc(sizeof(ABlk)); b->mem = malloc(cap); b->cap = cap; b->used = 0; b->next = 0; return b; }\n"
    out = out + "static void blk_release(ABlk* b) { while (b) { ABlk* nx = b->next; b->next = g_pool; g_pool = b; b = nx; } }\n"
    out = out + "static Arena arena_new(size_t bs) { Arena a; a.head = 0; a.blocksz = bs ? bs : 65536; for (int i = 0; i < 16; i++) a.bkt[i] = 0; a.freelist = 0; a.nfree = 0; return a; }\n"
    out = out + "static void arena_recycle(Arena* a, void* p, size_t n) { if (!a || !p || n < sizeof(FreeNode)) return; n = (n + 7) & ~(size_t)7; size_t k = n >> 3; FreeNode* fn = (FreeNode*)p; fn->size = n; if (k < 16) { fn->next = a->bkt[k]; a->bkt[k] = fn; return; } if (a->nfree >= 32) return; fn->next = a->freelist; a->freelist = fn; a->nfree++; }\n"
    out = out + "static Arena arena_child(Arena* p) { return arena_new(p->blocksz); }\n"
    out = out + "static void* arena_alloc(Arena* a, size_t n) { n = (n + 7) & ~(size_t)7; size_t k = n >> 3; if (k < 16) { if (a->bkt[k]) { FreeNode* fn = a->bkt[k]; a->bkt[k] = fn->next; return (void*)fn; } } else if (a->freelist) { FreeNode** link = &a->freelist; FreeNode** best = 0; size_t bestsz = (size_t)-1; for (; *link; link = &(*link)->next) if ((*link)->size >= n && (*link)->size <= 2*n && (*link)->size < bestsz) { best = link; bestsz = (*link)->size; } if (best) { FreeNode* fn = *best; *best = fn->next; a->nfree--; return (void*)fn; } } if (!a->head || a->head->used + n > a->head->cap) { size_t cap = a->blocksz; if (cap < n) cap = n; ABlk* b = blk_get(cap); b->next = a->head; a->head = b; } void* p = a->head->mem + a->head->used; a->head->used += n; return p; }\n"
    out = out + "static int arena_owns(Arena* a, const void* p) { for (ABlk* b = a->head; b; b = b->next) if ((const char*)p >= b->mem && (const char*)p < b->mem + b->cap) return 1; return 0; }\n"
    out = out + "static void arena_free(Arena* a) { for (int i = 0; i < 16; i++) a->bkt[i] = 0; a->freelist = 0; a->nfree = 0; blk_release(a->head); a->head = 0; }\n"
    # ---- concurrency runtime (CC-0..CC-4), mirroring runtime/hier_rt.c ----
    # A task is one OS thread running one call against a private arena tree;
    # arguments deep-copy IN before the thread starts, the result copies OUT at
    # wait. The done flag makes a double wait a defined loud failure (the named
    # handle's struct lives to its scope-exit finish). hier_pool_flush frees a
    # spawned thread's TLS block pool before it exits (the TLS dies with it).
    out = out + "static void hier_pool_flush(void) { while (g_pool) { ABlk* b = g_pool; g_pool = b->next; free(b->mem); free(b); } }\n"
    out = out + "typedef struct { pthread_t th; Arena root; void* ret; int done; } HTask;\n"
    out = out + "static HTask* hier_task_new(void) { HTask* t = malloc(sizeof(HTask)); t->root = arena_new(0); t->ret = 0; t->done = 0; return t; }\n"
    out = out + "static void hier_task_join(HTask* t) { if (t->done) { fprintf(stderr, \"hier: task already waited\\n\"); exit(1); } pthread_join(t->th, 0); t->done = 1; }\n"
    out = out + "static void hier_task_free(HTask* t) { arena_free(&t->root); free(t); }\n"
    out = out + "static void hier_task_finish(HTask* t) { if (!t->done) { pthread_join(t->th, 0); t->done = 1; } arena_free(&t->root); free(t); }\n"
    out = out + "static void hier_task_start(HTask* t, void* (*fn)(void*), void* arg) { if (pthread_create(&t->th, 0, fn, arg) != 0) { fprintf(stderr, \"hier: spawn failed (cannot create thread)\\n\"); exit(1); } }\n"
    # Channels (CC-5): a Vyukov bounded MPMC ring. Each cell has a sequence
    # counter and its OWN arena -- a sender claims a cell with one CAS, deep-
    # copies the payload in with NO lock held (cell-exclusive until the seq
    # store publishes), receivers claim/copy-out/recycle symmetrically. The
    # spin -> yield -> timed-park ladder plus the parked-waiter count means the
    # uncontended fast path does zero syscalls. Capacity rounds up to a power
    # of two. Mirrors runtime/hier_rt.c byte-for-byte in semantics + messages.
    # HCell is line-aligned and HChan pads enq/deq onto their own cache lines (Vyukov's
    # layout): the producer CASes enq while every consumer CASes deq -- packed together
    # they false-share one line and the ping-pong throttles both sides (measured 3.3x
    # on the pipeline bench). aligned_alloc backs the cells' 64-byte alignment.
    out = out + "typedef struct __attribute__((aligned(64))) { _Atomic long seq; long pos; void* val; Arena arena; } HCell;\n"
    out = out + "typedef struct { HCell* cells; long cap; char _pad0[64]; _Atomic long enq; char _pad1[64]; _Atomic long deq; char _pad2[64]; _Atomic int closed; _Atomic int waiters; pthread_mutex_t mu; pthread_cond_t cv; } HChan;\n"
    out = out + "static HChan* hier_chan_new(long cap) { if (cap < 1) { fprintf(stderr, \"hier: channel capacity must be >= 1\\n\"); exit(1); } long c2 = 2; /* min ring 2: one cell makes published (pos+1) == recycled (pos+cap) and a 2nd send overwrites the unreceived value */ while (c2 < cap) c2 <<= 1; HChan* ch = malloc(sizeof(HChan)); ch->cells = aligned_alloc(64, c2 * sizeof(HCell)); for (long i = 0; i < c2; i++) { atomic_store_explicit(&ch->cells[i].seq, i, memory_order_relaxed); ch->cells[i].pos = 0; ch->cells[i].val = 0; ch->cells[i].arena = arena_new(0); } ch->cap = c2; atomic_store_explicit(&ch->enq, 0, memory_order_relaxed); atomic_store_explicit(&ch->deq, 0, memory_order_relaxed); atomic_store_explicit(&ch->closed, 0, memory_order_relaxed); atomic_store_explicit(&ch->waiters, 0, memory_order_relaxed); pthread_mutex_init(&ch->mu, 0); pthread_cond_init(&ch->cv, 0); return ch; }\n"
    out = out + "static void hier_chan_park(HChan* ch) { pthread_mutex_lock(&ch->mu); atomic_fetch_add_explicit(&ch->waiters, 1, memory_order_relaxed); struct timespec ts; clock_gettime(CLOCK_REALTIME, &ts); ts.tv_nsec += 1000000; if (ts.tv_nsec >= 1000000000) { ts.tv_sec++; ts.tv_nsec -= 1000000000; } pthread_cond_timedwait(&ch->cv, &ch->mu, &ts); atomic_fetch_sub_explicit(&ch->waiters, 1, memory_order_relaxed); pthread_mutex_unlock(&ch->mu); }\n"
    # signal ONE waiter per commit (one cell published); close() still broadcasts; the
    # 1ms timed park self-heals any wake the signal/park race drops.
    out = out + "static void hier_chan_wake(HChan* ch) { if (atomic_load_explicit(&ch->waiters, memory_order_relaxed) > 0) { pthread_mutex_lock(&ch->mu); pthread_cond_signal(&ch->cv); pthread_mutex_unlock(&ch->mu); } }\n"
    out = out + "static HCell* hier_chan_send_cell(HChan* ch) { long pos = atomic_load_explicit(&ch->enq, memory_order_relaxed); int spins = 0; for (;;) { HCell* c = &ch->cells[pos & (ch->cap - 1)]; long d = atomic_load_explicit(&c->seq, memory_order_acquire) - pos; if (d == 0) { if (atomic_compare_exchange_weak_explicit(&ch->enq, &pos, pos + 1, memory_order_relaxed, memory_order_relaxed)) { if (atomic_load_explicit(&ch->closed, memory_order_acquire)) { fprintf(stderr, \"hier: send on a closed channel\\n\"); exit(1); } arena_free(&c->arena); c->pos = pos; return c; } } else if (d < 0) { if (atomic_load_explicit(&ch->closed, memory_order_acquire)) { fprintf(stderr, \"hier: send on a closed channel\\n\"); exit(1); } if (++spins < 256) { } else if (spins < 512) sched_yield(); else { hier_chan_park(ch); spins = 0; } pos = atomic_load_explicit(&ch->enq, memory_order_relaxed); } else { pos = atomic_load_explicit(&ch->enq, memory_order_relaxed); } } }\n"
    out = out + "static void hier_chan_send_commit(HChan* ch, HCell* c, void* val) { c->val = val; atomic_store_explicit(&c->seq, c->pos + 1, memory_order_release); hier_chan_wake(ch); }\n"
    out = out + "static HCell* hier_chan_recv_cell(HChan* ch) { long pos = atomic_load_explicit(&ch->deq, memory_order_relaxed); int spins = 0; for (;;) { HCell* c = &ch->cells[pos & (ch->cap - 1)]; long d = atomic_load_explicit(&c->seq, memory_order_acquire) - (pos + 1); if (d == 0) { if (atomic_compare_exchange_weak_explicit(&ch->deq, &pos, pos + 1, memory_order_relaxed, memory_order_relaxed)) { c->pos = pos; return c; } } else if (d < 0) { if (atomic_load_explicit(&ch->closed, memory_order_acquire) && atomic_load_explicit(&ch->enq, memory_order_acquire) == pos) return 0; if (++spins < 256) { } else if (spins < 512) sched_yield(); else { hier_chan_park(ch); spins = 0; } pos = atomic_load_explicit(&ch->deq, memory_order_relaxed); } else { pos = atomic_load_explicit(&ch->deq, memory_order_relaxed); } } }\n"
    out = out + "static void hier_chan_recv_commit(HChan* ch, HCell* c) { atomic_store_explicit(&c->seq, c->pos + ch->cap, memory_order_release); hier_chan_wake(ch); }\n"
    out = out + "static int hier_chan_try_recv(HChan* ch, HCell** out) { long pos = atomic_load_explicit(&ch->deq, memory_order_relaxed); for (;;) { HCell* c = &ch->cells[pos & (ch->cap - 1)]; long d = atomic_load_explicit(&c->seq, memory_order_acquire) - (pos + 1); if (d == 0) { if (atomic_compare_exchange_weak_explicit(&ch->deq, &pos, pos + 1, memory_order_relaxed, memory_order_relaxed)) { c->pos = pos; *out = c; return 1; } } else if (d < 0) { if (atomic_load_explicit(&ch->closed, memory_order_acquire) && atomic_load_explicit(&ch->enq, memory_order_acquire) == pos) return 2; return 0; } else { pos = atomic_load_explicit(&ch->deq, memory_order_relaxed); } } }\n"
    out = out + "static void hier_select_pause(int* spins) { (*spins)++; if (*spins < 64) return; if (*spins < 256) { sched_yield(); return; } struct timespec ts = { 0, 50000 }; nanosleep(&ts, 0); }\n"
    out = out + "static void hier_chan_close(HChan* ch) { pthread_mutex_lock(&ch->mu); if (atomic_load_explicit(&ch->closed, memory_order_relaxed)) { fprintf(stderr, \"hier: channel already closed\\n\"); exit(1); } atomic_store_explicit(&ch->closed, 1, memory_order_release); pthread_cond_broadcast(&ch->cv); pthread_mutex_unlock(&ch->mu); }\n"
    out = out + "static void hier_chan_free(HChan* ch) { for (long i = 0; i < ch->cap; i++) arena_free(&ch->cells[i].arena); free(ch->cells); pthread_mutex_destroy(&ch->mu); pthread_cond_destroy(&ch->cv); free(ch); }\n"
    out = out + "static long hier_ncpu(void) { const char* e = getenv(\"HIER_THREADS\"); if (e && *e) { long v = atol(e); if (v >= 1) return v; } long n = sysconf(_SC_NPROCESSORS_ONLN); return n > 0 ? n : 1; }\n"
    # String allocators take an arena; a NULL arena means malloc (the safe
    # fallback for not-yet-migrated contexts). owner-threading (ctx.owner) flips
    # provably-safe contexts (e.g. print args) to a real arena. hi_append is NOT
    # arena-based: accumulator buffers are realloc-grown, so they must be malloc.
    out = out + "static void* amem(Arena* a, size_t n) { return a ? arena_alloc(a, n) : malloc(n); }\n"
    # Length-carrying strings: an 8-byte length header sits just before the
    # returned char* (hidden behind it, so printf/strcmp are unaffected); arena
    # blocks are 8-aligned so the header word is aligned. len(s)/s[i] read it in
    # O(1) -- s[i] is bounds-checked (hi_sidx). Mirrors hierc's hier_str_alloc.
    out = out + "static char* hs(Arena* ar, long n) { char* base = (char*)amem(ar, (size_t)(8 + n + 1)); *(long*)base = n; char* d = base + 8; d[n] = 0; return d; }\n"
    out = out + "static char* hi_intern(const char* s) { long n = (long)strlen(s); char* base = (char*)malloc((size_t)(8 + n + 1)); *(long*)base = n; char* d = base + 8; memcpy(d, s, (size_t)n + 1); return d; }\n"
    out = out + "static long hi_sidx(const char* s, long i) { long n = ((const long*)s)[-1]; if (i < 0 || i >= n) { fprintf(stderr, \"hier: string index %ld out of bounds (len %ld)\\n\", i, n); exit(1); } return (long)(unsigned char)s[i]; }\n"
    out = out + "static char* sc(Arena* ar, const char* a, const char* b) { long la = (long)strlen(a), lb = (long)strlen(b); char* r = hs(ar, la + lb); memcpy(r, a, (size_t)la); memcpy(r + la, b, (size_t)lb); return r; }\n"
    out = out + "static char* sc_char(Arena* ar, const char* a, long c) { long la = (long)strlen(a); char* r = hs(ar, la + 1); memcpy(r, a, (size_t)la); r[la] = (char)c; return r; }\n"
    out = out + "static char* i2s(Arena* ar, long n) { char t[24]; int m = snprintf(t, sizeof t, \"%ld\", n); char* r = hs(ar, m); memcpy(r, t, (size_t)m); return r; }\n"
    out = out + "static char* b2s(Arena* ar, long b) { const char* s = b ? \"true\" : \"false\"; long m = (long)strlen(s); char* r = hs(ar, m); memcpy(r, s, (size_t)m); return r; }\n"
    out = out + "static char* scopy(Arena* ar, const char* s) { long n = (long)strlen(s); char* r = hs(ar, n); memcpy(r, s, (size_t)n); return r; }\n"
    out = out + "static void hi_append(Arena* a, char** s, long* len, long* cap, const char* e) { long le = (long)strlen(e); if (*len + le + 1 > *cap) { long nc = *cap > 0 ? *cap : 16; while (nc < *len + le + 1) nc *= 2; char* base = (char*)amem(a, (size_t)(8 + nc)); char* nb = base + 8; memcpy(nb, *s, (size_t)*len); *s = nb; *cap = nc; } memmove(*s + *len, e, (size_t)le); *len += le; (*s)[*len] = 0; ((long*)(*s))[-1] = *len; }\n"
    out = out + "static void hi_append_char(Arena* a, char** s, long* len, long* cap, long c) { if (*len + 2 > *cap) { long nc = *cap > 0 ? *cap : 16; while (nc < *len + 2) nc *= 2; char* base = (char*)amem(a, (size_t)(8 + nc)); char* nb = base + 8; memcpy(nb, *s, (size_t)*len); *s = nb; *cap = nc; } (*s)[*len] = (char)c; *len += 1; (*s)[*len] = 0; ((long*)(*s))[-1] = *len; }\n"
    out = out + "static char* f2s(Arena* ar, double x) { char t[64]; int m = snprintf(t, sizeof t, \"%.15g\", x); int fl = 0; for (int i = 0; i < m; i++) { char c = t[i]; if (c == '.' || c == 'e' || c == 'E' || c == 'n' || c == 'N' || c == 'i' || c == 'I') { fl = 1; break; } } if (!fl) { t[m++] = '.'; t[m++] = '0'; t[m] = 0; } char* r = hs(ar, m); memcpy(r, t, (size_t)m); return r; }\n"
    out = out + "static char* substr(Arena* ar, const char* s, long a, long b) { long n = b - a; char* r = hs(ar, n); memcpy(r, s + a, (size_t)n); return r; }\n"
    out = out + "static long hi_find(const char* s, const char* sub) { const char* p = strstr(s, sub); return p ? (long)(p - s) : -1; }\n"
    out = out + "static char* hi_input(Arena* ar) { size_t cap = 128, len = 0; char* b = malloc(cap); int c; fflush(stdout); while ((c = getchar()) != EOF && c != '\\n') { if (len + 1 >= cap) { cap *= 2; b = realloc(b, cap); } b[len++] = (char)c; } char* r = hs(ar, (long)len); memcpy(r, b, len); free(b); return r; }\n"
    out = out + "static char* hi_chr(Arena* ar, long n) { char* r = hs(ar, 1); r[0] = (char)(n & 0xff); return r; }\n"
    out = out + "static char* hi_getenv(Arena* ar, const char* name) { const char* v = getenv(name); return scopy(ar, v ? v : \"\"); }\n"
    out = out + "static void hi_die(const char* m) { fputs(m, stderr); fputc('\\n', stderr); exit(1); }\n"
    out = out + "static void hi_eprint(const char* m) { fputs(m, stderr); }\n"
    out = out + "static char* hi_read_all(Arena* ar) { size_t cap = 4096, len = 0; char* b = malloc(cap); int c; while ((c = getchar()) != EOF) { if (len + 1 >= cap) { cap *= 2; b = realloc(b, cap); } b[len++] = (char)c; } char* r = hs(ar, (long)len); memcpy(r, b, len); free(b); return r; }\n"
    out = out + "static char* hi_read_file(Arena* ar, const char* path) { FILE* f = fopen(path, \"rb\"); if (!f) return scopy(ar, \"\"); size_t cap = 4096, len = 0, n; char* b = amem(ar, cap); while ((n = fread(b + len, 1, cap - len, f)) > 0) { len += n; if (len == cap) { size_t nc = cap * 2; char* nb = amem(ar, nc); memcpy(nb, b, len); b = nb; cap = nc; } } fclose(f); char* r = hs(ar, (long)len); memcpy(r, b, len); return r; }\n"
    out = out + "static long hi_write_file(const char* path, const char* data) { FILE* f = fopen(path, \"wb\"); if (!f) return 0; long n = ((const long*)data)[-1]; size_t w = fwrite(data, 1, (size_t)n, f); fclose(f); return (w == (size_t)n) ? 1 : 0; }\n"
    out = out + "static int hi_argc = 0;\nstatic char** hi_argv = 0;\n"
    out = out + "typedef struct { int tag; void* val; } HOption;\n"
    out = out + "typedef struct { int tag; void* ok; void* err; } HResult;\n"
    out = out + "static void* hbox(Arena* ar, unsigned long n, void* src) { void* p = amem(ar, n); memcpy(p, src, n); return p; }\n"
    out = out + "static HOption hsome(void* v) { HOption o; o.tag = 1; o.val = v; return o; }\n"
    out = out + "static HOption hnone(void) { HOption o; o.tag = 0; o.val = 0; return o; }\n"
    out = out + "static HResult hok(void* v) { HResult r; r.tag = 1; r.ok = v; r.err = 0; return r; }\n"
    out = out + "static HResult herr(void* v) { HResult r; r.tag = 0; r.ok = 0; r.err = v; return r; }\n"
    return out

# One monomorphized value-array family per element type T: Arr_T holds a
# CTY* buffer; copy is a deep copy (value semantics). The struct definition is
# split from the functions so the element struct's full body can be emitted in
# between (the functions need sizeof(T) / by-value assignment, but the Arr_T
# struct itself only needs T as a pointer — this is what lets [P] and recursive
# structs like `struct Node { kids: [Node] }` compile).
fn gen_arr_type(dc: Decls, ctx: Ctx, et: string) -> string:
    nm := "Arr_" + mangle(et)                    # named-tag body; the typedef is forward-declared in the driver
    ct := cty(dc, ctx, et)                           # (so a fn value whose param/ret is [T] can name Arr_T incomplete)
    out := "struct " + nm + "_ { " + ct + "* data; long len; long cap; };\n"
    out = out + "static int " + nm + "_eq(" + nm + " a, " + nm + " b);\n"
    out = out + "static " + nm + " " + nm + "_from(Arena* ar, " + ct + "* s, long n);\n"
    return out + "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " a);\n"

fn gen_arr_fns(dc: Decls, ctx: Ctx, et: string) -> string:
    nm := "Arr_" + mangle(et)
    ct := cty(dc, ctx, et)                           # element C type, trailing space
    out := "static " + nm + " " + nm + "_new(void) { " + nm + " a; a.data = 0; a.len = 0; a.cap = 0; return a; }\n"
    # buffer lives in arena `ar` (NULL=malloc). push ARENA-GROWS (no realloc on
    # arena memory): allocate a doubled buffer and copy; the old one is dead and
    # reclaimed at arena_free. Elements are malloc'd by the store-copy at every
    # store site, so copy/slice stay SHALLOW (element pointers) and remain valid.
    if elem_deepcopy(dc, ctx, et):
        # heap elements live in the array's arena: _from (hence _copy/_slice)
        # deep-copies each element into `ar`, so a copied/returned/sliced array
        # fully owns its elements and frees them with its arena (closes the
        # element-residual leak). push grows the buffer shallowly (same array
        # identity, same arena) so it does NOT route through _from.
        out = out + "static " + nm + " " + nm + "_from(Arena* ar, " + ct + "* s, long n) { " + nm + " a; a.len = n; a.cap = n > 0 ? n : 0; a.data = n ? amem(ar, sizeof(" + ct + ") * n) : 0; for (long i = 0; i < n; i++) a.data[i] = " + elem_copy_expr(dc, ctx, et, "ar", "s[i]") + "; return a; }\n"
    else:
        out = out + "static " + nm + " " + nm + "_from(Arena* ar, " + ct + "* s, long n) { " + nm + " a; a.len = n; a.cap = n > 0 ? n : 0; a.data = n ? amem(ar, sizeof(" + ct + ") * n) : 0; if (n) memcpy(a.data, s, sizeof(" + ct + ") * n); return a; }\n"
    out = out + "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " a) { return " + nm + "_from(ar, a.data, a.len); }\n"
    out = out + "static void " + nm + "_push(Arena* ar, " + nm + "* a, " + ct + "v) { if (a->len == a->cap) { long nc = a->cap ? a->cap * 2 : 4; " + ct + "* nd = amem(ar, sizeof(" + ct + ") * nc); if (a->len) memcpy(nd, a->data, sizeof(" + ct + ") * a->len); if (ar && a->cap) arena_recycle(ar, a->data, sizeof(" + ct + ") * (size_t)a->cap); a->data = nd; a->cap = nc; } a->data[a->len++] = v; }\n"
    # push-loop fusion grow hook (every element type: shallow spine memcpy; the
    # element heap was already deep-copied into `ar` at each fused store)
    out = out + "static void " + nm + "_grow(Arena* ar, " + ct + "** data, long* cap, long len) { long nc = *cap ? *cap * 2 : 4; " + ct + "* nd = amem(ar, sizeof(" + ct + ") * nc); if (len) memcpy(nd, *data, sizeof(" + ct + ") * len); if (ar && *cap) arena_recycle(ar, *data, sizeof(" + ct + ") * (size_t)*cap); *data = nd; *cap = nc; }\n"
    popv := "a->data[a->len]"                        # scalar: the value; heap: a deep copy into `ar`
    if elem_deepcopy(dc, ctx, et):                   # (so the popped value outlives a later array recycle)
        popv = elem_copy_expr(dc, ctx, et, "ar", "a->data[a->len]")
    out = out + "static " + ct + nm + "_pop(Arena* ar, " + nm + "* a) { if (a->len == 0) { fprintf(stderr, \"hier: pop from an empty array\\n\"); exit(1); } a->len--; return " + popv + "; }\n"
    out = out + "static void " + nm + "_reserve(Arena* ar, " + nm + "* a, long n) { if (n <= a->cap) return; " + ct + "* nd = amem(ar, sizeof(" + ct + ") * n); if (a->len) memcpy(nd, a->data, sizeof(" + ct + ") * a->len); if (ar && a->cap) arena_recycle(ar, a->data, sizeof(" + ct + ") * (size_t)a->cap); a->data = nd; a->cap = n; }\n"
    out = out + "static " + nm + " " + nm + "_slice(Arena* ar, " + nm + " a, long lo, long hi) { return " + nm + "_from(ar, a.data + lo, hi - lo); }\n"
    # _eq for every element type (eq_field handles scalar/str/enum/struct/array/
    # option/result); the gen_arr_type forward decl lets composite eq cross-ref.
    out = out + "static int " + nm + "_eq(" + nm + " a, " + nm + " b) { if (a.len != b.len) return 0; for (long i = 0; i < a.len; i++) if (!(" + eq_field(dc, ctx, et, "a.data[i]", "b.data[i]") + ")) return 0; return 1; }\n"
    return out

# SOA typedef + helper forward decls — emitted BEFORE struct bodies so a struct
# may embed a soa by value, and before struct copy/eq so they can call the soa
# helpers. (Bodies are gen_soa, emitted after struct bodies for sizeof.)
fn gen_soa_decl(dc: Decls, ctx: Ctx, ty: string) -> string:
    sn := soa_struct(ty)
    nm := "Soa_" + sn
    si := 0
    for si < len(dc.structs):
        if dc.structs[si].name == sn:
            flds := dc.structs[si].fields
            out := "typedef struct {"
            i := 0
            for i < len(flds):
                out = out + " " + cty(dc, ctx, flds[i].ty) + "* f" + str(i) + ";"
                i = i + 1
            out = out + " long len; long cap; } " + nm + ";\n"
            out = out + "static void " + nm + "_push(Arena* ar, " + nm + "* s, " + ust(sn) + " v);\n"
            out = out + "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " s);\n"
            out = out + "static int " + nm + "_eq(" + nm + " a, " + nm + " b);\n"
            return out
        si = si + 1
    return ""

# SOA family for `soa [Struct]`: one growable buffer per struct field (f0, f1,
# ...) + a shared len/cap, instead of an array of records. Arena-backed (each
# field buffer lives in the owner arena, freed with its scope) like the Arr
# families -- earlier this was naive realloc/malloc and LEAKED (the leak fuzzer
# found it). push grows each buffer and scatters the struct's (scalar) fields.
fn gen_soa(dc: Decls, ctx: Ctx, ty: string) -> string:
    sn := soa_struct(ty)
    nm := "Soa_" + sn
    si := 0
    for si < len(dc.structs):
        if dc.structs[si].name == sn:
            flds := dc.structs[si].fields       # typedef + decls emitted by gen_soa_decl (early)
            out := "static void " + nm + "_push(Arena* ar, " + nm + "* s, " + ust(sn) + " v) {\n"
            out = out + "    if (s->len == s->cap) { long nc = s->cap ? s->cap * 2 : 4;\n"
            i := 0
            for i < len(flds):
                ct := cty(dc, ctx, flds[i].ty)
                out = out + "        " + ct + "* n" + str(i) + " = amem(ar, sizeof(" + ct + ") * nc); for (long j = 0; j < s->len; j = j + 1) n" + str(i) + "[j] = s->f" + str(i) + "[j]; if (ar && s->cap) arena_recycle(ar, s->f" + str(i) + ", sizeof(" + ct + ") * (size_t)s->cap); s->f" + str(i) + " = n" + str(i) + ";\n"
                i = i + 1
            out = out + "        s->cap = nc;\n    }\n"
            i = 0
            for i < len(flds):
                out = out + "    s->f" + str(i) + "[s->len] = v." + uf(flds[i].name) + ";\n"
                i = i + 1
            out = out + "    s->len = s->len + 1;\n}\n"
            # copy: deep-copy each field buffer (value semantics on bind/pass/return)
            out = out + "static " + nm + " " + nm + "_copy(Arena* ar, " + nm + " s) {\n"
            out = out + "    " + nm + " r; r.len = s.len; r.cap = s.len;\n"
            i = 0
            for i < len(flds):
                ct := cty(dc, ctx, flds[i].ty)
                out = out + "    r.f" + str(i) + " = s.len ? amem(ar, sizeof(" + ct + ") * s.len) : 0;\n"
                out = out + "    for (long j = 0; j < s.len; j = j + 1) r.f" + str(i) + "[j] = s.f" + str(i) + "[j];\n"
                i = i + 1
            out = out + "    return r;\n}\n"
            # structural eq: same length + every field equal elementwise
            out = out + "static int " + nm + "_eq(" + nm + " a, " + nm + " b) {\n"
            out = out + "    if (a.len != b.len) return 0;\n"
            out = out + "    for (long j = 0; j < a.len; j = j + 1) {\n"
            i = 0
            for i < len(flds):
                out = out + "        if (!(" + eq_field(dc, ctx, flds[i].ty, "a.f" + str(i) + "[j]", "b.f" + str(i) + "[j]") + ")) return 0;\n"
                i = i + 1
            out = out + "    }\n    return 1;\n}\n"
            # pop: shrink len, gather the (new) last element, deep-copy it into `ar`
            # (heap fields outlive a later push that overwrites the freed slot).
            out = out + "static " + ust(sn) + " " + nm + "_pop(" + nm + "* s) {\n"
            out = out + "    if (s->len == 0) { fprintf(stderr, \"hier: pop from an empty array\\n\"); exit(1); }\n"
            out = out + "    s->len = s->len - 1;\n"
            out = out + "    return " + gen_soa_gather(dc, ctx, ty, "(*s)", "s->len") + ";\n}\n"
            return out
        si = si + 1
    die("codegen: soa of unknown struct")
    return ""

# Runtime that depends on Arr_str (so it is emitted after the array families,
# not in the preamble): split a string on a separator into a [string].
fn gen_strlib() -> string:
    # buffer AND substrings in `ar` (the result's owner): Arr_str now deep-copies
    # str elements on copy/return, so the substrings can live in the array's arena
    # and free with it instead of leaking.
    out := "static Arr_str hi_split(Arena* ar, const char* s, const char* sep) {\n"
    out = out + "    Arr_str r = Arr_str_new();\n"
    out = out + "    long n = strlen(s), sl = strlen(sep);\n"
    out = out + "    if (sl == 0) { Arr_str_push(ar, &r, substr(ar, s, 0, n)); return r; }\n"
    out = out + "    long start = 0, i = 0;\n"
    out = out + "    while (i + sl <= n) {\n"
    out = out + "        if (strncmp(s + i, sep, sl) == 0) { Arr_str_push(ar, &r, substr(ar, s, start, i)); i += sl; start = i; }\n"
    out = out + "        else i = i + 1;\n"
    out = out + "    }\n"
    out = out + "    Arr_str_push(ar, &r, substr(ar, s, start, n));\n"
    out = out + "    return r;\n}\n"
    out = out + "static Arr_str hi_list_dir(Arena* ar, const char* path) {\n"
    out = out + "    Arr_str r = Arr_str_new();\n"
    out = out + "    DIR* d = opendir(path); if (!d) return r;\n"
    out = out + "    struct dirent* de;\n"
    out = out + "    while ((de = readdir(d)) != 0) {\n"
    out = out + "        if (de->d_name[0] == '.' && (de->d_name[1] == 0 || (de->d_name[1] == '.' && de->d_name[2] == 0))) continue;\n"
    out = out + "        Arr_str_push(ar, &r, scopy(ar, de->d_name));\n"   # headered copy; also survives readdir's buffer reuse
    out = out + "    }\n"
    out = out + "    closedir(d);\n    return r;\n}\n"
    out = out + "static Arr_str hi_args(Arena* ar) {\n"
    out = out + "    Arr_str r = Arr_str_new();\n"
    out = out + "    for (int i = 0; i < hi_argc; i++) Arr_str_push(ar, &r, scopy(ar, hi_argv[i]));\n"
    out = out + "    return r;\n}\n"
    return out

# String-keyed int map (the one map type the examples use). A faithful mirror
# of the C runtime's open-addressing table (runtime/hier_rt.c): FNV-1a hash,
# power-of-2 capacity (min 8), linear probing, rehash past 1/2 load, deep-copy
# value semantics, keys() in bucket order. No tombstones (the subset has no
# map delete). Mirroring it byte-for-byte is what makes keys()-order match.
# Depends on Arr_str.
fn gen_mhash() -> string:                        # shared string FNV-1a + int SplitMix64 hashes
    out := "static unsigned long mhash(const char* s) { unsigned long h = 1469598103934665603UL; for (; *s; s++) { h ^= (unsigned char)*s; h *= 1099511628211UL; } return h; }\n"
    out = out + "static unsigned long ikhash(long k) { unsigned long x = (unsigned long)k + 0x9e3779b97f4a7c15UL; x = (x ^ (x >> 30)) * 0xbf58476d1ce4e5b9UL; x = (x ^ (x >> 27)) * 0x94d049bb133111ebUL; return x ^ (x >> 31); }\n"
    return out

fn gen_map_type(dc: Decls, ctx: Ctx, ty: string) -> string:
    k := map_key(ty)
    if resolve_nt(dc, ctx, k) != "int" and resolve_nt(dc, ctx, k) != "str" and not enum_fieldless(dc, ctx, k):
        die_at(dc, ctx.line, "type: map keys must be string, int (directly or through a newtype), or a fieldless enum")   # fail-closed: a payload enum / struct / float key fell through to the string-key layout and emitted broken C
    v := map_val(ty)
    cvs := cty(dc, ctx, v)                        # value C type (has a trailing space)
    cv := substr(cvs, 0, len(cvs) - 1)
    M := "Map_" + k + "_" + mangle(v)            # named-tag body; typedef forward-declared in the driver (fn([K:V])->R)
    if resolve_nt(dc, ctx, k) == "int" or enum_fieldless(dc, ctx, k):   # int(-rep) keys incl. enum tags: a value array + occupancy bytes (0 is a real key)
        return "struct " + M + "_ { long* keys; " + cv + "* vals; unsigned char* occ; long len; long cap; };\n"
    return "struct " + M + "_ { char** keys; " + cv + "* vals; long len; long cap; };\n"

# Map family monomorphized over key k (str/int) and value v (int/float). The C
# value type cv is long/double. String keys use mhash + strcmp + a NULL-empty key
# array (key bytes copied in); int keys use ikhash + == + a separate occupancy
# byte array (0 is a real key, so there is no free empty marker). Neither uses
# tombstones — map delete rebuilds — so the probe stops at the first empty slot.
fn gen_map_fns(dc: Decls, ctx: Ctx, ty: string) -> string:
    k := map_key(ty)
    v := map_val(ty)
    cvs := cty(dc, ctx, v)                        # value C type (has a trailing space)
    cv := substr(cvs, 0, len(cvs) - 1)
    M := "Map_" + k + "_" + mangle(v)
    f := "map_" + k + "_" + mangle(v)
    s := "m" + mtag(k) + "_" + mangle(v)
    ka := "Arr_" + mangle(k)                     # keys() returns [K] (a newtype/enum key stays wrapped)
    kv := "m.keys[i]"                            # the value keys() pushes
    pre := ""
    if enum_fieldless(dc, ctx, k):               # enum key: tags are stored; keys() rebuilds the
        ei := 0                                  # wrapped values from a tag -> singleton table.
        for ei < len(dc.enums):                  # Tentative decls first: the singletons' initialized
            if dc.enums[ei].name == k:           # definitions are emitted later (enum fns step).
                tab := "static " + uet(k) + "* const " + f + "_ktab[] = {"
                vj := 0
                for vj < len(dc.enums[ei].variants):
                    pre = pre + "static " + uet(k) + " _sing_" + k + "_" + str(vj) + ";\n"
                    if vj > 0:
                        tab = tab + ","
                    tab = tab + " &_sing_" + k + "_" + str(vj)
                    vj = vj + 1
                pre = pre + tab + " };\n"
            ei = ei + 1
        kv = f + "_ktab[m.keys[i]]"
    vcopy := cp_field(dc, ctx, v, "ar", "val")   # deep-copy the value into ar (passthrough for scalars)
    vcmp := " || !(" + eq_field(dc, ctx, v, "b.vals[t]", "a.vals[i]") + ")"   # heap value: deep equality
    if v == "int" or v == "float" or v == "char":
        vcmp = " || b.vals[t] != a.vals[i]"      # scalar: byte-identical to before
    if resolve_nt(dc, ctx, k) == "int" or enum_fieldless(dc, ctx, k):
        out := pre + "static " + M + " " + s + "_cap(Arena* ar, long cap) { " + M + " m; long c = 8; while (c < cap) c *= 2; if (cap == 0) c = 0; m.cap = c; m.len = 0; if (c == 0) { m.keys = 0; m.vals = 0; m.occ = 0; return m; } m.keys = amem(ar, sizeof(long) * c); m.vals = amem(ar, sizeof(" + cv + ") * c); m.occ = amem(ar, c); for (long i = 0; i < c; i++) m.occ[i] = 0; return m; }\n"
        out = out + "static " + M + " " + f + "_new(void) { return " + s + "_cap(0, 0); }\n"
        out = out + "static long " + s + "_slot(" + M + " m, long k) { unsigned long mask = (unsigned long)m.cap - 1; long i = (long)(ikhash(k) & mask); while (m.occ[i] != 0) { if (m.keys[i] == k) return i; i = (long)((i + 1) & mask); } return i; }\n"
        out = out + "static void " + f + "_put(Arena* ar, " + M + "* m, long k, " + cv + " val) { if (m->cap == 0 || (m->len + 1) * 2 > m->cap) { long nc = m->cap ? m->cap * 2 : 8; " + M + " n = " + s + "_cap(ar, nc); for (long i = 0; i < m->cap; i++) if (m->occ[i]) { long t = " + s + "_slot(n, m->keys[i]); n.keys[t] = m->keys[i]; n.vals[t] = m->vals[i]; n.occ[t] = 1; n.len++; } *m = n; } long t = " + s + "_slot(*m, k); if (!m->occ[t]) { m->occ[t] = 1; m->keys[t] = k; m->len++; } m->vals[t] = " + vcopy + "; }\n"
        # in-place value projection: find-or-insert, return &slot value (#2). dormant until step 2 routes m[k] here.
        out = out + "static inline " + cv + "* " + s + "_slotptr(Arena* ar, " + M + "* m, long k) { if (m->cap == 0 || (m->len + 1) * 2 > m->cap) { long nc = m->cap ? m->cap * 2 : 8; " + M + " n = " + s + "_cap(ar, nc); for (long i = 0; i < m->cap; i++) if (m->occ[i]) { long t = " + s + "_slot(n, m->keys[i]); n.keys[t] = m->keys[i]; n.vals[t] = m->vals[i]; n.occ[t] = 1; n.len++; } *m = n; } long t = " + s + "_slot(*m, k); if (!m->occ[t]) { m->occ[t] = 1; m->keys[t] = k; m->len++; m->vals[t] = (" + cv + "){0}; } return &m->vals[t]; }\n"
        out = out + "static " + M + " " + f + "_copy(Arena* ar, " + M + " m) { " + M + " r = " + s + "_cap(ar, m.len ? m.len * 2 : 0); for (long i = 0; i < m.cap; i++) if (m.occ[i]) " + f + "_put(ar, &r, m.keys[i], m.vals[i]); return r; }\n"
        out = out + "static " + M + " " + f + "_set(Arena* ar, " + M + " m, long k, " + cv + " val) { " + M + " r = " + f + "_copy(ar, m); " + f + "_put(ar, &r, k, val); return r; }\n"
        out = out + "static " + cv + " " + f + "_get(" + M + " m, long k, " + cv + " def) { if (m.cap == 0) return def; long t = " + s + "_slot(m, k); return m.occ[t] ? m.vals[t] : def; }\n"
        out = out + "static int " + f + "_has(" + M + " m, long k) { if (m.cap == 0) return 0; long t = " + s + "_slot(m, k); return m.occ[t] != 0; }\n"
        out = out + "static " + M + " " + f + "_del(Arena* ar, " + M + " m, long k) { " + M + " r = " + f + "_new(); for (long i = 0; i < m.cap; i++) if (m.occ[i] && m.keys[i] != k) " + f + "_put(ar, &r, m.keys[i], m.vals[i]); return r; }\n"
        out = out + "static " + ka + " " + f + "_keys(Arena* ar, " + M + " m) { " + ka + " r = " + ka + "_new(); for (long i = 0; i < m.cap; i++) if (m.occ[i]) " + ka + "_push(ar, &r, " + kv + "); return r; }\n"
        out = out + "static int " + f + "_eq(" + M + " a, " + M + " b) { if (a.len != b.len) return 0; for (long i = 0; i < a.cap; i++) if (a.occ[i]) { long t = " + s + "_slot(b, a.keys[i]); if (b.occ[t] == 0" + vcmp + ") return 0; } return 1; }\n"
        return out
    out := "static " + M + " " + s + "_cap(Arena* ar, long cap) { " + M + " m; long c = 8; while (c < cap) c *= 2; if (cap == 0) c = 0; m.cap = c; m.len = 0; if (c == 0) { m.keys = 0; m.vals = 0; return m; } m.keys = amem(ar, sizeof(char*) * c); m.vals = amem(ar, sizeof(" + cv + ") * c); for (long i = 0; i < c; i++) m.keys[i] = 0; return m; }\n"
    out = out + "static " + M + " " + f + "_new(void) { return " + s + "_cap(0, 0); }\n"
    out = out + "static long " + s + "_slot(" + M + " m, const char* k) { unsigned long mask = (unsigned long)m.cap - 1; long i = (long)(mhash(k) & mask); while (m.keys[i] != 0) { if (strcmp(m.keys[i], k) == 0) return i; i = (long)((i + 1) & mask); } return i; }\n"
    out = out + "static void " + f + "_put(Arena* ar, " + M + "* m, char* k, " + cv + " val) { if (m->cap == 0 || (m->len + 1) * 2 > m->cap) { long nc = m->cap ? m->cap * 2 : 8; " + M + " n = " + s + "_cap(ar, nc); for (long i = 0; i < m->cap; i++) if (m->keys[i] != 0) { long t = " + s + "_slot(n, m->keys[i]); n.keys[t] = m->keys[i]; n.vals[t] = m->vals[i]; n.len++; } *m = n; } long t = " + s + "_slot(*m, k); if (m->keys[t] == 0) { m->keys[t] = sc(ar, k, \"\"); m->len++; } m->vals[t] = " + vcopy + "; }\n"
    # in-place value projection: find-or-insert, return &slot value (#2). dormant until step 2 routes m[k] here.
    out = out + "static inline " + cv + "* " + s + "_slotptr(Arena* ar, " + M + "* m, const char* k) { if (m->cap == 0 || (m->len + 1) * 2 > m->cap) { long nc = m->cap ? m->cap * 2 : 8; " + M + " n = " + s + "_cap(ar, nc); for (long i = 0; i < m->cap; i++) if (m->keys[i] != 0) { long t = " + s + "_slot(n, m->keys[i]); n.keys[t] = m->keys[i]; n.vals[t] = m->vals[i]; n.len++; } *m = n; } long t = " + s + "_slot(*m, k); if (m->keys[t] == 0) { m->keys[t] = sc(ar, k, \"\"); m->len++; m->vals[t] = (" + cv + "){0}; } return &m->vals[t]; }\n"
    out = out + "static " + M + " " + f + "_copy(Arena* ar, " + M + " m) { " + M + " r = " + s + "_cap(ar, m.len ? m.len * 2 : 0); for (long i = 0; i < m.cap; i++) if (m.keys[i] != 0) " + f + "_put(ar, &r, m.keys[i], m.vals[i]); return r; }\n"
    out = out + "static " + M + " " + f + "_set(Arena* ar, " + M + " m, char* k, " + cv + " val) { " + M + " r = " + f + "_copy(ar, m); " + f + "_put(ar, &r, k, val); return r; }\n"
    out = out + "static " + cv + " " + f + "_get(" + M + " m, char* k, " + cv + " def) { if (m.cap == 0) return def; long t = " + s + "_slot(m, k); return m.keys[t] ? m.vals[t] : def; }\n"
    out = out + "static int " + f + "_has(" + M + " m, char* k) { if (m.cap == 0) return 0; long t = " + s + "_slot(m, k); return m.keys[t] != 0; }\n"
    out = out + "static " + M + " " + f + "_del(Arena* ar, " + M + " m, char* k) { " + M + " r = " + f + "_new(); for (long i = 0; i < m.cap; i++) if (m.keys[i] != 0 && strcmp(m.keys[i], k) != 0) " + f + "_put(ar, &r, m.keys[i], m.vals[i]); return r; }\n"
    out = out + "static " + ka + " " + f + "_keys(Arena* ar, " + M + " m) { " + ka + " r = " + ka + "_new(); for (long i = 0; i < m.cap; i++) if (m.keys[i] != 0) " + ka + "_push(ar, &r, scopy(ar, m.keys[i])); return r; }\n"
    # structural equality: same length, and every live key in a present in b with
    # an equal value (same len + a's keys ⊆ b with equal values ⟹ equal).
    out = out + "static int " + f + "_eq(" + M + " a, " + M + " b) { if (a.len != b.len) return 0; for (long i = 0; i < a.cap; i++) if (a.keys[i] != 0) { long t = " + s + "_slot(b, a.keys[i]); if (b.keys[t] == 0" + vcmp + ") return 0; } return 1; }\n"
    return out

fn has_str(xs: [string], s: string) -> bool:
    i := 0
    for i < len(xs):
        if xs[i] == s:
            return true
        i = i + 1
    return false

# Record the array element types a type needs, recursively (so [[int]] also
# pulls in [int], and Option/Result element types are descended into).
fn note_arr_types(acc: inout [string], ty: string):
    b := base_ty(ty)
    if is_array(b):
        et := elem_ty(b)
        if not has_str(acc, et):
            push(acc, et)
        note_arr_types(&acc, et)
    elif is_option(b):
        note_arr_types(&acc, option_inner(b))
    elif is_result(b):
        note_arr_types(&acc, result_ok(b))
        note_arr_types(&acc, result_err(b))
    elif is_soa(b):                              # collect the soa family (Soa_<Struct>)
        if not has_str(acc, b):
            push(acc, b)
    elif is_tuple(b):
        if not has_str(acc, b):
            push(acc, b)
        parts := tuple_parts(b)
        i := 0
        for i < len(parts):
            note_arr_types(&acc, parts[i])
            i = i + 1
    elif is_map(b):
        note_arr_types(&acc, map_val(b))               # value family FIRST: a map-valued map's
        note_arr_types(&acc, "[" + map_key(b) + "]")   # inner map must be typedef'd before the outer
        if not has_str(acc, b):                        # (its struct holds an inner-map pointer member);
            push(acc, b)                               # keys(m) -> [K] array family also emitted
    elif is_func(b):                                   # fn(P...) -> R : collect param/ret families first
        ps := func_params(b)
        i := 0
        for i < len(ps):
            note_arr_types(&acc, ps[i])
            i = i + 1
        note_arr_types(&acc, func_ret(b))
        if not has_str(acc, b):
            push(acc, b)

# Walk an expression collecting composite array element types from literals
# (array literals / empty arrays that no annotation would reveal).
# The body walkers thread the var env (names/types), mirroring gen, so that
# type_of resolves variables inside tuple/array literals (e.g. t := (a, b)).
fn collect_expr(acc: inout [string], e: Expr, names: [string], types: [string], dc: Decls, ctx: Ctx):
    match e:
        EArrLit(elems, _el):
            note_arr_types(&acc, type_of(e, names, types, dc, ctx))
            j := 0
            for j < len(elems):
                collect_expr(&acc, elems[j], names, types, dc, ctx)
                j = j + 1
        EArrEmpty(ety, _el):
            note_arr_types(&acc, "[" + ety + "]")
        EMapEmpty(k, v, _el):
            note_arr_types(&acc, "{" + k + ":" + v + "}")
        EMapLit(keys, vals, _el):
            note_arr_types(&acc, type_of(e, names, types, dc, ctx))
            j := 0
            for j < len(vals):
                collect_expr(&acc, keys[j], names, types, dc, ctx)
                collect_expr(&acc, vals[j], names, types, dc, ctx)
                j = j + 1
        ETuple(elems, _el):
            note_arr_types(&acc, type_of(e, names, types, dc, ctx))
            j := 0
            for j < len(elems):
                collect_expr(&acc, elems[j], names, types, dc, ctx)
                j = j + 1
        EBin(op, l, r, _el):
            collect_expr(&acc, l, names, types, dc, ctx)
            collect_expr(&acc, r, names, types, dc, ctx)
        ECall(nm, args, _el):
            j := 0
            for j < len(args):
                collect_expr(&acc, args[j], names, types, dc, ctx)
                j = j + 1
        EField(b, f, _el):
            collect_expr(&acc, b, names, types, dc, ctx)
        EIndex(b, idx, _el):
            collect_expr(&acc, b, names, types, dc, ctx)
            collect_expr(&acc, idx, names, types, dc, ctx)
        ESlice(b, lo, hi, _el):
            collect_expr(&acc, b, names, types, dc, ctx)
            collect_expr(&acc, lo, names, types, dc, ctx)
            collect_expr(&acc, hi, names, types, dc, ctx)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            note_arr_types(&acc, mk_functype(pts, ret))   # dedups + collects param/ret families
        ECallV(callee, cargs, _el):
            collect_expr(&acc, callee, names, types, dc, ctx)
            j := 0
            for j < len(cargs):
                collect_expr(&acc, cargs[j], names, types, dc, ctx)
                j = j + 1
        EAddr(inner, _el):
            collect_expr(&acc, inner, names, types, dc, ctx)
        EInt(t, _el):
            j := 0
        EBool(t, _el):
            j := 0
        EChar(t, _el):
            j := 0
        EFloat(f, _el):
            j := 0
        EStr(s, _el):
            j := 0
        EVar(n, _el):
            if not has_str(names, n):              # a bare top-level fn name used as a value: collect its fn type
                note_arr_types(&acc, type_of(e, names, types, dc, ctx))
        ESpawn(sid, snm, sa, _el):
            j := 0
            for j < len(sa):
                collect_expr(&acc, sa[j], names, types, dc, ctx)
                j = j + 1

fn collect_block(acc: inout [string], stmts: [Stmt], names: [string], types: [string], dc: Decls, ctx: Ctx):
    ns := names
    ts := types
    i := 0
    for i < len(stmts):
        collect_stmt(&acc, stmts[i], &ns, &ts, dc, ctx)
        i = i + 1

fn collect_stmt(acc: inout [string], s: Stmt, names: inout [string], types: inout [string], dc: Decls, ctx: Ctx):
    match s:
        SDecl(n, e, _sl):
            collect_expr(&acc, e, names, types, dc, ctx)
            ty := type_of(e, names, types, dc, ctx)
            push(names, n)
            push(types, ty)
        SAssign(n, e, _sl):
            collect_expr(&acc, e, names, types, dc, ctx)
        SFieldAssign(lv, rhs, _sl):
            collect_expr(&acc, lv, names, types, dc, ctx)
            collect_expr(&acc, rhs, names, types, dc, ctx)
        SPrint(e, _sl):
            collect_expr(&acc, e, names, types, dc, ctx)
        SReturn(e, _sl):
            collect_expr(&acc, e, names, types, dc, ctx)
        SReturnVoid:
            j := 0
        SBreak:
            j := 0
        SContinue:
            j := 0
        SExpr(e, _sl):
            collect_expr(&acc, e, names, types, dc, ctx)
        STypedDecl(n, t, e, _sl):
            note_arr_types(&acc, t)
            collect_expr(&acc, e, names, types, dc, ctx)
            push(names, n)
            push(types, t)
        SOrReturn(n, e, _sl):
            collect_expr(&acc, e, names, types, dc, ctx)
            ety := type_of(e, names, types, dc, ctx)
            ty := ""
            if is_option(ety):                    # Option or_return binds the inner type
                ty = option_inner(ety)
            else:
                ty = result_ok(ety)               # (result_ok on a non-Result substrs out of range)
            push(names, n)
            push(types, ty)
        SDestructure(dnames, e, _sl):
            collect_expr(&acc, e, names, types, dc, ctx)
            parts := tuple_parts(type_of(e, names, types, dc, ctx))
            j := 0
            for j < len(dnames):
                push(names, dnames[j])
                push(types, parts[j])
                j = j + 1
        SMultiAssign(mnames, e, _sl):                  # vars already exist; just collect the RHS
            collect_expr(&acc, e, names, types, dc, ctx)
        SIf(c, tb, eb, _sl):
            collect_expr(&acc, c, names, types, dc, ctx)
            collect_block(&acc, tb, names, types, dc, ctx)
            collect_block(&acc, eb, names, types, dc, ctx)
        SWhile(c, body, _sl):
            collect_expr(&acc, c, names, types, dc, ctx)
            collect_block(&acc, body, names, types, dc, ctx)
        SForRange(n, a, b, st, body, _sl):
            collect_expr(&acc, a, names, types, dc, ctx)
            collect_expr(&acc, b, names, types, dc, ctx)
            collect_expr(&acc, st, names, types, dc, ctx)
            bn := names
            bt := types
            push(bn, n)
            push(bt, "int")
            collect_block(&acc, body, bn, bt, dc, ctx)
        SMatch(subj, variants, allbinds, bodies, _sl):
            collect_expr(&acc, subj, names, types, dc, ctx)
            sty := type_of(subj, names, types, dc, ctx)
            j := 0
            for j < len(bodies):
                bn := names                       # bind arm payloads so type_of resolves them
                bt := types                       # in the arm body (mirrors gen_stmt's match)
                binds := allbinds[j]
                if is_option(sty):
                    if len(binds) > 0:
                        push(bn, binds[0])
                        push(bt, option_inner(sty))
                elif is_result(sty):
                    if len(binds) > 0:
                        push(bn, binds[0])
                        if variants[j] == "Ok":
                            push(bt, result_ok(sty))
                        else:
                            push(bt, result_err(sty))
                else:
                    pts := variant_ptypes(dc, ctx, variants[j])
                    k := 0
                    for k < len(binds):
                        push(bn, binds[k])
                        push(bt, pts[k])
                        k = k + 1
                collect_block(&acc, bodies[j], bn, bt, dc, ctx)
                j = j + 1
        SParFor(v, a, b, body, pid, _sl):              # the chunk proc (and its partial type) is a lifted Func,
            collect_expr(&acc, a, names, types, dc, ctx)   # walked separately; only the site's bounds remain here
            collect_expr(&acc, b, names, types, dc, ctx)
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            sk := 0
            for sk < len(svars):
                collect_expr(&acc, schans[sk], names, types, dc, ctx)
                bn := names
                bt := types
                if svars[sk] == "recv":
                    push(bn, sbinds[sk])
                    push(bt, chan_inner(type_of(schans[sk], names, types, dc, ctx)))
                collect_block(&acc, sbodies[sk], bn, bt, dc, ctx)
                sk = sk + 1

# Element types needing an Arr_T family: int/str (cover every literal seen in
# practice) plus every array element type that appears in an annotation.
fn collect_elem_types(prog: Program, dc: Decls, ctx: Ctx) -> [string]:
    acc := []string
    push(acc, "int")
    push(acc, "str")
    push(acc, "float")
    i := 0                                       # seed every struct/enum name so a
    for i < len(prog.structs):                   # literal-only [Struct]/[Enum] (no annotation
        push(acc, prog.structs[i].name)          # to scan) still gets its Arr_T family
        i = i + 1
    i = 0
    for i < len(prog.enums):
        push(acc, prog.enums[i].name)
        i = i + 1
    i = 0
    for i < len(prog.funcs):
        f := prog.funcs[i]
        j := 0
        for j < len(f.ptypes):
            note_arr_types(&acc, f.ptypes[j])
            j = j + 1
        note_arr_types(&acc, f.ret)
        en := []string                           # seed the body walk with the params
        et := []string
        k := 0
        for k < len(f.params):
            push(en, f.params[k])
            push(et, f.ptypes[k])
            k = k + 1
        collect_block(&acc, f.body, en, et, dc, ctx)   # composite types from literals
        i = i + 1
    i = 0
    for i < len(prog.structs):
        j := 0
        for j < len(prog.structs[i].fields):
            note_arr_types(&acc, prog.structs[i].fields[j].ty)
            j = j + 1
        i = i + 1
    i = 0
    for i < len(prog.enums):
        j := 0
        for j < len(prog.enums[i].variants):
            k := 0
            for k < len(prog.enums[i].variants[j].ptypes):
                note_arr_types(&acc, prog.enums[i].variants[j].ptypes[k])
                k = k + 1
            j = j + 1
        i = i + 1
    return acc

# ---- standalone package driver -------------------------------------------
# With the filesystem builtins (read_file/list_dir/args) hierc0 can compile a
# package program directly from disk — `hierc0 path/to/main.hi` — instead of
# being fed `hierc --bundle ... | hierc0`. bundle() reproduces that bundler in
# Hier: it walks the import graph (dependencies first, deduped/cycle-safe via
# `seen`), concatenates each package's .hi files (sorted for determinism), and
# rewrites the ENTRY package's header to `package main` so it keeps the empty
# mangling prefix. No argument => read stdin (the bootstrap path, unchanged).

fn has_suffix(s: string, suf: string) -> bool:
    ls := len(s)
    lf := len(suf)
    if ls < lf:
        return false
    return substr(s, ls - lf, ls) == suf

fn str_lt(a: string, b: string) -> bool:           # byte-wise less-than (no string < in Hier)
    i := 0
    la := len(a)
    lb := len(b)
    for i < la and i < lb:
        if a[i] < b[i]:
            return true
        if a[i] > b[i]:
            return false
        i = i + 1
    return la < lb

fn insert_sorted(sorted: [string], v: string) -> [string]:   # no array index-set: rebuild
    out := []string
    placed := false
    i := 0
    for i < len(sorted):
        if not placed and str_lt(v, sorted[i]):
            push(out, v)
            placed = true
        push(out, sorted[i])
        i = i + 1
    if not placed:
        push(out, v)
    return out

fn sort_strs(xs: [string]) -> [string]:            # insertion sort (file lists are small)
    out := []string
    i := 0
    for i < len(xs):
        out = insert_sorted(out, xs[i])
        i = i + 1
    return out

fn dir_of(path: string) -> string:                 # "a/b/main.hi" -> "a/b" ; no slash -> "."
    i := len(path) - 1
    for i >= 0:
        if path[i] == 47:
            return substr(path, 0, i)
        i = i - 1
    return "."

fn rewrite_header(content: string) -> string:      # the leading `package X` line -> `package main`
    start := -1
    if has_prefix(content, "package "):
        start = 0
    else:
        idx := find(content, "\npackage ")
        if idx >= 0:
            start = idx + 1
    if start < 0:
        return content
    e := start
    for e < len(content) and content[e] != 10:
        e = e + 1
    return substr(content, 0, start) + "package main" + substr(content, e, len(content))

fn scan_imports(toks: [Token]) -> [string]:        # the file header's import paths (no full parse)
    out := []string
    i := 0
    for toks[i].kind == TNewline:
        i = i + 1
    if toks[i].kind == TIdent and toks[i].text == "package":
        i = i + 1
        if toks[i].kind == TIdent:
            i = i + 1
    running := true
    for running:
        for toks[i].kind == TNewline:
            i = i + 1
        if toks[i].kind == TIdent and toks[i].text == "import":
            i = i + 1
            if toks[i].kind == TIdent:
                i = i + 1
            if toks[i].kind == TStr:
                push(out, toks[i].text)
                i = i + 1
        else:
            running = false
    return out

fn is_package(toks: [Token]) -> bool:              # does the source open with a `package` decl?
    i := 0
    for toks[i].kind == TNewline:
        i = i + 1
    return toks[i].kind == TIdent and toks[i].text == "package"

# Resolve an import path to a package directory. `core:<name>` is a corelib
# import -> $HIER_CORELIB/<name> (a library importable from any program); anything
# else is relative to the importing package's dir. Mirrors hierc's resolve_pkg_dir.
fn resolve_import_dir(dir: string, imp: string) -> string:
    if has_prefix(imp, "core:"):
        root := getenv("HIER_CORELIB")
        if root == "":
            die("hierc0: import \"" + imp + "\" needs the HIER_CORELIB environment variable set to the corelib directory")
        return root + "/" + substr(imp, 5, len(imp))
    return dir + "/" + imp

fn bundle(dir: string, is_entry: bool, seen: inout [string]) -> string:
    k := 0
    for k < len(seen):
        if seen[k] == dir:
            return ""                              # already merged (shared dep / cycle)
        k = k + 1
    push(seen, dir)
    all := list_dir(dir)
    files := []string
    fi := 0
    for fi < len(all):
        if has_suffix(all[fi], ".hi"):
            push(files, all[fi])
        fi = fi + 1
    files = sort_strs(files)
    out := ""
    fj := 0                                         # dependencies first (post-order)
    for fj < len(files):
        imps := scan_imports(lex(read_file(dir + "/" + files[fj])))
        ij := 0
        for ij < len(imps):
            out = out + bundle(resolve_import_dir(dir, imps[ij]), false, &seen)
            ij = ij + 1
        fj = fj + 1
    fk := 0                                         # then this package's files
    for fk < len(files):
        c := read_file(dir + "/" + files[fk])
        if is_entry:
            c = rewrite_header(c)
        out = out + c + "\n"
        fk = fk + 1
    return out

# --- lambda lift pass -------------------------------------------------------
# Lambdas are parsed as ELambda nodes. Before typing/codegen, this scope-aware
# pass walks every function body, assigns each lambda a unique id, runs capture
# analysis (a free var that is an enclosing local is captured BY VALUE), and
# emits a top-level `__lam<id>` Func whose params are [captures...][lambda
# params...] (so its body codegen stays ordinary). The ELambda node is stamped
# with its id + capture names/types so gen_expr can build the closure value
# (env + thunk) at the use site. A LamInfo per lambda drives env-struct + thunk
# emission. hierc0 has NO mutable globals, so the lifted funcs, the capture
# counter, and the LamInfo list are all threaded by inout.
fn mk_functype(ptypes: [string], ret: string) -> string:   # fn(...) type string, byte-identical to sig_functype's format
    out := "fn("
    i := 0
    for i < len(ptypes):
        if i > 0:
            out = out + ","
        out = out + ptypes[i]
        i = i + 1
    return out + "->" + ret + ")"

# Gather every EVar name appearing in `e` (descending into nested lambda bodies,
# so an outer lambda transitively sees a var its inner lambda needs from an
# enclosing scope). Used for capture analysis (free-var scan).
fn collect_evars(e: Expr, out: inout [string]):
    match e:
        EVar(n, _el):
            push(out, n)
        EBin(o, l, r, _el):
            collect_evars(l, &out)
            collect_evars(r, &out)
        ECall(n, a, _el):
            push(out, n)                           # callee may be a captured fn-value local (g(x) where g is a closure); the lift filter keeps only enclosing locals
            j := 0
            for j < len(a):
                collect_evars(a[j], &out)
                j = j + 1
        EField(b, f, _el):
            collect_evars(b, &out)
        EIndex(b, ix, _el):
            collect_evars(b, &out)
            collect_evars(ix, &out)
        EArrLit(es, _el):
            j := 0
            for j < len(es):
                collect_evars(es[j], &out)
                j = j + 1
        EMapLit(ks, vs, _el):
            j := 0
            for j < len(ks):
                collect_evars(ks[j], &out)
                collect_evars(vs[j], &out)
                j = j + 1
        ETuple(es, _el):
            j := 0
            for j < len(es):
                collect_evars(es[j], &out)
                j = j + 1
        ESlice(b, lo, hi, _el):
            collect_evars(b, &out)
            collect_evars(lo, &out)
            collect_evars(hi, &out)
        ECallV(callee, cargs, _el):
            collect_evars(callee, &out)
            j := 0
            for j < len(cargs):
                collect_evars(cargs[j], &out)
                j = j + 1
        EAddr(x, _el):
            collect_evars(x, &out)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            collect_evars(body, &out)
        EInt(t, _el):
            return
        EBool(t, _el):
            return
        EChar(t, _el):
            return
        EFloat(t, _el):
            return
        EStr(s, _el):
            return
        EArrEmpty(t, _el):
            return
        EMapEmpty(k, v, _el):
            return
        ESpawn(sid, snm, sa, _el):
            j := 0
            for j < len(sa):
                collect_evars(sa[j], &out)
                j = j + 1

# Free-var scan over a parallel-for BODY (CC-3 capture analysis): every EVar
# occurrence, via the lambda free-var scan; body-local shadowing only yields a
# harmless extra chunk-proc param. (Reject-grade analysis -- acc-read audits,
# outer-write rejection -- stays in the C compiler, which gates user programs.)
fn pf_body_evars(stmts: [Stmt], out: inout [string]):
    i := 0
    for i < len(stmts):
        match stmts[i]:
            SDecl(n, e, _sl):
                collect_evars(e, &out)
            SAssign(n, e, _sl):
                collect_evars(e, &out)
            SFieldAssign(lv, r, _sl):
                collect_evars(lv, &out)
                collect_evars(r, &out)
            SPrint(e, _sl):
                collect_evars(e, &out)
            SReturn(e, _sl):
                collect_evars(e, &out)
            SReturnVoid:
                i = i
            SBreak:
                i = i
            SContinue:
                i = i
            SIf(c, t, el, _sl):
                collect_evars(c, &out)
                pf_body_evars(t, &out)
                pf_body_evars(el, &out)
            SWhile(c, b, _sl):
                collect_evars(c, &out)
                pf_body_evars(b, &out)
            SForRange(v, a, b, st, body, _sl):
                collect_evars(a, &out)
                collect_evars(b, &out)
                collect_evars(st, &out)
                pf_body_evars(body, &out)
            SExpr(e, _sl):
                collect_evars(e, &out)
            STypedDecl(n, ty, e, _sl):
                collect_evars(e, &out)
            SOrReturn(n, e, _sl):
                collect_evars(e, &out)
            SDestructure(ns, e, _sl):
                collect_evars(e, &out)
            SMultiAssign(ns, e, _sl):
                collect_evars(e, &out)
            SMatch(subj, vars, binds, bodies, _sl):
                collect_evars(subj, &out)
                k := 0
                for k < len(bodies):
                    pf_body_evars(bodies[k], &out)
                    k = k + 1
            SParFor(v, a, b, body, pid, _sl):
                collect_evars(a, &out)
                collect_evars(b, &out)
                pf_body_evars(body, &out)
            SSelect(uid, svars, schans, sbinds, sbodies, _sl):
                sk := 0
                for sk < len(svars):
                    collect_evars(schans[sk], &out)
                    pf_body_evars(sbodies[sk], &out)
                    sk = sk + 1
        i = i + 1

# Reduction accumulators of a parallel-for body: assignments `n = n OP rest`
# (OP in +,*) to a variable bound in the ENCLOSING env. These become identity-
# initialized locals of the chunk proc, folded at the in-order join.
fn pf_accs(stmts: [Stmt], outer: [string], accn: inout [string], accop: inout [string]):
    i := 0
    for i < len(stmts):
        match stmts[i]:
            SAssign(n, e, _sl):
                if has_str(outer, n) and not has_str(accn, n):
                    match e:
                        EBin(op, l, r, _el):
                            if (op == "+" or op == "*") and is_evar(l, n):
                                push(accn, n)
                                push(accop, op)
                        EInt(t, _el):
                            i = i
                        EBool(t, _el):
                            i = i
                        EChar(t, _el):
                            i = i
                        EFloat(f, _el):
                            i = i
                        EStr(s, _el):
                            i = i
                        EVar(vn, _el):
                            i = i
                        ECall(cn, ca, _el):
                            i = i
                        EField(b, f, _el):
                            i = i
                        EIndex(b, ix, _el):
                            i = i
                        EArrLit(es, _el):
                            i = i
                        EArrEmpty(t, _el):
                            i = i
                        EMapEmpty(k, v, _el):
                            i = i
                        EMapLit(ks, vs, _el):
                            i = i
                        ETuple(es, _el):
                            i = i
                        ESlice(b, lo, hi, _el):
                            i = i
                        EAddr(x, _el):
                            i = i
                        ELambda(lid, ps, pts, ret, bx, cn2, ct2, _el):
                            i = i
                        ECallV(c, a, _el):
                            i = i
                        ESpawn(sid, snm, sa, _el):
                            i = i
            SDecl(n, e, _sl):
                i = i
            SFieldAssign(lv, r, _sl):
                i = i
            SPrint(e, _sl):
                i = i
            SReturn(e, _sl):
                i = i
            SReturnVoid:
                i = i
            SBreak:
                i = i
            SContinue:
                i = i
            SIf(c, t, el, _sl):
                pf_accs(t, outer, &accn, &accop)
                pf_accs(el, outer, &accn, &accop)
            SWhile(c, b, _sl):
                pf_accs(b, outer, &accn, &accop)
            SForRange(v, a, b, st, body, _sl):
                pf_accs(body, outer, &accn, &accop)
            SExpr(e, _sl):
                i = i
            STypedDecl(n, ty, e, _sl):
                i = i
            SOrReturn(n, e, _sl):
                i = i
            SDestructure(ns, e, _sl):
                i = i
            SMultiAssign(ns, e, _sl):
                i = i
            SMatch(subj, vars, binds, bodies, _sl):
                k := 0
                for k < len(bodies):
                    pf_accs(bodies[k], outer, &accn, &accop)
                    k = k + 1
            SParFor(v, a, b, body, pid, _sl):
                pf_accs(body, outer, &accn, &accop)
            SSelect(uid, svars, schans, sbinds, sbodies, _sl):
                sk := 0
                for sk < len(svars):
                    pf_accs(sbodies[sk], outer, &accn, &accop)
                    sk = sk + 1
        i = i + 1

# "fn(a,b->r)" -> fills `parts` with the param types, returns the return type.
# Depth-aware over nested ([{ so a nested fn-type's own , and -> don't split.
fn fnty_split(ft: string, parts: inout [string]) -> string:
    inner := substr(ft, 3, len(ft) - 1)
    d := 0
    st := 0
    i := 0
    for i < len(inner):
        c := inner[i]
        if c == 40 or c == 91 or c == 123:        # ( [ {
            d = d + 1
        if c == 41 or c == 93 or c == 125:        # ) ] }
            d = d - 1
        if d == 0 and c == 44:                    # top-level comma
            push(parts, substr(inner, st, i))
            st = i + 1
        if d == 0 and c == 45 and i + 1 < len(inner) and inner[i + 1] == 62:   # top-level ->
            if i > st:
                push(parts, substr(inner, st, i))
            return substr(inner, i + 2, len(inner))
        i = i + 1
    return "void"

# Pierce-Turner checking mode (docs/inference.md), the pre-lift grounding: a
# known destination type `want` ("" = none) flows into the expressions that
# can consume one -- bare [] empties, int literals in float contexts, lambdas
# with elided param/return types -- BEFORE the lift, so capture analysis and
# codegen only ever see ground types. Mirrors hierc's resolve_exp head.
fn ground_pre(dc: Decls, ctx: Ctx, want: string, e: Expr) -> Expr:
    if want == "":
        return e
    match e:
        EArrEmpty(t, _el):
            if t != "":
                return e
            if is_map(want):
                return EMapEmpty(map_key(want), map_val(want), _el)
            if is_soa(want):
                return EArrEmpty(want, _el)
            if is_array(want):
                return EArrEmpty(elem_ty(want), _el)
            return e
        EInt(s, _el):
            if want == "float":
                return EFloat(s + ".0", _el)
            return e
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            if not is_func(want):
                return e
            wp := []string
            wr := fnty_split(want, &wp)
            if len(wp) != len(ps):
                return e
            npts := []string
            k := 0
            for k < len(pts):
                if pts[k] == "":
                    push(npts, wp[k])
                else:
                    push(npts, pts[k])
                k = k + 1
            nret := ret
            if ret == "void" and wr != "void":
                nret = wr
            return ELambda(id, ps, npts, nret, body, cn, ct, _el)
        EBool(t, _el):
            return e
        EChar(t, _el):
            return e
        EFloat(t, _el):
            return e
        EStr(t, _el):
            return e
        EVar(n, _el):
            return e
        EBin(o, l, r, _el):
            return e
        ECall(cn2, ca, _el):
            return e
        EField(b, f, _el):
            return e
        EIndex(b, ix, _el):
            return e
        EArrLit(es, _el):
            return e
        EMapEmpty(k2, v2, _el):
            return e
        EMapLit(ks, vs, _el):
            return e
        ETuple(es, _el):
            return e
        ESlice(b, lo, hi, _el):
            return e
        EAddr(x, _el):
            return e
        ECallV(c2, a2, _el):
            return e
        ESpawn(sid, snm, sa, _el):
            return e

# The destination type of argument `i` of a call to `nm`: user-fn params
# (from the pre-lift Sig table), struct fields, enum payloads, and the typed
# builtins (push/map_set/send). "" when nothing supplies one (Some/Ok/Err
# supply nothing, as in hierc). Shared by ground_args and the B-3 seek.
fn arg_want(dc: Decls, ctx: Ctx, names: [string], types: [string], nm: string, a: [Expr], i: int) -> string:
    if nm == "push" and i == 1:
        return elem_ty(type_of(a[0], names, types, dc, ctx))
    if nm == "map_set" and i == 2:
        return map_val(type_of(a[0], names, types, dc, ctx))
    if nm == "send" and i == 1:
        at := type_of(a[0], names, types, dc, ctx)
        if is_chan(at):
            return chan_inner(at)
        return ""
    if is_builtin_call(nm):
        return ""
    if has_str(names, nm):                        # indirect call through a fn-typed VAR: its param types
        ft := base_ty(var_type(names, types, nm))
        if is_func(ft):
            fp := []string
            fr := fnty_split(ft, &fp)
            if i < len(fp):
                return fp[i]
        return ""
    if is_newtype(dc, ctx, nm):                   # X(v): the underlying type grounds the wrapped literal
        return resolve_nt(dc, ctx, nm)
    si := map_get(dc.sigmap, nm, 0 - 1)
    if si >= 0 and i < len(dc.sigs[si].ptypes):
        return base_ty(dc.sigs[si].ptypes[i])
    sj := 0
    for sj < len(dc.structs):
        if dc.structs[sj].name == nm and i < len(dc.structs[sj].fields):
            return dc.structs[sj].fields[i].ty
        sj = sj + 1
    ej := 0
    for ej < len(dc.enums):
        vk := 0
        for vk < len(dc.enums[ej].variants):
            if dc.enums[ej].variants[vk].name == nm and i < len(dc.enums[ej].variants[vk].ptypes):
                return dc.enums[ej].variants[vk].ptypes[i]
            vk = vk + 1
        ej = ej + 1
    return ""

# Ground every argument of a call against its destination type (B-0/B-2).
fn ground_args(dc: Decls, ctx: Ctx, names: [string], types: [string], nm: string, a: [Expr]) -> [Expr]:
    out := []Expr
    i := 0
    for i < len(a):
        push(out, ground_pre(dc, ctx, arg_want(dc, ctx, names, types, nm, a, i), a[i]))
        i = i + 1
    return out

fn lift_exprs(es: [Expr], lifted: inout [Func], ctr: inout int, lams: inout [LamInfo], spawns: inout [SpawnInfo], pars: inout [ParInfo], names: inout [string], types: inout [string], dc: Decls, ctx: Ctx) -> [Expr]:
    out := []Expr
    i := 0
    for i < len(es):
        push(out, lift_expr(es[i], &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx))
        i = i + 1
    return out

fn lift_expr(e: Expr, lifted: inout [Func], ctr: inout int, lams: inout [LamInfo], spawns: inout [SpawnInfo], pars: inout [ParInfo], names: inout [string], types: inout [string], dc: Decls, ctx: Ctx) -> Expr:
    _sl := 0
    match e:
        EInt(t, _el):
            return e
        EBool(t, _el):
            return e
        EChar(t, _el):
            return e
        EFloat(t, _el):
            return e
        EStr(s, _el):
            return e
        EVar(n, _el):
            return e
        EArrEmpty(t, _el):
            return e
        EMapEmpty(k, v, _el):
            return e
        EBin(o, l, r, _el):
            return EBin(o, lift_expr(l, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_expr(r, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        ECall(n, a, _el):
            ga := ground_args(dc, ctx, names, types, n, a)   # B: per-arg destination types ground empties/literals/lambdas
            return ECall(n, lift_exprs(ga, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        EField(b, f, _el):
            return EField(lift_expr(b, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), f, _el)
        EIndex(b, ix, _el):
            return EIndex(lift_expr(b, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_expr(ix, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        EArrLit(es, _el):
            ges := []Expr                          # B-0: later elements take the first element's type
            ew := ""
            ek := 0
            for ek < len(es):
                ge := es[ek]
                if ek > 0:
                    if ew == "":
                        ew = type_of(es[0], names, types, dc, ctx)
                    ge = ground_pre(dc, ctx, ew, ge)
                push(ges, ge)
                ek = ek + 1
            return EArrLit(lift_exprs(ges, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        EMapLit(ks, vs, _el):
            return EMapLit(lift_exprs(ks, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_exprs(vs, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        ETuple(es, _el):
            return ETuple(lift_exprs(es, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        ESlice(b, lo, hi, _el):
            return ESlice(lift_expr(b, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_expr(lo, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_expr(hi, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        ECallV(callee, cargs, _el):
            # B: a call-on-expression's params ground its args too. EField
            # callees are method forms (UFCS / ch.send) -- their dispatch
            # resolves later, and type_of on the field would die; skip those.
            gca := cargs
            cvt := "void"
            if efield_fname(callee) == "":
                cvt = type_of(callee, names, types, dc, ctx)
            if is_func(cvt):
                cvp := []string
                cvr := fnty_split(cvt, &cvp)
                gc2 := []Expr
                gk := 0
                for gk < len(cargs):
                    cw := ""
                    if gk < len(cvp):
                        cw = cvp[gk]
                    push(gc2, ground_pre(dc, ctx, cw, cargs[gk]))
                    gk = gk + 1
                gca = gc2
            return ECallV(lift_expr(callee, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_exprs(gca, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        EAddr(x, _el):
            return EAddr(lift_expr(x, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _el)
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            kp0 := 0                              # B-2: an untyped param needed an expected fn type by now
            for kp0 < len(pts):
                if pts[kp0] == "":
                    die("type: lambda parameter '" + ps[kp0] + "' needs a type here -- no expected fn type supplies it")
                kp0 = kp0 + 1
            # push the lambda's own params so a nested lambda in the body can capture them
            mark := len(names)
            kp := 0
            for kp < len(ps):
                push(names, ps[kp])
                push(types, pts[kp])
                kp = kp + 1
            nb := lift_expr(body, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)   # lift nested lambdas first
            # capture analysis: a free var that is an ENCLOSING local (not an own
            # param, not a top-level fn/enum) is captured by value.
            fvs := []string
            collect_evars(nb, &fvs)
            capnames := []string
            captypes := []string
            fi := 0
            for fi < len(fvs):
                fv := fvs[fi]
                if has_str(ps, fv):
                    fv = fv                          # own param: in scope but not a capture
                elif has_str(capnames, fv):
                    fv = fv                          # already captured
                elif has_str(names, fv):             # an enclosing local -> capture by value (heap: deep-copied at creation)
                    push(capnames, fv)
                    push(captypes, var_type(names, types, fv))
                # else: a top-level fn / enum / None -> resolves inside the lifted proc, not a capture
                fi = fi + 1
            names = names[0:mark]                     # pop own params
            types = types[0:mark]
            myid := ctr
            ctr = ctr + 1
            # lifted proc params = [captures...][lambda params...]
            lparams := []string
            lptypes := []string
            ci := 0
            for ci < len(capnames):
                push(lparams, capnames[ci])
                push(lptypes, captypes[ci])
                ci = ci + 1
            pj := 0
            for pj < len(ps):
                push(lparams, ps[pj])
                push(lptypes, pts[pj])
                pj = pj + 1
            lbody := []Stmt
            if ret == "void":
                push(lbody, SExpr(nb, _sl))
            else:
                push(lbody, SReturn(nb, _sl))
            push(lifted, Func("__lam" + str(myid), lparams, lptypes, ret, lbody, 0, ""))
            push(lams, LamInfo(myid, mk_functype(pts, ret), capnames, captypes, pts, ret))
            return ELambda(myid, ps, pts, ret, nb, capnames, captypes, _el)
        ESpawn(id, nm, sargs, _el):
            # CC-1: assign the spawn-site id and record the SpawnInfo that drives
            # the HSpawnA_<id> args-struct + hier_spawn_<id> trampoline emission.
            nsa := lift_exprs(sargs, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            si := map_get(dc.sigmap, nm, -1)
            if si < 0:
                die("type: spawn of unknown function '" + nm + "'")
            if dc.sigs[si].is_extern == 1:
                die("type: cannot spawn an extern (FFI) function")
            if dc.sigs[si].ret == "void":
                die("type: a spawned function must return a value (wait(t) yields it)")
            sj := 0
            for sj < len(dc.sigs[si].ptypes):
                if is_inout(dc.sigs[si].ptypes[sj]):
                    die("type: cannot spawn a function with inout parameters (no shared state across threads)")
                sj = sj + 1
            sid := len(spawns)
            push(spawns, SpawnInfo(nm, dc.sigs[si].ptypes, dc.sigs[si].ret))
            return ESpawn(sid, nm, nsa, _el)

# B-3 (docs/inference.md): is `e` a bare incomplete initializer? 1 = bare [],
# 2 = bare None, 0 = neither. (hierc parses None as an E_NONE node; hierc0
# parses it as the 0-arg builtin call ECall("None", [], _el).)
fn pend_init_kind(e: Expr) -> int:
    match e:
        EArrEmpty(t, _el):
            if t == "":
                return 1
            return 0
        ECall(nm, a, _el):
            if nm == "None" and len(a) == 0:
                return 2
            return 0
        EInt(s, _el):
            return 0
        EBool(s, _el):
            return 0
        EChar(s, _el):
            return 0
        EFloat(s, _el):
            return 0
        EStr(s, _el):
            return 0
        EVar(s, _el):
            if s == "None":                       # a bare None parses as EVar("None", _el) in hierc0
                return 2
            return 0
        EBin(o, l, r, _el):
            return 0
        EField(b, f, _el):
            return 0
        EIndex(b, ix, _el):
            return 0
        EArrLit(es, _el):
            return 0
        EMapEmpty(k, v, _el):
            return 0
        EMapLit(ks, vs, _el):
            return 0
        ETuple(es, _el):
            return 0
        ESlice(b, lo, hi, _el):
            return 0
        EAddr(x, _el):
            return 0
        ELambda(id, ps, pts, ret, bx, cn, ct, _el):
            return 0
        ECallV(c, a2, _el):
            return 0
        ESpawn(sid, snm, sa, _el):
            return 0

# B-3 probe: the declared name if `s` is an untyped decl with a bare
# initializer ("" otherwise), with the initializer handed back via `ex`.
fn pend_probe(s: Stmt, ex: inout Expr) -> string:
    match s:
        SDecl(n, e, _sl):
            if pend_init_kind(e) != 0:
                ex = e
                return n
            return ""
        SAssign(n, e, _sl):
            return ""
        SFieldAssign(lv, r, _sl):
            return ""
        SPrint(e, _sl):
            return ""
        SReturn(e, _sl):
            return ""
        SReturnVoid:
            return ""
        SIf(c, t, el, _sl):
            return ""
        SWhile(c, b, _sl):
            return ""
        SForRange(v, a, b, st, body, _sl):
            return ""
        SExpr(e, _sl):
            return ""
        STypedDecl(n, ty, e, _sl):
            return ""
        SOrReturn(n, e, _sl):
            return ""
        SDestructure(ns, e, _sl):
            return ""
        SMultiAssign(ns, e, _sl):
            return ""
        SMatch(subj, vars, binds, bodies, _sl):
            return ""
        SBreak:
            return ""
        SContinue:
            return ""
        SParFor(v, a, b, body, pid, _sl):
            return ""
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            return ""

# B-3 seek, expression half: the first typed use of pending var `nm` inside
# `e` -- an argument position whose destination type is known (arg_want).
# A use anywhere else is hierc's "used before its type can be inferred"
# error; hierc gates programs, so here we just keep seeking.
fn pend_seek_expr(dc: Decls, ctx: Ctx, n2: [string], t2: [string], nm: string, e: Expr) -> string:
    match e:
        ECall(cn, a, _el):
            if cn == "push" and len(a) == 2 and evar_name(a[0]) == nm:        # push(xs, v) -> [typeof v]
                return "[" + type_of(a[1], n2, t2, dc, ctx) + "]"
            if cn == "map_set" and len(a) == 3 and evar_name(a[0]) == nm:     # map_set(m, k, v) -> {K:V}
                return "{" + type_of(a[1], n2, t2, dc, ctx) + ":" + type_of(a[2], n2, t2, dc, ctx) + "}"
            j := 0
            for j < len(a):
                if evar_name(a[j]) == nm:
                    w := arg_want(dc, ctx, n2, t2, cn, a, j)
                    if w != "":
                        return w
                else:
                    r := pend_seek_expr(dc, ctx, n2, t2, nm, a[j])
                    if r != "":
                        return r
                j = j + 1
            return ""
        EBin(o, l, r, _el):
            lr := pend_seek_expr(dc, ctx, n2, t2, nm, l)
            if lr != "":
                return lr
            return pend_seek_expr(dc, ctx, n2, t2, nm, r)
        EField(b, f, _el):
            return pend_seek_expr(dc, ctx, n2, t2, nm, b)
        EIndex(b, ix, _el):
            br := pend_seek_expr(dc, ctx, n2, t2, nm, b)
            if br != "":
                return br
            return pend_seek_expr(dc, ctx, n2, t2, nm, ix)
        EArrLit(es, _el):
            j := 0
            for j < len(es):
                if j > 0 and evar_name(es[j]) == nm and evar_name(es[0]) != nm:
                    return type_of(es[0], n2, t2, dc, ctx)   # an element checks against the FIRST element's type
                r := pend_seek_expr(dc, ctx, n2, t2, nm, es[j])
                if r != "":
                    return r
                j = j + 1
            return ""
        EMapLit(ks, vs, _el):
            j := 0
            for j < len(ks):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, ks[j])
                if r != "":
                    return r
                r = pend_seek_expr(dc, ctx, n2, t2, nm, vs[j])
                if r != "":
                    return r
                j = j + 1
            return ""
        ETuple(es, _el):
            j := 0
            for j < len(es):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, es[j])
                if r != "":
                    return r
                j = j + 1
            return ""
        ESlice(b, lo, hi, _el):
            return pend_seek_expr(dc, ctx, n2, t2, nm, b)
        EAddr(x, _el):
            return pend_seek_expr(dc, ctx, n2, t2, nm, x)
        ECallV(c, a, _el):
            cvt := "void"                         # a call-on-expression's param types ground a pending arg;
            if efield_fname(c) == "":             # EField callees are method forms -- type_of would die there
                cvt = type_of(c, n2, t2, dc, ctx)
            j := 0
            for j < len(a):
                if evar_name(a[j]) == nm and is_func(cvt):
                    cvp := []string
                    cvr := fnty_split(cvt, &cvp)
                    if j < len(cvp):
                        return cvp[j]
                r := pend_seek_expr(dc, ctx, n2, t2, nm, a[j])
                if r != "":
                    return r
                j = j + 1
            return ""
        ESpawn(sid, snm, sa, _el):
            j := 0
            for j < len(sa):
                if evar_name(sa[j]) == nm:
                    si := map_get(dc.sigmap, snm, 0 - 1)
                    if si >= 0 and j < len(dc.sigs[si].ptypes):
                        return base_ty(dc.sigs[si].ptypes[j])
                else:
                    r := pend_seek_expr(dc, ctx, n2, t2, nm, sa[j])
                    if r != "":
                        return r
                j = j + 1
            return ""
        EInt(s, _el):
            return ""
        EBool(s, _el):
            return ""
        EChar(s, _el):
            return ""
        EFloat(s, _el):
            return ""
        EStr(s, _el):
            return ""
        EVar(s, _el):
            return ""
        EArrEmpty(t, _el):
            return ""
        EMapEmpty(k, v, _el):
            return ""
        ELambda(id, ps, pts, ret, bx, cn, ct, _el):
            return ""

# B-3 seek, statement half: walk forward from a pending decl maintaining a
# COPY of the env (so a grounding value's type resolves with everything
# declared in between), returning the type the first grounding use implies:
# `nm = e` (typeof e), `return nm` (the fn's return type), `place = nm`
# (typeof place), or a typed argument position (pend_seek_expr). A shadowing
# redeclaration of `nm` ends the search. Recurses into nested blocks.
fn pend_seek(dc: Decls, ctx: Ctx, n2: inout [string], t2: inout [string], nm: string, stmts: [Stmt], from: int, fret: string) -> string:
    i := from
    for i < len(stmts):
        match stmts[i]:
            SAssign(x, e, _sl):
                if x == nm:
                    r0 := pend_seek_expr(dc, ctx, n2, t2, nm, e)   # m = map_set(m, k, v): the rhs READS nm --
                    if r0 != "":                                   # the call form grounds, not the (pending) type
                        return r0
                    return type_of(e, n2, t2, dc, ctx)
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
            SReturn(e, _sl):
                if evar_name(e) == nm:
                    return fret
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
            SFieldAssign(lv, rhs, _sl):
                if evar_name(rhs) == nm:
                    return type_of(lv, n2, t2, dc, ctx)
                r := pend_seek_expr(dc, ctx, n2, t2, nm, rhs)
                if r != "":
                    return r
            SDecl(x, e, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
                if x == nm:
                    return ""                     # shadowed before grounding
                push(n2, x)
                if pend_init_kind(e) != 0:
                    push(t2, "?")
                else:
                    push(t2, type_of(e, n2, t2, dc, ctx))
            STypedDecl(x, ty, e, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
                if x == nm:
                    return ""
                push(n2, x)
                push(t2, ty)
            SOrReturn(x, e, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
                rt2 := type_of(e, n2, t2, dc, ctx)
                push(n2, x)
                if is_option(rt2):
                    push(t2, option_inner(rt2))
                else:
                    push(t2, result_ok(rt2))
            SDestructure(ns, e, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
                dt := type_of(e, n2, t2, dc, ctx)
                dp := tuple_parts(dt)
                dk := 0
                for dk < len(ns):
                    push(n2, ns[dk])
                    push(t2, dp[dk])
                    dk = dk + 1
            SMultiAssign(ns, e, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
            SPrint(e, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
            SExpr(e, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, e)
                if r != "":
                    return r
            SIf(c, t, el, _sl):
                bn := n2
                bt := t2
                r := pend_seek(dc, ctx, &bn, &bt, nm, t, 0, fret)
                if r != "":
                    return r
                bn2 := n2
                bt2 := t2
                r = pend_seek(dc, ctx, &bn2, &bt2, nm, el, 0, fret)
                if r != "":
                    return r
            SWhile(c, b, _sl):
                bn := n2
                bt := t2
                r := pend_seek(dc, ctx, &bn, &bt, nm, b, 0, fret)
                if r != "":
                    return r
            SForRange(v, a, b, st, body, _sl):
                if v != nm:
                    bn := n2
                    bt := t2
                    push(bn, v)
                    push(bt, "int")
                    r := pend_seek(dc, ctx, &bn, &bt, nm, body, 0, fret)
                    if r != "":
                        return r
            SMatch(subj, vars, binds, bodies, _sl):
                r := pend_seek_expr(dc, ctx, n2, t2, nm, subj)
                if r != "":
                    return r
                mk := 0
                for mk < len(bodies):
                    bn := n2
                    bt := t2
                    mt := type_of(subj, n2, t2, dc, ctx)
                    if len(binds[mk]) > 0:
                        push(bn, binds[mk][0])
                        if is_option(mt):
                            push(bt, option_inner(mt))
                        elif vars[mk] == "Ok":
                            push(bt, result_ok(mt))
                        elif vars[mk] == "Err":
                            push(bt, result_err(mt))
                        else:
                            push(bt, "int")       # enum payload binds: rare in a seek; conservative
                    r = pend_seek(dc, ctx, &bn, &bt, nm, bodies[mk], 0, fret)
                    if r != "":
                        return r
                    mk = mk + 1
            SSelect(uid, svars, schans, sbinds, sbodies, _sl):
                sk := 0
                for sk < len(svars):
                    bn := n2
                    bt := t2
                    if svars[sk] == "recv":
                        push(bn, sbinds[sk])
                        push(bt, chan_inner(type_of(schans[sk], n2, t2, dc, ctx)))
                    r := pend_seek(dc, ctx, &bn, &bt, nm, sbodies[sk], 0, fret)
                    if r != "":
                        return r
                    sk = sk + 1
            SParFor(v, a, b, body, pid, _sl):
                if v != nm:
                    bn := n2
                    bt := t2
                    push(bn, v)
                    push(bt, "int")
                    r := pend_seek(dc, ctx, &bn, &bt, nm, body, 0, fret)
                    if r != "":
                        return r
            SReturnVoid:
                i = i
            SBreak:
                i = i
            SContinue:
                i = i
        i = i + 1
    return ""

fn lift_block(stmts: [Stmt], lifted: inout [Func], ctr: inout int, lams: inout [LamInfo], spawns: inout [SpawnInfo], pars: inout [ParInfo], names: inout [string], types: inout [string], dc: Decls, ctx: Ctx, fret: string) -> [Stmt]:
    _el := 0
    _sl := 0
    mark := len(names)                                # block-local decls don't leak to the enclosing scope
    out := []Stmt
    i := 0
    for i < len(stmts):
        st := stmts[i]
        pe := EInt("0", _el)
        pn := pend_probe(st, &pe)
        if pn != "":                                  # B-3: a bare decl grounds from its first use in this block
            sn := names
            stt := types
            pty := pend_seek(dc, ctx, &sn, &stt, pn, stmts, i + 1, fret)
            if pty == "":
                die("type: could not infer the type of '" + pn + "' -- no grounding use in its block (annotate the declaration)")
            st = STypedDecl(pn, pty, pe, _sl)              # the annotated form; ground_pre types the initializer
        push(out, lift_stmt(st, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret))
        i = i + 1
    names = names[0:mark]
    types = types[0:mark]
    return out

fn lift_stmt(s: Stmt, lifted: inout [Func], ctr: inout int, lams: inout [LamInfo], spawns: inout [SpawnInfo], pars: inout [ParInfo], names: inout [string], types: inout [string], dc: Decls, ctx: Ctx, fret: string) -> Stmt:
    _el := 0
    match s:
        SDecl(n, e, _sl):
            ne := lift_expr(e, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            nty := type_of(e, names, types, dc, ctx)  # type BEFORE pushing the name (sacc_stmt order):
            push(names, n)                            # a shadowing `y := y + 2` must resolve y to the
            push(types, nty)                          # OUTER decl, and names/types must stay in lockstep
            return SDecl(n, ne, _sl)
        SAssign(n, e, _sl):
            aw := ""                              # B: the existing var's type checks the RHS
            if has_str(names, n):
                aw = base_ty(var_type(names, types, n))
            return SAssign(n, lift_expr(ground_pre(dc, ctx, aw, e), &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        SFieldAssign(lv, rhs, _sl):
            fw := type_of(lv, names, types, dc, ctx)   # B: the place's type checks the stored value
            return SFieldAssign(lift_expr(lv, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_expr(ground_pre(dc, ctx, fw, rhs), &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        SPrint(e, _sl):
            return SPrint(lift_expr(e, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        SReturn(e, _sl):
            # A closure MAY escape: gen_stmt's SReturn re-homes its captured env into
            # _parent via copyenv (value semantics, sound). rule (a) lifted.
            return SReturn(lift_expr(ground_pre(dc, ctx, fret, e), &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        SReturnVoid:
            return s
        SIf(c, th, el, _sl):
            return SIf(lift_expr(c, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_block(th, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret), lift_block(el, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret), _sl)
        SWhile(c, b, _sl):
            return SWhile(lift_expr(c, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), lift_block(b, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret), _sl)
        SForRange(nm, a, b, st, body, _sl):
            na := lift_expr(a, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            nbb := lift_expr(b, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            nst := lift_expr(st, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            mark := len(names)                        # the loop var is in scope for the body only
            push(names, nm)
            push(types, "int")
            nbody := lift_block(body, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret)
            names = names[0:mark]
            types = types[0:mark]
            return SForRange(nm, na, nbb, nst, nbody, _sl)
        SExpr(e, _sl):
            return SExpr(lift_expr(e, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        STypedDecl(nm, ty, e, _sl):
            ne := lift_expr(ground_pre(dc, ctx, ty, e), &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            push(names, nm)
            push(types, ty)
            return STypedDecl(nm, ty, ne, _sl)
        SOrReturn(nm, e, _sl):
            return SOrReturn(nm, lift_expr(e, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        SDestructure(nms, e, _sl):
            return SDestructure(nms, lift_expr(e, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        SMultiAssign(nms, e, _sl):
            return SMultiAssign(nms, lift_expr(e, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx), _sl)
        SMatch(subj, vars, binds, bodies, _sl):
            ns := lift_expr(subj, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            nb := [][Stmt]
            k := 0
            for k < len(bodies):
                push(nb, lift_block(bodies[k], &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret))
                k = k + 1
            return SMatch(ns, vars, binds, nb, _sl)
        SBreak:
            return s
        SContinue:
            return s
        SParFor(v, a, b, body, pid0, _sl):
            # CC-3: lift the body to a chunk proc __par<pid>(__plo, __phi,
            # captures...) -> partial(s); register its spawn site (the driver
            # emits the trampoline) and the ParInfo the site codegen reads.
            na := lift_expr(a, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            nbb := lift_expr(b, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx)
            raw := []string
            pf_body_evars(body, &raw)
            accn := []string
            accop := []string
            pf_accs(body, names, &accn, &accop)
            capn := []string
            capt := []string
            j := 0
            for j < len(raw):
                if has_str(names, raw[j]) and not has_str(accn, raw[j]) and not has_str(capn, raw[j]) and raw[j] != v:
                    push(capn, raw[j])
                    push(capt, base_ty(var_type(names, types, raw[j])))
                j = j + 1
            pid := len(pars)
            accty := []string
            j = 0
            for j < len(accn):
                push(accty, base_ty(var_type(names, types, accn[j])))
                j = j + 1
            rty := "int"
            if len(accn) == 1:
                rty = accty[0]
            if len(accn) > 1:
                rty = "("
                j = 0
                for j < len(accn):
                    if j > 0:
                        rty = rty + ","
                    rty = rty + accty[j]
                    j = j + 1
                rty = rty + ")"
            cps := []string
            cpt := []string
            push(cps, "__plo")
            push(cpt, "int")
            push(cps, "__phi")
            push(cpt, "int")
            j = 0
            for j < len(capn):
                push(cps, capn[j])
                push(cpt, capt[j])
                j = j + 1
            cbody := []Stmt
            j = 0
            for j < len(accn):
                idv := EInt("0", _el)
                if accop[j] == "*":
                    idv = EInt("1", _el)
                if accty[j] == "float":
                    idv = EFloat("0.0", _el)
                    if accop[j] == "*":
                        idv = EFloat("1.0", _el)
                push(cbody, SDecl(accn[j], idv, _sl))
                j = j + 1
            push(cbody, SForRange(v, EVar("__plo", _el), EVar("__phi", _el), EInt("1", _el), body, _sl))
            if len(accn) == 0:
                push(cbody, SReturn(EInt("0", _el), _sl))
            if len(accn) == 1:
                push(cbody, SReturn(EVar(accn[0], _el), _sl))
            if len(accn) > 1:
                tup := []Expr
                j = 0
                for j < len(accn):
                    push(tup, EVar(accn[j], _el))
                    j = j + 1
                push(cbody, SReturn(ETuple(tup, _el), _sl))
            cn2 := cps
            ct2 := cpt
            cbody = lift_block(cbody, &lifted, &ctr, &lams, &spawns, &pars, &cn2, &ct2, dc, ctx, rty)
            push(lifted, Func("__par" + str(pid), cps, cpt, rty, cbody, 0, ""))
            sid := len(spawns)
            push(spawns, SpawnInfo("__par" + str(pid), cpt, rty))
            push(pars, ParInfo(sid, capn, capt, accn, accop, rty))
            return SParFor("", na, nbb, []Stmt, pid, _sl)
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            nch := []Expr
            nb := [][Stmt]
            sk := 0
            for sk < len(svars):
                push(nch, lift_expr(schans[sk], &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx))
                mark := len(names)
                if svars[sk] == "recv":
                    bty := chan_inner(type_of(schans[sk], names, types, dc, ctx))
                    push(names, sbinds[sk])
                    push(types, bty)
                push(nb, lift_block(sbodies[sk], &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, fret))
                names = names[0:mark]
                types = types[0:mark]
                sk = sk + 1
            return SSelect(uid, svars, nch, sbinds, nb, _sl)

# Does an expr / stmt / block contain a lambda anywhere? Used to skip the
# scope-aware lift (which calls type_of) for lambda-free functions — keeping a
# lambda-free program (incl. hierc0.hi itself) byte-identical and crash-free.
fn expr_has_lambda(e: Expr) -> bool:
    match e:
        ELambda(id, ps, pts, ret, body, cn, ct, _el):
            return true
        EBin(o, l, r, _el):
            return expr_has_lambda(l) or expr_has_lambda(r)
        ECall(n, a, _el):
            if has_prefix(n, "channel:"):         # channel creation gates the lift (its decl needs gen support)
                return true
            j := 0
            for j < len(a):
                if expr_has_lambda(a[j]):
                    return true
                j = j + 1
            return false
        EField(b, f, _el):
            return expr_has_lambda(b)
        EIndex(b, ix, _el):
            return expr_has_lambda(b) or expr_has_lambda(ix)
        EArrLit(es, _el):
            j := 0
            for j < len(es):
                if expr_has_lambda(es[j]):
                    return true
                j = j + 1
            return false
        EMapLit(ks, vs, _el):
            j := 0
            for j < len(ks):
                if expr_has_lambda(ks[j]) or expr_has_lambda(vs[j]):
                    return true
                j = j + 1
            return false
        ETuple(es, _el):
            j := 0
            for j < len(es):
                if expr_has_lambda(es[j]):
                    return true
                j = j + 1
            return false
        ESlice(b, lo, hi, _el):
            return expr_has_lambda(b) or expr_has_lambda(lo) or expr_has_lambda(hi)
        ECallV(callee, cargs, _el):
            if expr_has_lambda(callee):
                return true
            j := 0
            for j < len(cargs):
                if expr_has_lambda(cargs[j]):
                    return true
                j = j + 1
            return false
        EAddr(x, _el):
            return expr_has_lambda(x)
        EInt(t, _el):
            return false
        EBool(t, _el):
            return false
        EChar(t, _el):
            return false
        EFloat(t, _el):
            return false
        EStr(s, _el):
            return false
        EVar(n, _el):
            return false
        EArrEmpty(t, _el):
            return t == ""                        # a bare [] gates the lift: ground_pre runs there (B-0)
        EMapEmpty(k, v, _el):
            return false
        ESpawn(sid, snm, sa, _el):
            return true                           # conc gates the lift too: spawn sites get their ids there

fn block_has_lambda(stmts: [Stmt]) -> bool:
    i := 0
    for i < len(stmts):
        if stmt_has_lambda(stmts[i]):
            return true
        i = i + 1
    return false

fn stmt_has_lambda(s: Stmt) -> bool:
    match s:
        SDecl(n, e, _sl):
            if pend_init_kind(e) != 0:            # B-3: a bare decl gates the lift (pend_seek runs there);
                return true                       # decl-position ONLY -- `return None` etc never re-gates
            return expr_has_lambda(e)
        SAssign(n, e, _sl):
            return expr_has_lambda(e)
        SFieldAssign(lv, rhs, _sl):
            return expr_has_lambda(lv) or expr_has_lambda(rhs)
        SPrint(e, _sl):
            return expr_has_lambda(e)
        SReturn(e, _sl):
            return expr_has_lambda(e)
        SReturnVoid:
            return false
        SIf(c, th, el, _sl):
            return expr_has_lambda(c) or block_has_lambda(th) or block_has_lambda(el)
        SWhile(c, b, _sl):
            return expr_has_lambda(c) or block_has_lambda(b)
        SForRange(nm, a, b, st, body, _sl):
            return expr_has_lambda(a) or expr_has_lambda(b) or expr_has_lambda(st) or block_has_lambda(body)
        SExpr(e, _sl):
            return expr_has_lambda(e)
        STypedDecl(nm, ty, e, _sl):
            return expr_has_lambda(e)
        SOrReturn(nm, e, _sl):
            return expr_has_lambda(e)
        SDestructure(nms, e, _sl):
            return expr_has_lambda(e)
        SMultiAssign(nms, e, _sl):
            return expr_has_lambda(e)
        SMatch(subj, vars, binds, bodies, _sl):
            if expr_has_lambda(subj):
                return true
            k := 0
            for k < len(bodies):
                if block_has_lambda(bodies[k]):
                    return true
                k = k + 1
            return false
        SBreak:
            return false
        SContinue:
            return false
        SParFor(v, a, b, body, pid, _sl):
            return true                           # a parallel for IS a lift job (chunk-proc extraction)
        SSelect(uid, svars, schans, sbinds, sbodies, _sl):
            sk := 0
            for sk < len(svars):
                if expr_has_lambda(schans[sk]) or block_has_lambda(sbodies[sk]):
                    return true
                sk = sk + 1
            return false

# Run the lift over a whole program: returns the program with ELambda nodes
# stamped + lifted `__lam<id>` funcs appended, and fills `lams` (one per lambda)
# for env-struct + thunk emission. `dc` carries the ORIGINAL function sigs (built
# before the lift) so capture-type lookups resolve; rebuilt afterwards by main.
fn lift_program(prog: Program, dc: Decls, ctx: Ctx, lams: inout [LamInfo], spawns: inout [SpawnInfo], pars: inout [ParInfo]) -> Program:
    lifted := []Func
    ctr := 0
    nfuncs := []Func
    i := 0
    for i < len(prog.funcs):
        f := prog.funcs[i]
        if block_has_lambda(f.body):                  # only lambda-bearing funcs need the scope-aware lift (which
            names := []string                         # calls type_of); a lambda-free func is left UNCHANGED, so a
            types := []string                         # lambda-free program (incl. hierc0.hi) is byte-identical.
            seed_env(f, &names, &types)
            push(nfuncs, Func(f.name, f.params, f.ptypes, f.ret, lift_block(f.body, &lifted, &ctr, &lams, &spawns, &pars, &names, &types, dc, ctx, f.ret), f.is_extern, f.lib))
        else:
            push(nfuncs, f)
        i = i + 1
    i = 0
    for i < len(lifted):
        push(nfuncs, lifted[i])
        i = i + 1
    return Program(prog.structs, prog.enums, nfuncs, prog.ntnames, prog.ntunder)

# Fail-closed declaration checks (parity with the C compiler's parse-time
# guards): reject duplicate type names (struct/enum/newtype share one
# namespace), duplicate variant names (package-scoped), duplicate function
# names (no overloading), and duplicate struct field names. Without these,
# hierc0 accepted such programs and emitted C with duplicate symbols/members
# that cc then rejected (a fail-open). Message-only: the decl AST carries no
# position. Never fires on valid input, so fixpoint output is unchanged.
fn check_dups(prog: Program):
    tnames := []string
    i := 0
    for i < len(prog.structs):
        nm := prog.structs[i].name
        if has_str(tnames, nm):
            die("type '" + nm + "' is already defined")
        push(tnames, nm)
        fnames := []string
        j := 0
        for j < len(prog.structs[i].fields):
            fnm := prog.structs[i].fields[j].name
            if has_str(fnames, fnm):
                die("duplicate field '" + fnm + "' in struct '" + nm + "'")
            push(fnames, fnm)
            j = j + 1
        i = i + 1
    i = 0
    for i < len(prog.enums):
        nm := prog.enums[i].name
        if has_str(tnames, nm):
            die("type '" + nm + "' is already defined")
        push(tnames, nm)
        i = i + 1
    i = 0
    for i < len(prog.ntnames):
        if has_str(tnames, prog.ntnames[i]):
            die("type '" + prog.ntnames[i] + "' is already defined")
        push(tnames, prog.ntnames[i])
        i = i + 1
    vnames := []string
    i = 0
    for i < len(prog.enums):
        j := 0
        for j < len(prog.enums[i].variants):
            vn := prog.enums[i].variants[j].name
            if has_str(vnames, vn):
                die("variant name '" + vn + "' is already used in this package")
            push(vnames, vn)
            j = j + 1
        i = i + 1
    fns := []string
    i = 0
    for i < len(prog.funcs):
        nm := prog.funcs[i].name
        if has_str(fns, nm):
            die("'" + nm + "' is already defined")
        push(fns, nm)
        pnames := []string                            # duplicate parameter name -> duplicate C param
        j := 0
        for j < len(prog.funcs[i].params):
            pn := prog.funcs[i].params[j]
            if has_str(pnames, pn):
                die("duplicate parameter '" + pn + "' in function '" + nm + "'")
            push(pnames, pn)
            j = j + 1
        i = i + 1
    if not has_str(fns, "main"):                  # fail-closed: a program with no main emits main-less C (parity with hierc)
        die("no 'main' procedure")

fn main():
    a := args()
    src := ""
    if len(a) > 1:                                  # `hierc0 path` : compile that file or package
        content := read_file(a[1])
        if is_package(lex(content)):
            seen := []string
            src = bundle(dir_of(a[1]), true, &seen)
        else:
            src = content
    else:                                           # no argument : read stdin (the bootstrap path)
        src = read_all()
    toks := lex(src)
    pos := 0
    prog0 := parse_program(toks, &pos)
    check_dups(prog0)                                 # fail-closed: reject duplicate decls before codegen
    sigs0 := []Sig                                    # sigs over the ORIGINAL funcs: capture-type lookups during the lift
    sigmap0 := []string: int
    i := 0
    for i < len(prog0.funcs):
        push(sigs0, Sig(prog0.funcs[i].name, prog0.funcs[i].ret, prog0.funcs[i].ptypes, prog0.funcs[i].is_extern))
        if map_get(sigmap0, prog0.funcs[i].name, -1) < 0:
            sigmap0 = map_set(sigmap0, prog0.funcs[i].name, i)
        i = i + 1
    src_lines := split(src, chr(10))                  # for die_at diagnostics (snippet + caret)
    dc0 := Decls(sigs0, prog0.structs, prog0.enums, prog0.ntnames, prog0.ntunder, sigmap0, []ParInfo, src_lines, build_vmap(prog0.enums))
    ctx0 := Ctx([]string, []string, "", "0", 0, []int, []string, 0, []string, []string, []string, 0)
    lams := []LamInfo
    spawns := []SpawnInfo                             # CC: spawn sites (incl. parallel-for chunks)
    pars := []ParInfo                                 # CC-3: parallel-for sites
    prog := lift_program(prog0, dc0, ctx0, &lams, &spawns, &pars)     # stamp lambdas + capture analysis + lifted __lam funcs
    funcs := prog.funcs
    sigs := []Sig
    sigmap := []string: int
    i = 0
    for i < len(funcs):
        push(sigs, Sig(funcs[i].name, funcs[i].ret, funcs[i].ptypes, funcs[i].is_extern))
        if map_get(sigmap, funcs[i].name, -1) < 0:        # first-match wins (matches the old scan)
            sigmap = map_set(sigmap, funcs[i].name, i)
        i = i + 1
    dc := Decls(sigs, prog.structs, prog.enums, prog.ntnames, prog.ntunder, sigmap, pars, src_lines, build_vmap(prog.enums))
    ctx := Ctx([]string, []string, "", "0", 0, []int, []string, 0, []string, []string, []string, 0)
    ets := collect_elem_types(prog, dc, ctx)
    out := preamble()
    # Emission order is carefully staged so every C type is complete before use,
    # supporting arrays-of-structs, recursive structs, and mutual struct/enum refs:
    i = 0                                        # 1a. forward-declare struct tags
    for i < len(prog.structs):
        out = out + "typedef struct " + ust(prog.structs[i].name) + " " + ust(prog.structs[i].name) + ";\n"
        i = i + 1
    i = 0                                        # 1b. forward-declare enum tags
    for i < len(prog.enums):
        out = out + "typedef struct " + uet(prog.enums[i].name) + " " + uet(prog.enums[i].name) + ";\n"
        i = i + 1
    i = 0                                        # 1b'. forward-declare composite array/map tags so a fn value whose
    for i < len(ets):                            #      param/ret is [T]/[K:V] (fn([T])->R) can name it incomplete
        if not is_tuple(ets[i]) and not is_map(ets[i]) and not is_soa(ets[i]):
            out = out + "typedef struct Arr_" + mangle(ets[i]) + "_ Arr_" + mangle(ets[i]) + ";\n"
        i = i + 1
    i = 0
    for i < len(ets):
        if is_map(ets[i]):
            mt := "Map_" + map_key(ets[i]) + "_" + mangle(map_val(ets[i]))
            out = out + "typedef struct " + mt + "_ " + mt + ";\n"
        i = i + 1
    i = 0                                        # 1c. function-value typedefs FIRST — a container may hold a fn
    has_fnval := false                           #     value (array elem / struct field), so Fn_<suffix> must be
    for i < len(ets):                            #     complete before the array/struct bodies that embed it.
        if is_func(ets[i]):                      #     Common param/ret types (scalars/strings) are complete here.
            out = out + gen_func_typedef(dc, ctx, ets[i])
            has_fnval = true
        i = i + 1
    i = 0                                        # 2. array STRUCT bodies (element types
    for i < len(ets):                            #    only appear as pointers here, so fwd decls suffice)
        if not is_tuple(ets[i]) and not is_map(ets[i]) and not is_soa(ets[i]):
            out = out + gen_arr_type(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # 2c. soa typedefs + helper fwd decls (before struct
    for i < len(ets):                            #     bodies, so a struct may embed a soa by value)
        if is_soa(ets[i]):
            out = out + gen_soa_decl(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # map struct(s), one per value type used
    for i < len(ets):
        if is_map(ets[i]):
            out = out + gen_map_type(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # 3. enum + struct eq prototypes (mutual recursion)
    for i < len(prog.enums):
        out = out + "static int " + uet(prog.enums[i].name) + "_eq(" + uet(prog.enums[i].name) + "* a, " + uet(prog.enums[i].name) + "* b);\n"
        i = i + 1
    i = 0
    for i < len(prog.structs):
        out = out + "static int " + ust(prog.structs[i].name) + "_eq(" + ust(prog.structs[i].name) + " a, " + ust(prog.structs[i].name) + " b);\n"
        i = i + 1
    i = 0                                        # 4. user struct bodies (source order; array fields
    for i < len(prog.structs):                   #    use the now-complete Arr_T struct)
        out = out + gen_struct(prog.structs[i], dc, ctx)
        i = i + 1
    i = 0                                        # 5. enum struct bodies (payloads may be value structs)
    for i < len(prog.enums):
        out = out + gen_enum_decl(prog.enums[i], dc, ctx)
        i = i + 1
    i = 0                                        # 5a. tuple struct bodies — AFTER struct/enum bodies, so a
    for i < len(ets):                            #     tuple that embeds a struct/enum by value sees a complete type
        if is_tuple(ets[i]):
            out = out + gen_tuple_struct(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # 5a''. closure env structs (one per capturing lambda)
    for i < len(lams):
        if len(lams[i].capnames) > 0:
            out = out + "typedef struct {"
            cj := 0
            for cj < len(lams[i].captypes):
                out = out + " " + cty(dc, ctx, lams[i].captypes[cj]) + "c" + str(cj) + ";"
                cj = cj + 1
            out = out + " } Env_" + str(lams[i].id) + ";\n"
        i = i + 1
    i = 0                                        # 5b. struct/tuple copy PROTOTYPES, so the array
    for i < len(prog.structs):                   #     _from bodies below can deep-copy struct/tuple
        sn := prog.structs[i].name               #     elements regardless of copy-fn definition order
        if struct_is_heap(dc, ctx, sn):
            out = out + "static " + ust(sn) + " " + ust(sn) + "_copy(Arena* ar, " + ust(sn) + " s);\n"
        i = i + 1
    i = 0
    for i < len(ets):
        if is_tuple(ets[i]):
            tn := "Tup_" + tup_suffix(ets[i])
            out = out + "static " + tn + " " + tn + "_copy(Arena* ar, " + tn + " s);\n"
        i = i + 1
    i = 0                                        # 5c. enum copy protos (mutual recursion + array/
    for i < len(prog.enums):                     #     struct/tuple copy may deep-copy enum members)
        en := prog.enums[i].name
        out = out + "static " + uet(en) + "* " + uet(en) + "_copy(Arena* ar, " + uet(en) + "* s);\n"
        i = i + 1
    i = 0                                        # 6. array FUNCTIONS (need element bodies
    for i < len(ets):                            #    complete for sizeof / by-value moves)
        if not is_tuple(ets[i]) and not is_map(ets[i]) and not is_soa(ets[i]):
            out = out + gen_arr_fns(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # 6b. soa families (after struct bodies: push takes S_X by value)
    for i < len(ets):
        if is_soa(ets[i]):
            out = out + gen_soa(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # shared hash + per-value-type map families
    has_map := false
    for i < len(ets):
        if is_map(ets[i]):
            has_map = true
        i = i + 1
    if has_map:
        out = out + gen_mhash()
    i = 0
    for i < len(ets):
        if is_map(ets[i]):
            out = out + gen_map_fns(dc, ctx, ets[i])
        i = i + 1
    out = out + gen_strlib()
    i = 0                                        # 6b. tuple copy + equality (may call array fns above)
    for i < len(ets):
        if is_tuple(ets[i]):
            out = out + gen_tuple_copy(dc, ctx, ets[i])
            out = out + gen_tuple_eq(dc, ctx, ets[i])
        i = i + 1
    i = 0                                        # 7. enum constructors + copy + equality
    for i < len(prog.enums):
        out = out + gen_enum_ctors(prog.enums[i], dc, ctx)
        i = i + 1
    i = 0
    for i < len(prog.enums):
        out = out + gen_enum_copy(prog.enums[i], dc, ctx)
        i = i + 1
    i = 0
    for i < len(prog.enums):
        out = out + gen_enum_eq(prog.enums[i], dc, ctx)
        i = i + 1
    i = 0                                        # 8. struct equality + deep-copy fns
    for i < len(prog.structs):
        out = out + gen_struct_eq(dc, ctx, prog.structs[i])
        if struct_is_heap(dc, ctx, prog.structs[i].name):
            out = out + gen_struct_copy(dc, ctx, prog.structs[i])
        i = i + 1
    i = 0                                        # 9. prototypes
    for i < len(funcs):
        if funcs[i].is_extern == 1:              # FFI: real C ABI decl, not the h_/arena proto
            out = out + gen_extern_proto(funcs[i], dc, ctx)
        elif funcs[i].name != "main":
            out = out + gen_proto(funcs[i], dc, ctx)
        i = i + 1
    i = 0                                        # 9a'. CC spawn sites: per-site args struct + thread trampoline.
    for i < len(spawns):                         #      The trampoline runs the call with the task's root arena as
        si := str(i)                             #      _parent, parks the result in a root-allocated slot, then
        out = out + "typedef struct { HTask* t;"  #     flushes this thread's block pool (TLS dies with the thread).
        j := 0
        for j < len(spawns[i].argtypes):
            out = out + " " + cty(dc, ctx, spawns[i].argtypes[j]) + "a" + str(j) + ";"
            j = j + 1
        out = out + " } HSpawnA_" + si + ";\n"
        rct := cty(dc, ctx, spawns[i].retty)
        out = out + "static void* hier_spawn_" + si + "(void* _p) { HSpawnA_" + si + "* _a = (HSpawnA_" + si + "*)_p; " + rct + "_r = " + un(spawns[i].fname) + "(&_a->t->root"
        j = 0
        for j < len(spawns[i].argtypes):
            out = out + ", _a->a" + str(j)
            j = j + 1
        out = out + "); " + rct + "* _s = (" + rct + "*)amem(&_a->t->root, sizeof(" + rct + ")); *_s = _r; _a->t->ret = _s; hier_pool_flush(); return 0; }\n"
        i = i + 1
    if has_fnval:                                # 9b. fn-value adapter thunks (after protos: each forwards to h_<name>)
        i = 0
        for i < len(funcs):
            if funcs[i].name != "main" and funcs[i].is_extern == 0 and fn_value_eligible(funcs[i]) and not has_prefix(funcs[i].name, "__lam"):
                out = out + gen_fnval_thunk(funcs[i], dc, ctx)   # lifted lambdas get a capture-aware thunk instead (below); externs have no h_ wrapper
            i = i + 1
    i = 0                                        # 9c. closure thunks: unpack the env, call the lifted __lam proc
    for i < len(lams):
        out = out + gen_lambda_thunk(lams[i], dc, ctx)
        i = i + 1
    i = 0                                        # 9c'. env-copy thunks (after the copy fns above): re-home the env on closure return
    for i < len(lams):
        if len(lams[i].capnames) > 0:
            eid := str(lams[i].id)
            out = out + "static void* Env_" + eid + "_copy(Arena* a, void* _s) { Env_" + eid + "* s = (Env_" + eid + "*)_s; Env_" + eid + "* d = (Env_" + eid + "*)hbox(a, sizeof(Env_" + eid + "), s);"
            cj := 0
            for cj < len(lams[i].captypes):
                if elem_deepcopy(dc, ctx, lams[i].captypes[cj]):   # heap capture: deep-copy into `a` (scalars keep the hbox shallow copy)
                    out = out + " d->c" + str(cj) + " = " + cp_field(dc, ctx, lams[i].captypes[cj], "a", "s->c" + str(cj)) + ";"
                cj = cj + 1
            out = out + " return d; }\n"
        i = i + 1
    i = 0
    for i < len(funcs):
        if funcs[i].is_extern == 0:              # FFI externs have no body
            out = out + gen_func(funcs[i], dc, ctx)
        i = i + 1
    print(out)
