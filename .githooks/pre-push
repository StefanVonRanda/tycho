#!/bin/sh
# hier pre-push gate -- no broken code leaves this machine. (Local. No GitHub
# Actions, ever.) Runs the FAST correctness gates that catch regressions in
# seconds: the golden+sanitizer test suite and the self-host fixpoint. Both
# include every recycle/soundness regression test, so a reintroduced corruption
# bug is blocked here. Also runs `make corelib` (C-vs-hierc0 + standalone-hierc0
# vs goldens) so a type-system change can't silently break the stdlib's package
# mangling -- that path is NOT exercised by test or fixpoint.
#
# The heavier differential fuzz is NOT in this hook (it would make every push take
# minutes). Run it before a substantial push with `make ci` (full: test +
# fixpoint + fuzz N=500) or `make fuzz N=...`.
#
# Activate once:  make hooks   (sets core.hooksPath to .githooks)
# Emergency bypass (avoid): git push --no-verify
set -eu
cd "$(git rev-parse --show-toplevel)"

# Private per-run log (mktemp, not a fixed world-shared /tmp path): no multi-user
# collision/symlink risk, and each step APPENDS under a header so earlier steps'
# output survives. Kept on failure (path printed); removed on success.
LOG="$(mktemp "${TMPDIR:-/tmp}/hier-prepush.XXXXXX")"

printf 'pre-push: make test ... '
printf '===== make test =====\n' >>"$LOG"
if make -s test >>"$LOG" 2>&1; then
    printf 'ok\n'
else
    printf 'FAILED\n\n'; tail -20 "$LOG"
    printf '\npre-push BLOCKED: make test failed (full log: %s). Push aborted.\n' "$LOG"; exit 1
fi

printf 'pre-push: make fixpoint ... '
printf '===== make fixpoint =====\n' >>"$LOG"
if make -s fixpoint >>"$LOG" 2>&1; then
    printf 'ok\n'
else
    printf 'FAILED\n\n'; tail -20 "$LOG"
    printf '\npre-push BLOCKED: make fixpoint failed (full log: %s). Push aborted.\n' "$LOG"; exit 1
fi

printf 'pre-push: make corelib ... '
printf '===== make corelib =====\n' >>"$LOG"
if make -s corelib >>"$LOG" 2>&1; then
    printf 'ok\n'
else
    printf 'FAILED\n\n'; tail -20 "$LOG"
    printf '\npre-push BLOCKED: make corelib failed (full log: %s). Push aborted.\n' "$LOG"; exit 1
fi

rm -f "$LOG"
printf 'pre-push: gates green -- allowing push (run `make ci` for the full fuzz).\n'
