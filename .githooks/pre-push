#!/bin/sh
# tycho pre-push gate -- no broken code leaves this machine. (Local. No GitHub
# Actions, ever.) Runs the FULL DETERMINISTIC gate via `make ci N=0`: every ci
# lane EXCEPT the minutes-long differential fuzz campaign -- build, golden +
# sanitizer tests, self-host fixpoint, corelib + corelib-examples + the `site`
# dogfood, concurrency, ffi, formatter/LSP tools-check, the four accept/reject
# parity lanes, bench-guard, recursion, and spec-check -- plus a quick differential
# fuzz smoke (`make fuzz-quick`).
#
# Why this wide: a green `make test` is NOT a green tree. A `datetime`-FFI link
# break in the `site` dogfood, and cross-package type-mangling divergences, are
# invisible to test+fixpoint but caught here -- running only test+fixpoint (+
# corelib) once let a red `make ci` reach `main` unnoticed.
#
# The full fuzz campaign (fuzz N=200 + reject + leak + pkg, ~20 min) is NOT in
# this hook -- run it before a substantial push with `make ci`.
#
# Activate once:  make hooks   (sets core.hooksPath to .githooks)
# Emergency bypass (avoid): git push --no-verify
set -eu
cd "$(git rev-parse --show-toplevel)"

# Private per-run log (mktemp, not a fixed world-shared /tmp path): no multi-user
# collision/symlink risk. Each step APPENDS under a header; kept on failure (path
# printed), removed on success.
LOG="$(mktemp "${TMPDIR:-/tmp}/tycho-prepush.XXXXXX")"

gate() {   # gate "<label>" <make args...>
    label="$1"; shift
    printf 'pre-push: %s ... ' "$label"
    printf '\n===== %s =====\n' "$label" >>"$LOG"
    if make -s "$@" >>"$LOG" 2>&1; then
        printf 'ok\n'
    else
        printf 'FAILED\n\n'; tail -25 "$LOG"
        printf '\npre-push BLOCKED: %s failed (full log: %s). Push aborted.\n' "$label" "$LOG"
        exit 1
    fi
}

gate "make ci N=0 (all deterministic lanes)" ci N=0
gate "make fuzz-quick (differential smoke)"  fuzz-quick

rm -f "$LOG"
printf 'pre-push: gates green -- allowing push (run `make ci` for the full fuzz campaign).\n'
