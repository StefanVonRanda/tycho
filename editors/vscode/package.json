{
  "name": "tycho",
  "displayName": "Tycho",
  "description": "Tycho language support: syntax highlighting + live diagnostics via tycho-lsp.",
  "version": "0.0.1",
  "publisher": "tycho",
  "license": "SEE LICENSE IN ../../LICENSE",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:tycho"],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "tycho",
        "aliases": ["Tycho", "tycho"],
        "extensions": [".ty"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tycho",
        "scopeName": "source.tycho",
        "path": "./syntaxes/tycho.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Tycho",
      "properties": {
        "tycho.lspPath": {
          "type": "string",
          "default": "tycho-lsp",
          "description": "Path to the tycho-lsp language server binary (built by `make tycho-lsp`)."
        },
        "tycho.compilerPath": {
          "type": "string",
          "default": "tychoc",
          "description": "Path to the tycho compiler the server runs for diagnostics (passed as TYCHOC)."
        },
        "tycho.enableServer": {
          "type": "boolean",
          "default": true,
          "description": "Run tycho-lsp for live diagnostics. Disable for highlighting only."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
