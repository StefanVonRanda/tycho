# Example: core:fmath -- float utilities over the float builtins.
package main
import "core:fmath"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn main():
    print("round(3.7)       = " + str(fmath.round(3.7)) + "\n")
    print("trunc(3.7)       = " + str(fmath.trunc(3.7)) + "\n")
    print("clamp(99,0,10)   = " + str(fmath.clamp(99.0, 0.0, 10.0)) + "\n")
    print("max(2.5, 7.5)    = " + str(fmath.max(2.5, 7.5)) + "\n")
    print("lerp(0,10,0.25)  = " + str(fmath.lerp(0.0, 10.0, 0.25)) + "\n")
    print("approx_eq .1+.2=.3 = " + str(b2i(fmath.approx_eq(0.1 + 0.2, 0.3, 0.0001))) + "\n")
