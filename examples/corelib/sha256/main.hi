# Example: core:sha256 -- hash a string to a 64-char hex digest.
# Run via examples/corelib/run.sh.
package main
import "core:sha256"

fn main():
    print("sha256(\"\")      =\n  " + sha256.hex("") + "\n")
    print("sha256(\"hier\")  =\n  " + sha256.hex("hier") + "\n")
    print("sha256(\"hier!\") =\n  " + sha256.hex("hier!") + "\n")   # one byte different -> avalanche
    print("digest bytes     = " + str(len(sha256.digest("hier"))) + "\n")  # 32
