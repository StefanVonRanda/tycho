# Example: core:sha256 -- hash a string to a 64-char hex digest.
# Run via examples/corelib/run.sh.
package main
import "core:sha256"

fn main():
    println("sha256(\"\")      =\n  " + sha256.hex(""))
    println("sha256(\"tycho\")  =\n  " + sha256.hex("tycho"))
    println("sha256(\"tycho!\") =\n  " + sha256.hex("tycho!"))   # one byte different -> avalanche
    println("digest bytes     = " + str(len(sha256.digest("tycho"))))  # 32
