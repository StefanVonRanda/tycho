# Example: core:iter_float -- higher-order helpers over [float].
package main
import "core:iter_float"

fn dbl(x: float) -> float:
    return x * 2.0

fn main():
    xs := [1.5, 2.5, 3.0]
    doubled := iter_float.map(xs, dbl)
    print("map dbl[0]   = " + str(doubled[0]) + "\n")    # 3
    print("map dbl[1]   = " + str(doubled[1]) + "\n")    # 5
    sum := iter_float.reduce(xs, 0.0, fn(a: float, b: float) -> float: a + b)
    print("reduce sum   = " + str(sum) + "\n")           # 7
