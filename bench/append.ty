# In-place string append (thesis flagship). `acc = acc + e` in a loop is the
# textbook O(n^2) memory trap; Tycho grows acc's buffer in place, so building a
# 40000-char string stays in the low MBs. The naive copy-each-step baseline is
# ~828 MB at this N. make bench asserts peak RSS stays far below that.
fn build(n: int) -> string:
    acc := ""
    for i in range(n):
        acc = acc + "x"
    return acc

fn main():
    print(str(len(build(40000))) + "\n")
