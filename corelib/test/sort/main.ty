# corelib test: core:sort (argsort family + by_key). All sorts stable, inputs unmutated.
package main
import "core:sort"

fn jn(xs: [int]) -> string:
    r := ""
    for i in range(len(xs)):
        if i > 0:
            r = r + ","
        r = r + str(xs[i])
    return r

fn main():
    keys := [30, 10, 20, 10]
    println("asc=" + jn(sort.argsort(keys)))          # asc=1,3,2,0 (stable: first 10 before second)
    println("desc=" + jn(sort.argsort_desc(keys)))    # desc=0,2,1,3
    println("orig=" + jn(keys))                       # orig=30,10,20,10 (input untouched)
    names := ["carol", "alice", "bob", "alice"]
    println("strs=" + jn(sort.argsort(names)))        # strs=1,3,2,0 (generic argsort over strings)
    # asc/desc: sort the VALUES directly (the common case), generic over comparable
    println("asc2=" + jn(sort.asc(keys)))             # asc2=10,10,20,30 (stable)
    println("desc2=" + jn(sort.desc(keys)))           # desc2=30,20,10,10
    println("ascs=" + str(sort.asc(names)))           # ascs=[alice, alice, bob, carol]
    # parallel-array use: order words by count descending
    words := ["the", "fox", "jumps"]
    counts := [3, 7, 1]
    ord := sort.argsort_desc(counts)
    line := ""
    for i in range(len(ord)):
        line = line + words[ord[i]] + ":" + str(counts[ord[i]]) + " "
    println(line)                                     # fox:7 the:3 jumps:1
    # by_key with a closure: sort by distance from 50
    xs := [10, 60, 45, 90]
    bk := sort.by_key(xs, fn(x: int) -> int: (x - 50) * (x - 50))
    println("bykey=" + jn(bk))                        # bykey=45,60,10,90 (10/90 tie on key 1600: stable keeps 10 first)
    empty := []int                                         # generic argsort needs a typed empty (can't infer $T from bare [])
    println("edge=" + str(len(sort.argsort(empty))) + str(len(sort.argsort([5]))))   # edge=01
