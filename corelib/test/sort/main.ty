# corelib test: core:sort (argsort family + by_key). All sorts stable, inputs unmutated.
package main
import "core:sort"

fn jn(xs: [int]) -> string:
    r := ""
    for i in range(len(xs)):
        if i > 0:
            r = r + ","
        r = r + str(xs[i])
    return r

fn main():
    keys := [30, 10, 20, 10]
    print("asc=" + jn(sort.argsort(keys)) + "\n")          # asc=1,3,2,0 (stable: first 10 before second)
    print("desc=" + jn(sort.argsort_desc(keys)) + "\n")    # desc=0,2,1,3
    print("orig=" + jn(keys) + "\n")                       # orig=30,10,20,10 (input untouched)
    names := ["carol", "alice", "bob", "alice"]
    print("strs=" + jn(sort.argsort_str(names)) + "\n")    # strs=1,3,2,0
    # parallel-array use: order words by count descending
    words := ["the", "fox", "jumps"]
    counts := [3, 7, 1]
    ord := sort.argsort_desc(counts)
    line := ""
    for i in range(len(ord)):
        line = line + words[ord[i]] + ":" + str(counts[ord[i]]) + " "
    print(line + "\n")                                     # fox:7 the:3 jumps:1
    # by_key with a closure: sort by distance from 50
    xs := [10, 60, 45, 90]
    bk := sort.by_key(xs, fn(x: int) -> int: (x - 50) * (x - 50))
    print("bykey=" + jn(bk) + "\n")                        # bykey=45,60,10,90 (10/90 tie on key 1600: stable keeps 10 first)
    print("edge=" + str(len(sort.argsort([]))) + str(len(sort.argsort([5]))) + "\n")   # edge=01
