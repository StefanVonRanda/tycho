# corelib test: exercises core:raster (BMP + QOI, pure Tycho). tychoc and tychoc0
# must agree; output locked to corelib/test/raster.out (corelib/run.sh). The image
# is chosen to hit QOI's RGB, RUN, DIFF, RGBA, and INDEX chunks.
package main
import "core:raster"

fn b(x: bool) -> int:
    if x:
        return 1
    return 0

fn push_px(px: inout [int], r: int, g: int, bl: int, a: int):
    push(px, r)
    push(px, g)
    push(px, bl)
    push(px, a)

# byte-sum of a bytes buffer (via its byte-safe string view)
fn bsum(bs: bytes) -> int:
    s := to_str(bs)
    t := 0
    for i in range(len(s)):
        t = t + s[i]
    return t

# do two images have identical dimensions + pixels?
fn same(x: raster.Image, y: raster.Image) -> int:
    if x.width != y.width or x.height != y.height:
        return 0
    sa := to_str(x.pixels)
    sb := to_str(y.pixels)
    if len(sa) != len(sb):
        return 0
    for i in range(len(sa)):
        if sa[i] != sb[i]:
            return 0
    return 1

fn nth(bs: bytes, i: int) -> int:
    return to_str(bs)[i]

fn main():
    px := []int
    push_px(&px, 10, 20, 30, 255)          # RGB   (far from initial 0,0,0,255)
    push_px(&px, 10, 20, 30, 255)          # RUN   (== prev)
    push_px(&px, 11, 21, 31, 255)          # DIFF  (+1,+1,+1)
    push_px(&px, 11, 21, 31, 128)          # RGBA  (alpha change)
    push_px(&px, 10, 20, 30, 255)          # INDEX (seen as pixel 0)
    push_px(&px, 200, 50, 50, 255)         # RGB
    push_px(&px, 200, 50, 50, 255)         # RUN
    push_px(&px, 200, 50, 50, 255)         # RUN (flushed at last pixel)
    img := raster.make(4, 2, to_bytes(px))
    println("src wxh = " + str(img.width) + "x" + str(img.height))

    # ---- QOI round trip ----
    q := raster.encode_qoi(img)
    qd := raster.decode_qoi(q)
    println("qoi len = " + str(len(q)))
    println("qoi rt  = " + str(same(img, qd)))
    # header is spec-exact: 'qoif', width BE=4, height BE=2, channels 4, sRGB 0
    println("qoi hdr = " + str(nth(q, 0)) + " " + str(nth(q, 1)) + " " + str(nth(q, 2)) + " " + str(nth(q, 3)) + " w=" + str(nth(q, 7)) + " h=" + str(nth(q, 11)) + " ch=" + str(nth(q, 12)) + " cs=" + str(nth(q, 13)))
    # end marker = 00 00 00 00 00 00 00 01
    ql := len(q)
    println("qoi end = " + str(nth(q, ql - 8)) + str(nth(q, ql - 2)) + str(nth(q, ql - 1)))
    println("qoi sum = " + str(bsum(q)))

    # ---- BMP round trip ----
    bm := raster.encode_bmp(img)
    bd := raster.decode_bmp(bm)
    println("bmp len = " + str(len(bm)))       # 54 + 8*4 = 86
    println("bmp rt  = " + str(same(img, bd)))
    println("bmp sig = " + str(nth(bm, 0)) + str(nth(bm, 1)))   # 66 77 = 'BM'
    println("bmp sum = " + str(bsum(bm)))

    # ---- cross-codec: both decoders agree ----
    println("cross   = " + str(same(qd, bd)))

    # ---- fail closed ----
    println("bad qoi = " + str(raster.decode_qoi(to_bytes([1, 2, 3])).width))
    println("bad bmp = " + str(raster.decode_bmp(to_bytes([1, 2, 3])).width))
    empt := raster.decode_qoi(to_bytes([]int))
    println("empty   = " + str(empt.width))
