# corelib test: exercises core:strings; C compiler and tychoc0 must agree (corelib/run.sh).
# (f-string holes avoid nested string literals — the lexer would stop at the inner quote.)
package main
import "core:strings"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn main():
    println(strings.to_upper("Hello, World!"))           # HELLO, WORLD!
    println(strings.to_lower("Hello, World!"))           # hello, world!
    print(strings.repeat("ab", 3) + "|[" + strings.trim("   spaced text   ") + "]\n")  # ababab|[spaced text]
    bits := b2i(strings.starts_with("hello", "he")) * 4 + b2i(strings.ends_with("hello", "lo")) * 2 + b2i(strings.contains("hello", "ell"))
    miss := b2i(strings.starts_with("hi", "x")) + b2i(strings.contains("abc", "z"))
    p1 := strings.parse_int("-42")
    p2 := strings.parse_int("123stop")
    println(f"bits={bits} miss={miss} p1={p1} p2={p2}")       # bits=7 miss=0 p1=-42 p2=123
    # parse_int edges: int64 bounds parse exactly; overflow/empty/'-'/garbage -> 0
    pmax := strings.parse_int("9223372036854775807")
    pmin := strings.parse_int("-9223372036854775808")
    println(f"pmax={pmax} pmin={pmin}")                       # pmax=9223372036854775807 pmin=-9223372036854775808
    ovf := strings.parse_int("12345678901234567890")
    ovn := strings.parse_int("-9223372036854775809")
    pe := strings.parse_int("")
    pd := strings.parse_int("-")
    pg := strings.parse_int("garbage")
    println(f"ovf={ovf} ovn={ovn} pe={pe} pd={pd} pg={pg}")   # ovf=0 ovn=0 pe=0 pd=0 pg=0
    # is_space covers \v (11) and \f (12) too: trim strips them
    println("vt=[" + strings.trim(chr(11) + "x" + chr(12)) + "]")   # vt=[x]
    # ---- builtin split shapes (corelib composes with it; empty sep aborts by design) ----
    println("s1=[" + jn(split("a,b,c", ",")) + "]")            # s1=[a|b|c]
    println("s2=[" + jn(split(",a,", ",")) + "]")              # s2=[|a|] (empty pieces kept)
    println("s3=[" + jn(split("abc", ",")) + "]")              # s3=[abc]
    println("s4=" + str(len(split("", ","))))             # s4=1 (one empty piece)
    println("s5=[" + jn(split("a::b::c", "::")) + "]")         # s5=[a|b|c] (multi-char sep)
    # ---- lines: every documented shape ----
    println("l1=[" + jn(strings.lines("a" + chr(10) + "b")) + "]")                       # l1=[a|b]
    println("l2=[" + jn(strings.lines("a" + chr(10) + "b" + chr(10))) + "]")             # l2=[a|b]
    println("l3=[" + jn(strings.lines("a" + chr(13) + chr(10) + "b")) + "]")             # l3=[a|b]
    println("l4=" + str(len(strings.lines(""))))                                    # l4=0
    println("l5=" + str(len(strings.lines(chr(10)))))                               # l5=1 (one empty line)
    # ---- replace (package) + find (builtin substring search) ----
    println("r1=" + strings.replace("a-b-c", "-", "+"))   # r1=a+b+c
    println("r2=" + strings.replace("aaa", "aa", "b"))    # r2=ba (no rescan)
    println("r3=" + strings.replace("x", "", "y"))        # r3=x (empty old: unchanged)
    i1 := find("hello", "ll")
    i2 := find("hello", "zz")
    i3 := find("hello", "")
    println(f"i1={i1} i2={i2} i3={i3}")                        # i1=2 i2=-1 i3=0
    # ---- extensions: count / strip / pad / reverse / capitalize / split_once ----
    c1 := strings.count("a.b.c.d", ".")
    c2 := strings.count("aaa", "aa")
    println(f"count={c1},{c2}")                                # count=3,1
    println("strip=[" + strings.strip_prefix("core:x", "core:") + "][" + strings.strip_suffix("file.ty", ".ty") + "]")   # strip=[x][file]
    println("pad=[" + strings.pad_left("7", 3, "0") + "][" + strings.pad_right("7", 3, ".") + "]")    # pad=[007][7..]
    println("rc=" + strings.reverse("abc") + "," + strings.capitalize("hello"))    # rc=cba,Hello
    bf, af := strings.split_once("k=v=w", "=")
    nb, na := strings.split_once("nosep", "=")
    println("split=[" + bf + "][" + af + "][" + nb + "][" + na + "]")   # split=[k][v=w][nosep][]

fn jn(xs: [string]) -> string:    # local join with '|' so pieces are visible
    r := ""
    for i in range(len(xs)):
        if i > 0:
            r = r + "|"
        r = r + xs[i]
    return r
