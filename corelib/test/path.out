base ''=[.] '/'=[/] f=[file.txt]
base /a/b/c=[c] /a/b/c/=[c] a/b/=[b]
dir ''=[.] foo=[.] /foo=[/]
dir /a/b/c=[/a/b] /a/b/c/=[/a/b] a/b=[a]
ext a.txt=[.txt] .bashrc=[] tar.gz=[.gz] none=[]
ext dirdot=[]
stem a.txt=[a] .bashrc=[.bashrc] tar.gz=[archive.tar]
join a|b=[a/b] a/|b=[a/b] a|/b=[a/b]
join /|x=[/x] ''|b=[b] a|''=[a]
abs /a=1 a=0 empty=0
split /a/b/c.txt -> dir=[/a/b] base=[c.txt]
clean a/./b/../c=[a/c] /a//b/=[/a/b]
clean /..=[/] ''=[.] .=[.]
clean ../a=[../a] a/b/../../c=[c] a/../../b=[../b]
clean ///=[/] ./x=[x]
