# corelib test: exercises core:base64; the C compiler and tychoc0 must agree, and
# the output is locked to corelib/test/base64.out (corelib/run.sh).
# Binary cases are checked via lengths + re-encode equality (never printed raw).
package main
import "core:base64"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn main():
    # ---- the RFC 4648 test vectors (encode) ----
    println("enc ''     = [" + base64.encode("") + "]")        # []
    println("enc f      = " + base64.encode("f"))         # Zg==
    println("enc fo     = " + base64.encode("fo"))        # Zm8=
    println("enc foo    = " + base64.encode("foo"))       # Zm9v
    println("enc foob   = " + base64.encode("foob"))      # Zm9vYg==
    println("enc fooba  = " + base64.encode("fooba"))     # Zm9vYmE=
    println("enc foobar = " + base64.encode("foobar"))    # Zm9vYmFy

    # ---- decode the vectors back (text -> exact) ----
    println("dec Zg==   = " + base64.decode("Zg=="))      # f
    println("dec Zm8=   = " + base64.decode("Zm8="))      # fo
    println("dec foobar = " + base64.decode("Zm9vYmFy"))  # foobar

    # ---- decode is lenient: newlines in wrapped Base64 are skipped ----
    wrapped := "Zm9v" + "\n" + "YmFy"
    println("dec wrap   = " + base64.decode(wrapped))     # foobar

    # ---- text round-trip ----
    msg := "Hello, tycho! 1234567890"
    rt := base64.decode(base64.encode(msg))
    println(f"text_rt_ok = {b2i(rt == msg)}")                  # 1

    # ---- non-NUL binary (high bytes 252..255) round-trips exactly ----
    bin := chr(255) + chr(254) + chr(253) + chr(252)
    enc := base64.encode(bin)
    encu := base64.encode_url(bin)
    println("bin enc    = " + enc)                        # //79/A==
    println("bin encurl = " + encu)                       # __79_A
    # decode each form, re-encode to standard, and compare (avoids printing raw bytes)
    d1 := base64.decode(enc)
    d2 := base64.decode(encu)
    println(f"bin_std_ok = {b2i(base64.encode(d1) == enc)} len={len(d1)}")   # 1 len=4
    println(f"bin_url_ok = {b2i(base64.encode(d2) == enc)} len={len(d2)}")   # 1 len=4

    # ---- url-safe of a value that hits index 62/63 differs from standard ----
    println(f"url_differs = {b2i(base64.encode_url(bin) != base64.encode(bin))}")  # 1
