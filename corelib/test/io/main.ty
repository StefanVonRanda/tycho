# corelib test: exercises core:io; the C compiler and tychoc0 must agree, and
# the output is locked to corelib/test/io.out (corelib/run.sh).
#
# Filesystem side effects are confined to two fixed throwaway paths under /tmp
# (never the repo). Each run truncates first, so output is deterministic; the
# exists/list checks use repo-relative paths (the harness runs with cwd = repo
# root) and test membership only, never directory order.
package main
import "core:io"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn jn(xs: [string]) -> string:                 # join with '|' for stable printing
    out := ""
    for i in range(len(xs)):
        if i > 0:
            out = out + "|"
        out = out + xs[i]
    return out

fn main():
    tmp := "/tmp/tycho_corelib_io_selftest.txt"

    # write truncates; read returns the exact bytes; append extends
    w1 := io.write(tmp, "hello\nworld\n")
    body := io.read(tmp)
    w2 := io.append(tmp, "again\n")
    ls := io.read_lines(tmp)
    print(f"write={b2i(w1)} bytes={len(body)} append={b2i(w2)} lines={len(ls)}\n")
    print("joined=" + jn(ls) + "\n")

    # write_lines / read_lines round-trip (each line newline-terminated)
    w3 := io.write_lines(tmp, ["a", "b", "c"])
    rl := io.read_lines(tmp)
    print(f"wl={b2i(w3)} rl={len(rl)} " + jn(rl) + "\n")

    # a missing file reads as ""
    miss := io.read("/tmp/tycho_corelib_io_absent.xyz")
    print(f"missing=[{miss}] len={len(miss)}\n")

    # exists via list_dir membership (repo-relative paths; string-literal args
    # bound to locals first -- f-string holes can't hold a string literal)
    es := b2i(io.exists("corelib/test/io/main.ty"))
    en := b2i(io.exists("corelib/test/io/nope.xyz"))
    print(f"exists_self={es} exists_no={en}\n")
    emk := b2i(io.exists("Makefile"))
    lge := b2i(len(io.list("corelib/test/io")) >= 1)
    print(f"exists_mk={emk} list_ge1={lge}\n")
