# corelib test: exercises core:io; the C compiler and tychoc0 must agree, and
# the output is locked to corelib/test/io.out (corelib/run.sh).
#
# Filesystem side effects are confined to two fixed throwaway paths under /tmp
# (never the repo). Each run truncates first, so output is deterministic; the
# exists/list checks use repo-relative paths (the harness runs with cwd = repo
# root) and test membership only, never directory order.
package main
import "core:io"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn jn(xs: [string]) -> string:                 # join with '|' for stable printing
    out := ""
    for i in range(len(xs)):
        if i > 0:
            out = out + "|"
        out = out + xs[i]
    return out

fn addlen(acc: int, line: string) -> int:      # a fold_lines reducer
    return acc + len(line)

fn main():
    tmp := "/tmp/tycho_corelib_io_selftest.txt"

    # write truncates; read returns the exact bytes; append extends
    w1 := io.write(tmp, "hello\nworld\n")
    body := io.read(tmp)
    w2 := io.append(tmp, "again\n")
    ls := io.read_lines(tmp)
    println(f"write={b2i(w1)} bytes={len(body)} append={b2i(w2)} lines={len(ls)}")
    println("joined=" + jn(ls))

    # write_lines / read_lines round-trip (each line newline-terminated)
    w3 := io.write_lines(tmp, ["a", "b", "c"])
    rl := io.read_lines(tmp)
    println(f"wl={b2i(w3)} rl={len(rl)} " + jn(rl))

    # streaming line reader: one line at a time (bounded memory), round-tripping
    # the content write_lines wrote. An empty middle line stays Some("").
    w4 := io.write_lines(tmp, ["one", "", "three"])
    lr := io.open_lines(tmp)
    sn := 0
    sj := ""
    if not is_null(lr):
        d := false
        for not d:
            match io.read_line(lr):
                Some(s):
                    if sn > 0:
                        sj = sj + "|"
                    sj = sj + s
                    sn = sn + 1
                None:
                    d = true
        io.close_lines(lr)
    println(f"open={b2i(w4)} stream_lines={sn} " + sj)
    # fold_lines: bounded streaming reduce; a missing file folds to init
    tot := io.fold_lines(tmp, 0, addlen)
    missfold := io.fold_lines("/tmp/tycho_corelib_io_absent.xyz", 7, addlen)
    println(f"fold_sumlen={tot} fold_missing={missfold}")

    # read_bytes: binary-safe whole-file read (interior NUL bytes preserved, and
    # a missing file -> empty). Used immediately, the safe pattern.
    binf := "/tmp/tycho_corelib_io_bin.dat"
    io.write(binf, "AB" + chr(0) + "CD")
    rb := io.read_bytes(binf)
    rbmiss := io.read_bytes("/tmp/tycho_corelib_io_absent.xyz")
    println(f"read_bytes len={len(rb)} missing={len(rbmiss)}")

    # a missing file reads as ""
    miss := io.read("/tmp/tycho_corelib_io_absent.xyz")
    println(f"missing=[{miss}] len={len(miss)}")

    # exists via list_dir membership (repo-relative paths; string-literal args
    # bound to locals first -- f-string holes can't hold a string literal)
    es := b2i(io.exists("corelib/test/io/main.ty"))
    en := b2i(io.exists("corelib/test/io/nope.xyz"))
    println(f"exists_self={es} exists_no={en}")
    emk := b2i(io.exists("Makefile"))
    lge := b2i(len(io.list("corelib/test/io")) >= 1)
    println(f"exists_mk={emk} list_ge1={lge}")
