# corelib test: core:image. Hermetic -- builds an RGBA buffer in memory, encodes to
# PNG, decodes back, and checks identity (PNG is lossless, so the round-trip is
# exact). The compressed PNG bytes are libpng-version dependent, so the checks are
# boolean invariants (produced-a-PNG, signature, dimensions, pixel identity, corrupt
# handling) which are deterministic everywhere. tychoc and tychoc0 must agree and
# the output is locked to corelib/test/image.out (corelib/run.sh).
package main
import "core:image"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn main():
    # build a 3x2 RGBA image (24 bytes): pixel(x,y) = (x*40, y*80, 100, 255)
    px := ""
    y := 0
    for y < 2:
        x := 0
        for x < 3:
            px = px + chr(x * 40) + chr(y * 80) + chr(100) + chr(255)
            x = x + 1
        y = y + 1
    img := image.make(3, 2, to_bytes(px))            # 3*2*4 = 24 pixel bytes

    png := image.encode(img)
    println("encoded_ok=" + str(b2i(len(png) > 0)))                              # 1
    # PNG signature: 0x89 'P' 'N' 'G' (137 80 78 71). Index via a string view --
    # `bytes` itself is not indexable; to_str reinterprets the same buffer.
    sig := to_str(png)
    println("is_png=" + str(b2i(len(png) >= 8 and sig[0] == 137 and sig[1] == 80 and sig[2] == 78 and sig[3] == 71)))   # 1

    back := image.decode(png)
    println("dims=" + str(back.width) + "x" + str(back.height))                  # 3x2
    println("pixels_match=" + str(b2i(len(back.pixels) == 24 and to_str(back.pixels) == px)))   # 1

    # decode garbage -> fail closed (0x0 image, empty pixels)
    bad := image.decode(to_bytes("this is definitely not a png file"))
    println("corrupt=" + str(bad.width) + "x" + str(bad.height) + " pxlen=" + str(len(bad.pixels)))   # 0x0 pxlen=0
