# corelib test: core:decimal (built on core:bignum). Pure base-10 arithmetic ->
# fully deterministic. The headline is 0.1 + 0.2 == 0.3 EXACTLY (a float cannot).
# tychoc and tychoc0 must agree and the output is locked to corelib/test/decimal.out.
package main
import "core:decimal"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn main():
    # from_str / to_str round-trips, stored scale preserved
    println("rt=" + decimal.to_str(decimal.from_str("123.45")) + " " + decimal.to_str(decimal.from_str("-0.001")) + " " + decimal.to_str(decimal.from_str("42")) + " " + decimal.to_str(decimal.from_str("1000.00")))
    println("lead=" + decimal.to_str(decimal.from_str(".5")) + " " + decimal.to_str(decimal.from_str("-.25")))

    # the classic: 0.1 + 0.2 == 0.3 exactly (float gives 0.30000000000000004)
    s := decimal.add(decimal.from_str("0.1"), decimal.from_str("0.2"))
    println("point3=" + decimal.to_str(s) + " ok=" + str(b2i(decimal.to_str(s) == "0.3")))

    # add across scales / sub with borrow across the point
    println("add_mixed=" + decimal.to_str(decimal.add(decimal.from_str("1.5"), decimal.from_str("2.25"))))   # 3.75
    println("sub=" + decimal.to_str(decimal.sub(decimal.from_str("10.00"), decimal.from_str("0.01"))))       # 9.99

    # mul: scales add
    println("mul=" + decimal.to_str(decimal.mul(decimal.from_str("1.5"), decimal.from_str("1.5"))) + " " + decimal.to_str(decimal.mul(decimal.from_str("0.1"), decimal.from_str("0.1"))))   # 2.25 0.01

    # cmp: 1.5 == 1.50, 1.5 < 1.6, 2.0 > 1.99
    println("cmp=" + str(decimal.cmp(decimal.from_str("1.5"), decimal.from_str("1.50"))) + " " + str(decimal.cmp(decimal.from_str("1.5"), decimal.from_str("1.6"))) + " " + str(decimal.cmp(decimal.from_str("2.0"), decimal.from_str("1.99"))))

    # neg / abs
    println("negabs=" + decimal.to_str(decimal.neg(decimal.from_str("3.14"))) + " " + decimal.to_str(decimal.abs(decimal.from_str("-3.14"))))

    # rescale: increase is exact, decrease truncates toward zero
    println("rescale=" + decimal.to_str(decimal.rescale(decimal.from_str("1.5"), 4)) + " " + decimal.to_str(decimal.rescale(decimal.from_str("1.23456"), 2)))   # 1.5000 1.23

    # arbitrary precision: a 39-digit-coefficient decimal round-trips
    big := "123456789012345678901234567890.987654321"
    println("bigprec_ok=" + str(b2i(decimal.to_str(decimal.from_str(big)) == big)))

    # exact money: 100 * 0.01 == 1.00 with no drift
    acc := decimal.from_int(0)
    i := 0
    for i < 100:
        acc = decimal.add(acc, decimal.from_str("0.01"))
        i = i + 1
    println("cents=" + decimal.to_str(acc) + " ok=" + str(b2i(decimal.to_str(acc) == "1.00")))
