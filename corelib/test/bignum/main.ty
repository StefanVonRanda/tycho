# corelib test: core:bignum. Pure integer arithmetic -> fully deterministic. The
# 2^100 and 100! checks are self-verifying against their known canonical values, so
# a carry/overflow bug fails the assertion (not just the golden). tychoc and tychoc0
# must agree and the output is locked to corelib/test/bignum.out (corelib/run.sh).
package main
import "core:bignum"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn main():
    # from_int / to_str round-trips (incl. negative and multi-limb)
    println("i0=" + bignum.to_str(bignum.from_int(0)))
    println("i42=" + bignum.to_str(bignum.from_int(42)))
    println("ineg=" + bignum.to_str(bignum.from_int(0 - 42)))
    println("i5e9=" + bignum.to_str(bignum.from_int(5000000000)))
    # from_str / to_str round-trip (30 digits = 4 limbs) + leading-zero handling
    big := "123456789012345678901234567890"
    println("s_rt=" + str(b2i(bignum.to_str(bignum.from_str(big)) == big)))
    println("s_neg=" + bignum.to_str(bignum.from_str("-000123")))       # -123

    # add: carry across a limb boundary; sub: borrow across one
    println("carry=" + bignum.to_str(bignum.add(bignum.from_str("999999999999999999"), bignum.from_str("1"))))
    println("borrow=" + bignum.to_str(bignum.sub(bignum.from_str("1000000000000000000"), bignum.from_str("1"))))

    # signed add / mul / cancelling sub
    println("mixed=" + bignum.to_str(bignum.add(bignum.from_int(100), bignum.from_int(0 - 30))))     # 70
    println("mixed2=" + bignum.to_str(bignum.add(bignum.from_int(0 - 100), bignum.from_int(30))))    # -70
    println("mulneg=" + bignum.to_str(bignum.mul(bignum.from_int(0 - 7), bignum.from_int(6))))       # -42
    println("subzero=" + bignum.to_str(bignum.sub(bignum.from_str("42"), bignum.from_str("42"))))    # 0

    # cmp: greater / less (across sign) / equal
    println("cmp=" + str(bignum.cmp(bignum.from_str("100"), bignum.from_str("99"))) + " " + str(bignum.cmp(bignum.from_int(0 - 5), bignum.from_int(3))) + " " + str(bignum.cmp(bignum.from_str("12345678901234567890"), bignum.from_str("12345678901234567890"))))

    # 2^100 by repeated doubling, checked against the canonical value
    p := bignum.from_int(1)
    two := bignum.from_int(2)
    i := 0
    for i < 100:
        p = bignum.mul(p, two)
        i = i + 1
    pw := bignum.to_str(p)
    println("2^100=" + pw)
    println("2^100_ok=" + str(b2i(pw == "1267650600228229401496703205376")))

    # 100! -- accumulates deep carries and grows to 158 digits; checked canonical
    f := bignum.from_int(1)
    k := 2
    for k <= 100:
        f = bignum.mul(f, bignum.from_int(k))
        k = k + 1
    fact := "93326215443944152681699238856266700490715968264381621468592963895217599993229915608941463976156518286253697920827223758251185210916864000000000000000000000000"
    println("100!_ok=" + str(b2i(bignum.to_str(f) == fact)))

    # --- division (truncated toward zero, like int / and %): a = q*b + r ---
    println("dm=" + bignum.to_str(bignum.div(bignum.from_int(17), bignum.from_int(5))) + " " + bignum.to_str(bignum.mod(bignum.from_int(17), bignum.from_int(5))))                     # 3 2
    println("dm_aneg=" + bignum.to_str(bignum.div(bignum.from_int(0 - 17), bignum.from_int(5))) + " " + bignum.to_str(bignum.mod(bignum.from_int(0 - 17), bignum.from_int(5))))        # -3 -2
    println("dm_bneg=" + bignum.to_str(bignum.div(bignum.from_int(17), bignum.from_int(0 - 5))) + " " + bignum.to_str(bignum.mod(bignum.from_int(17), bignum.from_int(0 - 5))))        # -3 2
    # 2^100 / 2^50 == 2^50 exactly (p = 2^100, two = 2 from above)
    h := bignum.from_int(1)
    j := 0
    for j < 50:
        h = bignum.mul(h, two)
        j = j + 1
    println("pow_div_ok=" + str(b2i(bignum.cmp(bignum.div(p, h), h) == 0)))       # 2^100 / 2^50 == 2^50
    println("pow_mod_ok=" + str(b2i(bignum.is_zero(bignum.mod(p, h)))))           # exact -> remainder 0
    # invariant on a messy multi-limb division: a == q*b + r and 0 <= r < b
    aa := bignum.from_str("123456789012345678901234567890123456789")
    bb := bignum.from_str("98765432109876543")
    qq, rr := bignum.divmod(aa, bb)
    recon := bignum.add(bignum.mul(qq, bb), rr)
    println("div_invariant=" + str(b2i(bignum.cmp(recon, aa) == 0 and bignum.cmp(rr, bb) < 0)))   # 1
    # division by zero -> 0 (documented fail-closed)
    println("divzero=" + bignum.to_str(bignum.div(bignum.from_int(5), bignum.from_int(0))))        # 0

    # --- abs / pow / to_int ---
    println("abs=" + bignum.to_str(bignum.abs(bignum.from_int(0 - 42))) + " " + bignum.to_str(bignum.abs(bignum.from_int(42))))     # 42 42
    println("pow2_100_ok=" + str(b2i(bignum.to_str(bignum.pow(bignum.from_int(2), 100)) == "1267650600228229401496703205376")))    # 1
    println("pow_edge=" + bignum.to_str(bignum.pow(bignum.from_int(3), 0)) + " " + bignum.to_str(bignum.pow(bignum.from_int(0), 5)) + " " + bignum.to_str(bignum.pow(bignum.from_int(10), 3)))   # 1 0 1000
    println("to_int=" + str(bignum.to_int(bignum.from_int(42))) + " " + str(bignum.to_int(bignum.from_str("5000000000"))) + " " + str(bignum.to_int(bignum.from_int(0 - 7))))     # 42 5000000000 -7
    println("to_int_overflow=" + str(bignum.to_int(bignum.pow(bignum.from_int(10), 30))))          # 0 (10^30 doesn't fit)
