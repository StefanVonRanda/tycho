# corelib test: exercises core:cli; tychoc and tychoc0 must agree and the output
# is locked to corelib/test/cli.out (corelib/run.sh).
package main
import "core:cli"

fn yn(b: bool) -> string:
    if b:
        return "yes"
    return "no"

fn main():
    # argv WITHOUT the program name: a mix of options, long/short flags,
    # positionals, a `--` terminator, and a lone "-".
    argv := []string
    push(argv, "--out=build/app")     # option
    push(argv, "--level=3")           # option
    push(argv, "--verbose")           # long flag
    push(argv, "-xz")                 # short cluster -> x, z
    push(argv, "input.txt")           # positional
    push(argv, "-")                   # positional (lone dash)
    push(argv, "--")                  # end of options
    push(argv, "--not-an-option")     # positional (after --)
    push(argv, "last.txt")            # positional

    c := cli.parse(argv)

    println("out    = " + cli.get(c, "out", "?"))
    println("level  = " + cli.get(c, "level", "?"))
    println("missing= " + cli.get(c, "missing", "DEFAULT"))
    println("has out= " + yn(cli.has(c, "out")))
    println("has mis= " + yn(cli.has(c, "missing")))

    println("verbose= " + yn(cli.flag(c, "verbose")))
    println("flag x = " + yn(cli.flag(c, "x")))
    println("flag z = " + yn(cli.flag(c, "z")))
    println("flag q = " + yn(cli.flag(c, "q")))

    println("npos   = " + str(cli.count(c)))
    ps := cli.positionals(c)
    for i in range(len(ps)):
        println("pos[" + str(i) + "]= " + ps[i])

    # edge cases: empty argv, and a repeated option (last wins).
    empty := cli.parse([]string)
    println("empty n= " + str(cli.count(empty)))

    rep := []string
    push(rep, "--o=a")
    push(rep, "--o=b")
    println("repeat = " + cli.get(cli.parse(rep), "o", "?"))
