# corelib test: exercises core:fmath; the C compiler and tychoc0 must agree (corelib/run.sh).
# Negative float literals are written `0.0 - x` (the codebase's idiom).
package main
import "core:fmath"

fn main():
    print(f"minmax={fmath.min(2.5, 1.5)},{fmath.max(2.5, 1.5)}\n")              # 1.5, 2.5
    print(f"clamp={fmath.clamp(5.0, 0.0, 1.0)},{fmath.clamp(0.0 - 1.0, 0.0, 1.0)}\n")   # 1.0, 0.0
    print(f"sign={fmath.sign(0.0 - 3.0)},{fmath.sign(3.0)},{fmath.sign(0.0)}\n")        # -1.0,1.0,0.0
    print(f"round={fmath.round(2.5)},{fmath.round(0.0 - 2.5)},{fmath.round(2.4)}\n")    # 3.0,-3.0,2.0
    print(f"trunc={fmath.trunc(2.9)},{fmath.trunc(0.0 - 2.9)}\n")                       # 2.0,-2.0
    print(f"lerp={fmath.lerp(0.0, 10.0, 0.25)}\n")                                      # 2.5
    print(f"approx={fmath.approx_eq(0.1, 0.1, 0.0001)},{fmath.approx_eq(0.1, 0.2, 0.0001)}\n")
    print(f"consts={fmath.pi() > 3.0},{fmath.e() > 2.0}\n")
