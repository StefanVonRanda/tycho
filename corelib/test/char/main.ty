# corelib test: exercises core:char; the C compiler and tychoc0 must agree (corelib/run.sh).
package main
import "core:char"

fn main():
    println(f"digit={char.is_digit(53)},{char.is_digit(65)}")          # '5' yes, 'A' no
    println(f"alpha={char.is_alpha(65)},{char.is_alpha(48)}")          # 'A','0'
    println(f"alnum={char.is_alnum(48)},{char.is_alnum(45)}")          # '0','-'
    println(f"case={char.is_upper(65)},{char.is_lower(97)}")           # 'A','a'
    println(f"space={char.is_space(32)},{char.is_space(65)}")          # ' ','A'
    println(f"hex={char.is_hex(70)},{char.is_hex(103)}")              # 'F','g'
    println(f"to_upper={char.to_upper(97)} to_lower={char.to_lower(65)}")   # 'a'->65, 'A'->97
    println(f"digit_val={char.digit_val(55)},{char.digit_val(65)}")    # '7'->7, 'A'->-1
    println(f"hex_val={char.hex_val(57)},{char.hex_val(97)},{char.hex_val(70)}")  # '9'->9,'a'->10,'F'->15
