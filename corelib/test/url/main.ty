# corelib test: exercises core:url; the C compiler and tychoc0 must agree, and
# the output is locked to corelib/test/url.out (corelib/run.sh).
package main
import "core:url"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn main():
    # ---- encode: component-style (%20 for space), uppercase hex ----
    println("enc space   = " + url.encode("hello world"))     # hello%20world
    println("enc form    = " + url.encode_form("hello world")) # hello+world
    println("enc reserved= " + url.encode("a+b=c&d"))          # a%2Bb%3Dc%26d
    println("enc unres   = " + url.encode("safe-_.~"))         # safe-_.~ (unchanged)
    println("enc punct   = " + url.encode("/?#"))              # %2F%3F%23

    # ---- decode ----
    println("dec space   = " + url.decode("hello%20world"))    # hello world
    println("dec form    = " + url.decode_form("hello+world")) # hello world
    println("dec plus    = " + url.decode("a%2Bb"))            # a+b
    println("dec formmix = " + url.decode_form("a+b%2Bc"))     # a b+c

    # ---- lenient decode: malformed escapes pass through literally ----
    println("dec badhex  = " + url.decode("%ZZ"))              # %ZZ
    println("dec short   = " + url.decode("%2"))               # %2

    # ---- round-trip ----
    msg := "key=val&x=1 2/3?ok"
    rt := url.decode(url.encode(msg))
    println(f"rt_ok={b2i(rt == msg)}")                              # 1
    fmsg := "a b+c"
    frt := url.decode_form(url.encode_form(fmsg))
    println(f"form_rt_ok={b2i(frt == fmsg)}")                       # 1

    # ---- high (non-NUL) bytes encode as %XX and round-trip ----
    bin := chr(233) + chr(255) + chr(1)
    be := url.encode(bin)
    println("bin enc     = " + be)                             # %E9%FF%01
    db := url.decode(be)
    println(f"bin_ok={b2i(url.encode(db) == be)} len={len(db)}")    # 1 3

    # ---- byte-safe strings (A1): a decoded NUL is preserved ----
    z := url.decode("%00")
    println(f"decode_00_len={len(z)}")                              # 1
