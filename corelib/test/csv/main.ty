# corelib test: exercises core:csv; the C compiler and tychoc0 must agree, and
# the output is locked to corelib/test/csv.out (corelib/run.sh).
# Control bytes are escaped (\n \r \t) so each case prints on one line.
package main
import "core:csv"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn vis(s: string) -> string:                   # make control bytes visible
    out := ""
    for i in range(len(s)):
        c := s[i]
        if c == 10:
            out = out + "\\n"
        elif c == 13:
            out = out + "\\r"
        elif c == 9:
            out = out + "\\t"
        else:
            out = out + chr(c)
    return out

fn dump(rows: [[string]]) -> string:           # rows joined by " ; ", fields by "|"
    out := ""
    for r in range(len(rows)):
        if r > 0:
            out = out + " ; "
        row := rows[r]
        for c in range(len(row)):
            if c > 0:
                out = out + "|"
            out = out + vis(row[c])
    return out

fn show(label: string, s: string):
    println(label + dump(csv.parse(s)))

fn main():
    # ---- every documented input shape ----
    simple := "a,b,c"
    show("simple    = ", simple)               # a|b|c
    multi := "a,b\nc,d"
    show("multi     = ", multi)                # a|b ; c|d
    trail := "x,y\n"
    show("trailnl   = ", trail)                # x|y  (no empty trailing row)
    blank := "a\n\nb"
    show("blankline = ", blank)                # a ;  ; b
    empties := "a,,c"
    show("empties   = ", empties)              # a||c
    qcomma := "\"a,b\",c"
    show("qcomma    = ", qcomma)               # a,b|c
    qquote := "\"a\"\"b\",c"
    show("qquote    = ", qquote)               # a"b|c
    qnl := "\"a\nb\",c"
    show("qnewline  = ", qnl)                  # a\nb|c
    crlf := "a,b" + chr(13) + "\nc,d"          # \r has no string escape; build it
    show("crlf      = ", crlf)                 # a|b ; c|d
    qempty := "\"\",x"
    show("qempty    = ", qempty)               # |x
    unterm := "\"ab"
    show("unterm    = ", unterm)               # ab  (fail closed, no crash)

    # ---- empty input -> zero rows ----
    e := csv.parse("")
    println(f"emptyinput rows={len(e)}")       # 0

    # ---- safe accessor get() ----
    rows := csv.parse("a,b\nc,d")
    g00 := csv.get(rows, 0, 0)
    g11 := csv.get(rows, 1, 1)
    goob := csv.get(rows, 9, 9)
    println(f"get 0,0={g00} 1,1={g11} oob=[{goob}]")   # a d []

    # ---- serialize: only fields that need it are quoted ----
    special := [["a,b", "c\"d", "e\nf"], ["plain", "x"]]
    enc := csv.stringify(special)
    println("stringify = " + vis(enc))

    # ---- round-trip: parse(stringify(rows)) == rows ----
    rt := csv.parse(enc)
    same := b2i(dump(rt) == dump(special))
    println("roundtrip = " + dump(rt))
    nrows := len(rt)
    nr0 := len(rt[0])
    nr1 := len(rt[1])
    println(f"rt_ok={same} rows={nrows} r0={nr0} r1={nr1}")
