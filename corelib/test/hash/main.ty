# corelib test: exercises core:hash; the C compiler and tychoc0 must agree, and
# the output is locked to corelib/test/hash.out (corelib/run.sh).
# Checked against published vectors (CRC-32, FNV-1a) and hand-computed djb2/sdbm.
package main
import "core:hash"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn main():
    # ---- CRC-32 (zlib): "123456789" -> 0xCBF43926 is the canonical check ----
    println("crc ''     = " + hash.to_hex(hash.crc32("")))          # 00000000
    println("crc a      = " + hash.to_hex(hash.crc32("a")))         # e8b7be43
    println("crc abc    = " + hash.to_hex(hash.crc32("abc")))       # 352441c2
    println("crc check  = " + hash.to_hex(hash.crc32("123456789"))) # cbf43926

    # ---- FNV-1a 32 (reference vectors) ----
    println("fnv ''     = " + hash.to_hex(hash.fnv1a_32("")))       # 811c9dc5
    println("fnv a      = " + hash.to_hex(hash.fnv1a_32("a")))      # e40c292c
    println("fnv foobar = " + hash.to_hex(hash.fnv1a_32("foobar"))) # bf9cf968

    # ---- djb2 / sdbm (hand-computed for short inputs) ----
    println("djb2 a     = " + str(hash.djb2("a")))                  # 177670
    println("djb2 ab    = " + str(hash.djb2("ab")))                 # 5863208
    println("sdbm ''    = " + str(hash.sdbm("")))                   # 0
    println("sdbm a     = " + str(hash.sdbm("a")))                  # 97
    println("sdbm ab    = " + str(hash.sdbm("ab")))                 # 6363201

    # ---- to_hex sanity + values stay non-negative and 32-bit ----
    println("tohex 0    = " + hash.to_hex(0))                       # 00000000
    c := hash.crc32("tycho")
    f := hash.fnv1a_32("tycho")
    cc := b2i(c >= 0 and c < 4294967296)
    ff := b2i(f >= 0 and f < 4294967296)
    println(f"in_range crc={cc} fnv={ff}")                              # in_range crc=1 fnv=1
