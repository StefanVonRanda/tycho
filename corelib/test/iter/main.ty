package main
# corelib test: the GENERIC core:iter across int / string / float, with plain fns
# and capturing closures. All three compile paths must agree (corelib/run.sh).
import "core:iter"
import "core:arrays"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn dbl(x: int) -> int:
    return x + x

fn nonempty(s: string) -> int:
    if len(s) > 0:
        return 1
    return 0

fn main():
    xs := [1, 2, 3, 4, 5]
    println("map=" + arrays.join(iter.map(xs, dbl), ","))                          # 2,4,6,8,10
    thr := 10
    println("mapcl=" + arrays.join(iter.map(xs, fn(x: int) -> int: x + thr), ","))  # capturing closure
    println("filter=" + arrays.join(iter.filter(xs, fn(x: int) -> int: x % 2), ",")) # odds
    println("sum=" + str(iter.reduce(xs, 0, fn(a: int, b: int) -> int: a + b)))      # 15
    lim := 3
    println("count!=" + str(iter.count(xs, fn(x: int) -> int: x - lim)) + " any!=2=" + str(b2i(iter.any(xs, fn(x: int) -> int: x - 2))))
    # string instance (map closure + a named predicate)
    ws := ["hi", "", "yo", ""]
    println("smap=" + arrays.join(iter.map(ws, fn(s: string) -> string: s + "!"), ",") + " scount=" + str(iter.count(ws, nonempty)))
    # float instance (reduce)
    fs := [1.0, 2.0, 3.0]
    println("freduce=" + str(iter.reduce(fs, 0.0, fn(a: float, b: float) -> float: a + b)))   # 6.0
