# corelib test: exercises core:json; the C compiler and tychoc0 must agree, and
# the output is locked to corelib/test/json.out (corelib/run.sh).
package main
import "core:json"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn main():
    src := "{\"name\": \"tycho\", \"version\": 7, \"tags\": [\"systems\", \"arena\"], \"nested\": {\"ok\": true, \"n\": -3}, \"empty\": [], \"nothing\": null}"
    j := json.parse(src)

    # round-trip: parse then serialize -> compact canonical form
    println("round-trip: " + json.stringify(j))

    # accessors
    println("kind        = " + json.kind(j))
    println("version     = " + str(json.as_num(json.get(j, "version"))))
    println("name        = " + json.as_str(json.get(j, "name")))
    println("nested.n    = " + str(json.as_num(json.get(json.get(j, "nested"), "n"))))
    println("nested.ok   = " + str(b2i(json.as_bool(json.get(json.get(j, "nested"), "ok")))))
    println("tags.len    = " + str(json.len_of(json.get(j, "tags"))))
    println("tags[1]     = " + json.as_str(json.at(json.get(j, "tags"), 1)))
    println("tags[9]     = " + json.kind(json.at(json.get(j, "tags"), 9)))
    println("empty.len   = " + str(json.len_of(json.get(j, "empty"))))
    println("missing     = " + json.kind(json.get(j, "missing")))
    println("nothing     = " + json.kind(json.get(j, "nothing")))

    # object keys preserve insertion order
    ks := json.keys(j)
    println("keys.len    = " + str(len(ks)))
    println("key0        = " + ks[0])

    # escape round-trip: a JSON string with \" \n \t round-trips byte-identical
    esc_src := "\"a\\\"b\\nc\\td\""
    println("esc rt      = " + json.stringify(json.parse(esc_src)))

    # build a tree programmatically (cross-package variant construction)
    built := json.JArr([json.JNum(1), json.JStr("x"), json.JBool(true), json.JNull])
    println("built       = " + json.stringify(built))

    # truncated input fails closed to null (no out-of-bounds abort)
    println("truncated   = " + json.kind(json.parse("   ")))
