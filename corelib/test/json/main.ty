# corelib test: exercises core:json; the C compiler and tychoc0 must agree, and
# the output is locked to corelib/test/json.out (corelib/run.sh).
package main
import "core:json"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn main():
    src := "{\"name\": \"tycho\", \"version\": 7, \"tags\": [\"systems\", \"arena\"], \"nested\": {\"ok\": true, \"n\": -3}, \"empty\": [], \"nothing\": null}"
    j := json.parse(src)

    # round-trip: parse then serialize -> compact canonical form
    print("round-trip: " + json.stringify(j) + "\n")

    # accessors
    print("kind        = " + json.kind(j) + "\n")
    print("version     = " + str(json.as_num(json.get(j, "version"))) + "\n")
    print("name        = " + json.as_str(json.get(j, "name")) + "\n")
    print("nested.n    = " + str(json.as_num(json.get(json.get(j, "nested"), "n"))) + "\n")
    print("nested.ok   = " + str(b2i(json.as_bool(json.get(json.get(j, "nested"), "ok")))) + "\n")
    print("tags.len    = " + str(json.len_of(json.get(j, "tags"))) + "\n")
    print("tags[1]     = " + json.as_str(json.at(json.get(j, "tags"), 1)) + "\n")
    print("tags[9]     = " + json.kind(json.at(json.get(j, "tags"), 9)) + "\n")
    print("empty.len   = " + str(json.len_of(json.get(j, "empty"))) + "\n")
    print("missing     = " + json.kind(json.get(j, "missing")) + "\n")
    print("nothing     = " + json.kind(json.get(j, "nothing")) + "\n")

    # object keys preserve insertion order
    ks := json.keys(j)
    print("keys.len    = " + str(len(ks)) + "\n")
    print("key0        = " + ks[0] + "\n")

    # escape round-trip: a JSON string with \" \n \t round-trips byte-identical
    esc_src := "\"a\\\"b\\nc\\td\""
    print("esc rt      = " + json.stringify(json.parse(esc_src)) + "\n")

    # build a tree programmatically (cross-package variant construction)
    built := json.JArr([json.JNum(1), json.JStr("x"), json.JBool(true), json.JNull])
    print("built       = " + json.stringify(built) + "\n")

    # truncated input fails closed to null (no out-of-bounds abort)
    print("truncated   = " + json.kind(json.parse("   ")) + "\n")
