# corelib test: exercises core:hex; the C compiler and tychoc0 must agree, and
# the output is locked to corelib/test/hex.out (corelib/run.sh).
package main
import "core:hex"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn main():
    # ---- encode (lowercase) ----
    println("enc ''   = [" + hex.encode("") + "]")         # []
    println("enc A    = " + hex.encode("A"))          # 41
    println("enc hi   = " + hex.encode("hi"))         # 6869
    println("enc tycho = " + hex.encode("tycho"))       # 747963686f

    # ---- decode back (text -> exact) ----
    println("dec      = " + hex.decode("747963686f"))   # tycho
    println("dec U/L  = " + hex.decode("4869"))       # Hi  (0x48 0x69)

    # ---- lenient decode: separators are skipped, case-insensitive ----
    println("dec sep  = " + hex.decode("74:79:63:68:6f"))   # tycho
    println("dec spc  = " + hex.decode("68 69"))         # hi

    # ---- text round-trip ----
    msg := "Hello, tycho! 1234567890"
    rt := hex.decode(hex.encode(msg))
    println(f"text_rt_ok = {b2i(rt == msg)}")              # 1

    # ---- is_valid ----
    v1 := b2i(hex.is_valid("deadbeef"))
    v2 := b2i(hex.is_valid("DEADBEEF"))
    v3 := b2i(hex.is_valid("abc"))                          # odd length
    v4 := b2i(hex.is_valid("xyz"))                          # non-hex
    v5 := b2i(hex.is_valid(""))                             # empty is valid
    println(f"valid dead={v1} DEAD={v2} odd={v3} xyz={v4} empty={v5}")

    # ---- non-NUL binary round-trip + upper/lower case ----
    bin := chr(255) + chr(171) + chr(16) + chr(1)
    el := hex.encode(bin)
    eu := hex.encode_upper(bin)
    println("bin lower = " + el)                      # ffab1001
    println("bin UPPER = " + eu)                      # FFAB1001
    dl := hex.decode(el)
    du := hex.decode(eu)
    println(f"bin_ok lower={b2i(hex.encode(dl) == el)} upper={b2i(hex.encode(du) == el)} len={len(dl)}")  # 1 1 4

    # ---- byte-safe strings (A1): a decoded NUL is preserved, not dropped ----
    z := hex.decode("00")
    println(f"decode_00_len = {len(z)}")                   # 1 (the NUL byte is kept)
