package main
# corelib test: the GENERIC core:arrays across int / string / float. The C
# compiler, tychoc0 --bundle, and standalone tychoc0 must all agree (corelib/run.sh).
# min/max/sum/product require a non-empty array (they seed from xs[0]).
import "core:arrays"

fn b2i(b: bool) -> int:                       # str(bool) is not available; fold to int
    if b:
        return 1
    return 0

fn main():
    xs := [5, 3, 8, 3, 1]
    println("sum=" + str(arrays.sum(xs)) + " product=" + str(arrays.product([1, 2, 3, 4])) + " max=" + str(arrays.max(xs)) + " min=" + str(arrays.min(xs)))
    println("idx3=" + str(arrays.index_of(xs, 3)) + " idx9=" + str(arrays.index_of(xs, 9)) + " cnt3=" + str(arrays.count(xs, 3)) + " has8=" + str(b2i(arrays.contains(xs, 8))))
    println("sort=" + arrays.join(arrays.sort(xs), ",") + " sok=" + str(b2i(arrays.is_sorted(arrays.sort(xs)))) + " origok=" + str(b2i(arrays.is_sorted(xs))))
    println("rev=" + arrays.join(arrays.reverse(xs), ",") + " take=" + arrays.join(arrays.take(xs, 2), ",") + " drop=" + arrays.join(arrays.drop(xs, 3), ","))
    println("concat=" + arrays.join(arrays.concat([1, 2], [3, 4]), ",") + " fill=" + arrays.join(arrays.fill(3, 7), ",") + " dedup=" + arrays.join(arrays.dedup([1, 1, 2, 2, 2, 3, 1]), ","))
    # strings: comparable + has_str (NOT numeric)
    ss := ["pear", "apple", "fig", "apple"]
    println("s_sort=" + arrays.join(arrays.sort(ss), ",") + " s_min=" + arrays.min(ss) + " s_max=" + arrays.max(ss) + " s_has=" + str(b2i(arrays.contains(ss, "fig"))) + " s_dedup=" + arrays.join(arrays.dedup(arrays.sort(ss)), ","))
    # floats: numeric + comparable + has_str
    fs := [1.5, 0.5, 2.5]
    println("f_sum=" + str(arrays.sum(fs)) + " f_min=" + str(arrays.min(fs)) + " f_max=" + str(arrays.max(fs)) + " f_sort=" + arrays.join(arrays.sort(fs), ","))
