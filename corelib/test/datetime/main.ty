# corelib test: exercises core:datetime; the C compiler and tychoc0 must agree,
# and the output is locked to corelib/test/datetime.out (corelib/run.sh).
# Fixed timestamps keep the output deterministic; now_utc() (non-deterministic)
# is checked only for in-range fields.
package main
import "core:datetime"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn show(secs: int) -> string:                  # ISO + weekday name for a timestamp
    dt := datetime.from_unix(secs)
    return datetime.format_iso(dt) + " " + datetime.weekday_name(dt.weekday)

fn main():
    # known UTC timestamps -> civil fields
    a := show(0)
    b := show(946684800)
    c := show(1234567890)
    d := show(0 - 1)
    println("epoch    = " + a)            # 1970-01-01T00:00:00 Thu
    println("y2k      = " + b)            # 2000-01-01T00:00:00 Sat
    println("ts1234   = " + c)            # 2009-02-13T23:31:30 Fri
    println("preepoch = " + d)            # 1969-12-31T23:59:59 Wed

    # to_unix is the exact inverse of from_unix
    rt := datetime.to_unix(datetime.from_unix(1234567890))
    rtok := b2i(rt == 1234567890)
    println(f"roundtrip={rt} ok={rtok}")

    # leap years
    l2000 := b2i(datetime.is_leap(2000))
    l1900 := b2i(datetime.is_leap(1900))
    l2024 := b2i(datetime.is_leap(2024))
    l2023 := b2i(datetime.is_leap(2023))
    println(f"leap 2000={l2000} 1900={l1900} 2024={l2024} 2023={l2023}")

    # days in month
    f24 := datetime.days_in_month(2024, 2)
    f23 := datetime.days_in_month(2023, 2)
    apr := datetime.days_in_month(2024, 4)
    jan := datetime.days_in_month(2024, 1)
    println(f"dim feb2024={f24} feb2023={f23} apr={apr} jan={jan}")

    # weekday of a fixed civil date
    wd := datetime.weekday(2026, 6, 17)
    nm := datetime.weekday_name(wd)
    mn := datetime.month_name(6)
    println(f"wd 2026-{mn}-17 = {wd} {nm}")

    # the day-count core, directly
    dfc0 := datetime.days_from_civil(1970, 1, 1)
    dfcy2k := datetime.days_from_civil(2000, 1, 1)
    println(f"dfc epoch={dfc0} y2k={dfcy2k}")

    # fixed-offset timezones: the SAME UTC instant (ts1234) rendered at offsets
    ist := datetime.format_iso_tz(datetime.from_unix_at(1234567890, 19800), 19800)          # +5:30
    pst := datetime.format_iso_tz(datetime.from_unix_at(1234567890, 0 - 28800), 0 - 28800)  # -8:00
    utc := datetime.format_iso_tz(datetime.from_unix_at(1234567890, 0), 0)                   # Z
    println("ist = " + ist)              # 2009-02-14T05:01:30+05:30 (rolls to next day)
    println("pst = " + pst)              # 2009-02-13T15:31:30-08:00
    println("utc = " + utc)              # 2009-02-13T23:31:30Z
    # local-fields-at-offset -> UTC instant is the exact inverse
    tzrt := datetime.to_unix_at(datetime.from_unix_at(1234567890, 19800), 19800)
    println(f"tzroundtrip={tzrt} ok={b2i(tzrt == 1234567890)}")
    # offset formatting edge cases (incl. +5:45 Nepal)
    println("off = " + datetime.format_offset(0) + " " + datetime.format_offset(19800) + " " + datetime.format_offset(0 - 28800) + " " + datetime.format_offset(20700))

    # DST via an EXPLICIT POSIX TZ rule -- host-independent (the rule lives in the
    # string, no zoneinfo file), so the golden is reproducible. US Eastern is EST
    # (UTC-5) in winter and EDT (UTC-4) in summer.
    et := "EST5EDT,M3.2.0,M11.1.0"
    etjan := datetime.offset_at(et, 1234567890)          # 2009-02-13 UTC -> winter -> 0 - 18000
    etjul := datetime.offset_at(et, 1247000000)          # 2009-07-07 UTC -> summer -> 0 - 14400
    etz := datetime.offset_at("UTC0", 1234567890)        # 0
    println(f"et_jan={etjan} et_jul={etjul} utc0={etz}")
    # compose the pure + libc layers: ts1234 as US-Eastern wall-clock, DST applied
    nyc := datetime.format_iso_tz(datetime.from_unix_at(1234567890, etjan), etjan)
    println("nyc = " + nyc)                              # 2009-02-13T18:31:30-05:00

    # ---- parsing: inverse of format_iso / format_iso_tz ----
    p1 := datetime.parse_iso("2009-02-13T23:31:30")
    p1ok := b2i(datetime.ok(p1))
    p1iso := datetime.format_iso(p1)
    p1wd := datetime.weekday_name(p1.weekday)
    println(f"parse ok={p1ok} iso={p1iso} wd={p1wd}")     # 1 ... Fri
    # round-trip: format_iso(parse_iso(x)) == x
    x := "2026-06-17T08:09:10"
    xrt := b2i(datetime.format_iso(datetime.parse_iso(x)) == x)
    println(f"parse_rt={xrt}")                            # 1
    # a space date/time separator is accepted
    spok := b2i(datetime.ok(datetime.parse_iso("2000-01-01 00:00:00")))
    println(f"parse_space={spok}")                        # 1
    # with a zone suffix -> the UTC instant (ts1234 in three zones)
    ptz := datetime.parse_iso_tz("2009-02-14T05:01:30+05:30")
    ptzu := datetime.to_unix(ptz)
    ptzok := b2i(ptzu == 1234567890)
    println(f"parse_tz unix={ptzu} ok={ptzok}")           # 1234567890 1
    pneg := datetime.parse_iso_tz("2009-02-13T15:31:30-08:00")
    pnegok := b2i(datetime.to_unix(pneg) == 1234567890)
    println(f"parse_neg ok={pnegok}")                     # 1
    pz := datetime.parse_iso_tz("2009-02-13T23:31:30Z")
    pzu := datetime.to_unix(pz)
    println(f"parse_z unix={pzu}")                        # 1234567890
    # fail-closed: too short, bad separator, month 13, day 30 in Feb, bad offset
    bshort := b2i(datetime.ok(datetime.parse_iso("2009-02-13")))
    bsep := b2i(datetime.ok(datetime.parse_iso("2009/02/13T00:00:00")))
    bmon := b2i(datetime.ok(datetime.parse_iso("2009-13-01T00:00:00")))
    bday := b2i(datetime.ok(datetime.parse_iso("2009-02-30T00:00:00")))
    boff := b2i(datetime.ok(datetime.parse_iso_tz("2009-02-13T23:31:30+5")))
    println(f"fail short={bshort} sep={bsep} month={bmon} day={bday} off={boff}")  # all 0

    # ---- Common Log Format parsing (dd/Mon/yyyy:HH:MM:SS ±HHMM) ----
    clf := datetime.parse_clf("10/Oct/2000:13:55:36 -0700")
    println(f"clf ok={b2i(datetime.ok(clf))} iso={datetime.format_iso(clf)}")   # 1 ... 2000-10-10T13:55:36
    println("clf_utc = " + datetime.format_iso(datetime.parse_clf_tz("10/Oct/2000:13:55:36 -0700")))  # +7h -> 20:55:36
    println("clf_noz = " + datetime.format_iso(datetime.parse_clf_tz("01/Jan/2021:00:00:00")))         # no offset -> UTC
    mnjan := datetime.month_num("Jan")
    mndec := datetime.month_num("Dec")
    mnxyz := datetime.month_num("Xyz")
    println(f"month_num Jan={mnjan} Dec={mndec} Xyz={mnxyz}")                    # 1 12 0
    # fail-closed: wrong separators, bad month name, out-of-range day, short offset
    cbsep := b2i(datetime.ok(datetime.parse_clf("10-Oct-2000:13:55:36")))
    cbmon := b2i(datetime.ok(datetime.parse_clf("10/Zzz/2000:13:55:36")))
    cbday := b2i(datetime.ok(datetime.parse_clf("32/Oct/2000:13:55:36")))
    cboff := b2i(datetime.ok(datetime.parse_clf_tz("10/Oct/2000:13:55:36 -07")))
    println(f"clf_fail sep={cbsep} month={cbmon} day={cbday} off={cboff}")       # all 0

    # system local_offset() is host-dependent -- assert invariants, not the value
    lo := datetime.local_offset(1234567890)
    println("local_off_ok = " + str(b2i(lo >= 0 - 50400 and lo <= 50400 and lo % 900 == 0)))
    # now_local(): non-deterministic; fields must be in range
    nl := datetime.now_local()
    println("now_local_valid = " + str(b2i(nl.month >= 1 and nl.month <= 12 and nl.day >= 1 and nl.day <= 31 and nl.year >= 1970 and nl.hour >= 0 and nl.hour <= 23 and nl.second >= 0 and nl.second <= 59)))

    # now_utc(): value is non-deterministic, but the fields must be in range
    nu := datetime.now_utc()
    nvalid := b2i(nu.month >= 1 and nu.month <= 12 and nu.day >= 1 and nu.day <= 31 and nu.year >= 1970 and nu.hour >= 0 and nu.hour <= 23 and nu.second >= 0 and nu.second <= 59)
    println("now_valid = " + str(nvalid))
