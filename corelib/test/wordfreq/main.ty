# corelib DOGFOOD: a word-frequency report written the way a user would --
# core:strings tokenizes, a [string: int] map counts, keys() + core:arrays
# + core:sort order the report (lexicographic sort first, then a STABLE
# argsort_desc on counts = count-desc with alphabetical ties). This is the
# cross-package integration test: if the pieces don't compose, this breaks
# before a user finds out.
package main
import "core:strings"
import "core:sort"
import "core:arrays"

fn main():
    text := "The quick brown fox jumps over the lazy dog." + chr(10)
    text = text + "The dog barks; the fox runs." + chr(10)
    text = text + "  the   END  " + chr(10)
    # tokenize: lines -> lowercase -> strip punctuation -> split on spaces
    counts := []string: int
    for ln in strings.lines(text):
        clean := strings.to_lower(ln)
        clean = strings.replace(clean, ".", "")
        clean = strings.replace(clean, ";", "")
        for w in split(clean, " "):    # split is a builtin
            t := strings.trim(w)
            if len(t) > 0:
                counts[t] = map_get(counts, t, 0) + 1
    words := arrays.sort(keys(counts))
    nums := []int
    for w in words:
        push(nums, map_get(counts, w, 0))
    ord := sort.argsort_desc(nums)
    for i in range(len(ord)):
        if nums[ord[i]] > 1:
            println(words[ord[i]] + " " + str(nums[ord[i]]))
    println(f"unique={len(words)}")
