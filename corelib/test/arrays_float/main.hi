package main
# corelib test: exercises core:arrays_float; all three compile paths must agree (corelib/run.sh).
# Float results are compared to expected values and printed as ints/bools-as-int to avoid
# depending on float-to-string formatting.
import "core:arrays_float"

fn b2i(b: bool) -> int:
    if b:
        return 1
    return 0

fn main():
    xs := [2.5, 1.0, 3.5, 1.0]
    sumok := b2i(arrays_float.sum(xs) == 8.0)
    maxok := b2i(arrays_float.fmax(xs) == 3.5)
    minok := b2i(arrays_float.fmin(xs) == 1.0)
    print(f"sumok={sumok} maxok={maxok} minok={minok}\n")          # sumok=1 maxok=1 minok=1
    idx := arrays_float.index_of(xs, 3.5)
    miss := arrays_float.index_of(xs, 9.0)
    cnt := arrays_float.count(xs, 1.0)
    has := b2i(arrays_float.contains(xs, 2.5))
    print(f"idx={idx} miss={miss} cnt={cnt} has={has}\n")          # idx=2 miss=-1 cnt=2 has=1
    s := arrays_float.sort(xs)
    s0 := b2i(s[0] == 1.0)
    s3 := b2i(s[3] == 3.5)
    sok := b2i(arrays_float.is_sorted(s))
    origok := b2i(arrays_float.is_sorted(xs))
    print(f"s0={s0} s3={s3} sok={sok} origok={origok}\n")          # s0=1 s3=1 sok=1 origok=0
    rev := arrays_float.reverse(xs)
    rok := b2i(rev[0] == 1.0 and rev[3] == 2.5)
    print(f"rok={rok}\n")                                          # rok=1
    e := []float                                                   # documented empty sentinels: 0.0
    esum := b2i(arrays_float.sum(e) == 0.0)
    emin := b2i(arrays_float.fmin(e) == 0.0)
    emax := b2i(arrays_float.fmax(e) == 0.0)
    print(f"esum={esum} emin={emin} emax={emax}\n")                # esum=1 emin=1 emax=1
