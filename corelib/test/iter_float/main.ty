# corelib test: core:iter_float (higher-order over [float]; expression closures
# AND plain named fns as predicates -- lambdas in tycho are expression-bodied).
package main
import "core:iter_float"

fn ge2(x: float) -> int:
    if x >= 2.0:
        return 1
    return 0

fn lt2(x: float) -> int:
    if x < 2.0:
        return 1
    return 0

fn huge(x: float) -> int:
    if x > 100.0:
        return 1
    return 0

fn main():
    xs := [1.5, 2.5, 3.0, 0.5]
    dbl := iter_float.map(xs, fn(x: float) -> float: x * 2.0)
    print(str(dbl[0]) + " " + str(dbl[3]) + "\n")        # 3 1
    big := iter_float.filter(xs, ge2)
    print(str(len(big)) + "\n")                           # 2
    total := iter_float.reduce(xs, 0.0, fn(a: float, b: float) -> float: a + b)
    print(str(total) + "\n")                              # 7.5
    n := iter_float.count(xs, lt2)
    has := iter_float.any(xs, huge)
    hi := 0
    if has:
        hi = 1
    print(f"n={n} has={hi}\n")                            # n=2 has=0
