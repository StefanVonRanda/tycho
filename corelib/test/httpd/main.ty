# corelib test: exercises core:httpd over core:net entirely on the loopback
# interface, in one process/thread (connect() into the listen backlog completes
# the handshake before accept(), so listen -> connect -> accept -> exchange runs
# single-threaded and hermetic). No fixed port (bind 0 -> ephemeral). tychoc and
# tychoc0 must agree; output locked to corelib/test/httpd.out (corelib/run.sh).
package main
import "core:net"
import "core:httpd"

fn b(x: bool) -> int:
    if x:
        return 1
    return 0

fn crlf() -> string:                             # no \r escape in tycho strings
    return chr(13) + chr(10)

fn main():
    # ---- pure parsing (no socket): a request with headers + body ----
    nl := crlf()
    raw := "POST /submit?id=7 HTTP/1.1" + nl + "Host: localhost" + nl + "Content-Type: application/json" + nl + "Content-Length: 13" + nl + nl + "{\"a\":\"hello\"}"
    p := httpd.parse_request(raw)
    println("method = " + p.method)
    println("path   = " + p.path)
    println("version= " + p.version)
    println("host   = " + httpd.header(p, "Host"))
    println("ctype  = " + httpd.header(p, "content-type"))     # case-insensitive lookup
    println("clen   = " + httpd.header(p, "Content-Length"))
    println("missing= [" + httpd.header(p, "X-None") + "]")
    println("body   = " + p.body)
    println("bodylen= " + str(len(p.body)))

    # a malformed request line fails closed
    bad := httpd.parse_request("garbage" + nl + nl)
    println("bad_method_empty = " + str(b(bad.method == "")))

    # render a response: auto Content-Length + default Content-Type
    r0 := httpd.response(404, "nope")
    println("--- render ---")
    println(httpd.render(r0))

    # ---- loopback round trip over core:net ----
    srv := net.listen("127.0.0.1", 0)
    port := net.port_of(srv)
    cli := net.connect("127.0.0.1", port)
    conn := net.accept(srv)
    println("net_ok = " + str(b(srv >= 0 and port > 0 and cli >= 0 and conn >= 0)))

    # client -> server: send the raw request built above
    net.write(cli, to_bytes(raw))
    got := httpd.read_request(conn)
    println("srv_method = " + got.method)
    println("srv_path   = " + got.path)
    println("srv_body   = " + got.body)
    println("srv_bodylen= " + str(len(got.body)))

    # server -> client: build + send a response with an extra header
    resp := httpd.with_header(httpd.response(200, "pong"), "X-Extra", "yes")
    n := httpd.write_response(conn, resp)
    println("wrote_ok = " + str(b(n > 0)))
    net.close_fd(conn)

    # client reads + inspects the response (deterministic header order)
    wire := to_str(net.read(cli, 4096))
    rlines := split(wire, "\n")
    println("status = " + httpd.trim(rlines[0]))            # HTTP/1.1 200 OK
    println("has_extra = " + str(b(find(wire, "X-Extra: yes") >= 0)))
    println("has_clen  = " + str(b(find(wire, "Content-Length: 4") >= 0)))
    println("has_ctype = " + str(b(find(wire, "Content-Type: text/plain") >= 0)))
    rsep := find(wire, nl + nl)
    rbody := wire[rsep + 4:len(wire)]
    println("rbody = " + rbody)                             # pong

    net.close_fd(cli)
    net.close_fd(srv)
